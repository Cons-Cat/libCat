#pragma once

#include <cat/allocator>
#include <cat/stepanov>

namespace cat {

template <typename T>
class back_insert_stepanov_iterator
    : public stepanov_iterator_interface<
         output_iterator_tag, void, back_insert_stepanov_iterator<T>&, void> {
 public:
   using container_type = T;

   constexpr explicit back_insert_stepanov_iterator(T& input_iterable)
       : m_iterable(input_iterable) {
   }

   template <typename U>
   constexpr auto
   operator=(U& value) = delete;

   // `.insert()` is used instead of an overloaded = because it might
   // need to take an allocator parameter.

   template <typename U>
   constexpr auto
   insert(/* allocator */ auto& allocator, U& value)
      -> maybe<back_insert_stepanov_iterator<T>&> {
      maybe result = m_iterable.push_back(allocator, value);
      if (!result.has_value()) {
         return nullopt;
      }
      return *this;
   }

   template <typename U>
   constexpr auto
   insert(U& value) -> back_insert_stepanov_iterator<T>& {
      m_iterable.push_back(value);
      return *this;
   }

   template <typename U>
   constexpr auto
   insert(/* allocator */ auto& allocator, U const& value)
      -> maybe<back_insert_stepanov_iterator<T>&> {
      maybe result = m_iterable.push_back(allocator, value);
      if (!result.has_value()) {
         return nullopt;
      }
      return *this;
   }

   template <typename U>
   constexpr auto
   insert(U const& value) -> back_insert_stepanov_iterator<T>& {
      m_iterable.push_back(value);
      return *this;
   }

   template <typename U>
   constexpr auto
   operator=(U const& value) -> back_insert_stepanov_iterator<T>& {
      m_iterable.push_back(value);
      return *this;
   }

   template <typename U>
   constexpr auto
   insert(/* allocator */ auto& allocator, U&& value)
      -> maybe<back_insert_stepanov_iterator<T>&> {
      maybe result = m_iterable.push_back(allocator, fwd(value));
      if (!result.has_value()) {
         return nullopt;
      }
      return *this;
   }

   template <typename U>
   constexpr auto
   insert(U&& value) -> maybe<back_insert_stepanov_iterator<T>&> {
      prop(m_iterable.push_back(fwd(value)));
      return *this;
   }

   template <typename U>
   constexpr auto
   operator=(U&& value) -> back_insert_stepanov_iterator<T>& {
      m_iterable.push_back(fwd(value));
      return *this;
   }

   // Dereference operator is no-op.
   constexpr auto
   dereference() -> back_insert_stepanov_iterator<T>& {
      return *this;
   }

   // Increment operators are no-op.
   constexpr auto
   increment() -> back_insert_stepanov_iterator<T>& {
      return *this;
   }

 private:
   T& m_iterable;
};

