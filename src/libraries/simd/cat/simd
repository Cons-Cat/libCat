            __builtin_bit_cast(typename bits_vec::raw_type, operand.raw);
         return mask_type(__builtin_bit_cast(raw_type, a << b));
      }
   }

   constexpr auto
   operator<<=(mask_type const& operand) -> mask_type& {
      *this = *this << operand;
      return *this;
   }

   [[nodiscard]]
   constexpr auto
   operator>>(mask_type const& operand) const -> mask_type {
      if constexpr (is_integral<lane_scalar>) {
         return mask_type(this->raw >> operand.raw);
      } else {
         using lane_bits = detail::simd_mask_lane_bits_t<lane_scalar>;
         using bits_abi = typename abi_type::template make_abi_type<lane_bits>;
         using bits_vec = simd<lane_bits, bits_abi>;
         typename bits_vec::raw_type const a =
            __builtin_bit_cast(typename bits_vec::raw_type, this->raw);
         typename bits_vec::raw_type const b =
            __builtin_bit_cast(typename bits_vec::raw_type, operand.raw);
         return mask_type(__builtin_bit_cast(raw_type, a >> b));
      }
   }

   constexpr auto
   operator>>=(mask_type const& operand) -> mask_type& {
      *this = *this >> operand;
      return *this;
   }

   // Logical lane `i` maps to `mask_traits` storage (`lane_scalar`); decode is
   // ABI-defined but operator[] always yields abstract `bool`.
   [[nodiscard, gnu::no_sanitize("bounds")]]
   constexpr auto
   operator[](idx index) const -> bool {
      return mask_traits::decode_lane(raw, index);
   }

   constexpr auto
   set_lane(idx index, bool value) -> void {
      mask_traits::encode_lane(raw, index, value);
   }

   // Logical NOT per lane (`simd_mask` stays a mask).
   [[nodiscard]]
   constexpr auto
   operator!() const -> mask_type {
      // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2025/p3922r1.pdf
      mask_type result{};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         result.set_lane(i, !(*this)[i]);
      }
      return result;
   }

   // Integral `simd` lanes from abstract mask lanes (feeds mask→`simd` ctor).
   [[nodiscard]]
   constexpr auto
   operator+() const
      -> simd<detail::simd_unary_signed_integer_from_element_t<T>,
              typename abi_type::template make_abi_type<
                 detail::simd_unary_signed_integer_from_element_t<T>>>
      requires(detail::has_simd_mask_unary_integral_conversion_v<T>)
   {
      // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2025/p3922r1.pdf
      using I = detail::simd_unary_signed_integer_from_element_t<T>;
      using vec = simd<I, typename abi_type::template make_abi_type<I>>;
      vec out{};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         bool const lane = (*this)[i];
         out.set_lane(i, static_cast<I>(+static_cast<bool>(lane)));
      }
      return out;
   }

   [[nodiscard]]
   constexpr auto
   operator-() const
      -> simd<detail::simd_unary_signed_integer_from_element_t<T>,
              typename abi_type::template make_abi_type<
                 detail::simd_unary_signed_integer_from_element_t<T>>>
      requires(detail::has_simd_mask_unary_integral_conversion_v<T>)
   {
      // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2025/p3922r1.pdf
      using I = detail::simd_unary_signed_integer_from_element_t<T>;
      using vec = simd<I, typename abi_type::template make_abi_type<I>>;
      vec out{};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         bool const lane = (*this)[i];
         out.set_lane(i, static_cast<I>(-static_cast<bool>(lane)));
      }
      return out;
   }

   [[nodiscard]]
   constexpr auto
   operator~() const
      -> simd<detail::simd_unary_signed_integer_from_element_t<T>,
              typename abi_type::template make_abi_type<
                 detail::simd_unary_signed_integer_from_element_t<T>>>
      requires(detail::has_simd_mask_unary_integral_conversion_v<T>)
   {
      // P3922R1.
      // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2025/p3922r1.pdf
      using I = detail::simd_unary_signed_integer_from_element_t<T>;
      using vec = simd<I, typename abi_type::template make_abi_type<I>>;
      vec out{};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         bool const lane = (*this)[i];
         int const promoted = static_cast<bool>(lane);
         out.set_lane(i, static_cast<I>(~promoted));
      }
      return out;
   }

   [[nodiscard, gnu::no_sanitize("bounds")]]
   constexpr auto
   lane_byte(idx index) const -> unsigned char const& {
      return *(reinterpret_cast<unsigned char const*>(__builtin_addressof(raw))
               + index.raw * sizeof(lane_scalar));
   }

   // Evaluate true if every lane is non-zero.
   [[nodiscard]]
   constexpr auto
   all_of() const -> bool {
      return simd_all_of(*this);
   }

   // Evaluate true if any lanes are non-zero.
   [[nodiscard]]
   constexpr auto
   any_of() const -> bool {
      return simd_any_of(*this);
   }

   // Evaluate true if every lane is zero.
   [[nodiscard]]
   constexpr auto
   none_of() const -> bool {
      return !(this->any_of());
   }

   // Standard mask reductions-style helpers on logical lanes (standard mask
   // wording: reduce_min_index / reduce_max_index over true lane indices).
   [[nodiscard]]
   constexpr auto
   count_if_true() const -> idx {
      return detail::simd_abi::mask_count_if_true<T, abi_type>::invoke(*this);
   }

   // Lowest index of a true lane.
   // `count_if_true()` is non-zero (at least one true lane).
   [[nodiscard]]
   constexpr auto
   find_if_true() const -> idx {
      return detail::simd_abi::mask_find_if_true<T, abi_type>::invoke(*this);
   }

   // Highest index of a true lane.
   // `count_if_true()` is non-zero (at least one true lane).
   [[nodiscard]]
   constexpr auto
   find_last_if_true() const -> idx {
      return detail::simd_abi::mask_find_last_if_true<T, abi_type>::invoke(
         *this);
   }

   // Bit i equals `operator[](i)` for every i in `[0, size())`. Body in
   // `implementations/simd_mask_bitset.tpp`
   // (`simd_to_bitset`).
   [[nodiscard]]
   constexpr auto
   to_bitset() const -> ::cat::bitset<abi_type::lanes>;

   // Let N be `word_bits` (`sizeof(uword)` in bits from `<cat/bit>`). Either
   // `size() <= N` as a lane count comparison or every lane with index `i >= N`
   // is false. Packing only consults lanes below N. High true lanes when
   // `abi_type::lanes` exceeds N violate the TS contract and yield a wrong
   // packed value.
   [[nodiscard]]
   constexpr auto
   to_uword() const -> uword {
      typename uword::raw_type bits = 0u;
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         if (i >= word_bits) {
            break;
         }
         if ((*this)[i]) {
            bits |= (1uz << i.raw);
         }
      }
      return uword(bits);
   }

   template <typename UInt>
      requires(is_unsigned_integral<UInt> && !is_bool<UInt>)
   explicit constexpr simd_mask(UInt pattern_bits) {
      this->raw = raw_type{};
      uword const bits = static_cast<uword>(pattern_bits);
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         this->set_lane(i, ((bits.raw >> i.raw) & 1uz) != 0uz);
      }
   }

   // Fill all lanes with `value`. This is also known as a "splat" operation.
   constexpr auto
   fill(bool value) -> mask_type {
      this->raw = raw_type{};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         this->set_lane(i, value);
      }
      return *this;
   }

   // Load each logical lane from one `bool` per lane in `lane_bools` (gather
   // from memory into mask lanes; not a `raw_type` object representation; use
   // `raw` assignment for that).
   constexpr auto
   load(bool const* lane_bools) -> mask_type& {
      this->raw = raw_type{};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         this->set_lane(i, lane_bools[i.raw]);
      }
      return *this;
   }

   [[nodiscard]]
   static constexpr auto
   size() -> idx {
      return abi_type::lanes;
   }

   [[nodiscard]]
   constexpr iterator
   begin() {
      return iterator(this, 0u);
   }

   [[nodiscard]]
   constexpr const_iterator
   begin() const {
      return const_iterator(this, 0u);
   }

   [[nodiscard]]
   constexpr const_iterator
   cbegin() const {
      return begin();
   }

   [[nodiscard]]
   constexpr default_sentinel_t
   end() const {
      return default_sentinel;
   }

   [[nodiscard]]
   constexpr default_sentinel_t
   cend() const {
      return end();
   }

   [[nodiscard]]
   constexpr auto
   data() -> lane_scalar* {
      return __builtin_bit_cast(lane_scalar*, &raw);
   }

   [[nodiscard]]
   constexpr auto
   data() const -> lane_scalar const* {
      return __builtin_bit_cast(lane_scalar const*, &raw);
   }

   raw_type raw;
};

// Count all true lanes in this mask.
template <typename T, typename Abi>
[[nodiscard]]
constexpr auto
popcount(simd_mask<T, Abi> const& mask) -> int {
   // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2022/p2638r0.pdf
   return static_cast<int>(mask.count_if_true());
}

// Deduced `simd` matches `simd(+mask)` from the converting constructor above.
template <typename T, typename Abi>
   requires(detail::has_simd_mask_unary_integral_conversion_v<T>)
