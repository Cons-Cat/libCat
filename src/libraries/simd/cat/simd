// P3983R1 array-like object representation query for `simd<T, Abi>`.
// https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2026/p3983r1.html
template <typename T, typename Abi>
inline constexpr bool is_simd_array_like =
   sizeof(simd<T, Abi>) == Abi::lanes.raw * sizeof(T);

// Constants for prefetch. `__builtin_prefetch` takes `int` for its
// read-or-write and locality operands in Clang. The enum uses the same
// underlying type so values match that interface without a narrower promotion
// story.
// NOLINTNEXTLINE(performance-enum-size)
enum class prefetch_hint : int {
   // Prefetch data into non-temporal cache structure and into a location close
   // to the processor, minimizing cache pollution.
   non_temporal = 0,
   // Prefetch data into level 3 cache and higher, or an implementation-specific
   // choice.
   temporal_2 = 1,
   // Prefetch data into level 2 cache and higher.
   temporal_1 = 2,
   // Prefetch data into all levels of the cache hierarchy.
   temporal_0 = 3,
};

template <prefetch_hint hint>
void
prefetch(void const* _Nonnull p_source) {
   __builtin_prefetch(
      p_source, static_cast<int>(hint) & 0x4 >> 2, static_cast<int>(hint) & 0x3
   );
}

void
prefetch_for_one_read(auto const* _Nonnull p_vector) {
   prefetch<prefetch_hint::non_temporal>(p_vector);
}

void
prefetch_close(auto const* _Nonnull p_vector) {
   prefetch<prefetch_hint::temporal_0>(p_vector);
}

void
prefetch_mid(auto const* _Nonnull p_vector) {
   prefetch<prefetch_hint::temporal_1>(p_vector);
}

void
prefetch_far(auto const* _Nonnull p_vector) {
   prefetch<prefetch_hint::temporal_2>(p_vector);
}

void
prefetch_for_modify(auto const* _Nonnull p_vector) {
   prefetch<prefetch_hint::temporal_0>(p_vector);
}

// Physical mask storage and per-lane truth patterns are owned by each ABI tag's
// `simd_mask_lane` traits (`decode_lane`/`encode_lane`). `operator[]` still
// exposes abstract `bool` lanes. `simd_all_of`/`simd_any_of` dispatch through
// `detail::simd_abi::mask_all_of`/`mask_any_of` (lane loops in primaries.
// AVX2 `movmsk*` partial specializations in `simd_avx2_mask_ops.hpp`).
//
// Standard mask reductions / mask subscript relate to logical mask elements
// (`bool`), not raw bit layout.
template <typename T, typename Abi>
[[nodiscard]]
constexpr auto
simd_all_of(simd_mask<T, Abi> mask) -> bool {
   // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2022/p2638r0.pdf
   return detail::simd_abi::mask_all_of<T, Abi>::invoke(mask);
}

template <typename T, typename Abi>
[[nodiscard]]
constexpr auto
simd_any_of(simd_mask<T, Abi> mask) -> bool {
   // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2022/p2638r0.pdf
   return detail::simd_abi::mask_any_of<T, Abi>::invoke(mask);
}

// Dispatch `any_of()` to the native SIMD ABI. `simd_mask::raw` round-trips
// through the equivalent `target_abi` mask (same `simd_abi::mask_lane`
// encoding), which breaks the recursion into the generic overload above.
template <typename T>
[[nodiscard]]
auto
simd_any_of(simd_mask<T, simd_abi::native<T>> mask) -> bool {
   // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2022/p2638r0.pdf
   return simd_any_of(
      simd_mask<T, typename simd_abi::native<T>::target_abi>(mask.raw)
   );
}

// Dispatch `all_of()` to the native SIMD ABI.
template <typename T>
[[nodiscard]]
auto
simd_all_of(simd_mask<T, simd_abi::native<T>> mask) -> bool {
   // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2022/p2638r0.pdf
   return simd_all_of(
      simd_mask<T, typename simd_abi::native<T>::target_abi>(mask.raw)
   );
}

