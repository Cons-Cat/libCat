// Memory alignment for `simd<T, simd_abi::fixed_size<T, size>>` follows the
// same idea as `std::simd`. An implementation-defined power of two no larger
// than the object and not exceeding the native SIMD alignment from `target_abi`
// Effectively, short vectors are 16-byte aligned, and long vectors are 32-byte
// aligned.
[[nodiscard]]
consteval auto
simd_memory_alignment_for_fixed_size(
   idx object_size, ualign native_cap, ualign element_align
) -> ualign {
   uword const bounded = object_size <= native_cap
                            ? static_cast<uword>(object_size.raw)
                            : static_cast<uword>(native_cap);
   if (bounded == 0u) {
      return element_align;
   }
   ualign alignment = 1u;
   while (alignment * 2u <= bounded) {
      alignment *= 2u;
   }
   return alignment < element_align ? element_align : alignment;
}

}  // namespace detail

// ABI tags for `simd`, in `cat::simd_abi` to mirror `std::simd_abi` from the
// P1928R2 / P3922R1 family of proposals. They give an extensible API via
// overloading on the ABI tag, and a type-safe API by requiring compatible ABI
// tags between `simd` operands.

namespace simd_abi {

template <typename T, idx in_lanes>
struct fixed_size;

template <typename T>
struct native;

template <typename T>
struct compatible;

template <typename T>
struct scalar;

}  // namespace simd_abi

// `simd_abi::fixed_size` is a portable SIMD ABI that can be expected to work
// across any supported build target, so long as `in_lanes` (an `idx` lane
// count) does not exceed that target's maximum vector size.
template <typename T, idx in_lanes>
struct simd_abi::fixed_size {
   using scalar_type = T;

   // Produce a similar `simd_abi::fixed_size` for type `U`.
   template <typename U>
   using make_abi_type =
      simd_abi::fixed_size<U, idx{in_lanes.raw * sizeof(T) / sizeof(U)}>;

   constexpr fixed_size() = delete;

   // TODO: Select `target_abi` portably.
   using target_abi = x64::avx_abi<T>;
   static constexpr idx lanes = in_lanes;
   static constexpr idx size = idx(lanes.raw * sizeof(T));
   static constexpr ualign alignment =
      detail::simd_memory_alignment_for_fixed_size(
         size, target_abi::alignment, alignof(T)
      );

   template <typename ElementT>
   using simd_mask_lane = simd_abi::mask_lane<
      simd_abi::fixed_size<
         ElementT, idx{in_lanes.raw * sizeof(T) / sizeof(ElementT)}>,
      ElementT>;
};

// `simd_abi::native` is a portable SIMD ABI that can be expected to work on
// any supported build target. However, you cannot safely assume the size or
// alignment this ABI expresses.
template <typename T>
struct simd_abi::native {
   using scalar_type = T;

   // Produce a similar `simd_abi::native` for type `U`.
   template <typename U>
   using make_abi_type = simd_abi::native<U>;

   constexpr native() = delete;

   // TODO: Select `target_abi` portably.
   using target_abi = x64::avx_abi<T>;
   static constexpr idx size = target_abi::size;
   static constexpr idx lanes = target_abi::lanes;
   static constexpr ualign alignment = target_abi::alignment;

   template <typename ElementT>
   using simd_mask_lane =
      simd_abi::mask_lane<simd_abi::native<ElementT>, ElementT>;
};

// An ABI tag for efficient execution that stays stable across translation
// units on the target. Same layout as `simd_abi::native` today (`target_abi`).
// Distinct type so `simd<T, simd_abi::compatible<T>>` differs from
// `simd<T, simd_abi::native<T>>` for overload resolution / tagging.
template <typename T>
struct simd_abi::compatible {
   using scalar_type = T;

   template <typename U>
   using make_abi_type = simd_abi::compatible<U>;

   constexpr compatible() = delete;

   using target_abi = x64::avx_abi<T>;
   static constexpr idx size = target_abi::size;
   static constexpr idx lanes = target_abi::lanes;
   static constexpr ualign alignment = target_abi::alignment;

   template <typename ElementT>
   using simd_mask_lane =
      simd_abi::mask_lane<simd_abi::compatible<ElementT>, ElementT>;
};

// Standard-shaped scalar ABI. It stores exactly one lane.
template <typename T>
struct simd_abi::scalar {
   using scalar_type = T;

   template <typename U>
   using make_abi_type = simd_abi::scalar<U>;

   constexpr scalar() = delete;

   static constexpr idx size = sizeof(T);
   static constexpr idx lanes = 1u;
   static constexpr ualign alignment = alignof(T);

   template <typename ElementT>
   using simd_mask_lane =
      simd_abi::mask_lane<simd_abi::scalar<ElementT>, ElementT>;
};

namespace detail {

template <typename T, idx lane_count, typename... Abis>
struct deduce_from_candidates;

template <typename T, idx lane_count>
struct deduce_from_candidates<T, lane_count> {
   using type = cat::simd_abi::fixed_size<T, lane_count>;
};

template <typename T, idx lane_count, typename Abi, typename... Abis>
struct deduce_from_candidates<T, lane_count, Abi, Abis...> {
   using rebound_abi = Abi::template make_abi_type<T>;
   using fallback = deduce_from_candidates<T, lane_count, Abis...>::type;
   using type =
      conditional<rebound_abi::lanes == lane_count, rebound_abi, fallback>;
};

template <typename T, idx lane_count, typename... Abis>
struct deduce_impl {
   using type = deduce_from_candidates<
      T, lane_count, Abis..., cat::simd_abi::native<T>, x64::sse_abi<T>,
      cat::simd_abi::scalar<T>>::type;
};

}  // namespace detail

namespace simd_abi {
template <typename T, idx lane_count, typename... Abis>
using deduce = detail::deduce_impl<T, lane_count, Abis...>::type;
}  // namespace simd_abi

