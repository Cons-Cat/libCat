template <typename T, typename Abi>
   requires(is_same<typename Abi::scalar_type, T>)
class
   [[clang::preferred_name(fixed_size_simd<T, Abi::lanes>),
     clang::preferred_name(native_simd<T>),
     clang::preferred_name(scalar_simd<T>),
     clang::preferred_name(x64::avx_simd<T>),
     clang::preferred_name(x64::sse_simd<T>),
     clang::preferred_name(fixed_size_unaligned_simd<T, Abi::lanes>),
     clang::preferred_name(native_unaligned_simd<T>),
     clang::preferred_name(compatible_unaligned_simd<T>),
     clang::preferred_name(scalar_unaligned_simd<T>)]] alignas(Abi::alignment
                                                                  .raw) simd {
   // `mapped_type` is the fundamental storage shape for each lane (`T` may be
   // a libCat arithmetic wrapper). That keeps `cat::simd_abi` hooks aligned
   // with hardware intrinsics.
   using mapped_type = simd_vector_element<T>;

   struct unaligned_abi {
      using scalar_type = T;
      static constexpr idx size = Abi::size;
      static constexpr idx lanes = Abi::lanes;
      // By setting `alignment` to 1 here, and by extension in the definition of
      // `simd::raw_type` produced by this ABI, Clang produces unaligned SIMD
      // instructions for operations on this ABI.
      static constexpr ualign alignment = 1u;
   };

   using unaligned_vector = simd<T, unaligned_abi>;

 public:
   using value_type = T;
   // TODO: Figure out what `reference` should be for lane values.
   // using reference = T&;
   using abi_type = Abi;
   using mask_type = simd_mask<T, abi_type>;
   using scalar_type = value_type;
   // Contiguous buffer / `.raw` lane element (differs from `value_type` when it
   // is a wrapper such as `cat::int4`).
   using memory_lane = simd_vector_element<T>;

   using iterator = detail::simd_range_stepanov_iterator<simd>;
   using const_iterator = detail::simd_range_stepanov_iterator<simd const>;

   // `gnu::vector_size` is a Clang attribute that represents SIMD data-types.
   // `gnu::aligned` is a Clang attribute that guarantees alignment for all
   // instances of a type. We can use this to conditionally under-align SIMD.
   using raw_type
      [[gnu::vector_size(Abi::size.raw), gnu::aligned(Abi::alignment.raw)]] =
         mapped_type;

   constexpr simd() = default;

   constexpr simd(simd const& operand) = default;

   constexpr simd(simd&& operand) = default;

   // This cannot be passed by reference.
   [[gnu::always_inline]]
   constexpr simd(unaligned_vector operand)
       : raw(operand.raw) {
   }

   [[gnu::nodebug]]
   constexpr simd(raw_type values)
       : raw(values) {
   }

   // One scalar `value` is converted to `T` and that value is stored in every
   // lane. This is not the multi-argument per-lane constructor.
   template <typename U>
      requires(
         is_constructible<T, remove_cvref<U>>
         && detail::simd_broadcast_really_convertible_to<remove_cvref<U>, T>()
      )
   constexpr explicit(
      !detail::simd_broadcast_really_convertible_to<remove_cvref<U>, T>()
   ) simd(U&& value) {
      // These semantics are described by P3844R2.
      this->fill(static_cast<scalar_type>($fwd(value)));
   }

   // When the scalar must be a compile-time constant (`consteval`), the splat
   // is the same as `simd(U&&)`. Inexact conversion is undefined and is
   // rejected by failed constant evaluation on a violated `[[assume]]`.
   template <typename U>
      requires detail::simd_consteval_broadcast_arg<remove_cvref<U>, T>
   consteval simd(U value) {
      // These semantics are described by P3844R2.
      [[assume(
         detail::has_simd_broadcast_consteval_value<remove_cvref<U>, T>(value)
      )]];
      this->fill(static_cast<scalar_type>(value));
   }

   // Construct from a variadic argument list.
   template <typename... Us>
      requires(sizeof...(Us) > 1u && sizeof...(Us) == Abi::lanes.raw)
   [[gnu::nodebug]] constexpr simd(Us&&... arguments)
       // Clang requires curly braces here.
       : raw(
            raw_type{simd_lane_to_storage(static_cast<T>($fwd(arguments)))...}
         ) {
   }

   // Construct from a constant list, such as `value_list` or
   // `integer_sequence`.
   // TODO: Should this be removed, along with `cat::List`'s?
   template <typename U, U... Us>
      requires(sizeof...(Us) == Abi::lanes.raw)
   [[gnu::nodebug]] constexpr simd(value_type_list<U, Us...> /*unused*/)
       : raw(raw_type{simd_lane_to_storage(static_cast<T>(Us))...}) {
   }

   // `simd` from `simd_mask` by way of unary + on the mask.
   template <typename U, typename AbiM>
   constexpr simd(simd_mask<U, AbiM> const& k)
      requires(is_same<
               simd<T, Abi>,
               simd<
                  detail::simd_unary_signed_integer_from_element_t<U>,
                  typename AbiM::template make_abi_type<
                     detail::simd_unary_signed_integer_from_element_t<U>>>>)
       : simd(+k) {
      // P3922R1 `+k` is the standard mask to `simd` bridge.
      // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2025/p3922r1.pdf
   }

   // Any ABI for which this `simd` is equal to in size and overaligned can be
   // explicitly converted to.
   template <typename OtherAbi>
      requires(
         OtherAbi::size == abi_type::size
         && OtherAbi::alignment <= abi_type::alignment
         && OtherAbi::lanes == abi_type::lanes
      )
   [[gnu::always_inline]]
   explicit constexpr
   operator simd<T, OtherAbi>() const {
      return this->raw;
   }

   // Any ABI for which this `simd` is equal to in size and overaligned can be
   // explicitly converted to, and any underlying type for which this `simd`'s
   // is compatible with, can be converted to.
   template <typename OtherAbi, typename U>
      requires(
         is_convertible<U, T> && OtherAbi::size == abi_type::size
         && OtherAbi::alignment <= abi_type::alignment
         && OtherAbi::lanes == abi_type::lanes
      )
   [[gnu::always_inline]]
   explicit constexpr
   operator simd<U, OtherAbi>() const {
      return __builtin_convertvector(
         this->raw, typename simd<U, OtherAbi>::raw_type
      );
   }

   // Copy-assign the raw value of a `simd` to this.
   constexpr auto
   operator=(simd const& operand) -> simd& = default;

   // Move-assign the raw value of another `simd` into this.
   constexpr auto
   operator=(simd&& operand) -> simd& = default;

   // Value equality. `true` iff every lane compares equal (`NaN` lanes behave
   // like scalar floating-point compare).
   [[nodiscard]]
   constexpr auto
   operator==(simd const& operand) const -> bool {
      for (idx i = 0u; i < Abi::lanes; ++i) {
         if ((*this)[i] != operand[i]) {
            return false;
         }
      }
      return true;
   }

   // Compare greater-than for each lane to another `simd`'s lanes, and store
   // the results in a new `simd`.
   [[nodiscard, gnu::always_inline]]
   constexpr auto
   operator>(simd const& operand) const -> simd_mask<T, abi_type> {
      return this->raw > operand.raw;
   }

   // Compare greater-than-or-equal for each lane to another `simd`'s lanes, and
   // store the results in a new `simd`.
   [[nodiscard, gnu::always_inline]]
   constexpr auto
   operator>=(simd const& operand) const -> simd_mask<T, abi_type> {
      return this->raw >= operand.raw;
   }

   // Compare less-than for each lane to another `simd`'s lanes, and store the
   // results in a new `simd`.
   [[nodiscard, gnu::always_inline]]
   constexpr auto
   operator<(simd const& operand) const -> simd_mask<T, abi_type> {
      return this->raw < operand.raw;
   }

   // Compare less-than-or-equal for each lane to another `simd`'s lanes, and
   // store the results in a new `simd`.
   [[nodiscard, gnu::always_inline]]
   constexpr auto
   operator<=(simd const& operand) const -> simd_mask<T, abi_type> {
      return this->raw <= operand.raw;
   }

   template <typename U, typename OtherAbi>
      requires(
