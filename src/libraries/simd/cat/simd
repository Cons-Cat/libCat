   [[nodiscard]]
   constexpr auto
   operator()(simd<T, Abi> const& v, simd<T, Abi>::scalar_type seed) const
      -> decltype(v.reduce_in_order_fadd(seed)) {
      // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2018/p0918r1.pdf
      return v.reduce_in_order_fadd(seed);
   }
};

