namespace detail {

// Memory alignment for `simd<T, fixed_size_abi<T, N>>` follows the same idea
// as `std::simd`. An implementation-defined power of two no larger than the
// object and not exceeding the native SIMD alignment from `target_abi`
// Effectively, short vectors are 16-byte aligned, and long vectors are 32-byte
// aligned.
[[nodiscard]]
consteval auto
simd_memory_alignment_for_fixed_size(idx object_size, uword native_cap,
                                     uword element_align) -> uword {
   uword const bounded = object_size <= native_cap
                            ? static_cast<uword>(object_size.raw)
                            : native_cap;
   if (bounded == 0u) {
      return element_align;
   }
   uword r = 1u;
   while (r * 2u <= bounded) {
      r *= 2u;
   }
   return r < element_align ? element_align : r;
}

}  // namespace detail

// ABI tags for `simd`. These are used for providing an extensible API by
// overloading functions for `simd` objects with different ABI tags, as well as
// providing a type-safe API by requiring compatible ABI tags between `simd`
// operands.

// `fixed_size_abi` is a portable SIMD ABI that can be expected to work across
// any supported build target, so long as `in_lanes` (an `idx` lane count) does
// not exceed that target's maximum vector size.
template <typename T, idx in_lanes>
struct fixed_size_abi {
   using scalar_type = T;

   // Produce a similar `fixed_size_abi` for type `U`.
   template <typename U>
   using make_abi_type =
      fixed_size_abi<U, idx{in_lanes.raw * sizeof(T) / sizeof(U)}>;

   constexpr fixed_size_abi() = delete;

   // TODO: Select `target_abi` portably.
   using target_abi = x64::avx2_abi<T>;
   static constexpr idx lanes = in_lanes;
   static constexpr idx size = idx(lanes.raw * sizeof(T));
   static constexpr uword alignment =
      detail::simd_memory_alignment_for_fixed_size(
         size, target_abi::alignment, static_cast<uword>(alignof(T)));

   template <typename ElementT>
   using simd_mask_lane =
      simd_abi::mask_lane<fixed_size_abi<ElementT, idx{in_lanes.raw * sizeof(T)
                                                       / sizeof(ElementT)}>,
                          ElementT>;
};

// `native_abi` is a portable SIMD ABI that can be expected to work on any
// supported build target. However, you cannot safely assume the size or
// alignment this ABI expresses.
template <typename T>
struct native_abi {
   using scalar_type = T;

   // Produce a similar `native_abi` for type `U`.
   template <typename U>
   using make_abi_type = native_abi<U>;

   constexpr native_abi() = delete;

   // TODO: Select `target_abi` portably.
   using target_abi = x64::avx2_abi<T>;
   static constexpr idx size = target_abi::size;
   static constexpr idx lanes = target_abi::lanes;
   static constexpr uword alignment = target_abi::alignment;

   template <typename ElementT>
   using simd_mask_lane = simd_abi::mask_lane<native_abi<ElementT>, ElementT>;
};

// An ABI tag for efficient execution that stays stable across translation units
// on the target. Same layout as `native_abi` today (`target_abi`); distinct
// type so `simd<T, compatible<T>>` differs from `simd<T, native<T>>` for
// overload resolution / tagging.
template <typename T>
struct compatible_abi {
   using scalar_type = T;

   template <typename U>
   using make_abi_type = compatible_abi<U>;

   constexpr compatible_abi() = delete;

   using target_abi = x64::avx2_abi<T>;
   static constexpr idx size = target_abi::size;
   static constexpr idx lanes = target_abi::lanes;
   static constexpr uword alignment = target_abi::alignment;

   template <typename ElementT>
   using simd_mask_lane =
      simd_abi::mask_lane<compatible_abi<ElementT>, ElementT>;
};

// Portable 16-byte XMM-sized SIMD ABI with no ISA-specific hook
// specializations in libCat (elementwise / generic paths only). Lane count is
// `16 / sizeof(T)`. Use beside `native_abi` when that tag aliases an x86 ISA
// ABI on the host (for example `avx2_abi`).
template <typename T>
struct scalar_abi {
   using scalar_type = T;

   template <typename U>
   using make_abi_type = scalar_abi<U>;

   constexpr scalar_abi() = delete;

   static constexpr idx size = 16u;
   static constexpr idx lanes{size.raw / sizeof(T)};
   static constexpr uword alignment = 16u;

   static_assert(sizeof(T) > 0 && size.raw % sizeof(T) == 0,
                 "`scalar_abi` element size must divide 16 bytes");
   static_assert(lanes > 0,
                 "`scalar_abi` lane count derived from sizeof(T) must be "
                 "positive");

   template <typename ElementT>
   using simd_mask_lane = simd_abi::mask_lane<scalar_abi<ElementT>, ElementT>;
};

namespace simd_abi {
template <typename T, idx N>
using fixed_size = fixed_size_abi<T, N>;
template <typename T>
using native = native_abi<T>;
template <typename T>
using compatible = compatible_abi<T>;
template <typename T>
using scalar = scalar_abi<T>;

template <typename BaseAbi>
using unaligned = unaligned_abi<BaseAbi>;
}  // namespace simd_abi

namespace detail {
// Cast a `native_abi` or `fixed_size_abi` vector into its underlying
// representation.
template <typename abi_type, typename T>
constexpr auto
native_cast(simd<T, abi_type> vector) {
   return static_cast<simd<T, typename native_abi<T>::target_abi>>(vector);
}

template <typename abi_type, typename T>
constexpr auto
native_cast(simd_mask<T, abi_type> mask) {
   return static_cast<simd_mask<T, typename native_abi<T>::target_abi>>(mask);
}

template <typename V>
inline constexpr bool is_cat_simd = false;

template <typename T, typename Abi>
inline constexpr bool is_cat_simd<simd<T, Abi>> = true;

template <typename M>
inline constexpr bool is_cat_simd_mask = false;

template <typename T, typename Abi>
inline constexpr bool is_cat_simd_mask<simd_mask<T, Abi>> = true;

template <typename Ty>
inline constexpr bool has_simd_mask_unary_integral_conversion_v =
   sizeof(Ty) == 1zu || sizeof(Ty) == 2zu || sizeof(Ty) == 4zu
   || sizeof(Ty) == 8zu;

template <typename Ty>
   requires(has_simd_mask_unary_integral_conversion_v<Ty>)
using simd_unary_signed_integer_from_element_t =
   conditional<sizeof(Ty) == 1zu, signed char,
               conditional<sizeof(Ty) == 2zu, short,
                           conditional<sizeof(Ty) == 4zu, int, long long>>>;

}  // namespace detail

template <typename V>
concept is_simd = detail::is_cat_simd<V>;

template <typename M>
concept is_simd_mask = detail::is_cat_simd_mask<M>;

template <typename X>
concept is_simd_or_mask = is_simd<X> || is_simd_mask<X>;

// Element type stored in `simd::raw` (`GNU` vector lanes). `T` is the logical
// lane type (`int`, `cat::int4`, ...). Raw `bool` uses `unsigned char` storage
// because `[[gnu::vector_size]]` cannot be `bool`. Other lanes use
// `make_raw_arithmetic`
template <typename T>
struct simd_vector_element_trait {
   using type = raw_arithmetic_type<T>;
};

template <>
struct simd_vector_element_trait<bool> {
   using type = unsigned char;
};

template <typename T>
using simd_vector_element = simd_vector_element_trait<T>::type;

namespace detail {

// Integral type with the same size as a mask lane, for `__builtin_bit_cast`
// when `lane_scalar` is not an integral type (e.g. `arithmetic<float>`).
template <typename LaneScalar>
using simd_mask_lane_bits_t =
   conditional<sizeof(LaneScalar) == 4zu, unsigned int,
               conditional<sizeof(LaneScalar) == 8zu, unsigned long long,
                           conditional<sizeof(LaneScalar) == 2zu,
                                       unsigned short, unsigned char>>>;

}  // namespace detail

// Logical lane value to an element of `simd<T, Abi>::raw_type`.
template <typename T>
[[gnu::always_inline, gnu::nodebug]]
constexpr auto
simd_lane_to_storage(T lane) -> simd_vector_element<T> {
   if constexpr (is_same<T, bool>) {
      return static_cast<unsigned char>(lane ? 1u : 0u);
   }
   return static_cast<simd_vector_element<T>>(make_raw_arithmetic(lane));
}

// Inverse of `simd_lane_to_storage` for one vector lane slot (Clang accepts
// GNU vector `raw[i]` reads in constant evaluation; `reinterpret_cast` lane
// pointers are not).
template <typename T>
[[gnu::always_inline, gnu::nodebug]]
constexpr auto
simd_lane_from_raw(simd_vector_element<T> slot) -> T {
   if constexpr (is_same<T, bool>) {
      return static_cast<bool>(slot);
   }
   if constexpr (is_same<T, bool2>) {
      return bool2(slot);
   }
   if constexpr (is_same<T, bool4>) {
      return bool4(slot);
   }
   return static_cast<T>(static_cast<raw_arithmetic_type<T>>(slot));
}

