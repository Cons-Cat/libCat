// ABI hook templates (primaries below). specialize these per `Abi` in target
// headers (`detail/simd_*`) for fast paths. unspecialized templates keep the
// portable lane loops.
namespace cat::detail::simd_abi {

// Count all true lanes in this mask.
template <typename T, typename Abi>
struct mask_count_if_true {
   [[nodiscard]]
   static constexpr auto
   invoke(simd_mask<T, Abi> const& m) -> idx {
      // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2022/p2638r0.pdf
      idx n = 0u;
      for (idx i = 0u; i < Abi::lanes; ++i) {
         if (m[i]) {
            ++n;
         }
      }
      return n;
   }
};

// Find the first lane of `m` that is true. `count_if_true()` is non-zero (at
// least one true lane).
template <typename T, typename Abi>
struct mask_find_if_true {
   [[nodiscard]]
   static constexpr auto
   invoke(simd_mask<T, Abi> const& m) -> idx {
      // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2022/p2638r0.pdf
      for (idx i = 0u; i < Abi::lanes; ++i) {
         if (m[i]) {
            return i;
         }
      }
      __builtin_unreachable();
   }
};

// Find the last lane of `m` that is true. `count_if_true()` is non-zero (at
// least one true lane).
template <typename T, typename Abi>
struct mask_find_last_if_true {
   [[nodiscard]]
   static constexpr auto
   invoke(simd_mask<T, Abi> const& m) -> idx {
      // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2022/p2638r0.pdf
      idx max_i = 0u;
      for (idx i = 0u; i < Abi::lanes; ++i) {
         if (m[i]) {
            max_i = i;
         }
      }
      return max_i;
   }
};

// Find whether every lane of `mask` is true.
template <typename T, typename Abi>
struct mask_all_of {
   [[nodiscard]]
   static constexpr auto
   invoke(simd_mask<T, Abi> const& mask) -> bool {
      if consteval {
         for (idx i = 0u; i < Abi::lanes; ++i) {
            if (!mask[i]) {
               return false;
            }
         }
         return true;
      }
      return __builtin_reduce_and(
         mask.raw != typename simd_mask<T, Abi>::raw_type{}
      );
   }
};

// Find whether any lane of `mask` is true.
template <typename T, typename Abi>
struct mask_any_of {
   [[nodiscard]]
   static constexpr auto
   invoke(simd_mask<T, Abi> const& mask) -> bool {
      if consteval {
         for (idx i = 0u; i < Abi::lanes; ++i) {
            if (mask[i]) {
               return true;
            }
         }
         return false;
      }
      return __builtin_reduce_or(
         mask.raw != typename simd_mask<T, Abi>::raw_type{}
      );
   }
};

