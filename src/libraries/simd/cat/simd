   // Logical lane `i` maps to `mask_traits` storage (`lane_scalar`). Decode is
   // ABI-defined but `operator[]` always yields abstract `bool`.
   //
   // Deliberately NOT `[[gnu::always_inline]]`: at -O3 + LTO Clang folds the
   // inlined `decode_lane(raw, i)` into a wider load that ignores the
   // `gnu::aligned(1)` annotation on the unaligned mask's `raw_type`, which
   // segfaults `simd_avx_unaligned_abi_mask` on a 2-byte-misaligned
   // simd_mask. (See `tests/src/test_simd_sse_avx.cpp`'s unaligned mask
   // test and the file-level policy comment on `cat::simd`.) Codegen on
   // an aligned mask is already fine without the attribute -- Clang
   // inlines this thin wrapper at every optimization level.
   [[nodiscard, gnu::no_sanitize("bounds")]]
   constexpr auto
   operator[](idx index) const -> bool {
      return mask_traits::decode_lane(raw, index);
   }

   [[gnu::always_inline]]
   constexpr auto
   set_lane(idx index, bool value) -> void {
      mask_traits::encode_lane(raw, index, value);
   }

   // Logical NOT per lane (`simd_mask` stays a mask).
   [[nodiscard, gnu::always_inline]]
   constexpr auto
   operator!() const -> mask_type {
      // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2025/p3922r1.pdf
      mask_type result{};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         result.set_lane(i, !(*this)[i]);
      }
      return result;
   }

   // Integral `simd` lanes from abstract mask lanes (feeds mask -> `simd`
   // constructor).
   [[nodiscard, gnu::always_inline]]
   constexpr auto
   operator+() const -> simd<
      detail::simd_unary_signed_integer_from_element_t<T>,
      typename abi_type::template make_abi_type<
         detail::simd_unary_signed_integer_from_element_t<T>>> {
      // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2025/p3922r1.pdf
      using I = detail::simd_unary_signed_integer_from_element_t<T>;
      using vec = simd<I, typename abi_type::template make_abi_type<I>>;
      vec out{};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         bool const lane = (*this)[i];
         out.set_lane(i, static_cast<I>(+static_cast<int>(lane)));
      }
      return out;
   }

   [[nodiscard]]
   constexpr auto
   operator-() const -> simd<
      detail::simd_unary_signed_integer_from_element_t<T>,
      typename abi_type::template make_abi_type<
         detail::simd_unary_signed_integer_from_element_t<T>>> {
      // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2025/p3922r1.pdf
      using I = detail::simd_unary_signed_integer_from_element_t<T>;
      using vec = simd<I, typename abi_type::template make_abi_type<I>>;
      vec out{};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         bool const lane = (*this)[i];
         out.set_lane(i, static_cast<I>(-static_cast<int>(lane)));
      }
      return out;
   }

   [[nodiscard]]
   constexpr auto
   operator~() const -> simd<
      detail::simd_unary_signed_integer_from_element_t<T>,
      typename abi_type::template make_abi_type<
         detail::simd_unary_signed_integer_from_element_t<T>>> {
      // P3922R1.
      // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2025/p3922r1.pdf
      using I = detail::simd_unary_signed_integer_from_element_t<T>;
      using vec = simd<I, typename abi_type::template make_abi_type<I>>;
      vec out{};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         bool const lane = (*this)[i];
         int const promoted = static_cast<int>(lane);
         out.set_lane(i, static_cast<I>(~promoted));
      }
      return out;
   }

   [[nodiscard, gnu::no_sanitize("bounds"), gnu::always_inline]]
   constexpr auto
   lane_byte(idx index) const -> unsigned char const& {
      return *(
         reinterpret_cast<unsigned char const*>(__builtin_addressof(raw))
         + (index.raw * sizeof(lane_scalar))
      );
   }

   // Evaluate true if every lane is non-zero.
   [[nodiscard]]
   constexpr auto
   all_of() const -> bool {
      return simd_all_of(*this);
   }

   // Evaluate true if any lanes are non-zero.
   [[nodiscard]]
   constexpr auto
   any_of() const -> bool {
      return simd_any_of(*this);
   }

   // Evaluate true if every lane is zero.
   [[nodiscard]]
   constexpr auto
   none_of() const -> bool {
      return !(this->any_of());
   }

   // Standard mask reductions-style helpers on logical lanes (standard mask
   // wording. `reduce_min_index`/`reduce_max_index` over true lane indices).
   [[nodiscard]]
   constexpr auto
   count_if_true() const -> idx {
      return detail::simd_abi::mask_count_if_true<T, abi_type>::invoke(*this);
   }

   // Lowest index of a true lane. `count_if_true()` is non-zero (at least one
   // true lane).
   [[nodiscard]]
   constexpr auto
   find_if_true() const -> idx {
      return detail::simd_abi::mask_find_if_true<T, abi_type>::invoke(*this);
   }

   // Highest index of a true lane. `count_if_true()` is non-zero (at least one
   // true lane).
   [[nodiscard]]
   constexpr auto
   find_last_if_true() const -> idx {
      return detail::simd_abi::mask_find_last_if_true<T, abi_type>::invoke(
         *this
      );
   }

   // Bit i equals `operator[](i)` for every i in `[0, size())`. Body in
   // `implementations/simd_mask_bitset.tpp` (`simd_to_bitset`).
   [[nodiscard]]
   constexpr auto
   to_bitset() const -> cat::bitset<abi_type::lanes>;

   // Let N be `word_bits` (`sizeof(uword)` in bits from `<cat/bit>`). Either
   // `size() <= N` as a lane count comparison or every lane with index `i >= N`
   // is false. Packing only consults lanes below N. High true lanes when
   // `abi_type::lanes` exceeds N violate the TS contract and yield a wrong
   // packed value.
   [[nodiscard]]
   constexpr auto
   to_uword() const -> uword {
      uword bits = 0u;
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         if (i >= word_bits) {
            break;
         }
         if ((*this)[i]) {
            bits |= (1uz << i);
         }
      }
      return bits;
   }

   template <typename UInt>
      requires(is_unsigned_integral<UInt> && !is_bool<UInt>)
   explicit constexpr simd_mask(UInt pattern_bits) {
      this->raw = raw_type{};
      uword const bits = static_cast<uword>(pattern_bits);
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         this->set_lane(i, ((bits >> i) & 1uz) != 0uz);
      }
   }

   // Fill all lanes with `value`. This is also known as a "splat" operation.
   constexpr auto
   fill(bool value) -> mask_type {
      this->raw = raw_type{};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         this->set_lane(i, value);
      }
      return *this;
   }

   // Load each logical lane from one `bool` per lane in `p_lane_bools` (gather
   // from memory into mask lanes. Not a `raw_type` object representation. Use
   // `raw` assignment for that).
   constexpr auto
   load(bool const* _Nonnull p_lane_bools) -> mask_type& {
      this->raw = raw_type{};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         this->set_lane(i, p_lane_bools[i]);
      }
      return *this;
   }

   [[nodiscard]]
   static constexpr auto
   size() -> idx {
      return abi_type::lanes;
   }

   // Make `cat::simd_mask` iterable like a container.
   [[nodiscard]]
   constexpr auto
   begin_pos() const -> idx {
      return 0u;
   }

   [[nodiscard]]
   constexpr auto
   end_pos() const -> idx {
      return size();
   }

   constexpr void
   inc_pos(idx& position) const {
      ++position;
   }

   constexpr void
   dec_pos(idx& position) const {
      position = idx(position.raw - 1u);
   }

   constexpr void
   offset_pos(idx& position, iword offset) const {
      position = idx(static_cast<idx::raw_type>(position + offset));
   }

   [[nodiscard]]
   constexpr auto
   distance(idx left, idx right) const -> iword {
      return right - left;
   }

   [[nodiscard]]
   constexpr auto
   read_at_unchecked(idx position) const -> bool {
      return (*this)[position];
   }

   // Implement Stepanov iteration as well, as per P3983R1.
   [[nodiscard]]
   constexpr auto
   begin() -> iterator {
      return iterator(this, 0u);
   }

   [[nodiscard]]
   constexpr auto
   begin() const -> const_iterator {
      return const_iterator(this, 0u);
   }

   [[nodiscard]]
   constexpr auto
   cbegin() const -> const_iterator {
      return begin();
   }

   [[nodiscard]]
   constexpr auto
   end() const -> default_sentinel_t {
      return default_sentinel;
   }

   [[nodiscard]]
   constexpr auto
   cend() const -> default_sentinel_t {
      return end();
   }

   [[nodiscard, gnu::always_inline, gnu::returns_nonnull,
     gnu::assume_aligned(Abi::alignment.raw)]]
   constexpr auto
   data() [[clang::lifetimebound]] -> lane_scalar* _Nonnull {
      return __builtin_bit_cast(lane_scalar*, &raw);
   }

   [[nodiscard, gnu::always_inline, gnu::returns_nonnull,
     gnu::assume_aligned(Abi::alignment.raw)]]
   constexpr auto
   data() const [[clang::lifetimebound]] -> lane_scalar const* _Nonnull {
      return __builtin_bit_cast(lane_scalar const*, &raw);
   }

   // Invoke `callback` on each lane in order. Unlike `std::for_each`, the
   // callback is perfect-forwarded. The callback may take a single lane
   // value, or a lane value and its `idx`.
   template <typename Callback>
      requires(
         is_invocable<Callback, scalar_type>
         || is_invocable<Callback, scalar_type, idx>
      )
   [[gnu::always_inline]]
   constexpr void
   for_each(Callback&& callback) const {
#pragma clang loop vectorize_predicate(enable)
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         if constexpr (is_invocable<Callback, scalar_type, idx>) {
            $fwd(callback)((*this)[i], i);
         } else {
            $fwd(callback)((*this)[i]);
         }
      }
   }

   raw_type raw;
};

// Count all true lanes in this mask.
template <typename T, typename Abi>
[[nodiscard]]
constexpr auto
popcount(simd_mask<T, Abi> const& mask) -> int {
