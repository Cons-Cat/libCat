namespace cat {

template <typename T, typename Abi>
class
   [[clang::preferred_name(fixed_size_simd_mask<T, Abi::lanes>),
     clang::preferred_name(native_simd_mask<T>),
     clang::preferred_name(scalar_simd_mask<T>),
     clang::preferred_name(x64::avx_simd_mask<T>),
     clang::preferred_name(x64::sse_simd_mask<T>),
     clang::preferred_name(fixed_size_unaligned_simd_mask<T, Abi::lanes>),
     clang::preferred_name(native_unaligned_simd_mask<T>),
     clang::preferred_name(compatible_unaligned_simd_mask<T>),
     clang::preferred_name(
        scalar_unaligned_simd_mask<T>
     )]] alignas(Abi::alignment.raw) simd_mask {
 public:
   // The `[[gnu::always_inline]]` policy on intrinsic-/operator-using
   // members is the same as `cat::simd`'s -- see the comment at the top
   // of that class for the rationale and the empirical validation under
   // `.cache/simd-target-probe/`.
   using abi_type = Abi;
   using mask_traits = Abi::template simd_mask_lane<T>;
   using mask_type = simd_mask<T, abi_type>;
   using value_type = bool;
   // TODO: Figure out what `reference` should be for logical mask lanes.
   // using reference = unsigned char&;
   using simd_type = simd<T, abi_type>;
   using scalar_type = value_type;

   using lane_scalar = mask_traits::lane_scalar;
   using raw_type = mask_traits::raw_type;

   using iterator = detail::simd_range_stepanov_iterator<mask_type>;
   using const_iterator = detail::simd_range_stepanov_iterator<mask_type const>;

   constexpr simd_mask() = default;

   constexpr simd_mask(simd_mask<T, Abi> const& operand) = default;

   constexpr simd_mask(simd_mask<T, Abi>&& operand) = default;

   constexpr simd_mask(raw_type value) : raw(value) {
   }

   constexpr simd_mask(bool value) {
      // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2025/p3844r2.pdf
      this->fill(value);
   }

   // Implicitly convert to `bool` under the `scalar` ABI so that `cat::simd`
   // can be a drop-in replacement to `cat::basic_int` or `cat::basic_float`.
   constexpr
   operator bool() const
      requires(abi_type::lanes == 1u)
   {
      return (*this)[0u];
   }

   // Construct from a variadic argument list (one `bool` per logical lane).
   template <typename... Bools>
   constexpr simd_mask(Bools&&... arguments)
      requires(
         sizeof...(arguments) > 1 && sizeof...(arguments) == abi_type::lanes.raw
      )
   {
      this->raw = raw_type{};
      bool const lane_vals[] = {static_cast<bool>($fwd(arguments))...};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         this->set_lane(i, lane_vals[i.raw]);
      }
   }

   // Construct from a constant list, such as `value_list` or
   // `integer_sequence`.
   template <bool... lane_bools>
   constexpr simd_mask(value_type_list<bool, lane_bools...> const /*unused*/)
      requires(sizeof...(lane_bools) == abi_type::lanes.raw)
   {
      this->raw = raw_type{};
      bool const lane_vals[] = {lane_bools...};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         this->set_lane(i, lane_vals[i.raw]);
      }
   }

   // Rebinding `simd_mask` to another ABI tag with the same lane count, storage
   // size, and element type `T` (standard explicit conversion).
   template <typename OtherAbi>
   [[gnu::always_inline]]
   explicit constexpr
   operator simd_mask<T, OtherAbi>() const
      requires(
         OtherAbi::size == abi_type::size
         && OtherAbi::alignment <= abi_type::alignment
         && OtherAbi::lanes == abi_type::lanes
      )
   {
      return this->raw;
   }

   // Mask-to-mask when the lane element type becomes `U`.
   // `__builtin_convertvector` matches standard element-wise conversion between
   // lanes.
   template <typename OtherAbi, typename U>
   [[gnu::always_inline]]
   explicit constexpr
   operator simd_mask<U, OtherAbi>() const
      requires(
         is_convertible<U, T> && OtherAbi::size == abi_type::size
         && OtherAbi::alignment <= abi_type::alignment
         && OtherAbi::lanes == abi_type::lanes
      )
   {
      return __builtin_convertvector(
         this->raw, typename simd_mask<U, OtherAbi>::raw_type
      );
   }

   // Copy-assign the raw value of a `simd` to this.
   constexpr auto
   operator=(mask_type const& operand) -> mask_type& = default;

   // Move-assign the raw value of another `simd` into this.
   constexpr auto
   operator=(mask_type&& operand) -> mask_type& {
      this->raw = move(operand).raw;
      return *this;
   }

