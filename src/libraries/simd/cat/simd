namespace cat {

template <typename T, typename in_abi>
   requires(is_same<typename in_abi::scalar_type, T>)
constexpr auto
simd<T, in_abi>::undef() & -> detail::simd_overflow_reference<
   T, in_abi, overflow_policies::wrap>
   requires(!is_bool<T>)
{
   return detail::simd_overflow_reference<T, in_abi, overflow_policies::wrap>(
      *this);
}

template <typename T, typename in_abi>
   requires(is_same<typename in_abi::scalar_type, T>)
constexpr auto
simd<T, in_abi>::wrap() & -> detail::simd_overflow_reference<
   T, in_abi, overflow_policies::wrap>
   requires(!is_bool<T>)
{
   return detail::simd_overflow_reference<T, in_abi, overflow_policies::wrap>(
      *this);
}

template <typename T, typename in_abi>
   requires(is_same<typename in_abi::scalar_type, T>)
constexpr auto
simd<T, in_abi>::sat() & -> detail::simd_overflow_reference<
   T, in_abi, overflow_policies::saturate>
   requires(!is_bool<T>)
{
   return detail::simd_overflow_reference<T, in_abi,
                                          overflow_policies::saturate>(*this);
}

