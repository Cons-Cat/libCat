#include "cat/detail/simd_mask_lane_sseavx.hpp"

namespace cat {

template <typename T, typename in_abi>
class alignas(in_abi::alignment.raw) simd_mask {
 public:
   using abi_type = in_abi;
   using mask_traits = typename in_abi::template simd_mask_lane<T>;
   using mask_type = simd_mask<T, abi_type>;
   using value_type = bool;
   using reference = unsigned char&;
   using simd_type = simd<T, abi_type>;
   using scalar_type = value_type;

   using lane_scalar = typename mask_traits::lane_scalar;
   using raw_type = typename mask_traits::raw_type;

   using iterator = detail::simd_range_iterator<mask_type>;
   using const_iterator = detail::simd_range_iterator<mask_type const>;

   constexpr simd_mask() = default;

   constexpr simd_mask(simd_mask<T, in_abi> const& operand) = default;

   constexpr simd_mask(simd_mask<T, in_abi>&& operand) = default;

   constexpr simd_mask(raw_type value) : raw(value) {
   }

   constexpr simd_mask(bool) = delete (
      "A `cat::simd_mask` was constructed from a `bool`. This may mean == or "
      "!= was used to compare `cat::simd` or `cat::simd_mask`."
      "Use `equal_lanes` / `unequal_lanes` instead. To broadcast one bool to "
      "every "
      "lane, use `make_simd_mask_filled`.");

   // Construct from a variadic argument list (one bool per logical lane).
   template <typename... bools>
   constexpr simd_mask(bools&&... values)
      requires(sizeof...(values) > 1
               && sizeof...(values) == abi_type::lanes.raw)
   {
      this->raw = raw_type{};
      bool const lane_vals[] = {static_cast<bool>(fwd(values))...};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         this->set_lane(i, lane_vals[i.raw]);
      }
   }

   // Construct from a constant list, such as `value_list` or
   // `integer_sequence`.
   template <bool... bools>
   constexpr simd_mask(value_type_list<bool, bools...> const)
      requires(sizeof...(bools) == abi_type::lanes.raw)
   {
      this->raw = raw_type{};
      bool const lane_vals[] = {bools...};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         this->set_lane(i, lane_vals[i.raw]);
      }
   }

   // Rebinding `simd_mask` to another ABI tag with the same
   // lane count, storage size, and element type `T` (standard explicit
   // conversion).
   template <typename other_abi_type>
   explicit constexpr
   operator simd_mask<T, other_abi_type>() const
      requires(other_abi_type::size == abi_type::size
               && other_abi_type::alignment <= abi_type::alignment
               && other_abi_type::lanes == abi_type::lanes)
   {
      return this->raw;
   }

   // Mask-to-mask when the lane element type becomes `U`.
   // `__builtin_convertvector` matches standard element-wise conversion between
   // lanes.
   template <typename other_abi_type, typename U>
   explicit constexpr
   operator simd_mask<U, other_abi_type>() const
      requires(is_convertible<U, T> && other_abi_type::size == abi_type::size
               && other_abi_type::alignment <= abi_type::alignment
               && other_abi_type::lanes == abi_type::lanes)
   {
      return __builtin_convertvector(
         this->raw, typename simd_mask<U, other_abi_type>::raw_type);
   }

   // Copy-assign the raw value of a `simd` to this.
   constexpr auto
   operator=(mask_type const& operand) -> mask_type& = default;

   // Move-assign the raw value of another `simd` into this.
   constexpr auto
   operator=(mask_type&& operand) -> mask_type& {
      this->raw = move(operand).raw;
      return *this;
   }

   // Compare equality for each lane to another mask's lanes. Integral lane
   // storage matches `raw ==`. floating-point lanes use logical equality so
   // compare masks (`NaN == NaN` as float lanes would be wrong).
   [[nodiscard]]
   constexpr auto
   operator==(mask_type const& operand) const -> mask_type {
      if constexpr (is_integral<lane_scalar>) {
         return mask_type(this->raw == operand.raw);
      }
      simd_mask out{};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         out.set_lane(i, (*this)[i] == operand[i]);
      }
      return out;
   }

   [[nodiscard]]
   constexpr auto
   operator!=(mask_type const& operand) const -> mask_type {
      if constexpr (is_integral<lane_scalar>) {
         return mask_type(this->raw != operand.raw);
      }
      simd_mask out{};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         out.set_lane(i, (*this)[i] != operand[i]);
      }
      return out;
   }

   // Element-wise logical && / || on mask lanes (standard
   // `basic_mask`. complements bitwise & / | on `raw` below).
   [[nodiscard]]
   friend constexpr auto
   operator&&(simd_mask const& lhs, simd_mask const& rhs) -> simd_mask {
      simd_mask out{};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         out.set_lane(i, lhs[i] && rhs[i]);
      }
      return out;
   }

   [[nodiscard]]
   friend constexpr auto
   operator||(simd_mask const& lhs, simd_mask const& rhs) -> simd_mask {
      simd_mask out{};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         out.set_lane(i, lhs[i] || rhs[i]);
      }
      return out;
   }

   [[nodiscard]]
   constexpr auto
   operator&(mask_type const& operand) const -> mask_type {
      if constexpr (is_integral<lane_scalar>) {
         return mask_type(this->raw & operand.raw);
      } else {
         using lane_bits = detail::simd_mask_lane_bits_t<lane_scalar>;
         using bits_abi = typename abi_type::template make_abi_type<lane_bits>;
         using bits_vec = simd<lane_bits, bits_abi>;
         typename bits_vec::raw_type const a =
            __builtin_bit_cast(typename bits_vec::raw_type, this->raw);
         typename bits_vec::raw_type const b =
            __builtin_bit_cast(typename bits_vec::raw_type, operand.raw);
         return mask_type(__builtin_bit_cast(raw_type, a & b));
      }
   }

   constexpr auto
   operator&=(mask_type const& operand) -> mask_type& {
      *this = *this & operand;
      return *this;
   }

   [[nodiscard]]
   constexpr auto
   operator|(mask_type const& operand) const -> mask_type {
      if constexpr (is_integral<lane_scalar>) {
         return mask_type(this->raw | operand.raw);
      } else {
         using lane_bits = detail::simd_mask_lane_bits_t<lane_scalar>;
         using bits_abi = typename abi_type::template make_abi_type<lane_bits>;
         using bits_vec = simd<lane_bits, bits_abi>;
         typename bits_vec::raw_type const a =
            __builtin_bit_cast(typename bits_vec::raw_type, this->raw);
         typename bits_vec::raw_type const b =
            __builtin_bit_cast(typename bits_vec::raw_type, operand.raw);
         return mask_type(__builtin_bit_cast(raw_type, a | b));
      }
   }

   constexpr auto
   operator|=(mask_type const& operand) -> mask_type& {
      *this = *this | operand;
      return *this;
   }

   [[nodiscard]]
   constexpr auto
   operator^(mask_type const& operand) const -> mask_type {
      if constexpr (is_integral<lane_scalar>) {
         return mask_type(this->raw ^ operand.raw);
      } else {
         using lane_bits = detail::simd_mask_lane_bits_t<lane_scalar>;
         using bits_abi = typename abi_type::template make_abi_type<lane_bits>;
         using bits_vec = simd<lane_bits, bits_abi>;
         typename bits_vec::raw_type const a =
            __builtin_bit_cast(typename bits_vec::raw_type, this->raw);
         typename bits_vec::raw_type const b =
            __builtin_bit_cast(typename bits_vec::raw_type, operand.raw);
         return mask_type(__builtin_bit_cast(raw_type, a ^ b));
      }
   }

   constexpr auto
   operator^=(mask_type const& operand) -> mask_type& {
      *this = *this ^ operand;
      return *this;
   }

   [[nodiscard]]
   constexpr auto
   operator%(mask_type const& operand) const -> mask_type {
      if constexpr (is_integral<lane_scalar>) {
         return mask_type(this->raw % operand.raw);
      } else {
         using lane_bits = detail::simd_mask_lane_bits_t<lane_scalar>;
         using bits_abi = typename abi_type::template make_abi_type<lane_bits>;
         using bits_vec = simd<lane_bits, bits_abi>;
         typename bits_vec::raw_type const a =
            __builtin_bit_cast(typename bits_vec::raw_type, this->raw);
         typename bits_vec::raw_type const b =
            __builtin_bit_cast(typename bits_vec::raw_type, operand.raw);
