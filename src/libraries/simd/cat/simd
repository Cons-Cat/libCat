   [[nodiscard, gnu::always_inline]]
   constexpr auto
   reduce_assoc_fadd(scalar_type seed) const
      -> simd<T, simd_abi::fixed_size<T, 1u>>
      requires(is_floating_point<T>)
   {
      // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2018/p0918r1.pdf
      simd<T, simd_abi::fixed_size<T, 1u>> out{};
      out.set_lane(
         0u, static_cast<T>(__builtin_reduce_assoc_fadd(
                this->raw,
                static_cast<raw_arithmetic_type<T>>(make_raw_arithmetic(seed))
             ))
      );
      return out;
   }

   [[nodiscard, gnu::always_inline]]
   constexpr auto
   reduce_in_order_fadd(scalar_type seed) const
      -> simd<T, simd_abi::fixed_size<T, 1u>>
      requires(is_floating_point<T>)
   {
      // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2018/p0918r1.pdf
      simd<T, simd_abi::fixed_size<T, 1u>> out{};
      out.set_lane(
         0u, static_cast<T>(__builtin_reduce_in_order_fadd(
                this->raw,
                static_cast<raw_arithmetic_type<T>>(make_raw_arithmetic(seed))
             ))
      );
      return out;
   }

   // Fill all lanes with `value`. This is also known as a "splat" operation.
   template <typename U>
      requires(is_constructible<scalar_type, U>)
   constexpr auto
   fill(U value) -> simd& {
      scalar_type const fill_value = static_cast<scalar_type>(value);
      mapped_type const lane = simd_lane_to_storage(fill_value);
      if constexpr (abi_type::lanes == 2uz) {
         this->raw = raw_type{lane, lane};
      } else if constexpr (abi_type::lanes == 4uz) {
         this->raw = raw_type{lane, lane, lane, lane};
      } else if constexpr (abi_type::lanes == 8uz) {
         this->raw = raw_type{lane, lane, lane, lane, lane, lane, lane, lane};
      } else if constexpr (abi_type::lanes == 16uz) {
         this->raw = raw_type{
            lane, lane, lane, lane, lane, lane, lane, lane,
            lane, lane, lane, lane, lane, lane, lane, lane,
         };
      } else if constexpr (abi_type::lanes == 32uz) {
         this->raw = raw_type{
            lane, lane, lane, lane, lane, lane, lane, lane, lane, lane, lane,
            lane, lane, lane, lane, lane, lane, lane, lane, lane, lane, lane,
            lane, lane, lane, lane, lane, lane, lane, lane, lane, lane,
         };
      }
      return *this;
   }

   // Load a vector from `data`, aligned to `abi_type::alignment` (also called a
   // "gather").
   [[gnu::always_inline]]
   constexpr auto
   load_aligned(memory_lane const* _Nonnull p_data) -> simd& {
      if consteval {
         for (idx i = 0u; i < abi_type::lanes; ++i) {
            this->set_lane(i, static_cast<T>(p_data[i]));
         }
      } else {
         this->raw = __builtin_bit_cast(simd const*, p_data)->raw;
      }
      return *this;
   }

   // Load a vector from `data` with any alignment (gather). This may be slower
   // than `.loaded_aligned()`.
   [[gnu::always_inline]]
   constexpr auto
   load_unaligned(memory_lane const* _Nonnull p_data) -> simd& {
      if consteval {
         for (idx i = 0u; i < abi_type::lanes; ++i) {
            this->set_lane(i, static_cast<T>(p_data[i]));
         }
      } else {
         this->raw = __builtin_bit_cast(unaligned_vector const*, p_data)->raw;
      }
      return *this;
   }

   // Load a vector from `data` (gather, aligned vs unaligned chosen from ABI).
   [[gnu::always_inline]]
   constexpr auto
   load(memory_lane const* _Nonnull p_data) -> simd& {
      if constexpr (abi_type::alignment > alignof(T) && alignof(T) > 1uz) {
         return this->load_aligned(p_data);
      } else {
         return this->load_unaligned(p_data);
      }
   }

   [[gnu::always_inline]]
   constexpr auto
   load_non_temporal(memory_lane const* _Nonnull p_data) -> simd& {
      if consteval {
         return this->load(p_data);
      } else {
         this->raw = __builtin_nontemporal_load(
            __builtin_bit_cast(raw_type const*, p_data)
         );
         return *this;
      }
   }

   // P3299-shaped memory (pointer + length. No `cat::span`):

   // Write lanes to aligned memory (also called a "scatter").
   [[gnu::always_inline]]
   constexpr void
   store_aligned(memory_lane* _Nonnull p_data) const {
      if consteval {
         for (idx i = 0u; i < abi_type::lanes; ++i) {
            p_data[i] = simd_lane_to_storage((*this)[i]);
         }
      } else {
         __builtin_bit_cast(simd*, p_data)->raw = this->raw;
      }
   }

   // Write lanes to arbitrarily aligned memory (scatter).
   [[gnu::always_inline]]
   constexpr void
   store_unaligned(memory_lane* _Nonnull p_data) const {
      if consteval {
         for (idx i = 0u; i < abi_type::lanes; ++i) {
            p_data[i] = simd_lane_to_storage((*this)[i]);
         }
      } else {
         __builtin_bit_cast(unaligned_vector*, p_data)->raw = this->raw;
      }
   }

   // Write lanes to memory (scatter, aligned vs unaligned chosen from ABI).
   [[gnu::always_inline]]
   constexpr void
   store(memory_lane* _Nonnull p_data) const {
      if constexpr (abi_type::alignment > alignof(T) && alignof(T) > 1uz) {
         this->store_aligned(p_data);
      } else {
         this->store_unaligned(p_data);
      }
   }

   [[gnu::always_inline]]
   constexpr void
   store_non_temporal(memory_lane* _Nonnull p_data) const {
      if consteval {
         this->store(p_data);
      } else {
         __builtin_nontemporal_store(
            this->raw, __builtin_bit_cast(raw_type*, p_data)
         );
      }
   }

   // Read at most `count` scalars from `p_data` (partial gather). Lanes at
   // `count..lanes-1` are zero-filled. If `count` exceeds `lanes`, only `lanes`
   // scalars are read.
   constexpr auto
   partial_load(memory_lane const* _Nonnull p_data, idx count) -> simd& {
      this->fill(scalar_type{});
      idx const n = count < abi_type::lanes ? count : abi_type::lanes;
      for (idx i = 0u; i < n; ++i) {
         this->set_lane(i, static_cast<T>(p_data[i]));
      }
      return *this;
   }

   // Write min(`count`, `lanes`) scalars to `p_data` (partial scatter).
   // Trailing elements are untouched.
   constexpr void
   partial_store(memory_lane* _Nonnull p_data, idx count) const {
      idx const n = count < abi_type::lanes ? count : abi_type::lanes;
      for (idx i = 0u; i < n; ++i) {
         p_data[i] = simd_lane_to_storage((*this)[i]);
      }
   }

   [[nodiscard]]
   static constexpr auto
   size() -> idx {
      return abi_type::lanes;
   }

   // Make `cat::simd` iterable like a container.
   [[nodiscard]]
   constexpr auto
   begin_pos() const -> idx {
      return 0u;
   }

   [[nodiscard]]
   constexpr auto
   end_pos() const -> idx {
      return size();
   }

   constexpr void
   inc_pos(idx& position) const {
      ++position;
   }

   constexpr void
   dec_pos(idx& position) const {
      position = idx(position.raw - 1u);
   }

   constexpr void
   offset_pos(idx& position, iword offset) const {
      position = idx(static_cast<idx::raw_type>((position + offset).raw));
   }

   [[nodiscard]]
   constexpr auto
   distance(idx left, idx right) const -> iword {
      return right - left;
   }

   [[nodiscard]]
   constexpr auto
   read_at_unchecked(idx position) const -> scalar_type {
      return (*this)[position];
   }

   // Implement Stepanov iteration as well, as per P3983R1.
   [[nodiscard]]
   constexpr auto
   begin() -> iterator {
      return iterator(this, 0u);
   }

   [[nodiscard]]
   constexpr auto
   begin() const -> const_iterator {
      return const_iterator(this, 0u);
   }

   [[nodiscard]]
   constexpr auto
   cbegin() const -> const_iterator {
      return begin();
   }

   [[nodiscard]]
   constexpr auto
   end() const -> default_sentinel_t {
      return default_sentinel;
   }

   [[nodiscard]]
   constexpr auto
   cend() const -> default_sentinel_t {
      return end();
   }

   [[nodiscard, gnu::always_inline, gnu::returns_nonnull,
     gnu::assume_aligned(Abi::alignment.raw)]]
   constexpr auto
   data() [[clang::lifetimebound]] -> T* _Nonnull {
      return __builtin_bit_cast(T*, &raw);
   }

   [[nodiscard, gnu::always_inline, gnu::returns_nonnull,
     gnu::assume_aligned(Abi::alignment.raw)]]
   constexpr auto
   data() const [[clang::lifetimebound]] -> T* _Nonnull {
      return __builtin_bit_cast(T const*, &raw);
   }

   // Invoke `callback` on each lane in order, with a Clang vectorization
   // hint on the surrounding loop. A callable that fails to vectorize
   // surfaces a Clang remark instead of silently scalarizing. The callback
   // may take a single lane value, or a lane value and its `idx`.
   template <typename Callback>
      requires(
         is_invocable<Callback, scalar_type>
         || is_invocable<Callback, scalar_type, idx>
      )
   [[gnu::always_inline]]
   constexpr void
   for_each(Callback&& callback) const {
#pragma clang loop vectorize_predicate(enable)
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         if constexpr (is_invocable<Callback, scalar_type, idx>) {
            $fwd(callback)((*this)[i], i);
         } else {
            $fwd(callback)((*this)[i]);
         }
      }
   }

   raw_type raw;
};

// `operator+` where `cat::simd` is the right-hand side operand.
template <is_arithmetic U, typename T, typename Abi>
   requires(detail::simd_broadcast_really_convertible_to<U, T>())
[[nodiscard]]
constexpr auto
operator+(U lhs, simd<T, Abi> const& rhs) -> simd<T, Abi> {
   return rhs + lhs;
}

// `operator-` where `cat::simd` is the right-hand side operand.
template <is_arithmetic U, typename T, typename Abi>
   requires(detail::simd_broadcast_really_convertible_to<U, T>())
[[nodiscard]]
constexpr auto
operator-(U lhs, simd<T, Abi> const& rhs) -> simd<T, Abi> {
   return simd<T, Abi>(lhs) - rhs;
}

// `operator*` where `cat::simd` is the right-hand side operand.
template <is_arithmetic U, typename T, typename Abi>
   requires(detail::simd_broadcast_really_convertible_to<U, T>())
[[nodiscard]]
constexpr auto
operator*(U lhs, simd<T, Abi> const& rhs) -> simd<T, Abi> {
   return simd<T, Abi>(lhs) * rhs;
}

// `operator/` where `cat::simd` is the right-hand side operand.
template <is_arithmetic U, typename T, typename Abi>
   requires(detail::simd_broadcast_really_convertible_to<U, T>())
[[nodiscard]]
constexpr auto
operator/(U lhs, simd<T, Abi> const& rhs) -> simd<T, Abi> {
   return simd<T, Abi>(lhs) / rhs;
}

