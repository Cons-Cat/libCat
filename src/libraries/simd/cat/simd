   // Element-wise logical && / || on mask lanes (standard `basic_mask`.
   // complements bitwise & / | on `raw` below).
   [[nodiscard]]
   friend constexpr auto
   operator&&(simd_mask const& lhs, simd_mask const& rhs) -> simd_mask {
