   requires(is_same<typename Abi::scalar_type, T>)
template <typename Idx, typename IdxAbi>
constexpr auto
simd<T, Abi>::operator[](simd<Idx, IdxAbi> const& indices) const {
   return simd_permute(*this, indices);
}

template <typename T, typename Abi>
   requires(is_same<typename Abi::scalar_type, T>)
template <typename... Ts>
   requires(sizeof...(Ts) >= 2)
constexpr auto
simd<T, Abi>::operator[](Ts&&... lanes) const {
   return simd_permute(
      *this, simd<T, simd_abi::fixed_size<T, idx(sizeof...(Ts))>>(
                static_cast<T>($fwd(lanes))...
             )
   );
}

