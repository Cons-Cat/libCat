// `default: __builtin_unreachable();`, but only when the user did NOT
// already supply a `default:` clause. That holds when the last
// `$simd_switch` argument is a paren-wrapped `(arch, body)` tuple from
// `$abi(...)`. The `simd_dispatch_baseline_covers` `static_assert` in
// `$simd_switch` guarantees that one of the listed entries' runtime
// predicates always holds, so the switch never actually reaches this
// synthetic arm. It exists so the optimizer gets an explicit "no other
// case is possible" hint and so clang-tidy's
// `bugprone-switch-missing-default-case` doesn't flag the expansion.
#define CAT_SIMD_SYNTH_DEFAULT(...) \
   CAT_CONCAT(CAT_SIMD_SYNTH_DEFAULT_, CAT_IS_PAREN(CAT_LAST_ARG(__VA_ARGS__)))
#define CAT_SIMD_SYNTH_DEFAULT_0  // user-supplied `default:` already present.
#define CAT_SIMD_SYNTH_DEFAULT_1 \
   default:                      \
      __builtin_unreachable();

// SIMD dispatch for different ABIs. See the `simd_dispatch` file masthead
// comment for API usage. The trailing `default:` clause is the user's
// own switch-style fallback (verbatim text, not a lambda); it runs when
// no `$abi(...)` entry's CPU-support check passes. The selector walks
// arch entries in priority order, never picks the default sentinel
// (whose `_PRI` is -1), and falls through to the user's `default:` only
// when every `$abi` entry rejects the host, which can only happen if
// the file baseline is below all listed archs.
//
// `CAT_NO_CPUID` opts a target out of runtime CPU feature detection
// (see `<cat/cpuid>`), which `$simd_switch` depends on to pick a
// `$abi(...)` entry. Calling `$simd_switch` in that configuration is a
// programming error, so the macro expands to a `_Pragma("GCC error ...")`
// at the call site instead of silently no-oping.
#ifdef CAT_NO_CPUID
// `_Pragma` takes a *single* string-literal argument (consumed in translation
// phase 4). Adjacent-literal concatenation only happens later in phase 6, so
// keep the message on one line.
#define CAT_SIMD_SWITCH(...)                                                   \
   _Pragma("GCC error \"`$simd_switch` is unavailable when `CAT_NO_CPUID` is " \
           "defined! Re-enable CPUID to use this.\"")
#else
#define CAT_SIMD_SWITCH(...)                                                   \
   ([&]() -> decltype(auto) {                                                  \
      /* Compile-time entry metadata. The user's trailing `default:` text is   \
         tracked via a sentinel meta entry (empty arch, priority -1). */       \
      static constexpr ::cat::array meta{                                      \
         CAT_FOR_EACH_COMMA(CAT_META_ENTRY, __VA_ARGS__)};                     \
      static_assert(                                                           \
         ::cat::detail::simd_dispatch_last_is_default(meta)                    \
            || ::cat::detail::simd_dispatch_baseline_covers(meta,              \
                                                            CAT_BASELINE_PRI), \
         "`$simd_switch` requires a `default:` clause as its last argument, "  \
         "unless one of the listed `$abi(arch, ...)` entries has "             \
         "`CAT_PRI_<arch> <= CAT_BASELINE_PRI` (i.e. the build's `-m<arch>` "  \
         "baseline already guarantees that arch is supported).");              \
      static_assert(::cat::detail::simd_dispatch_default_count(meta) <= 1u,    \
                    "`$simd_switch` has multiple `default:` clauses!");        \
      static_assert(                                                           \
         !::cat::detail::simd_dispatch_has_duplicate_arch(meta),               \
         "`$simd_switch` has duplicate target archs! Every `$abi` must be "    \
         "unique.");                                                           \
      /* Per-entry CPU-support predicate, decayed to `bool(*)()`. The default  \
         sentinel (when present) gets a trivial `+[]() -> bool { return true;  \
         }` predicate, so it is picked last-resort and the switch falls        \
         through to the user's `default:`. When no `default:` is present, the  \
         baseline-coverage `static_assert` above guarantees that at least one  \
         listed `$abi(arch, ...)`'s runtime predicate must return true. */     \
      static constexpr ::cat::array<bool (*)(), meta.size()>                   \
         cat_$simd_support_table{                                              \
            CAT_FOR_EACH_COMMA(CAT_SUP_ENTRY, __VA_ARGS__)};                   \
      /* Source-index walk order, sorted descending by `_PRI_<arch>`. */       \
      static constexpr auto cat_$simd_priority_order =                         \
         ::cat::detail::simd_dispatch_priority_permutation(meta);              \
      /* `static const` caches the first supported entry. */                   \
      static ::cat::idx const cat_$simd_selected = []() -> ::cat::idx {        \
         for (::cat::idx i = 0u; i < cat_$simd_priority_order.size(); ++i) {   \
            ::cat::idx const source_index = cat_$simd_priority_order[i];       \
            if (cat_$simd_support_table[source_index]()) {                     \
               return source_index;                                            \
            }                                                                  \
         }                                                                     \
         __builtin_unreachable();                                              \
      }();                                                                     \
      /* `case`s for each `$abi` entry. `CAT_SIMD_SYNTH_DEFAULT` adds an       \
         implicit `default: __builtin_unreachable();` iff the user omitted     \
         their own `default:` (the baseline-coverage `static_assert` above     \
         guarantees the synthetic arm is never reached). */                    \
      switch (cat_$simd_selected.raw) {                                        \
         CAT_FOR_EACH_INDEXED(CAT_SIMD_DISPATCH_ENTRY, __VA_ARGS__)            \
         CAT_SIMD_SYNTH_DEFAULT(__VA_ARGS__)                                   \
      }                                                                        \
   }())
#endif

// `CAT_SIMD_SWITCH` should never be `#undef`'d. The redefinable macro
// `$simd_switch` exists to make this macro more ergonomic.
#pragma clang final(CAT_SIMD_SWITCH)

#define $simd_switch CAT_SIMD_SWITCH
