   using NS::int_unalign_1x2;                                          \
   using NS::int_unalign_1x4;                                          \
   using NS::int_unalign_1x8;                                          \
   using NS::int_unalign_1x16;                                         \
   using NS::int_unalign_1x32;                                         \
   using NS::int_unalign_1x_;                                          \
   using NS::uint_unalign_1x2;                                         \
   using NS::uint_unalign_1x4;                                         \
   using NS::uint_unalign_1x8;                                         \
   using NS::uint_unalign_1x16;                                        \
   using NS::uint_unalign_1x32;                                        \
   using NS::uint_unalign_1x_;                                         \
   using NS::char1x16;                                                 \
   using NS::char1x32;                                                 \
   using NS::char1x_;                                                  \
   using NS::char_unalign_1x16;                                        \
   using NS::char_unalign_1x32;                                        \
   using NS::char_unalign_1x_;                                         \
   using NS::int2x2;                                                   \
   using NS::int2x4;                                                   \
   using NS::int2x8;                                                   \
   using NS::int2x16;                                                  \
   using NS::int2x_;                                                   \
   using NS::uint2x2;                                                  \
   using NS::uint2x4;                                                  \
   using NS::uint2x8;                                                  \
   using NS::uint2x16;                                                 \
   using NS::uint2x_;                                                  \
   using NS::int_unalign_2x2;                                          \
   using NS::int_unalign_2x4;                                          \
   using NS::int_unalign_2x8;                                          \
   using NS::int_unalign_2x16;                                         \
   using NS::int_unalign_2x_;                                          \
   using NS::uint_unalign_2x2;                                         \
   using NS::uint_unalign_2x4;                                         \
   using NS::uint_unalign_2x8;                                         \
   using NS::uint_unalign_2x16;                                        \
   using NS::uint_unalign_2x_;                                         \
   using NS::int4x2;                                                   \
   using NS::int4x4;                                                   \
