   }
};

template <typename Simd>
struct make_simd_mask_ignore_last_impl {
   [[nodiscard]]
   constexpr auto
   operator()(idx ignore_tail_count) const -> typename Simd::mask_type {
      idx const width = Simd::abi_type::lanes;
      typename Simd::mask_type lane_mask{};
      for (idx i = 0u; i < width; ++i) {
         lane_mask.set_lane(i, i < width - ignore_tail_count);
