   template <typename T, typename Abi>
      requires(is_integral<T> && !is_bool<T>)
   [[nodiscard]]
   constexpr auto
   invoke_full(simd<T, Abi> x, simd<T, Abi> y, simd<T, Abi> z) const
      -> simd<T, Abi> {
      if constexpr (has_simd_abi_ternary_full<simd_abi::op_fshl, T, Abi>) {
         return simd_abi_apply_ternary_full<simd_abi::op_fshl, T, Abi>(x, y, z);
      }
      return simd<T, Abi>(__builtin_elementwise_fshl(x.raw, y.raw, z.raw));
