   constexpr simd_bitreverse_impl() = default;

   template <typename T, typename Abi>
      requires(is_integral<T> && !is_bool<T>)
   [[nodiscard]]
   constexpr auto
   invoke_full(simd<T, Abi> input) const -> simd<T, Abi> {
      // P2638R0 §1.18 / §1.20 per-lane bit-reverse on integral lanes.
      // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2022/p2638r0.pdf
      if constexpr (has_simd_abi_unary_full<simd_abi::op_bitreverse, T, Abi>) {
         return simd_abi_apply_unary_full<simd_abi::op_bitreverse, T, Abi>(
            input);
      } else {
         return simd<T, Abi>(__builtin_elementwise_bitreverse(input.raw));
      }
   }

   template <typename T>
      requires(is_integral<T> && !is_bool<T>)
   [[nodiscard]]
   constexpr auto
   invoke_lanewise(T x) const -> T {
      // P2638R0 §1.18 / §1.20 per-lane bit-reverse (fallback lane hook).
      // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2022/p2638r0.pdf
      using U = make_unsigned_type<T>;
      U const u = static_cast<U>(x);
      U reversed{};
      if constexpr (sizeof(U) == 1) {
         reversed = static_cast<U>(static_cast<unsigned char>(
            __builtin_bitreverse32(static_cast<unsigned int>(u)) >> 24u));
      } else if constexpr (sizeof(U) == 2) {
         reversed = static_cast<U>(__builtin_bitreverse16(
            static_cast<unsigned short>(static_cast<unsigned>(u))));
      } else if constexpr (sizeof(U) == 4) {
         reversed = static_cast<U>(
            __builtin_bitreverse32(static_cast<unsigned int>(u)));
      } else {
         reversed = static_cast<U>(
            __builtin_bitreverse64(static_cast<unsigned long long>(
               static_cast<unsigned long long>(u))));
      }
      return static_cast<T>(reversed);
   }
};

