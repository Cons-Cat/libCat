struct simd_min_impl : simd_elementwise_binary_interface<simd_min_impl> {
   constexpr simd_min_impl() = default;

   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   invoke_full(simd<T, Abi> left, simd<T, Abi> right) const -> simd<T, Abi> {
      if constexpr (is_floating_point<T>) {
         if constexpr (has_simd_abi_binary_full<simd_abi::op_minimum, T, Abi>) {
            return simd_abi_apply_binary_full<simd_abi::op_minimum, T, Abi>(
               left, right);
         } else {
            return simd<T, Abi>(
               __builtin_elementwise_minimum(left.raw, right.raw));
         }
      } else {
         simd<T, Abi> result{};
         for (idx i = 0u; i < Abi::lanes; ++i) {
            result.set_lane(i, left[i] < right[i] ? left[i] : right[i]);
         }
         return result;
      }
   }

   template <typename T>
   [[nodiscard]]
   constexpr auto
   invoke_lanewise(T left, T right) const -> T {
      if constexpr (is_floating_point<T>) {
         using R = raw_arithmetic_type<T>;
         if constexpr (is_same<R, float>) {
            return T(
               __builtin_fminf(static_cast<R>(make_raw_arithmetic(left)),
                               static_cast<R>(make_raw_arithmetic(right))));
         }
         return T(__builtin_fmin(static_cast<R>(make_raw_arithmetic(left)),
                                 static_cast<R>(make_raw_arithmetic(right))));
      } else {
         return left < right ? left : right;
      }
   }
};

