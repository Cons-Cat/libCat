struct simd_compress_impl {
   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   operator()(simd<T, Abi> input, simd_mask<T, Abi> selector) const
      -> simd<T, Abi> {
      if constexpr (has_simd_abi_compress<T, Abi>) {
         return simd_abi_apply_compress<T, Abi>(input, selector);
      } else {
         simd<T, Abi> result{};
         idx next_packed_lane = 0u;
#pragma clang loop vectorize_predicate(enable)
         for (idx i = 0u; i < Abi::lanes; ++i) {
            if (selector[i]) {
               result.set_lane(next_packed_lane, input[i]);
               ++next_packed_lane;
            }
         }
         for (; next_packed_lane < Abi::lanes; ++next_packed_lane) {
            result.set_lane(next_packed_lane, T{});
         }
         return result;
      }
   }
};

struct simd_expand_impl {
   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   operator()(simd<T, Abi> packed_values, simd_mask<T, Abi> selector,
              simd<T, Abi> background = {}) const -> simd<T, Abi> {
      if constexpr (has_simd_abi_expand<T, Abi>) {
         return simd_abi_apply_expand<T, Abi>(packed_values, selector,
                                              background);
      } else {
         simd<T, Abi> result = background;
         idx packed_read_index = 0u;
#pragma clang loop vectorize_predicate(enable)
         for (idx i = 0u; i < Abi::lanes; ++i) {
            if (selector[i]) {
               result.set_lane(i, packed_values[packed_read_index]);
               ++packed_read_index;
            }
         }
         return result;
      }
   }
};

template <typename T>
   requires(is_integral<T> && !is_bool<T>)
[[nodiscard]]
constexpr auto
simd_rotate_left_lane(T operand, iword count) -> T {
   iword const w = iword(sizeof(T) * 8u);
   auto const w_r = w.raw;
   auto c_r = count.raw % w_r;
   if (c_r < 0) {
      c_r += w_r;
   }
   if (c_r == 0) {
      return operand;
   }
   auto const unsigned_bits = static_cast<make_unsigned_type<T>>(operand);
   idx::raw_type const cu = static_cast<idx::raw_type>(c_r);
   idx::raw_type const ws = static_cast<idx::raw_type>(w_r);
   return static_cast<T>((unsigned_bits << cu) | (unsigned_bits >> (ws - cu)));
}

template <typename T>
   requires(is_integral<T> && !is_bool<T>)
[[nodiscard]]
constexpr auto
simd_rotate_right_lane(T operand, iword count) -> T {
   iword const w = iword(sizeof(T) * 8u);
   auto const w_r = w.raw;
   auto c_r = count.raw % w_r;
   if (c_r < 0) {
      c_r += w_r;
   }
   if (c_r == 0) {
      return operand;
   }
   auto const unsigned_bits = static_cast<make_unsigned_type<T>>(operand);
   idx::raw_type const cu = static_cast<idx::raw_type>(c_r);
   idx::raw_type const ws = static_cast<idx::raw_type>(w_r);
   return static_cast<T>((unsigned_bits >> cu) | (unsigned_bits << (ws - cu)));
}

template <typename T, typename Abi>
   requires(is_integral<T> && !is_bool<T>)
[[nodiscard]]
constexpr auto
simd_rotate_left_generic(simd<T, Abi> input, iword count) -> simd<T, Abi> {
   simd<T, Abi> result{};
   for (idx i = 0u; i < Abi::lanes; ++i) {
      result.set_lane(i, simd_rotate_left_lane(input[i], count));
   }
   return result;
}

