// Subscript yields masked gather-style loads from a contiguous base pointer.
template <simd_memory_kind Kind>
struct simd_load_impl {
   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   operator[](simd_mask<T, Abi> lane_mask) const {
      if constexpr (Kind == simd_memory_kind::aligned) {
         return simd_load_aligned_blend_masked_impl<simd_mask<T, Abi>>{
            lane_mask};
      } else {
         return simd_load_blend_masked_impl<simd_mask<T, Abi>>{lane_mask};
      }
   }
};

// Subscript yields masked scatter-style stores to a contiguous base pointer.
//
// `simd_store_aligned` / `simd_store_unaligned` / `simd_store` name the memory
// contract for symmetry with `simd_load_*`; each is only a subscript entry
// that returns `simd_store_to_masked_impl`, like `simd_load_impl` returning
// `simd_load_blend_masked_impl` / `simd_load_aligned_blend_masked_impl`.
struct simd_store_impl {
   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   operator[](simd_mask<T, Abi> lane_mask) const
      -> simd_store_to_masked_impl<simd_mask<T, Abi>> {
      return {lane_mask};
   }
};

template <typename T, typename Abi>
[[nodiscard]]
constexpr auto
simd_if_else_apply(simd_mask<T, Abi> mask, simd<T, Abi> on_true,
                   simd<T, Abi> on_false) -> simd<T, Abi> {
   // P2638R0 §1.3 masked lane pick (readable `where`/`select` style blend).
   // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2022/p2638r0.pdf
   simd<T, Abi> result{};
#pragma clang loop vectorize_predicate(enable)
   for (idx i = 0u; i < Abi::lanes; ++i) {
      result.set_lane(i, mask[i] ? on_true[i] : on_false[i]);
   }
   return result;
}

// Indexed gather: each lane reads from `base[indices[i]]`.
