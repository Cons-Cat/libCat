   constexpr simd_sin_impl() = default;

   template <typename T, typename Abi>
      requires(is_floating_point<T>)
   [[nodiscard]]
   constexpr auto
   invoke_full(simd<T, Abi> input) const -> simd<T, Abi> {
      if constexpr (has_simd_abi_unary_full<simd_abi::op_sin, T, Abi>) {
         return simd_abi_apply_unary_full<simd_abi::op_sin, T, Abi>(input);
      } else {
         return simd<T, Abi>(__builtin_elementwise_sin(input.raw));
      }
   }

   template <typename T>
      requires(is_floating_point<T>)
   [[nodiscard]]
   constexpr auto
   invoke_lanewise(T x) const -> T {
      using R = raw_arithmetic_type<T>;
      if constexpr (is_same<R, float>) {
         return T(__builtin_sinf(static_cast<R>(make_raw_arithmetic(x))));
      }
      return T(__builtin_sin(static_cast<R>(make_raw_arithmetic(x))));
   }
};

