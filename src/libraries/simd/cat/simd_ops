template <typename T>
   requires(is_floating_point<T>)
[[nodiscard]]
constexpr auto
simd_nroot_lane(T x, iword n) -> T {
   if (n <= 1) {
      return x;
   }
   if (x == T(0)) {
      return x;
   }
   T abs_x = x < T(0) ? static_cast<T>(-x) : x;
   T const root_magnitude = [&]() -> T {
      auto const abs_raw = make_raw_arithmetic(abs_x);
      if constexpr (is_same<raw_arithmetic_type<T>, float>) {
         return static_cast<T>(
            emulated_powf(abs_raw, 1.f / static_cast<float>(n.raw)));
      } else {
         return static_cast<T>(emulated_pow(static_cast<double>(abs_raw),
                                            1. / static_cast<double>(n.raw)));
      }
   }();
   if (x < T(0)) {
      if ((n.raw & 1u) != 0u) {
         return static_cast<T>(-root_magnitude);
      }
      if constexpr (is_same<raw_arithmetic_type<T>, float>) {
         return static_cast<T>(__builtin_nanf(""));
      } else {
         return static_cast<T>(__builtin_nan(""));
      }
   }
   return root_magnitude;
}

template <typename T>
   requires(is_floating_point<T>)
[[nodiscard]]
constexpr auto
simd_rnroot_lane(T x, iword n) -> T {
   if (n <= 0) {
      return x;
   }
   if (n == 1) {
      using R = raw_arithmetic_type<T>;
      R const rx = static_cast<R>(make_raw_arithmetic(x));
      return T(static_cast<R>(1) / rx);
   }
   using R = raw_arithmetic_type<T>;
   R const root = static_cast<R>(make_raw_arithmetic(simd_nroot_lane(x, n)));
   return T(static_cast<R>(1) / root);
}

template <typename T>
   requires(is_floating_point<T>)
[[nodiscard]]
constexpr auto
simd_rcbrt_lane(T x) -> T {
   return simd_rnroot_lane(x, iword(3));
}

template <typename T, typename Abi>
   requires(is_floating_point<T>)
[[nodiscard]]
constexpr auto
simd_nroot_generic(simd<T, Abi> input, iword n) -> simd<T, Abi> {
   if (n <= 1) {
      return input;
   }
   simd<T, Abi> abs_x(__builtin_elementwise_abs(input.raw));
   simd<T, Abi> reciprocal_root{};
   reciprocal_root.fill(T(1) / static_cast<T>(n.raw));
   simd<T, Abi> root_magnitude(
      __builtin_elementwise_pow(abs_x.raw, reciprocal_root.raw));
   simd<T, Abi> zeros{};
   zeros.fill(T(0));
   if ((n.raw & 1u) != 0u) {
      return simd_if_else_impl{}(input < zeros, zeros - root_magnitude,
                                 root_magnitude);
   }
   simd<T, Abi> quiet_nans{};
   if constexpr (is_same<raw_arithmetic_type<T>, float>) {
      quiet_nans.fill(static_cast<T>(__builtin_nanf("")));
   } else {
      quiet_nans.fill(static_cast<T>(__builtin_nan("")));
   }
   return simd_if_else_impl{}(input < zeros, quiet_nans, root_magnitude);
}

