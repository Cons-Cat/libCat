// -*- mode: c++ -*-
#pragma once

// Chunk iterator over scalar buffers as
// `simd<Lane, fixed_size_abi<Lane, width>>`. Implemented with
// `stepanov_iterator_interface`, parallel to
// `cat::reverse_proxy_stepanov_iterator`.

#include <cat/arithmetic>
#include <cat/simd>
#include <cat/stepanov>
#include <cat/utility>

namespace cat {

template <typename T>
concept vectorizable_element = is_trivially_copyable<T> && (sizeof(T) <= 32u);

template <typename Lane, idx width>
struct as_vectorized_chunk_reference {
   using value_type = simd<Lane, fixed_size_abi<Lane, width>>;
   using raw_pointer = raw_arithmetic_type<Lane>*;

   raw_pointer p_data = nullptr;

   [[nodiscard]]
   constexpr
   operator value_type() const {
      value_type chunk{};
      chunk.load(p_data);
      return chunk;
   }

   constexpr auto
   operator=(value_type const& chunk) -> as_vectorized_chunk_reference& {
      chunk.store(p_data);
      return *this;
   }
};

template <typename Lane, idx width, bool is_const>
class vectorized_stepanov_iterator
    : public proxy_stepanov_iterator_interface<
         random_access_iterator_tag, simd<Lane, fixed_size_abi<Lane, width>>,
         conditional<is_const, simd<Lane, fixed_size_abi<Lane, width>>,
                     as_vectorized_chunk_reference<Lane, width>>> {
   using self_type = vectorized_stepanov_iterator<Lane, width, is_const>;

 public:
   using value_type = simd<Lane, fixed_size_abi<Lane, width>>;
   using raw_pointer_element = raw_arithmetic_type<Lane>;
   using storage_pointer =
      conditional<is_const, raw_pointer_element const*, raw_pointer_element*>;

   storage_pointer p = nullptr;

   constexpr vectorized_stepanov_iterator() = default;
   constexpr vectorized_stepanov_iterator(self_type const&) = default;
   constexpr vectorized_stepanov_iterator(self_type&&) = default;

   constexpr explicit vectorized_stepanov_iterator(storage_pointer ptr)
       : p(ptr) {
   }

   [[nodiscard]]
   static constexpr auto
   size() -> idx {
      return width;
   }

   constexpr void
   advance(iword offset) {
      p += static_cast<decltype(p - p)>(offset * iword(width.raw));
   }

   [[nodiscard]]
   constexpr auto
   distance_to(self_type const& other) const -> iword {
      return iword((other.p - p)
                   / static_cast<decltype(other.p - p)>(width.raw));
   }

   [[nodiscard]]
   constexpr auto
   dereference() -> as_vectorized_chunk_reference<Lane, width>
      requires(!is_const)
   {
      return {p};
   }

   [[nodiscard]]
   constexpr auto
   dereference() const {
      if constexpr (is_const) {
         value_type chunk{};
         chunk.load(p);
         return chunk;
      } else {
         return as_vectorized_chunk_reference<Lane, width>{p};
      }
   }
};

template <typename Lane, idx width>
[[nodiscard]]
constexpr auto
as_vectorized(raw_arithmetic_type<Lane> const* p_lane)
   -> vectorized_stepanov_iterator<Lane, width, true>
   requires(vectorizable_element<Lane> && is_arithmetic<Lane>)
{
   return vectorized_stepanov_iterator<Lane, width, true>(p_lane);
}

template <typename Lane, idx width>
[[nodiscard]]
constexpr auto
as_vectorized(raw_arithmetic_type<Lane>* p_lane)
   -> vectorized_stepanov_iterator<Lane, width, false>
   requires(vectorizable_element<Lane> && is_arithmetic<Lane>)
{
   return vectorized_stepanov_iterator<Lane, width, false>(p_lane);
}

}  // namespace cat
