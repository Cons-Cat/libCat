// Type-erased `set_memory` function.
template <typename T>
[[clang::no_builtin, gnu::no_sanitize_address]]
// Clang may still replace this loop with `memset`. `memset` can call back into
// this route, which makes a circular reference some linkers reject.
constexpr void
set_memory_detail(void* p_source, T value, idx const size) {
   // TODO: Assert that these parameters do not index out of bounds or loop
   // infinitely.

   // Unsafe cast `p_source` to a `T*`.
   uintptr<T> p_current = __builtin_bit_cast(T*, p_source);
   iword remaining_bytes = size;

   if consteval {
      for (idx i = 0u; i < size; ++i) {
         *p_current = value;
         p_current += sizeof(T);
      }
   } else {
      // Fill until `p_current` has proper SIMD alignment.
      while (!is_aligned(p_current, native_abi<T>::alignment)) {
         *p_current = value;
         p_current += sizeof(T);
         remaining_bytes -= sizeof(T);
      }

      // Non-type template parameters are not allowed in a lambda's
      // template parameter list, so the lanes are passed through a
      // `constant`.
      auto vectorized_fill = [&]<typename lanes_constant>(lanes_constant) {
         // TODO: Consider optimizing this by tiling the loop.
         constexpr idx lanes = lanes_constant::value;
         using vector_type = fixed_size_simd<T, lanes>;
         while (remaining_bytes >= sizeof(vector_type)) {
            auto* p_vector = __builtin_bit_cast(vector_type*, p_current);
            p_vector->fill(value);
            p_current += lanes;
            remaining_bytes -= lanes;
         }
      };

      // Fill out 32-byte portion.
      if constexpr (native_abi<T>::size >= 32u) {
         vectorized_fill(constant<32_idx>{});
      }

      // TODO: Support `fill()` on 16-byte x86-64 simd.
      // // Fill out 16-byte portion.
      // if constexpr (native_abi<T>::size >= 16) {
      //     vectorized_fill(constant<16_idx>{});
      // }

      // Fill out remaining portion one byte at a time.
      set_memory_scalar(static_cast<T*>(p_current), value,
                        idx(remaining_bytes));
   }
}
}  // namespace detail

// Set all bytes at this address to `value`.
template <typename T = unsigned char>
   requires(sizeof(T) <= 8)
constexpr void
set_memory(void* p_source, T value, idx size) {
   detail::set_memory_detail(p_source, make_raw_arithmetic(value), size);
}

// `[[gnu::noinline]]` prevents Clang from constant-folding this function out.
// Set all bytes at this address to `value`. This function cannot be
// constant-folded out.
template <typename T = unsigned char>
   requires(sizeof(T) <= 8)
[[gnu::noinline]]
constexpr void
set_memory_explicit(void* p_source, T value, idx size) {
   set_memory(p_source, value, size);
}

// Set all bytes at this address to zero.
constexpr void
zero_memory(void* p_source, idx size) {
   detail::set_memory_detail(p_source, static_cast<unsigned char>(0u), size);
}

// `[[gnu::noinline]]` prevents Clang from constant-folding this function out.
// Set all bytes at this address to zero. This function cannot be
// constant-folded out.
[[gnu::noinline]]
constexpr void
zero_memory_explicit(void* p_source, idx bytes) {
   zero_memory(p_source, bytes);
}

// Set all bytes in a trivial object to `value`.
template <typename T, typename U = unsigned char>
   requires(is_implicit_lifetime<T> && sizeof(U) == 1)
constexpr void
set_object(T& object, U value) {
   set_memory(__builtin_addressof(object), value, sizeof(T));
}

