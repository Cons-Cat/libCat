// Implement `fill_memory()` and `memset()`.
void
fill_memory_impl(byte* _Nonnull p_destination, byte byte_value, idx bytes);

// Type-erased `fill_memory` function.
template <typename T>
[[clang::no_builtin, gnu::no_sanitize_address]]
// Clang may still replace this loop with `memset`. `memset` can call back into
// this route, which makes a circular reference some linkers reject.
constexpr void
fill_memory_detail(void* _Nonnull p_source, T value, idx const size) {
   // TODO: Assert that these parameters do not index out of bounds or loop
   // infinitely.

   // Unsafe cast `p_source` to a `T*`.
   uintptr<T> p_current = __builtin_bit_cast(T*, p_source);
   iword remaining_bytes = size;

   if consteval {
      for (idx i = 0u; i < size; ++i) {
         *p_current = value;
         p_current += sizeof(T);
      }
   } else {
      if constexpr (sizeof(T) == 1u) {
         byte fill_byte;
         fill_byte = byte(value);
         fill_memory_impl(
            static_cast<byte* _Nonnull>(p_source), fill_byte, size
         );
         return;
      }

      // Fill until `p_current` has proper SIMD alignment. Bounded by
      // `remaining_bytes` so a small `size` cannot overshoot when the
      // starting pointer is misaligned by more bytes than `size`.
      while (remaining_bytes > 0
             && !is_aligned(p_current, cat::simd_abi::native<T>::alignment)) {
         *p_current = value;
         p_current += sizeof(T);
         remaining_bytes -= sizeof(T);
      }

      // TODO: Optimize this with a tiled loop and proper SIMD widths.

      // Non-type template parameters are not allowed in a lambda's template
      // parameter list, so the lanes are passed through a `constant`.
      auto vectorized_fill = [&]<idx lanes> {
         // TODO: Consider optimizing this by tiling the loop.
         using vector_type = fixed_size_simd<T, lanes>;
         while (remaining_bytes >= sizeof(vector_type)) {
            auto* _Nonnull p_vector =
               __builtin_bit_cast(vector_type*, p_current);
            p_vector->fill(value);
            p_current += lanes;
            remaining_bytes -= lanes;
         }
      };

      // Fill out 32-byte portion.
      if constexpr (cat::simd_abi::native<T>::size >= 32u) {
         vectorized_fill.template operator()<32u>();
      }

      // TODO: Support `fill()` on 16-byte x86-64 SIMD.
      // // Fill out 16-byte portion.
      // if constexpr (cat::simd_abi::native<T>::size >= 16) {
      //     vectorized_fill.template operator()<16u>();
      // }

      // Fill out remaining portion one byte at a time.
      fill_memory_scalar(
         static_cast<T*>(p_current), value, idx(remaining_bytes)
      );
   }
}
}  // namespace detail

// Set all bytes at this address to `value`.
template <typename T = unsigned char>
   requires(sizeof(T) <= 8)
constexpr void
fill_memory(void* _Nonnull p_source, T value, idx size) {
   detail::fill_memory_detail(p_source, make_raw_arithmetic(value), size);
}

// `[[gnu::noinline]]` prevents Clang from constant-folding this function out.
// Set all bytes at this address to `value`. This function cannot be
// constant-folded out.
template <typename T = unsigned char>
   requires(sizeof(T) <= 8)
[[gnu::noinline]]
constexpr void
fill_memory_explicit(void* _Nonnull p_source, T value, idx size) {
   fill_memory(p_source, value, size);
}

// Set all bytes at this address to zero.
constexpr void
zero_memory(void* _Nonnull p_source, idx size) {
   detail::fill_memory_detail(p_source, static_cast<unsigned char>(0u), size);
}

// `[[gnu::noinline]]` prevents Clang from constant-folding this function out.
// Set all bytes at this address to zero. This function cannot be
// constant-folded out.
[[gnu::noinline]]
constexpr void
zero_memory_explicit(void* _Nonnull p_source, idx bytes) {
   zero_memory(p_source, bytes);
}

// Set all bytes in a trivial object to `value`.
template <typename T, typename U = unsigned char>
   requires(is_implicit_lifetime<T> && sizeof(U) == 1)
constexpr void
set_object(T& object, U value) {
   fill_memory(__builtin_addressof(object), value, sizeof(T));
}

// Zero out all bytes in a trivial object. This function cannot be
// constant-folded out.
template <typename T, typename U = unsigned char>
   requires(is_implicit_lifetime<T> && sizeof(U) == 1)
// This function cannot be constant-folded out by a compiler. The
// `[[gnu::noinline]]` attribute prevents this.
[[gnu::noinline]]
constexpr void
set_object_explicit(T& object, U value) {
   fill_memory_explicit(__builtin_addressof(object), value, sizeof(T));
}

// Zero out all bytes in a trivial object.
template <typename T>
   requires(is_implicit_lifetime<T>)
constexpr void
zero_object(T& object) {
   zero_memory(__builtin_addressof(object), sizeof(T));
}

// Zero out all bytes in a trivial object. This function cannot be
// constant-folded out.
template <typename T>
   requires(is_implicit_lifetime<T>)
// This function cannot be constant-folded out by a compiler. The
// `[[gnu::noinline]]` attribute prevents this.
[[gnu::noinline]]
constexpr void
zero_object_explicit(T& object) {
   zero_memory_explicit(__builtin_addressof(object), sizeof(T));
}

// Prevent a compiler from constant-folding the non-`const`-qualified `p_object`
// when it shares its location in memory with, but has distinct lifetime from, a
// separate `const`-qualified object.
template <typename T>
[[nodiscard, gnu::returns_nonnull]]
constexpr auto
launder(T* _Nullable p_object) -> T* _Nonnull {
   return __builtin_launder(p_object);
}

// `launder` cannot be used on functions.
template <typename FunctionPtrReturn, typename... Args>
constexpr void launder(FunctionPtrReturn (*_Nonnull)(Args...)) = delete;

template <typename FunctionPtrReturn, typename... Args>
constexpr void launder(FunctionPtrReturn (*_Nonnull)(Args..., ...)) = delete;

// `launder` cannot be used on `void*`.
constexpr void
launder(void* _Nullable) = delete;
constexpr void
launder(void const* _Nullable) = delete;
constexpr void
launder(void volatile* _Nullable) = delete;
constexpr void
launder(void const volatile* _Nullable) = delete;

// `launder` cannot be used on `nullptr`. Without this overload the call is
// ambiguous between the deleted `void*` cv-overloads.
constexpr void
launder(decltype(nullptr)) = delete;

template <typename T>
[[gnu::returns_nonnull]]
auto
relocate_at(T* _Nonnull p_source, T* _Nonnull p_destination) -> T* _Nonnull {
   if constexpr (is_trivially_relocatable<T>) {
      if (p_source == p_destination) {
         return launder(p_destination);
      }
      __builtin_memcpy_inline(p_destination, p_source, sizeof(T));
      return launder(p_destination);
   } else {
      T* _Nonnull p_new = new (p_destination) T(move(*p_source));
      p_source->~T();
      return p_new;
   }
}

template <typename T>
[[gnu::returns_nonnull]]
auto
relocate(T& source, T* _Nonnull p_destination) -> T* _Nonnull {
   return relocate_at(__builtin_addressof(source), p_destination);
}

