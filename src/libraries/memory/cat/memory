// Implement `copy_memory()` and `memcpy()`.
void
copy_memory_impl(
   byte const* _Nonnull __restrict p_source,
   byte* _Nonnull __restrict p_destination, idx bytes
);

// Implement `copy_memory_backward()` and `memmove()`.
void
copy_memory_backward_impl(
