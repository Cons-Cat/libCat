// `memcpy`-class copy: the `[p_source, p_source+bytes)` and
// `[p_destination, p_destination+bytes)` intervals must not overlap (including
// a single shared byte). Violations are rejected by `assert`
constexpr void
copy_memory(void const* p_source, void* p_destination, idx bytes);

template <typename T>
class span;

[[nodiscard]]
constexpr auto
is_memory_overlapping(void const* p_first, idx first_bytes,
                      void const* p_second, idx second_bytes) -> bool;

// This is implemented in `<cat/span>`.
template <typename T>
[[nodiscard]]
constexpr auto
is_memory_overlapping(span<T const> first, span<T const> second) -> bool;

constexpr void
copy_memory_scalar(void const* p_source, void* p_destination, idx bytes);

// This is implemented in `<cat/span>`.
template <typename T>
   requires(is_implicit_lifetime<T>)
constexpr void
copy_memory(span<T const> source, span<T> destination);

template <typename T>
   requires(is_implicit_lifetime<T>)
constexpr void
copy_memory_backward(span<T const> source, span<T> destination);

// `memmove`-class scalar copy: overlapping intervals are allowed. When they
// overlap, copies forward when `p_destination <= p_source` and backward
// otherwise so every source byte is read before it can be overwritten
constexpr void
copy_memory_backward_scalar(void const* p_source, void* p_destination,
                            idx bytes);

// `memmove`-class copy for arbitrary length. Overlapping source and destination
// intervals are allowed
constexpr void
copy_memory_backward(void const* p_source, void* p_destination, idx bytes);

template <typename T = unsigned char>
   requires(sizeof(T) <= 8)
[[clang::no_builtin]]
constexpr void
set_memory_scalar(T* p_source, T value, idx size) {
   for (idx i = 0u; i < size; ++i) {
      p_source[i] = value;
   }
}

template <typename T = unsigned char>
   requires(sizeof(T) <= 8)
// This function cannot be constant-folded out by a compiler. The
// `[[gnu::noinline]]` attribute prevents this.
[[gnu::noinline]]
constexpr void
set_memory_scalar_explicit(T* p_source, T value, idx size) {
   set_memory_scalar(p_source, value, size);
}

constexpr void
zero_memory_scalar(void* p_source, idx bytes) {
   set_memory_scalar((unsigned char*)p_source, (unsigned char)0, bytes);
}

// This function cannot be constant-folded out by a compiler. The
// `[[gnu::noinline]]` attribute prevents this.
[[gnu::noinline]]
constexpr void
zero_memory_scalar_explicit(void* p_source, idx bytes) {
   set_memory_scalar((unsigned char*)p_source, (unsigned char)0, bytes);
}

