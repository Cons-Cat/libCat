// `memcpy`-class copy. The `[p_source, p_source+bytes)` and
// `[p_destination, p_destination+bytes)` intervals must not overlap (including
// a single shared byte). Violations are rejected by `assert`. The `__restrict`
// qualifiers communicate the non-overlap to the optimizer.
constexpr void
copy_memory(
   void const* _Nonnull __restrict p_source,
   void* _Nonnull __restrict p_destination, idx bytes
);

template <typename T, idx extent>
class span;

// This is implemented in `<cat/span>`.
template <typename T>
[[nodiscard]]
constexpr auto
is_pointer_in_range(T const* _Nullable p_pointer, span<T const> range) -> bool;

[[nodiscard]]
constexpr auto
is_memory_overlapping(
   void const* _Nonnull p_first, idx first_bytes, void const* _Nonnull p_second,
   idx second_bytes
) -> bool;

// This is implemented in `<cat/span>`.
template <typename T>
[[nodiscard]]
constexpr auto
is_memory_overlapping(span<T const> first, span<T const> second) -> bool;

constexpr void
copy_memory_scalar(
   void const* _Nonnull __restrict p_source,
   void* _Nonnull __restrict p_destination, idx bytes
);

[[nodiscard]]
constexpr auto
compare_memory(
   void const* _Nonnull p_lhs, void const* _Nonnull p_rhs, idx bytes
) -> std::strong_ordering;

[[nodiscard]]
constexpr auto
compare_memory_scalar(
   void const* _Nonnull p_lhs, void const* _Nonnull p_rhs, idx bytes
) -> std::strong_ordering;

// This is implemented in `<cat/span>`.
template <typename T>
   requires(is_implicit_lifetime<T>)
constexpr void
copy_memory(span<T const> source, span<T> destination);

template <typename T>
   requires(is_implicit_lifetime<T>)
constexpr void
copy_memory_backward(span<T const> source, span<T> destination);

// `memmove`-class scalar copy. Overlapping intervals are allowed. When they
// overlap, copies forward when `p_destination <= p_source` and backward
// otherwise so every source byte is read before it can be overwritten.
constexpr void
copy_memory_backward_scalar(
   void const* _Nonnull p_source, void* _Nonnull p_destination, idx bytes
);

// `memmove`-class copy for arbitrary length. Overlapping source and destination
// intervals are allowed.
constexpr void
copy_memory_backward(
   void const* _Nonnull p_source, void* _Nonnull p_destination, idx bytes
);

template <typename T = unsigned char>
   requires(sizeof(T) <= 8)
[[clang::no_builtin]]
constexpr void
fill_memory_scalar(T* _Nonnull p_source, T value, idx size) {
   for (idx i = 0u; i < size; ++i) {
      p_source[i] = value;
   }
}

template <typename T = unsigned char>
   requires(sizeof(T) <= 8)
// This function cannot be constant-folded out by a compiler. The
// `[[gnu::noinline]]` attribute prevents this.
[[gnu::noinline]]
constexpr void
fill_memory_scalar_explicit(T* _Nonnull p_source, T value, idx size) {
   fill_memory_scalar(p_source, value, size);
}

constexpr void
zero_memory_scalar(void* _Nonnull p_source, idx bytes) {
   fill_memory_scalar(
      static_cast<unsigned char*>(p_source), (unsigned char)0, bytes
   );
}

// This function cannot be constant-folded out by a compiler. The
// `[[gnu::noinline]]` attribute prevents this.
[[gnu::noinline]]
constexpr void
zero_memory_scalar_explicit(void* _Nonnull p_source, idx bytes) {
   fill_memory_scalar(
      static_cast<unsigned char*>(p_source), (unsigned char)0, bytes
   );
}

