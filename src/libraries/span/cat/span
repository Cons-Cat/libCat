// -*- mode: c++ -*-
// vim: set ft=cpp:
#pragma once

// `cat::span` is primarily based upon `std::span`. It is a non-owning view over
// a contiguous sequence of `T`, parameterized by an element type and an
// optional constant `fixed_extent`. When `fixed_extent == dynamic_extent`, its
// length is stored alongside the pointer. Otherwise, length is encoded in the
// type.
//
// The interface is additionally informed by the following papers:
//
// P4190R0   Implement an `initializer_list` constructor, constrained so
//           that only spans of `const` element type may bind a brace-init.
//
// P3786R2   Tuple protocol for fixed-extent spans. Adds `cat::get` and the
//           `std::tuple_size` / `std::tuple_element` specializations so
//           structured bindings work on `span<T, N>` when `N !=
//           dynamic_extent`.
//
// Comparison operators (`==` and `<=>`) follow Barry Revzin's `span_ext`
// design.
// https://brevzin.github.io/c++/2020/03/30/span-comparisons/
// Both compare against any `is_random_access` range with a matching element
// type. Three-way ordering uses a "synth three way" fallback so element types
// that only model `<` (without a native `<=>`) still order lexicographically.
// The implementations live out-of-line in `implementations/span.tpp`.
//
// `cat::span` is `[[clang::trivial_abi]]` so it passes in registers, and
// `[[gsl::Pointer(T)]]` so it participates in Clang's lifetime analysis.
// It matches the ABI of `nix::io_vector` for trivial syscall compatibility.

#include <detail/initializer_list.hpp>

#include <cat/bit>
#include <cat/compare>
#include <cat/container>
#include <cat/math>
#include <cat/memory>
#include <cat/meta>

namespace cat {

inline constexpr idx dynamic_extent = idx::max();

template <typename T, idx fixed_extent>
class [[clang::trivial_abi, gsl::Pointer(T)]]
span
    // It is not possible to make this an aggregate class while using CRTP
    // classes.
    : public container_interface<span<T, fixed_extent>, T>,
      public random_access_stepanov_iterable_interface<T> {
 public:
   static constexpr idx extent = fixed_extent;

   // `element_type` is the only span-specific typedef; everything else
   // (`value_type`, `reference`, `const_reference`, `pointer`,
   // `const_pointer`, `size_type`, `difference_type`, and the iterator
   // family) comes from `container_interface` / `stepanov_iterable_interface`.
   using element_type = T;

   constexpr span() = default;
   constexpr span(span<T, fixed_extent> const&) = default;
   constexpr span(span<T, fixed_extent>&&) = default;

   // Construct a `span` as `{address, length}`.
   constexpr span(T* p_in_data [[clang::lifetimebound]], idx in_length)
       : m_p_data(p_in_data), m_size(in_length) {
      if constexpr (fixed_extent != dynamic_extent) {
         assert(in_length == fixed_extent);
      }
   }

   // Construct an empty `span` with `nullptr`.
   constexpr span(decltype(nullptr)) : m_p_data(nullptr), m_size(0) {
      if constexpr (fixed_extent != dynamic_extent) {
         assert(fixed_extent == 0u);
      }
   }

   // Construct a span from a static `initializer_list`.
   template <typename InitListValueType>
      requires(is_const<T> && is_same<InitListValueType, remove_const<T>>)
   constexpr span(initializer_list<InitListValueType> initializers)
       : m_p_data(initializers.begin()), m_size(initializers.size()) {
      if constexpr (fixed_extent != dynamic_extent) {
         assert(initializers.size() == fixed_extent);
      }
   }

   template <__SIZE_TYPE__ length>
      requires(fixed_extent == dynamic_extent || length == fixed_extent)
   constexpr span(identity<T> (&array)[length])
       : m_p_data(array), m_size(length) {
   }

   // Implicitly convert a contiguous container into a span. Const-correctness
   // is managed by the deduction guides below.
   template <is_random_access U>
   constexpr span(U& container [[clang::lifetimebound]])
      requires(is_convertible<typename U::value_type (*)[], T (*)[]>)
       : m_p_data(container.data()), m_size(container.size()) {
      if constexpr (fixed_extent != dynamic_extent) {
         assert(container.size() == fixed_extent);
      }
   }

   template <typename U, idx other_extent>
      requires((fixed_extent == dynamic_extent || other_extent == dynamic_extent
                || fixed_extent == other_extent)
               && is_convertible<U (*)[], T (*)[]>)
   constexpr span(span<U, other_extent> const& other [[clang::lifetimebound]]
                  )
       : m_p_data(other.data()), m_size(other.size()) {
      if constexpr (fixed_extent != dynamic_extent) {
         assert(other.size() == fixed_extent);
      }
   }

   template <typename U>
   constexpr span(U&& container) =
      delete ("A `cat::span` cannot alias a temporary, because the span would"
              "immediately dangle.");

   constexpr auto
   operator=(span<T, fixed_extent> const&) -> span<T, fixed_extent>& = default;
   constexpr auto
   operator=(span<T, fixed_extent>&&) -> span<T, fixed_extent>& = default;

   // Construct a span from a static `initializer_list`.
   template <typename InitListValueType>
      requires(is_const<T> && is_same<InitListValueType, remove_const<T>>)
   constexpr auto
   operator=(initializer_list<InitListValueType> initializers)
      -> span<T, fixed_extent>& {
      if constexpr (fixed_extent != dynamic_extent) {
         assert(initializers.size() == fixed_extent);
      }
      m_p_data = initializers.begin();
      m_size = initializers.size();
      return *this;
   }

   // Implicitly convert a contiguous container into a span. Const-correctness
   // is managed by the deduction guides below.
   template <is_random_access U>
   auto
   operator=(U& container [[clang::lifetimebound]]) -> span<T, fixed_extent>&
      requires(is_convertible<typename U::value_type (*)[], T (*)[]>)
   {
      if constexpr (fixed_extent != dynamic_extent) {
         assert(container.size() == fixed_extent);
      }
      m_p_data = container.data();
      m_size = container.size();
      return *this;
   }

   template <typename U>
   auto
   operator=(U&& container) =
      delete ("A `cat::span` cannot alias a temporary, because the span would"
              "immediately dangle.");

   // Get the non-`const` address that this `span` starts at.
   [[nodiscard]]
   constexpr auto
   data() -> T* {
      return m_p_data;
   }

   // Get the `const` address that this `span` starts at.
   [[nodiscard]]
   constexpr auto
   data() const -> T const* {
      return m_p_data;
   }

   // Get the number of elements owned by this `span`.
   [[nodiscard]]
   constexpr auto
   size() const -> idx {
      if constexpr (fixed_extent == dynamic_extent) {
         return m_size;
      } else {
         return fixed_extent;
      }
   }

   // Get the size of the `span` in bytes.
   [[nodiscard]]
   constexpr auto
   size_bytes() const -> idx {
      return size() * sizeof(T);
   }

   // Runtime `first(count)`. Returns the first `count` elements as a
   // dynamic-extent span. Mirrors `std::span::first(size_type)`.
   [[nodiscard]]
   constexpr auto
   first(idx count) const -> span<T> {
      return subspan(0u, count);
   }

   // Runtime `last(count)`. Returns the last `count` elements as a
   // dynamic-extent span. Mirrors `std::span::last(size_type)`.
   [[nodiscard]]
   constexpr auto
   last(idx count) const -> span<T> {
      if !consteval {
         assert(count <= size());
      }
      return subspan(idx(size() - count), count);
   }

   // `count` is a count of elements (not an end index). When `count` is
   // `dynamic_extent` the resulting span extends to the end of this one.
   [[nodiscard]]
   constexpr auto
   subspan(idx offset, idx count = dynamic_extent) const -> span<T> {
      if !consteval {
         assert(offset <= size());
         if (count != dynamic_extent) {
            assert(count <= size() - offset);
         }
      }
      idx const result_size =
         (count != dynamic_extent) ? count : idx(size() - offset);
      return span<T>(m_p_data + offset.raw, result_size);
   }

   // Compile-time `first<N>()` returns a fixed-extent subview of the first
   // `count` elements. Mirrors `std::span::first<count>()`.
   template <idx count>
      requires(fixed_extent == dynamic_extent || count <= fixed_extent)
   [[nodiscard]]
   constexpr auto
   first() const -> span<T, count> {
      if constexpr (fixed_extent == dynamic_extent) {
         assert(count <= size());
      }
      return span<T, count>(m_p_data, count);
   }

   // Compile-time `last<N>()` returns a fixed-extent subview of the last
   // `count` elements. Mirrors `std::span::last<count>()`.
   template <idx count>
      requires(fixed_extent == dynamic_extent || count <= fixed_extent)
   [[nodiscard]]
   constexpr auto
   last() const -> span<T, count> {
      if constexpr (fixed_extent == dynamic_extent) {
         assert(count <= size());
      }
      return span<T, count>(m_p_data + (size().raw - count.raw), count);
   }

   // Compile-time `subspan<offset, count>()`. Mirrors `std::span`'s template
   // overload: `count` is a count of elements. When `count` is omitted on a
   // fixed-extent span the result extent is `fixed_extent - offset`.
   template <idx offset, idx count = dynamic_extent>
      requires(fixed_extent == dynamic_extent
               || (offset <= fixed_extent
                   && (count == dynamic_extent
                       || count <= fixed_extent - offset)))
   [[nodiscard]]
   constexpr auto
   subspan() const {
      constexpr idx result_extent = []() consteval {
         if constexpr (count != dynamic_extent) {
            return count;
         } else if constexpr (fixed_extent != dynamic_extent) {
            return idx(fixed_extent.raw - offset.raw);
         } else {
            return dynamic_extent;
         }
      }();
      if constexpr (fixed_extent == dynamic_extent) {
         assert(offset <= size());
         if constexpr (count != dynamic_extent) {
            assert(count <= size() - offset);
         }
      }
      idx const result_size =
         (count != dynamic_extent) ? count : idx(size() - offset);
      return span<T, result_extent>(m_p_data + offset.raw, result_size);
   }

   template <is_random_access R>
      requires(is_same<remove_cv<typename R::value_type>, remove_cv<T>>
               && is_equality_comparable<remove_cv<T>>)
   [[nodiscard]]
   constexpr auto
   operator==(R const& rhs) const -> bool;

   template <is_random_access R>
      requires(is_same<remove_cv<typename R::value_type>, remove_cv<T>>
               && requires(remove_cv<T> const& left, remove_cv<T> const& right) {
                     { left < right } -> is_convertible<bool>;
                     { right < left } -> is_convertible<bool>;
                  })
   [[nodiscard]]
   constexpr auto
   operator<=>(R const& rhs) const;

 protected:
   // This is arranged as pointer, then size, to follow the ABI of Linux
   // standard `iovec`s. Unfortunately, that is opposite of Windows' standard
   // `WSABUF`.
   T* m_p_data;
   idx m_size;
};

template <typename T>
span(initializer_list<T>) -> span<T const>;

template <typename T, __SIZE_TYPE__ length>
span(T (&)[length]) -> span<T, length>;

// Deduce the `value_type` of containers.
template <typename T>
span(T&) -> span<typename T::value_type>;

// Deduce the `value_type` of containers.
template <typename T>
span(T const&) -> span<typename T::value_type const>;

// Reinterpret a `cat::span` as a read-only view of its underlying bytes.
// Mirrors `std::as_bytes`. Uses `__builtin_bit_cast`, the same primitive
// `cat::uintptr` and `cat::byte` use, in place of `reinterpret_cast`. Still
// not `constexpr` because Clang forbids `bit_cast` to a pointer type during
// constant evaluation, and even a constexpr `byte*` could not be read from
// in a constant expression.
template <typename T, idx fixed_extent>
[[nodiscard]]
auto
as_bytes(span<T, fixed_extent> source) noexcept {
   constexpr idx result_extent = (fixed_extent == dynamic_extent)
                                    ? dynamic_extent
                                    : fixed_extent * sizeof(T);
   return span<cat::byte const, result_extent>(
      __builtin_bit_cast(cat::byte const*, source.data()), source.size_bytes());
}

// Reinterpret a non-`const` `cat::span` as a writable view of its underlying
// bytes. Mirrors `std::as_writable_bytes`. Disabled when `T` is `const`. Uses
// `__builtin_bit_cast` for the same reasons as `as_bytes`.
template <typename T, idx fixed_extent>
   requires(!is_const<T>)
[[nodiscard]]
auto
as_writable_bytes(span<T, fixed_extent> source) noexcept {
   constexpr idx result_extent = (fixed_extent == dynamic_extent)
                                    ? dynamic_extent
                                    : fixed_extent * sizeof(T);
   return span<cat::byte, result_extent>(
      __builtin_bit_cast(cat::byte*, source.data()), source.size_bytes());
}

// Create a span between two addresses.
template <typename T>
constexpr auto
make_span_between(T* p_start, T* p_end) {
   return span(p_start, p_end - p_start);
}

namespace detail {
template <typename T>
constexpr auto
maybe_span_has_value(span<T> value) -> bool {
   return value.data() != nullptr;
}

template <typename T>
constexpr auto
maybe_span_nullopt() -> span<T> {
   return span<T>(nullptr);
}
}  // namespace detail

// Simplify nullable spans.
template <typename T>
using maybe_span = maybe<compact<span<T>, detail::maybe_span_has_value<T>,
                                 detail::maybe_span_nullopt<T>>>;

template <idx index, typename T, idx fixed_extent>
   requires(fixed_extent != dynamic_extent && index < fixed_extent)
[[nodiscard]]
constexpr auto
get(span<T, fixed_extent> s) -> T& {
   return s[index];
}

}  // namespace cat

namespace std {

template <typename T, ::cat::idx fixed_extent>
   requires(fixed_extent != ::cat::dynamic_extent)
struct tuple_size<::cat::span<T, fixed_extent>>
    : ::cat::constant<fixed_extent.raw> {};

template <typename T, ::cat::idx fixed_extent>
   requires(fixed_extent != ::cat::dynamic_extent)
struct tuple_size<::cat::span<T, fixed_extent> const>
    : tuple_size<::cat::span<T, fixed_extent>> {};

template <typename T, ::cat::idx fixed_extent>
   requires(fixed_extent != ::cat::dynamic_extent)
struct tuple_size<::cat::span<T, fixed_extent> volatile>
    : tuple_size<::cat::span<T, fixed_extent>> {};

template <typename T, ::cat::idx fixed_extent>
   requires(fixed_extent != ::cat::dynamic_extent)
struct tuple_size<::cat::span<T, fixed_extent> const volatile>
    : tuple_size<::cat::span<T, fixed_extent>> {};

template <__SIZE_TYPE__ index, typename T, ::cat::idx fixed_extent>
   requires(fixed_extent != ::cat::dynamic_extent && index < fixed_extent)
struct tuple_element<index, ::cat::span<T, fixed_extent>> {
   using type = T&;
};

template <__SIZE_TYPE__ index, typename T, ::cat::idx fixed_extent>
   requires(fixed_extent != ::cat::dynamic_extent && index < fixed_extent)
struct tuple_element<index, ::cat::span<T, fixed_extent> const> {
   using type = T&;
};

template <__SIZE_TYPE__ index, typename T, ::cat::idx fixed_extent>
   requires(fixed_extent != ::cat::dynamic_extent && index < fixed_extent)
struct tuple_element<index, ::cat::span<T, fixed_extent> volatile> {
   using type = T&;
};

template <__SIZE_TYPE__ index, typename T, ::cat::idx fixed_extent>
   requires(fixed_extent != ::cat::dynamic_extent && index < fixed_extent)
struct tuple_element<index, ::cat::span<T, fixed_extent> const volatile> {
   using type = T&;
};

}  // namespace std

// We implement these functions here instead of in `cat::memory` because they
// have circular dependencies.
namespace cat {

template <typename T>
[[nodiscard]]
constexpr auto
is_pointer_in_range(T const* p_pointer, span<T const> const range) -> bool {
   static_assert(!is_function<T>,
                 "`is_pointer_in_range` does not accept function types.");

   if consteval {
      for (T const& entry : range) {
         if (p_pointer == __builtin_addressof(entry)) {
            return true;
         }
      }
      return false;
   }

   if (range.size() == 0u) {
      return false;
   }

   T const* const p_begin = range.data();
   T const* const p_end = p_begin + range.size();
   return !less<>{}(p_pointer, p_begin) && less<>{}(p_pointer, p_end);
}

template <typename T>
[[nodiscard]]
constexpr auto
is_memory_overlapping(span<T const> const first, span<T const> const second)
   -> bool {
   return is_memory_overlapping(first.data(), first.size() * sizeof(T),
                                second.data(), second.size() * sizeof(T));
}

template <typename T>
   requires(is_implicit_lifetime<T>)
constexpr void
copy_memory(span<T const> const source, span<T> destination) {
   copy_memory(source.data(), destination.data(),
               (source.size() * sizeof(T)).to_idx().assert());
}

template <typename T>
   requires(is_implicit_lifetime<T>)
constexpr void
copy_memory_backward(span<T const> const source, span<T> destination) {
   copy_memory_backward(source.data(), destination.data(),
                        (source.size() * sizeof(T)).to_idx().assert());
}

}  // namespace cat

