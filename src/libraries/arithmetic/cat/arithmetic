// `cat::arithmetic`, `cat::index`, and `cat::arithmetic_ptr` are containers for
// numeric data types which both prevent unsound implicit type conversions and
// make safe comparisons between different arithmetic types.
//
// All of their conversion operators, is_arithmetic operators and constructors
// are generic with constraints. Because these methods are constrained, it
// is possible that the compiler will fail to resolve any satisfying
// overloads for an invocation of an operator or constructor, and thus prevent
// compilation.
//
// Constraints such as "the operand's size must be less than or equal to my
// own size" guarantee that an unwanted overload cannot be resolved.
// This solution is concise, because any constraint broadly applies to all
// possible type conversions.
//
// There are attribute `enable_if` overloads that relax these constraints for
// compile-time known sound conversions.
//
// There are also attribute `enable_if` overloads that relax these constraints.
//
// `cat::arithmetic` is an abstraction over fundamental integer and
// floating-point arithmetic types.
//
// `cat::index` is a 63-bit unsigned integer type that is used to index arrays
// and containers. This type is recommended for the iterator of `for` loops and
// the parameter of indexing functions or quantities of memory.
//
// It is roughly analogous to `std::size_t`, however because it
// is 63-bit, it may safely convert to both 64-bit signed and unsigned integers.
// Subtracting from a `cat::index` will cast to `cat::iword`, thereby teaching
// the type system that this subtraction will never underflow. When the
// difference is compile-time known to be positive, this is relaxed and a
// `cat::index` is returned instead. This is important for expressions involving
// literals used within subscripting.
//
// All `for` loops in libCat use either `cat::index` or `cat::iword` as its
// iterator integer.
//
// `cat::arithmetic_ptr` is a pointer type that is used to store pointers to
// arithmetic types. It is essentially a type-safe `std::intptr_t` or
// `std::uintptr_t` that may only reinterpret-cast back to the pointer type that
// it originates from.
#define ssizeof(argument) cat::make_signed(sizeof(argument))

namespace cat {

// These policies control the overflow semantics of `arithmetic`s.
enum class overflow_policies : unsigned char {
   undefined,
   wrap,
   saturate,
   trap,
};

template <typename WrappedQual, overflow_policies Semantics>
class overflow_reference;

template <typename T, typename storage_type, overflow_policies overflow_policy>
   requires(sizeof(storage_type) == sizeof(void*))
class arithmetic_ptr;

template <overflow_policies overflow_policy>
class index;

// Unwraps `cat::arithmetic`, `cat::index`, `cat::arithmetic_ptr`, `cat::bool2`,
// and `cat::bool4` into their `raw` values.
template <typename T>
[[gnu::always_inline, gnu::nodebug]]
constexpr auto
make_raw_arithmetic(T value) {
   if constexpr (requires { value.raw; }) {
      return value.raw;
   } else if constexpr (__is_pointer(T)) {
      return reinterpret_cast<__UINTPTR_TYPE__>(value);
   } else {
      return value;
   }
}

// Unwraps `cat::arithmetic`, `cat::index`, `cat::arithmetic_ptr`, `cat::bool2`,
// and `cat::bool4` into their `raw` types.
template <typename T>
using raw_arithmetic_type = decltype(make_raw_arithmetic(T{}));

template <typename T>
concept is_raw_arithmetic = is_same<T, raw_arithmetic_type<T>>;

template <typename T>
concept is_raw_integral = is_integral<T> && is_raw_arithmetic<T>;

template <typename T>
concept is_raw_floating_point = is_floating_point<T> && is_raw_arithmetic<T>;

namespace detail {
template <typename>
struct is_idx_trait : false_trait {};

template <overflow_policies policy>
struct is_idx_trait<index<policy>> : true_trait {};

template <typename T>
concept is_idx = is_idx_trait<T>::value;

template <typename T>
concept is_arithmetic_ptr = requires { T::ptr; };
}  // namespace detail

template <is_integral T>
constexpr auto
make_signed(T value) -> make_signed_type<T> {
   // return __builtin_bit_cast(make_signed_type<T>, value);
   return static_cast<make_signed_type<T>>(value);
}

// Identity on the value. Works with `cat::make_signed_type` for floating-point
// types.
template <is_floating_point T>
[[gnu::always_inline, gnu::nodebug]]
constexpr auto
make_signed(T value) -> T {
   return value;
}

template <is_integral T>
constexpr auto
make_unsigned(T value) -> make_unsigned_type<T> {
   // return __builtin_bit_cast(make_unsigned_type<T>, value);
   return static_cast<make_unsigned_type<T>>(value);
}

template <is_integral sign_type, is_integral T>
constexpr auto
make_sign_from(T value) -> copy_sign_from<sign_type, T> {
   return static_cast<copy_sign_from<sign_type, T>>(value);
}

template <is_integral sign_type, is_integral T>
constexpr auto
make_sign_from(sign_type, T value) -> copy_sign_from<sign_type, T> {
   return static_cast<copy_sign_from<sign_type, T>>(value);
}

template <typename T>
concept is_safe_arithmetic =
   detail::is_idx<T> || detail::is_arithmetic_ptr<T>
   || (is_arithmetic<T> && !__is_same(T, raw_arithmetic_type<T>));

template <typename T>
concept is_unsafe_arithmetic =
   is_arithmetic<T> && __is_same(T, raw_arithmetic_type<T>);

template <typename T>
concept is_safe_integral =
   detail::is_idx<T> || detail::is_arithmetic_ptr<T>
   || (is_integral<T> && !__is_same(T, raw_arithmetic_type<T>));

template <typename T>
concept is_unsafe_integral =
   is_integral<T> && __is_same(T, raw_arithmetic_type<T>);

namespace detail {
// The larger the `order` in this hierarchy is, the greater its precedence
// is in integer promotion. Any type with a lower `order` can safely convert
// to a type with a higher `order`, regardless of signed-ness.

// This specialization matches fundamental arithmetic types as well as
// `cat::arithmetic` specializations.
template <typename T>
struct integer_promotion_hierarchy {
   static constexpr unsigned long order = sizeof(T);
};

template <overflow_policies policy>
struct integer_promotion_hierarchy<index<policy>> {
   // 7 is smaller than 8 from `uword`, but larger than 4 from `uint4`.
   // `uint4` should promote to `index`, and `index` should promote to
   // `uword`.
   static constexpr unsigned long order = 7;
};

template <typename T, typename storage_type, overflow_policies policy>
struct integer_promotion_hierarchy<arithmetic_ptr<T, storage_type, policy>> {
   // 9 is larger than 8 from `uword` and `iword`, so all integers should
   // promote to `arithmetic_ptr`.
   static constexpr unsigned long order = 9;
};

// Extract the overflow policy from a type.
template <typename T>
struct overflow_policy_for_impl {
   // Fundamental types default to `undefined` overflow.
   static constexpr overflow_policies value = overflow_policies::undefined;
};

template <typename T, overflow_policies policy>
struct overflow_policy_for_impl<arithmetic<T, policy>> {
   static constexpr overflow_policies value = policy;
};

template <overflow_policies policy>
struct overflow_policy_for_impl<index<policy>> {
   static constexpr overflow_policies value = policy;
};

template <typename T, typename storage_type, overflow_policies policy>
struct overflow_policy_for_impl<arithmetic_ptr<T, storage_type, policy>> {
   static constexpr overflow_policies value = policy;
};

template <typename T>
struct overflow_policy_for : overflow_policy_for_impl<remove_cvref<T>> {};

template <typename T>
inline constexpr overflow_policies overflow_policy_of =
   overflow_policy_for<T>::value;

// Rebind the overflow policy of an arithmetic-like type. Raw integers and
// floats become `arithmetic<T, new_policy>`; `arithmetic`, `index`, and
// `arithmetic_ptr` keep their kind and replace just the policy.
template <typename T, overflow_policies new_policy>
struct rebind_overflow_policy {
   using type = arithmetic<T, new_policy>;
};

template <typename T, overflow_policies old_policy,
          overflow_policies new_policy>
struct rebind_overflow_policy<arithmetic<T, old_policy>, new_policy> {
   using type = arithmetic<T, new_policy>;
};

template <overflow_policies old_policy, overflow_policies new_policy>
struct rebind_overflow_policy<index<old_policy>, new_policy> {
   using type = index<new_policy>;
};

template <typename T, typename storage_type, overflow_policies old_policy,
          overflow_policies new_policy>
struct rebind_overflow_policy<arithmetic_ptr<T, storage_type, old_policy>,
                              new_policy> {
   using type = arithmetic_ptr<T, storage_type, new_policy>;
};

// `promoted_arithmetic` picks the result shape for a binary op. For
// `undefined` LHS this is the wider of the two operands tagged with `left`'s
// policy, which is what `+` and `*` need so the result has room for the worst
// case. For `wrap` / `saturate` LHS we never widen: the user opted into a
// fixed-width well-defined overflow domain, and silently growing into a wider
// type would defeat that intent. (`-`, `/`, `%`, shifts, `&`, and `|` keep
// the LHS's storage type by construction; the same-width-or-narrower
// constraints on `&` / `|` reject the truncating direction outright.)
template <typename left, typename right>
consteval auto
promoted_arithmetic() {
   constexpr overflow_policies policy = overflow_policy_of<left>;

   if constexpr (policy != overflow_policies::undefined) {
      // wrap / sat / trap: never promote, always return LHS shape.
      return typename rebind_overflow_policy<left, policy>::type();
   } else if constexpr (integer_promotion_hierarchy<left>::order
                        >= integer_promotion_hierarchy<right>::order) {
      // LHS wins on width: keep its kind, force `policy` (a no-op when
      // `left` already has that policy; for raw `left` this wraps it).
      return typename rebind_overflow_policy<left, policy>::type();
   } else {
      // RHS wins on width: keep RHS's kind (`arithmetic`, `index`,
      // `arithmetic_ptr`, or a raw type) and tag it with `left`'s policy.
      return typename rebind_overflow_policy<right, policy>::type();
   }
}

template <typename left, typename right>
   requires(  // Both types must have the same float-ness. Floating point
              // implicit conversions are subtly pessimizing:
              is_floating_point<left> == is_floating_point<right>)
using promoted_type = decltype(promoted_arithmetic<remove_constref<left>,
                                                   remove_constref<right>>());

}  // namespace detail

template <typename left_type, typename right_type>
concept is_safe_arithmetic_comparison =
   // `raw_arithmetic_type` is needed here to prevent a recursive constraint in
   // evaluating the `<` operator inside `is_signed`.
   (  // If both types have the same signed-ness:
      (is_signed<raw_arithmetic_type<left_type>>
       == is_signed<raw_arithmetic_type<right_type>>)
      // Or, if left_type is signed and larger than right_type:
      || (is_signed<raw_arithmetic_type<left_type>>
          && is_unsigned<raw_arithmetic_type<right_type>>
          && (sizeof(left_type) > sizeof(right_type)))
      // Or, if right_type is signed and larger than left_type.
      || (is_unsigned<raw_arithmetic_type<left_type>>
          && is_signed<raw_arithmetic_type<right_type>>
          && (sizeof(left_type) < sizeof(right_type))))
   // And both types have the same floating-point-ness.
   && (is_floating_point<left_type> == is_floating_point<right_type>);

// Any `arithmetic` can safely convert to a type larger than itself, but not
// smaller than itself.
template <typename from_type, typename to_type>
concept is_safe_arithmetic_conversion =
   ((detail::integer_promotion_hierarchy<from_type>::order
     <= detail::integer_promotion_hierarchy<to_type>::order)
    && is_safe_arithmetic_comparison<from_type, to_type>)

   // A special-case exception must be made for `index` -> `iword`. This
   // doesn't work by default because they have different signed-ness.
   // TODO: Support overflow semantics.
   || (is_same<from_type, index<overflow_policies::undefined>>
       && is_same<to_type,
                  arithmetic<signed long, overflow_policies::undefined>>);

namespace detail {

// Wide type for lossless round-trip checks in
// `raw_source_fits_implicit_storage`. Unsigned `U` into signed `Dest` keeps the
// comparison in unsigned space so a truncated signed intermediate does not get
// confused with a huge unsigned. Integral into floating storage is handled in
// `raw_source_fits_implicit_storage` before this alias is used.
template <typename DestStorage, typename RawSource>
using implicit_raw_compare_wide = conditional<
   is_unsigned_integral<RawSource> && is_signed_integral<DestStorage>,
   larger_type<make_unsigned_type<RawSource>, make_unsigned_type<DestStorage>>,
   conditional<is_unsigned_integral<RawSource>
                  && is_unsigned_integral<DestStorage>,
               larger_type<make_unsigned_type<RawSource>, DestStorage>,
               larger_type<RawSource, DestStorage>>>;

// Value check for the four raw `enable_if` converting constructors. Width
// and signedness pairing are enforced on the `arithmetic` constructors; this
// only answers whether the runtime value fits the destination storage.
// This is `constexpr` rather than `consteval`
template <typename Dest, typename U>
constexpr auto
raw_source_fits_implicit_storage(U const& other) -> bool {
   auto const raw = make_raw_arithmetic(other);
   using raw_value = remove_cvref<decltype(raw)>;
   if constexpr (is_floating_point<Dest>) {
      if constexpr (is_integral<raw_value>) {
         // Integral to float. `implicit_raw_compare_wide` does not support
         // `float` `Dest`.
         Dest const fd = static_cast<Dest>(raw);
         if (!__builtin_isfinite(fd)) {
            return false;
         }
         return static_cast<U>(fd) == other;
      }
      // Floating to floating in floating storage only, avoiding
      // `implicit_raw_compare_wide`.
      Dest const narrowed = static_cast<Dest>(raw);
      if (!__builtin_isfinite(narrowed)) {
         return false;
      }
      return static_cast<long double>(narrowed)
             == static_cast<long double>(raw);
   } else {
      if constexpr (is_floating_point<raw_value>) {
         Dest const to_dest = static_cast<Dest>(raw);
         if (!__builtin_isfinite(static_cast<double>(to_dest))) {
            return false;
         }
         return static_cast<long double>(to_dest)
                == static_cast<long double>(raw);
      } else {
         if constexpr (is_signed_integral<U> && is_unsigned_integral<Dest>) {
            if (raw < 0) {
               return false;
            }
         }
         using wide_type = implicit_raw_compare_wide<Dest, raw_value>;
         return static_cast<wide_type>(static_cast<Dest>(raw))
                == static_cast<wide_type>(raw);
      }
   }
}

// `<=>` for two raw integers of any signedness/width combination. Negative
// signed operands are handled up front (strictly less / strictly greater than
// any unsigned value) so that the subsequent cast through `common_type` only
// ever runs on non-negative values, where it is lossless in every direction.
template <typename RawL, typename RawR>
[[nodiscard, gnu::always_inline, gnu::nodebug]]
constexpr auto
raw_mixed_integral_spaceship(RawL const lhs, RawR const rhs) {
   if constexpr (is_signed_integral<RawL> && is_unsigned_integral<RawR>) {
      if (lhs < 0) {
         return std::strong_ordering::less;
      }
   } else if constexpr (is_unsigned_integral<RawL>
                        && is_signed_integral<RawR>) {
      if (rhs < 0) {
         return std::strong_ordering::greater;
      }
   }
   using C = common_type<RawL, RawR>;
   return static_cast<C>(lhs) <=> static_cast<C>(rhs);
}

// `==` companion to `raw_mixed_integral_spaceship`. A negative signed operand
// can never equal an unsigned operand.
template <typename RawL, typename RawR>
[[nodiscard, gnu::always_inline, gnu::nodebug]]
constexpr auto
raw_mixed_integral_equals(RawL const lhs, RawR const rhs) -> bool {
   if constexpr (is_signed_integral<RawL> && is_unsigned_integral<RawR>) {
      if (lhs < 0) {
         return false;
      }
   } else if constexpr (is_unsigned_integral<RawL>
                        && is_signed_integral<RawR>) {
      if (rhs < 0) {
         return false;
      }
   }
   using C = common_type<RawL, RawR>;
   return static_cast<C>(lhs) == static_cast<C>(rhs);
}

}  // namespace detail

// Add two integers with saturating overflow.
template <is_raw_integral T>
[[nodiscard]]
constexpr auto
sat_add(T lhs, T rhs) -> T {
   T sum;
   bool overflow = __builtin_add_overflow(lhs, rhs, &sum);
   if (overflow) {
      // Same-sign overflow is the only case `__builtin_add_overflow`
      // can report for signed `T` (mixed-sign sums always fit), so the
      // sign of `lhs` chooses the saturation endpoint. For unsigned
      // `T`, only positive-direction overflow is possible.
      if constexpr (is_signed<T>) {
         return lhs < 0 ? limits<T>::min() : limits<T>::max();
      } else {
         return limits<T>::max();
      }
   }
   return sum;
}

// Erase redundant type information for `sat_add()`.
template <is_integral T, is_integral U>
   requires(is_safe_arithmetic_comparison<T, U>)
[[nodiscard, gnu::always_inline, gnu::nodebug]]
constexpr auto
sat_add(T lhs, U rhs) -> detail::promoted_type<T, U> {
   // Saturating is_arithmetic inputs must be raw and cast to the same size.
   using type = raw_arithmetic_type<larger_type<T, U>>;
   return sat_add(static_cast<type>(lhs), static_cast<type>(rhs));
}

// Add two integers with wrapping overflow.
template <is_integral T, is_integral U>
   requires(is_safe_arithmetic_comparison<T, U>)
[[nodiscard, gnu::always_inline, gnu::nodebug]]
constexpr auto
wrap_add(T lhs, U rhs) -> detail::promoted_type<T, U> {
   // Cast to a raw, unsigned, integer to guarantee wrapping semantics.
   using type = raw_arithmetic_type<make_unsigned_type<larger_type<T, U>>>;
   return detail::promoted_type<T, U>(static_cast<type>(lhs)
                                      + static_cast<type>(rhs));
}

// Forward declared so the wider-space `sat_*` overloads below can clamp
// their wider intermediate back into the LHS raw type.
template <is_raw_integral T, is_raw_integral U>
[[nodiscard, gnu::always_inline, gnu::nodebug]]
constexpr auto
sat_cast(U value) -> T;

// Subtract two integers with saturating overflow.
template <is_raw_integral T>
[[nodiscard]]
constexpr auto
sat_sub(T lhs, T rhs) -> T {
   T sum;
   bool overflow = __builtin_sub_overflow(lhs, rhs, &sum);
   if (overflow) {
      // For signed `T`, opposite-sign operands are the only overflow
      // shape (same-sign differences always fit). The sign of `lhs`
      // points at the saturating endpoint: a positive `lhs` minus a
      // negative `rhs` saturates upward, and the inverse saturates
      // downward. Unsigned `T` can only underflow (saturate to `0`).
      if constexpr (is_signed<T>) {
         return lhs < 0 ? limits<T>::min() : limits<T>::max();
      } else {
         return limits<T>::min();
      }
   }
   return sum;
}

// Erase redundant type information for `sat_sub()`. Computes the difference
// in the wider operand's space and saturates back into the LHS raw type so
// the result honors the LHS-shape rule for `-`.
template <is_integral T, is_integral U>
   requires(is_safe_arithmetic_comparison<T, U>)
[[nodiscard, gnu::always_inline, gnu::nodebug]]
constexpr auto
sat_sub(T lhs, U rhs) -> remove_constref<T> {
   using wide = raw_arithmetic_type<larger_type<T, U>>;
   using lhs_raw = raw_arithmetic_type<T>;
   return remove_constref<T>(cat::sat_cast<lhs_raw>(
      sat_sub(static_cast<wide>(lhs), static_cast<wide>(rhs))));
}

// Subtract two integers with wrapping overflow.
template <is_integral T, is_integral U>
   requires(is_safe_arithmetic_comparison<T, U>)
[[nodiscard, gnu::always_inline, gnu::nodebug]]
constexpr auto
wrap_sub(T lhs, U rhs) -> remove_constref<T> {
   // Cast to a raw, unsigned, integer to guarantee wrapping semantics.
   // Two's-complement truncation back to the LHS width preserves wrap.
   using wide = raw_arithmetic_type<make_unsigned_type<larger_type<T, U>>>;
   using lhs_raw = raw_arithmetic_type<T>;
   return remove_constref<T>(
      static_cast<lhs_raw>(static_cast<wide>(lhs) - static_cast<wide>(rhs)));
}

// Multiply two integers with saturating overflow.
template <is_raw_integral T>
[[nodiscard]]
constexpr auto
sat_mul(T lhs, T rhs) -> T {
   T sum;
   bool overflow = __builtin_mul_overflow(lhs, rhs, &sum);
   if (overflow) {
      // For signed `T`, the true result's sign is the XOR of the
      // operands' signs: same sign overflows positive, mixed sign
      // overflows negative. (Neither operand can be zero on overflow.)
      // Unsigned `T` only overflows positive.
      if constexpr (is_signed<T>) {
         return ((lhs ^ rhs) < 0) ? limits<T>::min() : limits<T>::max();
      } else {
         return limits<T>::max();
      }
   }
   return sum;
}

// Erase redundant type information for `sat_mul()`.
template <is_integral T, is_integral U>
   requires(is_safe_arithmetic_comparison<T, U>)
[[nodiscard, gnu::always_inline, gnu::nodebug]]
constexpr auto
sat_mul(T lhs, U rhs) -> detail::promoted_type<T, U> {
   // Saturating is_arithmetic inputs must be raw and cast to the same size.
   using type = raw_arithmetic_type<larger_type<T, U>>;
   return sat_mul(static_cast<type>(lhs), static_cast<type>(rhs));
}

// Multiply two integers with wrapping overflow.
template <is_integral T, is_integral U>
   requires(is_safe_arithmetic_comparison<T, U>)
[[nodiscard, gnu::always_inline, gnu::nodebug]]
constexpr auto
wrap_mul(T lhs, U rhs) -> detail::promoted_type<T, U> {
   // Cast to a raw, unsigned, integer to guarantee wrapping semantics.
   using type = raw_arithmetic_type<make_unsigned_type<larger_type<T, U>>>;
   return detail::promoted_type<T, U>(static_cast<type>(lhs)
                                      * static_cast<type>(rhs));
}

// Divide two integers with saturating overflow.
template <is_raw_integral T>
[[nodiscard]]
constexpr auto
sat_div(T lhs, T rhs) -> T {
   if constexpr (is_signed<T>) {
      // The only signed division that overflows is `min() / -1`, whose
      // mathematical result is `-min() == max() + 1`. Saturate to
      // `max()` and skip the divide that would otherwise be UB.
      if (rhs == T(-1) && lhs == limits<T>::min()) {
         return limits<T>::max();
      }
   }
   // Unsigned integer division cannot overflow.
   return lhs / rhs;
}

// Erase redundant type information for `sat_div()`. The math is done in
// the wider operand's space, but `|a / b| <= |a|` (with the lone exception
// of signed `INT_MIN / -1`, which the inner `sat_div` already saturates),
// so the result is then saturated back into the LHS raw type.
template <is_integral T, is_integral U>
   requires(is_safe_arithmetic_comparison<T, U>)
[[nodiscard, gnu::always_inline, gnu::nodebug]]
constexpr auto
sat_div(T lhs, U rhs) -> remove_constref<T> {
   using wide = raw_arithmetic_type<larger_type<T, U>>;
   using lhs_raw = raw_arithmetic_type<T>;
   return remove_constref<T>(cat::sat_cast<lhs_raw>(
      sat_div(static_cast<wide>(lhs), static_cast<wide>(rhs))));
}

// Divide two integers with wrapping overflow.
//
// Division can only overflow at signed `min() / -1` (mathematically
// `-min() == max() + 1`); two's-complement wrap of that result is
// `min()` itself. Every other division is in range, so just compute
// it in the wider operand's space (preserving signedness so a negative
// result keeps its sign) and narrow back to the LHS storage.
template <is_integral T, is_integral U>
   requires(is_safe_arithmetic_comparison<T, U>)
[[nodiscard, gnu::always_inline, gnu::nodebug]]
constexpr auto
wrap_div(T lhs, U rhs) -> remove_constref<T> {
   using wide = raw_arithmetic_type<larger_type<T, U>>;
   using lhs_raw = raw_arithmetic_type<T>;
   wide const wide_lhs = static_cast<wide>(lhs);
   wide const wide_rhs = static_cast<wide>(rhs);
   if constexpr (is_signed<wide>) {
      if (wide_rhs == wide(-1) && wide_lhs == limits<wide>::min()) {
         return remove_constref<T>(static_cast<lhs_raw>(limits<wide>::min()));
      }
   }
   return remove_constref<T>(static_cast<lhs_raw>(wide_lhs / wide_rhs));
}

// Left bit-shifting two unsigned integers with saturating overflow. The
// highest set bit lives at position `bits - 1 - clz(value)`; if `bits`
// would push it past the most-significant position, saturate to `max()`.
template <is_raw_integral T, is_raw_integral U>
   requires(is_unsigned<T>)
[[nodiscard]]
constexpr auto
sat_shl(T value, U bits) -> T {
   if (value == 0) {
      return T(0);
   }
   // TODO: Swap back to `__builtin_stdc_leading_zeros` once the
