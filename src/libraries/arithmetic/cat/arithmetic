      return value > 0 ? limits<T>::max() : limits<T>::min();
   }
   using utype = make_unsigned_type<T>;
   T const result = static_cast<T>(static_cast<utype>(value) << bits);
   if (static_cast<T>(result >> bits) != value) {
      return value > 0 ? limits<T>::max() : limits<T>::min();
   }
   return result;
}

