   constexpr bool2(bool input)
       : raw(static_cast<raw_type>(static_cast<unsigned char>(input))) {
   }

   template <is_arithmetic T>
   [[gnu::always_inline, gnu::nodebug]]
   constexpr explicit bool2(T input)
       : raw(static_cast<raw_type>(make_raw_arithmetic(input)
                                         != raw_arithmetic_type<T>(0)
