sat_shr(index<P> value, U bits) -> index<P> {
   using signed_size = make_signed_type<__SIZE_TYPE__>;
   auto const raw_bits = make_raw_arithmetic(bits);
   auto const signed_value = __builtin_bit_cast(signed_size, value.raw);
   return index<P>(
      __builtin_bit_cast(__SIZE_TYPE__, sat_shr(signed_value, raw_bits)));
}

// Left bit-rotation of a `cat::index`. Rotation happens over the lower
// `bit_width - 1` bits (the usable index range) so the high bit stays
// zero and the `index` invariant is preserved. The shift count is taken
// modulo that ring width, so any non-negative count is valid.
template <overflow_policies P, is_integral U>
[[nodiscard, gnu::always_inline, gnu::nodebug]]
constexpr auto
wrap_shl(index<P> value, U bits) -> index<P> {
   constexpr __SIZE_TYPE__ ring_bits = (sizeof(__SIZE_TYPE__) * 8u) - 1u;
   constexpr __SIZE_TYPE__ ring_mask =
      (static_cast<__SIZE_TYPE__>(1) << ring_bits) - 1u;
   __SIZE_TYPE__ const norm =
      static_cast<__SIZE_TYPE__>(make_raw_arithmetic(bits)) % ring_bits;
   if (norm == 0) {
      return index<P>(value.raw & ring_mask);
   }
   return index<P>(((value.raw << norm) | (value.raw >> (ring_bits - norm)))
                   & ring_mask);
}

// Right bit-rotation mirror of `wrap_shl(index)`. Bits rotated off the
// bottom re-enter at the top of the 63-bit ring; the high bit stays
// zero.
template <overflow_policies P, is_integral U>
[[nodiscard, gnu::always_inline, gnu::nodebug]]
constexpr auto
wrap_shr(index<P> value, U bits) -> index<P> {
   constexpr __SIZE_TYPE__ ring_bits = (sizeof(__SIZE_TYPE__) * 8u) - 1u;
   constexpr __SIZE_TYPE__ ring_mask =
      (static_cast<__SIZE_TYPE__>(1) << ring_bits) - 1u;
   __SIZE_TYPE__ const norm =
      static_cast<__SIZE_TYPE__>(make_raw_arithmetic(bits)) % ring_bits;
   if (norm == 0) {
      return index<P>(value.raw & ring_mask);
   }
   return index<P>(((value.raw >> norm) | (value.raw << (ring_bits - norm)))
                   & ring_mask);
}

