}

// TODO: Mark these member functions `[[gnu::nodebug]]`.
// TODO: Implement trapping overflow policy.
// `arithmetic` can represent an integer or floating point value. It prevents
// unsafe casts or operations. This is a trivial `struct` so it can be used as a
// non-type template parameter.
template <typename T,
          overflow_policies overflow_policy = overflow_policies::undefined>
class arithmetic :
    // Generate arithmetic operators.
    public arithmetic_interface<arithmetic<T, overflow_policy>> {
 public:
   using raw_type = T;

   static constexpr overflow_policies policy = overflow_policy;

   T raw;

   constexpr arithmetic() = default;
   constexpr arithmetic(arithmetic const&) = default;
   constexpr arithmetic(arithmetic&&) = default;

   // Implicit raw conversions when the shape and value fit (`enable_if`),
   // including integral sources into floating storage when the value is exactly
   // representable.
   template <is_arithmetic U>
      requires(
         detail::has_raw_implicit_storage_shape<raw_arithmetic_type<U>, T>())
   [[gnu::always_inline, gnu::nodebug]]
   constexpr arithmetic(U other) __attribute__((enable_if(
      detail::raw_source_fits_implicit_storage<T>(other),
      "value is out of range for implicit conversion to this arithmetic type")))
       : raw(static_cast<T>(make_raw_arithmetic(other))) {
   }

   // Constructing with safe conversions is implicit, but constructing with
   // unsafe conversions is explicit.
   template <is_arithmetic U>
   [[gnu::always_inline, gnu::nodebug]]
   constexpr explicit(!is_safe_arithmetic_conversion<U, T>) arithmetic(U other)
       : raw(static_cast<T>(make_raw_arithmetic(other))) {
   }

   template <typename U>
   [[gnu::always_inline, gnu::nodebug]]
   constexpr explicit
   operator U() const {
      return static_cast<U>(raw);
   }

   template <is_arithmetic U>
      requires(is_safe_arithmetic_comparison<T, U>)
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr auto
   operator<=>(U rhs) const {
      using common = common_type<raw_type, raw_arithmetic_type<U>>;
      return common(raw) <=> common(make_raw_arithmetic(rhs));
   }

   template <is_arithmetic U>
      requires(is_safe_arithmetic_comparison<T, U>)
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator==(arithmetic lhs, U rhs) -> bool {
      return lhs.raw == make_raw_arithmetic(rhs);
   }

   template <is_arithmetic U>
      requires(!is_safe_arithmetic_comparison<T, U>
               && !detail::is_idx<arithmetic>
               && sizeof(T) >= sizeof(raw_arithmetic_type<U>)
               && ((is_unsigned_integral<T> && is_signed_integral<U>)
                   || (is_signed_integral<T> && is_unsigned_integral<U>)))
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator<=>(arithmetic lhs, U rhs) __attribute__((enable_if(
      detail::raw_mixed_integral_compare_sound(lhs.raw,
                                               make_raw_arithmetic(rhs)),
      "mixed signed-unsigned comparison is not sound for these values!"))) {
      auto const rhs_raw = make_raw_arithmetic(rhs);
      if !consteval {
         assert(detail::raw_mixed_integral_compare_sound(lhs.raw, rhs_raw));
      }
      if constexpr (is_signed_integral<raw_type>
                    && is_unsigned_integral<raw_arithmetic_type<U>>) {
         if (lhs.raw < 0) {
            return std::strong_ordering::less;
         }
      }
      if constexpr (is_unsigned_integral<raw_type>
                    && is_signed_integral<raw_arithmetic_type<U>>) {
         if (rhs_raw < 0) {
            return std::strong_ordering::greater;
         }
      }
      using common = common_type<raw_type, raw_arithmetic_type<U>>;
      return static_cast<common>(lhs.raw) <=> static_cast<common>(rhs_raw);
   }

   template <is_arithmetic U>
      requires(!is_safe_arithmetic_comparison<T, U>
               && !detail::is_idx<arithmetic>
               && sizeof(T) >= sizeof(raw_arithmetic_type<U>)
               && ((is_unsigned_integral<T> && is_signed_integral<U>)
                   || (is_signed_integral<T> && is_unsigned_integral<U>)))
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   friend constexpr bool  // NOLINTNEXTLINE
   operator==(arithmetic lhs, U rhs) __attribute__((enable_if(
      detail::raw_mixed_integral_compare_sound(lhs.raw,
                                               make_raw_arithmetic(rhs)),
      "mixed signed-unsigned comparison is not sound for these values!"))) {
      auto const rhs_raw = make_raw_arithmetic(rhs);
      if !consteval {
         verify(detail::raw_mixed_integral_compare_sound(lhs.raw, rhs_raw));
