// -*- mode: c++ -*-
// vim: set ft=cpp:
#pragma once

#include <cat/arithmetic>
#include <cat/meta>

// We generate arithmetic operators by finding implementations of the
// corresponding member functions in a CRTP derived `class`. These include:
//
//    `.add()`
//    `.bit_and()`
//    `.bit_complement()`
//    `.bit_not()`
//    `.bit_or()`
//    `.bit_xor()`
//    `.divide_by()`
//    `.divide_into()`
//    `.modulo_by()`
//    `.modulo_into()`
//    `.multiply()`
//    `.negate()`
//    `.shift_left_by()`
//    `.shift_left_into()`
//    `.shift_right_by()`
//    `.shift_right_into()`
//    `.subtract_by()`
//    `.subtract_from()`
//
// These are each wrapped by conventional operator overloading, so to add an
// overload of both `operator+` and `operator+=` simultaneously, you need only
// implement an overload or template specialization of `.add()`. If any are
// absent, they are gracefully ignored and corresponding operators are not
// generated.
//
// These are all aggregated by the `arithmetic_interface` template, but they may
// be selected granularly by the smaller CRTP classes:
//
//     `plus_interface`
//     `minus_interface`
//     `multiply_interface`
//     `divide_interface`
//     `modulo_interface`
//     `bitwise_interface`
//
// Before deducing operands, operators follow overload resolution rules to
// attempt implicit constructing them to `Derived`.
//
// This is actually not handled implicitly by simple type deduction, due to
// attribute `enable_if`. These overloads supercede type deduction, so they
// cannot take a forwarding reference, therefore we handle both r-value and
// l-value `const` reference parameters in separate bodies for each operator.
// Supporting attribute `enable_if` in this way allows, for example,
// `cat::index` to handle `+= 1` without special casing any operators.

namespace cat {

template <typename T>
struct arithmetic_interface;

template <typename T>
struct bitwise_interface;

namespace detail {
// TODO: Commutative operators should support non-commutative operations.

template <typename T, typename U>
concept has_add_interface = requires(T lhs, U rhs) { lhs.add(rhs); };

template <typename T, typename U>
concept has_subtract_by_interface =
   requires(T lhs, U rhs) { lhs.subtract_by(rhs); };

template <typename T>
concept has_negate_interface = requires(T lhs) { lhs.negate(lhs); };

template <typename T, typename U>
concept has_multiply_interface = requires(T lhs, U rhs) { lhs.multiply(rhs); };

template <typename T, typename U>
concept has_divide_by_interface =
   requires(T lhs, U rhs) { lhs.divide_by(rhs); };

template <typename T, typename U>
concept has_modulo_by_interface =
   requires(T lhs, U rhs) { lhs.modulo_by(rhs); };

template <typename T, typename U>
concept has_shift_left_by_interface =
   requires(T lhs, U rhs) { lhs.shift_left_by(rhs); };

template <typename T, typename U>
concept has_shift_right_by_interface =
   requires(T lhs, U rhs) { lhs.shift_right_by(rhs); };

template <typename T, typename U>
concept has_bit_and_interface = requires(T lhs, U rhs) { lhs.bit_and(rhs); };

template <typename T, typename U>
concept has_bit_or_interface = requires(T lhs, U rhs) { lhs.bit_or(rhs); };

template <typename T, typename U>
concept has_bit_xor_interface = requires(T lhs, U rhs) { lhs.bit_xor(rhs); };

template <typename T, typename U>
concept has_bit_not_interface = requires(T lhs, U rhs) { lhs.bit_not(rhs); };

template <typename T>
concept has_bit_complement = requires(T lhs) { lhs.bit_complement(); };

// `operator++`/`operator--` assign `add(1)`/`subtract_by(1)` back to the
// operand. They exist only when those calls preserve the operand type (for
// example `cat::index` subtraction against another `index` widens to
// `cat::iword`, so decrement is not generated).
template <typename D>
concept has_unary_increment =
   is_same<remove_cvref<D>,
           remove_cvref<decltype(declval<remove_cvref<D> const&>().add(
              remove_cvref<D>(1)))>>;

template <typename D>
concept has_unary_decrement =
   is_same<remove_cvref<D>,
           remove_cvref<decltype(declval<remove_cvref<D> const&>().subtract_by(
              static_cast<typename remove_cvref<D>::raw_type>(1)))>>;

// Left-hand compound assignments exist only when the corresponding member
// (`add`, `subtract_by`, ...) returns the same type as the operand, matching
// the binary operator result type.
template <typename D, typename T>
concept has_plus_assign = is_same<
   remove_cvref<D>,
   remove_cvref<decltype(declval<remove_cvref<D>&>().add(declval<T>()))>>;

template <typename D, typename T>
concept has_minus_assign =
   is_same<remove_cvref<D>,
           remove_cvref<decltype(declval<remove_cvref<D>&>().subtract_by(
              declval<T>()))>>;

template <typename D, typename T>
concept has_multiply_assign = is_same<
   remove_cvref<D>,
   remove_cvref<decltype(declval<remove_cvref<D>&>().multiply(declval<T>()))>>;

template <typename D, typename T>
concept has_divide_assign = is_same<
   remove_cvref<D>,
   remove_cvref<decltype(declval<remove_cvref<D>&>().divide_by(declval<T>()))>>;

template <typename D, typename T>
concept has_modulo_assign = is_same<
   remove_cvref<D>,
   remove_cvref<decltype(declval<remove_cvref<D>&>().modulo_by(declval<T>()))>>;

template <typename D, typename T>
concept has_bit_and_assign = is_same<
   remove_cvref<D>,
   remove_cvref<decltype(declval<remove_cvref<D>&>().bit_and(declval<T>()))>>;

template <typename D, typename T>
concept has_bit_or_assign = is_same<
   remove_cvref<D>,
   remove_cvref<decltype(declval<remove_cvref<D>&>().bit_or(declval<T>()))>>;

template <typename D, typename T>
concept has_shift_left_assign =
   is_same<remove_cvref<D>,
           remove_cvref<decltype(declval<remove_cvref<D>&>().shift_left_by(
              declval<T>()))>>;

template <typename D, typename T>
concept has_shift_right_assign =
   is_same<remove_cvref<D>,
           remove_cvref<decltype(declval<remove_cvref<D>&>().shift_right_by(
              declval<T>()))>>;

// Member `operator@` on `arithmetic_interface` uses `derived` as the left
// operand. These concepts require the corresponding member call on `D const`
// with `T` as the right operand to be valid.
template <typename D, typename T>
concept has_binary_plus =
   requires { declval<remove_cvref<D> const>().add(declval<T>()); };

template <typename D, typename T>
concept has_binary_subtract_by =
   requires { declval<remove_cvref<D> const>().subtract_by(declval<T>()); };

template <typename D, typename T>
concept has_binary_multiply =
   requires { declval<remove_cvref<D> const>().multiply(declval<T>()); };

template <typename D, typename T>
concept has_binary_divide_by =
   requires { declval<remove_cvref<D> const>().divide_by(declval<T>()); };

template <typename D, typename T>
concept has_binary_bit_and =
   requires { declval<remove_cvref<D> const>().bit_and(declval<T>()); };

template <typename D, typename T>
concept has_binary_bit_or =
   requires { declval<remove_cvref<D> const>().bit_or(declval<T>()); };

template <typename D, typename T>
concept has_binary_modulo_by =
   requires { declval<remove_cvref<D> const>().modulo_by(declval<T>()); };

template <typename D, typename T>
concept has_shift_left_by =
   requires { declval<remove_cvref<D> const>().shift_left_by(declval<T>()); };

template <typename D, typename T>
concept has_shift_right_by =
   requires { declval<remove_cvref<D> const>().shift_right_by(declval<T>()); };

// Reverse-order friends use `self.foo(other)` with the same `self` `D const` or
// `D&&` as the member forms when `foo` is `add`, `multiply`, `bit_and`, or
// `bit_or`. Those `has_reverse_binary_*` aliases document that link.
template <typename D, typename T>
concept has_reverse_binary_plus = has_binary_plus<D, T>;

template <typename D, typename T>
concept has_reverse_binary_multiply = has_binary_multiply<D, T>;

template <typename D, typename T>
concept has_reverse_binary_bit_and = has_binary_bit_and<D, T>;

template <typename D, typename T>
concept has_reverse_binary_bit_or = has_binary_bit_or<D, T>;

// `subtract_from`, `divide_into`, `modulo_into`, and `shift_*_into` are the
// reverse hooks when the left operand of `operator@` is not `Derived`.
template <typename D, typename T>
concept has_reverse_binary_minus = requires {
                                      requires(requires(remove_cvref<D> const& self, T&& x) {
      { self.subtract_from(static_cast<T&&>(x)) };
   }
   || requires(remove_cvref<D>&& self, T&& x) {
         { self.subtract_from(static_cast<T&&>(x)) };
      });
                                   };

template <typename D, typename T>
concept has_reverse_binary_divide =
   requires { declval<remove_cvref<D> const>().divide_into(declval<T>()); };

template <typename D, typename T>
concept has_reverse_binary_modulo =
   requires { declval<remove_cvref<D> const>().modulo_into(declval<T>()); };

template <typename D, typename T>
concept has_reverse_shift_left =
   requires { declval<remove_cvref<D> const>().shift_left_into(declval<T>()); };

template <typename D, typename T>
concept has_reverse_shift_right =
   requires {
      declval<remove_cvref<D> const>().shift_right_into(declval<T>());
   };
}  // namespace detail

// CRTP class for generating a commutative + operator.
template <typename Derived>
struct plus_interface {
 private:
   constexpr plus_interface() = default;
   friend Derived;
   friend struct arithmetic_interface<Derived>;

 public:
   using decay_Derived = remove_cvref<Derived>;

   // Same-type + where the RHS may implicitly construct `decay_Derived`.
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr auto
   operator+(this Derived const& self, decay_Derived const& other)
      -> decltype(auto)
      requires(detail::has_binary_plus<Derived, decay_Derived const&>
               && is_constructible<Derived, decay_Derived const&>)
   {
      return self.add(other);
   }

   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr auto
   operator+(this Derived const& self, decay_Derived&& other) -> decltype(auto)
      requires(detail::has_binary_plus<Derived, decay_Derived &&>
               && is_constructible<Derived, decay_Derived &&>)
   {
      return self.add(move(other));
   }

   // + operator where this is a left-hand-side operand.
   template <typename T>
      requires(detail::has_binary_plus<Derived, T>
               && !is_same<remove_cvref<T>, decay_Derived>)
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr auto
   operator+(this auto&& self, T&& other) -> decltype(auto) {
      return $fwd(self).add($fwd(other));
   }

   // + operators where this is a right-hand-side operand.

   // `this` is an l-value.
   template <typename T>
   // If this operator's left operand can add `Derived` as its right-hand
   // operand, this overload is ambiguous.
      requires(!detail::has_add_interface<T, Derived>
               && !is_same<remove_cvref<T>, decay_Derived>
               && detail::has_reverse_binary_plus<Derived, T>)
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator+(T&& other, decay_Derived const& self) -> decltype(auto) {
      return self.add($fwd(other));
   }

   // `this` is an r-value.
   template <typename T>
   // If this operator's left operand can add `Derived` as its right-hand
   // operand, this overload is ambiguous.
      requires(!detail::has_add_interface<T, Derived>
               && !is_same<remove_cvref<T>, decay_Derived>
               && detail::has_reverse_binary_plus<Derived, T>)
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator+(T&& other, Derived&& self) -> decltype(auto) {
      return $fwd(self).add($fwd(other));
   }

   [[gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator+=(Derived& self, decay_Derived const& rhs) -> Derived&
      requires(detail::has_plus_assign<decay_Derived, decay_Derived>
               && is_constructible<Derived, decay_Derived const&>)
   {
      self = self.add(rhs);
      return self;
   }

   [[gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator+=(Derived& self, decay_Derived&& rhs) -> Derived&
      requires(detail::has_plus_assign<decay_Derived, decay_Derived>
               && is_constructible<Derived, decay_Derived &&>)
   {
      self = self.add(move(rhs));
      return self;
   }

   // += operator where this is a left-hand-side operand.
   template <typename T>
      requires(detail::has_plus_assign<decay_Derived, T>
               && !is_same<remove_cvref<T>, decay_Derived>)
   [[gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator+=(Derived& self, T&& other) -> Derived& {
      self = self.add($fwd(other));
      return self;
   }

   // += operators where this is a right-hand-side operand.

   // `this` is an l-value.
   template <typename T>
   // If this operator's left operand can add `Derived` as its right-hand
   // operand, this overload is ambiguous.
      requires(!detail::has_add_interface<T, Derived>
               && detail::has_reverse_binary_plus<Derived, T>)
   [[gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator+=(T& other, Derived const& self) -> T& {
      other = self.add(other);
      return other;
   }

   // `this` is an r-value.
   template <typename T>
   // If this operator's left operand can add `Derived` as its right-hand
   // operand, this overload is ambiguous.
      requires(!detail::has_add_interface<T, Derived>
               && detail::has_reverse_binary_plus<Derived, T>)
   [[gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator+=(T& other, Derived&& self) -> T& {
      other = move(self).add(other);
      return other;
   }

   // Unary ++ operators.

   // `this` is an l-value.
   [[gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator++(Derived& self) -> Derived&
      requires(detail::has_unary_increment<Derived>)
   {
      self = self.add(Derived(1));
      return self;
   }

   // `this` is an r-value.
   [[gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator++(Derived&& self) -> Derived
      requires(detail::has_unary_increment<Derived>)
   {
      return move(self).add(Derived(1));
   }

   // `this` is an l-value.
   [[gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator++(Derived& self, int) -> Derived&
      requires(detail::has_unary_increment<Derived>)
   {
      self = self.add(Derived(1));
      return self;
   }

   // `this` is an r-value.
   [[gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator++(Derived&& self, int) -> Derived
      requires(detail::has_unary_increment<Derived>)
   {
      return move(self).add(Derived(1));
   }
};

// CRTP class for generating a commutative - operator.
template <typename Derived>
struct minus_interface {
 private:
   constexpr minus_interface() = default;
   friend Derived;
   friend struct arithmetic_interface<Derived>;

 public:
   using decay_Derived = remove_cvref<Derived>;

   // Same-type - where the RHS may implicitly construct `decay_Derived`.
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr auto
   operator-(this Derived const& lhs, decay_Derived const& other)
      -> decltype(auto)
      requires(detail::has_binary_subtract_by<Derived, decay_Derived const&>
               && is_constructible<Derived, decay_Derived const&>)
   {
      return lhs.subtract_by(other);
   }

   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr auto
   operator-(this Derived const& lhs, decay_Derived&& other) -> decltype(auto)
      requires(detail::has_binary_subtract_by<Derived, decay_Derived &&>
               && is_constructible<Derived, decay_Derived &&>)
   {
      return lhs.subtract_by(move(other));
   }

   // - operator where this is a left-hand-side operand.
   template <typename T>
      requires(detail::has_binary_subtract_by<Derived, T>
               && !is_same<remove_cvref<T>, decay_Derived>)
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr auto
   operator-(this auto&& lhs, T&& other) -> decltype(auto) {
      return $fwd(lhs).subtract_by($fwd(other));
   }

   // - operators where this is a right-hand-side operand.

   // `this` is an l-value.
   template <typename T>
   // If this operator's left operand can `subtract_by` `Derived` as its
   // right-hand operand, this overload is ambiguous.
      requires(!detail::has_subtract_by_interface<T, Derived>
               && !is_same<remove_cvref<T>, decay_Derived>
               && detail::has_reverse_binary_minus<Derived, T>)
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator-(T&& other, decay_Derived const& self) -> decltype(auto) {
      return self.subtract_from($fwd(other));
   }

   // `this` is an r-value.
   template <typename T>
   // If this operator's left operand can `subtract_by` `Derived` as its
   // right-hand operand, this overload is ambiguous.
      requires(!detail::has_subtract_by_interface<T, Derived>
               && !is_same<remove_cvref<T>, decay_Derived>
               && detail::has_reverse_binary_minus<Derived, T>)
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator-(T&& other, Derived&& self) -> decltype(auto) {
      return $fwd(self).subtract_from($fwd(other));
   }

   // Same-type compound assignment when `subtract_by(rhs)` preserves `Derived`.
   [[gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator-=(Derived& self, decay_Derived const& rhs) -> Derived&
      requires(detail::has_minus_assign<decay_Derived, decay_Derived>
               && is_constructible<Derived, decay_Derived const&>)
   {
      self = self.subtract_by(rhs);
      return self;
   }

   [[gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator-=(Derived& self, decay_Derived&& rhs) -> Derived&
      requires(detail::has_minus_assign<decay_Derived, decay_Derived>
               && is_constructible<Derived, decay_Derived &&>)
   {
      self = self.subtract_by(move(rhs));
      return self;
   }

   // -= operator where this is a left-hand-side operand.
   template <typename T>
      requires(detail::has_minus_assign<decay_Derived, T>
               && !is_same<remove_cvref<T>, decay_Derived>)
   [[gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator-=(Derived& self, T&& other) -> Derived& {
      self = self.subtract_by($fwd(other));
      return self;
   }

   // -= operators where this is a right-hand-side operand.

   // `this` is an l-value.
   template <typename T>
   // If this operator's left operand can `subtract_by` `Derived` as its
   // right-hand operand, this overload is ambiguous.
      requires(!detail::has_subtract_by_interface<T, Derived>
               && detail::has_reverse_binary_minus<Derived, T>)
   [[gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator-=(T& other, Derived const& self) -> T& {
      other = self.subtract_from(other);
      return other;
   }

   // `this` is an r-value.
   template <typename T>
   // If this operator's left operand can `subtract_by` `Derived` as its
   // right-hand operand, this overload is ambiguous.
      requires(!detail::has_subtract_by_interface<T, Derived>
               && detail::has_reverse_binary_minus<Derived, T>)
   [[gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator-=(T& other, Derived&& self) -> T& {
      other = move(self).subtract_from(other);
      return other;
   }

   // Unary -- operators.

   // `this` is an l-value.
   [[gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator--(Derived& self) -> Derived&
      requires(detail::has_unary_decrement<Derived>)
   {
      self = self.subtract_by(static_cast<typename decay_Derived::raw_type>(1));
      return self;
   }

   // `this` is an r-value.
   [[gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator--(Derived&& self) -> Derived
      requires(detail::has_unary_decrement<Derived>)
   {
      return move(self).subtract_by(
         static_cast<typename decay_Derived::raw_type>(1));
   }

   // `this` is an l-value.
   [[gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator--(Derived& self, int) -> Derived&
      requires(detail::has_unary_decrement<Derived>)
   {
      self = self.subtract_by(static_cast<typename decay_Derived::raw_type>(1));
      return self;
   }

   // `this` is an r-value.
   [[gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator--(Derived&& self, int) -> Derived
      requires(detail::has_unary_decrement<Derived>)
   {
      return move(self).subtract_by(
         static_cast<typename decay_Derived::raw_type>(1));
   }
};

// CRTP class for generating a commutative * operator.
template <typename Derived>
struct multiply_interface {
 private:
   constexpr multiply_interface() = default;
   friend Derived;
   friend struct arithmetic_interface<Derived>;

 public:
   using decay_Derived = remove_cvref<Derived>;

   // Same-type * where the RHS may implicitly construct `decay_Derived`.
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr auto
   operator*(this Derived const& self, decay_Derived const& other)
      -> decltype(auto)
      requires(detail::has_binary_multiply<Derived, decay_Derived const&>
               && is_constructible<Derived, decay_Derived const&>)
   {
      return self.multiply(other);
   }

   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr auto
   operator*(this Derived const& self, decay_Derived&& other) -> decltype(auto)
      requires(detail::has_binary_multiply<Derived, decay_Derived &&>
               && is_constructible<Derived, decay_Derived &&>)
   {
      return self.multiply(move(other));
   }

   // * operator where this is a left-hand-side operand.
   template <typename T>
      requires(detail::has_binary_multiply<Derived, T>
               && !is_same<remove_cvref<T>, decay_Derived>)
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr auto
   operator*(this auto&& self, T&& other) -> decltype(auto) {
      return $fwd(self).multiply($fwd(other));
   }

   // * operators where this is a right-hand-side operand.

   // `this` is an l-value.
   template <typename T>
   // If this operator's left operand can add `Derived` as its right-hand
   // operand, this overload is ambiguous.
      requires(!detail::has_multiply_interface<T, Derived>
               && !is_same<remove_cvref<T>, decay_Derived>
               && detail::has_reverse_binary_multiply<Derived, T>)
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator*(T&& other, decay_Derived const& self) -> decltype(auto) {
      return self.multiply($fwd(other));
   }

   // `this` is an r-value.
   template <typename T>
   // If this operator's left operand can add `Derived` as its right-hand
   // operand, this overload is ambiguous.
      requires(!detail::has_multiply_interface<T, Derived>
               && !is_same<remove_cvref<T>, decay_Derived>
               && detail::has_reverse_binary_multiply<Derived, T>)
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator*(T&& other, Derived&& self) -> decltype(auto) {
      return $fwd(self).multiply($fwd(other));
   }

   // Same-type compound assignment when `multiply(rhs)` preserves `Derived`.
   [[gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator*=(Derived& self, decay_Derived const& rhs) -> Derived&
      requires(detail::has_multiply_assign<decay_Derived, decay_Derived>
               && is_constructible<Derived, decay_Derived const&>)
   {
      self = self.multiply(rhs);
      return self;
   }

   [[gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator*=(Derived& self, decay_Derived&& rhs) -> Derived&
      requires(detail::has_multiply_assign<decay_Derived, decay_Derived>
