template <typename Derived>
struct arithmetic_interface : plus_interface<Derived>,
                              minus_interface<Derived>,
                              multiply_interface<Derived>,
                              divide_interface<Derived>,
                              modulo_interface<Derived>,
                              bitwise_interface<Derived> {
 private:
   constexpr arithmetic_interface() = default;
   friend Derived;

 public:
   // No-op unary + operator for operand.
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator+(Derived const& self) {
      return self;
   }

   friend constexpr auto
   operator+(Derived&& self) {
      return self;
   }

   // Unary - operator for operand.
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator-(Derived const& self)
      requires(is_signed<Derived>)
   {
      if constexpr (detail::has_negate_interface<Derived>) {
         return self.negate();
      } else {
         // Subtract `self` from 0 to negate itself.
         return static_cast<Derived>(0) - self;
