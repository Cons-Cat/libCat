template <typename ElementType, typename ReferenceType>
class basic_atomic_accessor {
 public:
   using offset_policy = basic_atomic_accessor;
   using element_type = ElementType;
   using reference = ReferenceType;
   using data_handle_type = ElementType*;

   constexpr basic_atomic_accessor() = default;

   template <typename OtherElementType>
      requires is_convertible<OtherElementType (*)[], element_type (*)[]>
   constexpr basic_atomic_accessor(
      basic_atomic_accessor<OtherElementType, ReferenceType> other) {
      static_cast<void>(other);
   }

   constexpr auto
   access(data_handle_type p_data, __SIZE_TYPE__ index) const -> reference {
      return reference(p_data[index]);
   }

   constexpr auto
   offset(data_handle_type p_data, __SIZE_TYPE__ index) const
      -> data_handle_type {
      return p_data + index;
   }
};

template <typename ElementType>
using atomic_accessor =
   basic_atomic_accessor<ElementType, atomic<ElementType&>>;

template <typename ElementType>
using atomic_accessor_relaxed =
   basic_atomic_accessor<ElementType, atomic_ref_relaxed<ElementType>>;

template <typename ElementType>
using atomic_accessor_acq_rel =
   basic_atomic_accessor<ElementType, atomic_ref_acq_rel<ElementType>>;

template <typename ElementType>
using atomic_accessor_seq_cst =
   basic_atomic_accessor<ElementType, atomic_ref_seq_cst<ElementType>>;

