// -*- mode: c++ -*-
// vim: set ft=cpp:
#pragma once

#include <cat/arithmetic>

// `cat::atomic` is an atomic arithmetic wrapper closely based upon
// `std::atomic`.
//
// Atomic references are spelled `cat::atomic<T&>`, mirroring `cat::maybe<T&>`.
// Overflow semantics of `cat::basic_int` are supported, as is the syntax of
// its `.wrap()`, `.sat()`, etc. members. Deprecated volatile support and the
// `consume` memory order are removed.
//
// This class is also informed by the following papers:
//
// P0883R2  Atomic initialization.
// P2689R3  Bound atomic references and accessors.
// P2835R7  Expose std::atomic_ref's object address.
// P3008R6  Atomic floating-point min/max.
// P3111R8  Atomic reduction operations.
// P3181R1  Atomic stores and object lifetimes (specification only).
// P3255R2  Expose whether atomic notifying operations are lock-free.
// P3309R3  Make atomic operations `constexpr`.
// P3323R1  const-qualified types in atomic and atomic_ref.
// P3366R1  Remove deprecated atomic initialization API from C++26.
// P3860R1  atomic_ref converting constructor between cv variants.
// P3936R0  Safer atomic_ref::address (void* return).
// P4221R0  Atomic compare.
//
// Waiting on spin-polls and notifications are currently no-ops. Fences are host
// fences for now.
// TODO: This should be fixed.

namespace cat {

// NOLINTNEXTLINE
enum memory_order : int {
   relaxed = 0,
   // We don't use `consume`.
   // https://open-std.org/jtc1/sc22/wg21/docs/papers/2025/p3475r2.pdf
   acquire = 2,
   release = 3,
   acq_rel = 4,
   seq_cst = 5,
};

inline constexpr memory_order memory_order_relaxed = memory_order::relaxed;
inline constexpr memory_order memory_order_acquire = memory_order::acquire;
inline constexpr memory_order memory_order_release = memory_order::release;
inline constexpr memory_order memory_order_acq_rel = memory_order::acq_rel;
inline constexpr memory_order memory_order_seq_cst = memory_order::seq_cst;

namespace detail {
enum memory_order_modifier : unsigned int {
   mask = 0x0ffff,
   modifier_mask = 0xffff0000,
   hle_acquire = 0x10000,
   hle_release = 0x20000,
};
}  // namespace detail

constexpr auto
operator|(memory_order order, detail::memory_order_modifier modifier)
   -> memory_order {
   return static_cast<memory_order>((unsigned)order | (unsigned)modifier);
}

constexpr auto
operator&(memory_order order, detail::memory_order_modifier modifier)
   -> memory_order {
   return static_cast<memory_order>((unsigned)order & (unsigned)modifier);
}

namespace detail {
constexpr auto
cmpexch_failure_order2(memory_order order) -> memory_order {
   if (order == memory_order::acq_rel) {
      return memory_order::acquire;
   }
   if (order == memory_order::release) {
      return memory_order::relaxed;
   }
   return order;
}

constexpr auto
cmpexch_failure_order(memory_order order) -> memory_order {
   return memory_order(
      cmpexch_failure_order2(order & detail::memory_order_modifier::mask)
      | detail::memory_order_modifier(
         order & detail::memory_order_modifier::modifier_mask));
}

constexpr void
assert_load_order(memory_order order) {
   memory_order test_value = order & detail::mask;

   assert(test_value != memory_order::release);
   assert(test_value != memory_order::acq_rel);
}

constexpr void
assert_store_order(memory_order order) {
   memory_order test_value = order & detail::mask;

   assert(test_value != memory_order::acquire);
   assert(test_value != memory_order::acq_rel);
}

inline void
atomic_pause_once() {
   __builtin_ia32_pause();
}

// P3008R6 helpers. These mirror IEEE 754-2019 minimum/maximum and
// minimumNumber/maximumNumber, with `-0 < +0` and quiet-NaN handling per the
// paper's recommended semantics.
template <typename Fp>
constexpr auto
fp_maximum(Fp a, Fp b) -> Fp {
   auto const ra = make_raw_arithmetic(a);
   auto const rb = make_raw_arithmetic(b);
   if (__builtin_isnan(ra)) {
      return a;
   }
   if (__builtin_isnan(rb)) {
      return b;
   }
   if (ra < rb) {
      return b;
   }
   if (rb < ra) {
      return a;
   }
   return __builtin_signbit(rb) ? a : b;
}

template <typename Fp>
constexpr auto
fp_minimum(Fp a, Fp b) -> Fp {
   auto const ra = make_raw_arithmetic(a);
   auto const rb = make_raw_arithmetic(b);
   if (__builtin_isnan(ra)) {
      return a;
   }
   if (__builtin_isnan(rb)) {
      return b;
   }
   if (ra < rb) {
      return a;
   }
   if (rb < ra) {
      return b;
   }
   return __builtin_signbit(ra) ? a : b;
}

template <typename Fp>
constexpr auto
fp_maximum_num(Fp a, Fp b) -> Fp {
   auto const ra = make_raw_arithmetic(a);
   auto const rb = make_raw_arithmetic(b);
   if (__builtin_isnan(ra)) {
      return b;
   }
   if (__builtin_isnan(rb)) {
      return a;
   }
   if (ra < rb) {
      return b;
   }
   if (rb < ra) {
      return a;
   }
   return __builtin_signbit(rb) ? a : b;
}

template <typename Fp>
constexpr auto
fp_minimum_num(Fp a, Fp b) -> Fp {
   auto const ra = make_raw_arithmetic(a);
   auto const rb = make_raw_arithmetic(b);
   if (__builtin_isnan(ra)) {
      return b;
   }
   if (__builtin_isnan(rb)) {
      return a;
   }
   if (ra < rb) {
      return a;
   }
   if (rb < ra) {
      return b;
   }
   return __builtin_signbit(ra) ? a : b;
}

template <typename T>
consteval auto
atomic_default_overflow_policy() -> overflow_policies {
   if constexpr (requires { T::policy; }) {
      if constexpr (T::policy == overflow_policies::saturate) {
         return overflow_policies::saturate;
      }
   }
   return overflow_policies::wrap;
}

template <typename AtomicQual, overflow_policies overflow_policy>
class atomic_overflow_reference {
 public:
   using value_type = remove_cvref<AtomicQual>::value_type;
   using raw_value = remove_cvref<AtomicQual>::raw_value;

   constexpr explicit atomic_overflow_reference(AtomicQual& atomic)
       : m_p_atomic(__builtin_addressof(atomic)) {
   }

   constexpr auto
   fetch_add(auto operand, memory_order order = memory_order::seq_cst)
      -> value_type
      requires(!is_same<value_type, bool>)
   {
      if constexpr (overflow_policy == overflow_policies::saturate) {
         return fetch_update<false>(
            [operand](value_type observed) {
               return add_saturating(observed, operand);
            },
            order);
      } else {
         return value_type(__atomic_fetch_add(
            m_p_atomic->storage_ptr(), make_raw_arithmetic(operand), order));
      }
   }

   constexpr auto
   fetch_sub(auto operand, memory_order order = memory_order::seq_cst)
      -> value_type
      requires(!is_same<value_type, bool>)
   {
      if constexpr (overflow_policy == overflow_policies::saturate) {
         return fetch_update<false>(
            [operand](value_type observed) {
               return sub_saturating(observed, operand);
            },
            order);
      } else {
         return value_type(__atomic_fetch_sub(
            m_p_atomic->storage_ptr(), make_raw_arithmetic(operand), order));
      }
   }

   constexpr auto
   add_fetch(auto operand, memory_order order = memory_order::seq_cst)
      -> value_type
      requires(!is_same<value_type, bool>)
   {
      if constexpr (overflow_policy == overflow_policies::saturate) {
         return fetch_update<true>(
            [operand](value_type observed) {
               return add_saturating(observed, operand);
            },
            order);
      } else {
         return value_type(__atomic_add_fetch(
            m_p_atomic->storage_ptr(), make_raw_arithmetic(operand), order));
      }
   }

   constexpr auto
   sub_fetch(auto operand, memory_order order = memory_order::seq_cst)
      -> value_type
      requires(!is_same<value_type, bool>)
   {
      if constexpr (overflow_policy == overflow_policies::saturate) {
         return fetch_update<true>(
            [operand](value_type observed) {
               return sub_saturating(observed, operand);
            },
            order);
      } else {
         return value_type(__atomic_sub_fetch(
            m_p_atomic->storage_ptr(), make_raw_arithmetic(operand), order));
      }
   }

   constexpr auto
   operator++(int) -> value_type
      requires(!is_same<value_type, bool>)
   {
      return fetch_add(1);
   }

   constexpr auto
   operator++() -> value_type
      requires(!is_same<value_type, bool>)
   {
      return add_fetch(1);
   }

   constexpr auto
   operator--(int) -> value_type
      requires(!is_same<value_type, bool>)
   {
      return fetch_sub(1);
   }

   constexpr auto
   operator--() -> value_type
      requires(!is_same<value_type, bool>)
   {
      return sub_fetch(1);
   }

   constexpr auto
   operator+=(auto operand) -> value_type
      requires(!is_same<value_type, bool>)
   {
      return add_fetch(operand);
   }

   constexpr auto
   operator-=(auto operand) -> value_type
      requires(!is_same<value_type, bool>)
   {
      return sub_fetch(operand);
   }

   // P3111R8 reduction operations on the wrap/saturate overflow view. These
   // forward to the corresponding `fetch_*`, discarding the prior value.
   constexpr void
   store_add(auto operand, memory_order order = memory_order::seq_cst)
      requires(!is_same<value_type, bool>)
   {
      if !consteval {
         detail::assert_store_order(order);
      }
      (void)fetch_add(operand, order);
   }

   constexpr void
   store_sub(auto operand, memory_order order = memory_order::seq_cst)
      requires(!is_same<value_type, bool>)
   {
      if !consteval {
         detail::assert_store_order(order);
      }
      (void)fetch_sub(operand, order);
   }

 private:
   template <bool return_new, typename Operation>
   constexpr auto
   fetch_update(Operation&& operation, memory_order order) -> value_type {
      memory_order failure_order = cmpexch_failure_order(order);
      value_type observed = m_p_atomic->load(failure_order);
      for (;;) {
         value_type desired = operation(observed);
         value_type expected = observed;
         if (m_p_atomic->compare_exchange_weak(expected, desired, order,
                                               failure_order)) {
            if constexpr (return_new) {
               return desired;
            } else {
               return observed;
            }
         }
         observed = expected;
      }
   }

   static constexpr auto
   add_saturating(value_type observed, auto operand) -> value_type {
      raw_value const raw_observed = make_raw_arithmetic(observed);
      raw_value const raw_operand =
         static_cast<raw_value>(make_raw_arithmetic(operand));
      return value_type(cat::sat_add(raw_observed, raw_operand));
   }

   static constexpr auto
   sub_saturating(value_type observed, auto operand) -> value_type {
      raw_value const raw_observed = make_raw_arithmetic(observed);
      raw_value const raw_operand =
         static_cast<raw_value>(make_raw_arithmetic(operand));
      return value_type(cat::sat_sub(raw_observed, raw_operand));
   }

   AtomicQual* m_p_atomic;
};
}  // namespace detail

// TODO: Add CUDA-style scoped atomics when libCat has non-host memory scopes.
constexpr void
thread_fence(memory_order order) {
   __atomic_thread_fence(order);
}

constexpr void
signal_fence(memory_order order) {
   __atomic_signal_fence(order);
}

class atomic_flag {
 public:
   static constexpr bool is_always_lock_free =
      __atomic_always_lock_free(sizeof(bool), nullptr);

   // P3255R2: libCat's `notify_*` are no-ops (trivially lock-free) and `wait`
   // is a `pause`-based spin (signal-safe).
   static constexpr bool notify_is_always_lock_free = true;
   static constexpr bool wait_is_always_signal_safe = true;

   constexpr atomic_flag() = default;
   ~atomic_flag() = default;
   atomic_flag(atomic_flag const&) = delete;
   auto
   operator=(atomic_flag const&) -> atomic_flag& = delete;

   [[nodiscard]]
   auto
   test(memory_order order = memory_order::seq_cst) const -> bool {
      detail::assert_load_order(order);

      return __atomic_load_n(&m_value, order);
   }

   auto
   test_and_set(memory_order order = memory_order::seq_cst) -> bool {
      return __atomic_test_and_set(&m_value, order);
   }

   void
   clear(memory_order order = memory_order::seq_cst) {
      detail::assert_store_order(order);

      __atomic_clear(&m_value, order);
   }

   void
   wait(bool old, memory_order order = memory_order::seq_cst) const {
      while (test(order) == old) {
         detail::atomic_pause_once();
      }
   }

   void
   notify_one() {
   }

   void
   notify_all() {
   }

   [[nodiscard]]
   static constexpr auto
   notify_is_lock_free() noexcept -> bool {
      return notify_is_always_lock_free;
   }

   [[nodiscard]]
   static constexpr auto
   wait_is_signal_safe() noexcept -> bool {
      return wait_is_always_signal_safe;
   }

 private:
   bool m_value = false;
};

static_assert(atomic_flag::is_always_lock_free);

template <typename T>
class atomic;

template <typename T>
   requires(!is_reference<T> && !is_const<T> && !is_volatile<T>)
class atomic<T> {
 public:
   using value_type = T;
   using raw_value = raw_arithmetic_type<T>;
   using difference_type =
      conditional<is_pointer<T>, __PTRDIFF_TYPE__, value_type>;

   static constexpr unsigned long
      required_alignment = sizeof(raw_value) > alignof(T) ? sizeof(raw_value)
                                                          : alignof(T);
   static constexpr bool is_always_lock_free =
      __atomic_always_lock_free(sizeof(raw_value), nullptr);

   // P3255R2: libCat's `notify_*` are no-ops (trivially lock-free) and `wait`
   // is a `pause`-based spin (signal-safe).
   static constexpr bool notify_is_always_lock_free = true;
   static constexpr bool wait_is_always_signal_safe = true;

   constexpr atomic() = default;

   // Construction has no racing observer, so initialize storage directly.
   constexpr atomic(T desired) : m_value(desired) {
   }

   ~atomic() = default;
   atomic(atomic const&) = delete;
   auto
   operator=(atomic const&) -> atomic& = delete;

   constexpr
   operator T() const {
      return load();
   }

   constexpr auto
   operator=(T operand) -> T {
      store(operand);
      return operand;
   }

   constexpr auto
   undef() & -> detail::atomic_overflow_reference<atomic,
                                                  overflow_policies::undefined>
      requires(!is_same<T, bool>)
   {
      return detail::atomic_overflow_reference<atomic,
                                               overflow_policies::undefined>(
         *this);
   }

   constexpr auto
   wrap() & -> detail::atomic_overflow_reference<atomic,
                                                 overflow_policies::wrap>
      requires(!is_same<T, bool>)
   {
      return detail::atomic_overflow_reference<atomic, overflow_policies::wrap>(
         *this);
   }

   constexpr auto
   sat() & -> detail::atomic_overflow_reference<atomic,
                                                overflow_policies::saturate>
      requires(is_integral<T> && !is_same<T, bool>)
   {
      return detail::atomic_overflow_reference<atomic,
                                               overflow_policies::saturate>(
         *this);
   }

   // TODO: This should handle all boolean types, not just `bool`.
   constexpr auto
   operator++(int) -> T
      requires(!is_same<T, bool>)
   {
      return fetch_add(1);
   }

   constexpr auto
   operator++() -> T
      requires(!is_same<T, bool>)
   {
      return add_fetch(1);
   }

   constexpr auto
   operator--(int) -> T
      requires(!is_same<T, bool>)
   {
      return fetch_sub(1);
   }

   constexpr auto
   operator--() -> T
      requires(!is_same<T, bool>)
   {
      return sub_fetch(1);
   }

   constexpr auto
   operator+=(auto operand) -> T
      requires(!is_same<T, bool>)
   {
      return add_fetch(operand);
   }

   constexpr auto
   operator-=(auto operand) -> T
      requires(!is_same<T, bool>)
   {
      return sub_fetch(operand);
   }

   constexpr auto
   operator&=(auto operand) -> T
      requires(is_integral<T> && !is_same<T, bool>)
   {
      return T(__atomic_and_fetch(storage_ptr(), make_raw_arithmetic(operand),
                                  int(memory_order::seq_cst)));
   }

   constexpr auto
   operator|=(auto operand) -> T
      requires(is_integral<T> && !is_same<T, bool>)
   {
      return T(__atomic_or_fetch(storage_ptr(), make_raw_arithmetic(operand),
                                 int(memory_order::seq_cst)));
   }

   constexpr auto
   operator^=(auto operand) -> T
      requires(is_integral<T> && !is_same<T, bool>)
   {
      return T(__atomic_xor_fetch(storage_ptr(), make_raw_arithmetic(operand),
                                  int(memory_order::seq_cst)));
   }

   [[nodiscard]]
   auto
   is_lock_free() const -> bool {
      return __atomic_is_lock_free(sizeof(raw_value), storage_ptr());
   }

   [[nodiscard]]
   static constexpr auto
   notify_is_lock_free() noexcept -> bool {
      return notify_is_always_lock_free;
   }

   [[nodiscard]]
   static constexpr auto
   wait_is_signal_safe() noexcept -> bool {
      return wait_is_always_signal_safe;
   }

   constexpr void
   store(auto storing, memory_order operand = memory_order::seq_cst) {
      if consteval {
         m_value = T(storing);
         return;
      }

      memory_order test_value = operand & detail::mask;

      assert(test_value != memory_order::acquire);
      assert(test_value != memory_order::acq_rel);

      __atomic_store_n(storage_ptr(), make_raw_arithmetic(storing), operand);
   }

   constexpr auto
   load(memory_order order = memory_order::seq_cst) const -> T {
      if consteval {
         return m_value;
      }

      memory_order test_value = order & detail::mask;

      assert(test_value != memory_order::release);
      assert(test_value != memory_order::acq_rel);

      return T(__atomic_load_n(storage_ptr(), order));
   }

   constexpr auto
   exchange(T operand, memory_order order = memory_order::seq_cst) -> T {
      if consteval {
         T observed = m_value;
         m_value = operand;
         return observed;
      }

      return T(__atomic_exchange_n(storage_ptr(), make_raw_arithmetic(operand),
                                   order));
   }

   constexpr auto
   compare_exchange_weak(T& operand, T success_value,
                         memory_order success_order, memory_order failure_order)
      -> bool {
      if consteval {
         if (m_value == operand) {
            m_value = success_value;
            return true;
         }
         operand = m_value;
         return false;
      }

      memory_order test_value1 = success_order & detail::mask;
      memory_order test_value2 = failure_order & detail::mask;

      assert(test_value2 != memory_order::release);
      assert(test_value2 != memory_order::acq_rel);
      assert(test_value2 <= test_value1);

      raw_value observed = make_raw_arithmetic(operand);
      // The `_n` builtin requires integer or pointer storage; floating-point
      // storage uses the generic `__atomic_compare_exchange` form that does
      // bytewise comparison of the value representation.
      if constexpr (is_floating_point<T>) {
         raw_value desired = make_raw_arithmetic(success_value);
         bool const result =
            __atomic_compare_exchange(storage_ptr(), &observed, &desired, 1,
                                      success_order, failure_order);
         operand = T(observed);
         return result;
      } else {
         raw_value const desired = make_raw_arithmetic(success_value);
         bool const result = __atomic_compare_exchange_n(
            storage_ptr(), &observed, desired, 1, success_order, failure_order);
         operand = T(observed);
         return result;
      }
   }

   constexpr auto
   compare_exchange_weak(T& operand, T success_value,
                         memory_order order = memory_order::seq_cst) -> bool {
      return compare_exchange_weak(operand, success_value, order,
                                   detail::cmpexch_failure_order(order));
   }

   constexpr auto
   compare_exchange_strong(T& operand, T success_value,
                           memory_order success_order,
                           memory_order failure_order) -> bool {
      if consteval {
         if (m_value == operand) {
            m_value = success_value;
            return true;
         }
         operand = m_value;
         return false;
      }

      memory_order test_value1 = success_order & detail::mask;
      memory_order test_value2 = failure_order & detail::mask;

      assert(test_value2 != memory_order::release);
      assert(test_value2 != memory_order::acq_rel);
      assert(test_value2 <= test_value1);

      raw_value observed = make_raw_arithmetic(operand);
      if constexpr (is_floating_point<T>) {
         raw_value desired = make_raw_arithmetic(success_value);
         bool const result =
            __atomic_compare_exchange(storage_ptr(), &observed, &desired, 0,
                                      success_order, failure_order);
         operand = T(observed);
         return result;
      } else {
         raw_value const desired = make_raw_arithmetic(success_value);
         bool const result = __atomic_compare_exchange_n(
            storage_ptr(), &observed, desired, 0, success_order, failure_order);
         operand = T(observed);
         return result;
      }
   }

   constexpr auto
   compare_exchange_strong(T& operand, T success_value,
                           memory_order order = memory_order::seq_cst) -> bool {
      return compare_exchange_strong(operand, success_value, order,
                                     detail::cmpexch_failure_order(order));
   }

   // P4221R0: bitwise compare without writing back. The two-order overload
   // mirrors `compare_exchange_strong` requirements on success and failure
   // orderings, both restricted to load orderings.
   [[nodiscard]]
   constexpr auto
   compare(T expected, memory_order success, memory_order failure) const
      -> bool {
      if consteval {
         return m_value == expected;
      }

      detail::assert_load_order(success);
      detail::assert_load_order(failure);
      assert((failure & detail::mask) <= (success & detail::mask));

      raw_value const observed = __atomic_load_n(storage_ptr(), success);
      return observed == make_raw_arithmetic(expected);
   }

   [[nodiscard]]
   constexpr auto
   compare(T expected, memory_order order = memory_order::seq_cst) const
      -> bool {
      return compare(expected, order, order);
   }

   // P4221R0: like `compare`, but writes the observed value into `expected`
   // on failure (matching `compare_exchange_strong`'s failure path).
   constexpr auto
   compare_load(T& expected, memory_order success, memory_order failure) const
      -> bool {
      if consteval {
         if (m_value == expected) {
            return true;
         }
         expected = m_value;
         return false;
      }

      detail::assert_load_order(success);
      detail::assert_load_order(failure);
      assert((failure & detail::mask) <= (success & detail::mask));

      raw_value const observed = __atomic_load_n(storage_ptr(), success);
      if (observed == make_raw_arithmetic(expected)) {
         return true;
      }
      expected = T(observed);
      return false;
   }

   constexpr auto
   compare_load(T& expected, memory_order order = memory_order::seq_cst) const
      -> bool {
      return compare_load(expected, order, order);
   }

   constexpr auto
   fetch_add(auto operand, memory_order order = memory_order::seq_cst) -> T
      requires(!is_same<T, bool>)
   {
      if consteval {
         T observed = m_value;
         m_value = T(observed + operand);
         return observed;
      }

      if constexpr (detail::atomic_default_overflow_policy<T>()
                    == overflow_policies::saturate) {
         return sat().fetch_add(operand, order);
      } else if constexpr (is_pointer<T> || is_floating_point<T>) {
         return fetch_update(
            [operand](T observed) {
               return observed + operand;
            },
            order);
      } else {
         return T(__atomic_fetch_add(storage_ptr(),
                                     make_raw_arithmetic(operand), order));
      }
   }

   constexpr auto
   fetch_sub(auto operand, memory_order order = memory_order::seq_cst) -> T
      requires(!is_same<T, bool>)
   {
      if consteval {
         T observed = m_value;
         m_value = T(observed - operand);
         return observed;
      }

      if constexpr (detail::atomic_default_overflow_policy<T>()
                    == overflow_policies::saturate) {
         return sat().fetch_sub(operand, order);
      } else if constexpr (is_pointer<T> || is_floating_point<T>) {
         return fetch_update(
            [operand](T observed) {
               return observed - operand;
            },
            order);
      } else {
         return T(__atomic_fetch_sub(storage_ptr(),
                                     make_raw_arithmetic(operand), order));
      }
   }

   constexpr auto
   fetch_and(auto operand, memory_order order = memory_order::seq_cst) -> T
      requires(is_integral<T> && !is_same<T, bool>)
   {
      if consteval {
         T observed = m_value;
         m_value =
            T(make_raw_arithmetic(observed) & make_raw_arithmetic(operand));
         return observed;
      }

      return T(__atomic_fetch_and(storage_ptr(), make_raw_arithmetic(operand),
                                  order));
   }

   constexpr auto
   fetch_or(auto operand, memory_order order = memory_order::seq_cst) -> T
      requires(is_integral<T> && !is_same<T, bool>)
   {
      if consteval {
         T observed = m_value;
         m_value =
            T(make_raw_arithmetic(observed) | make_raw_arithmetic(operand));
         return observed;
      }

      return T(
         __atomic_fetch_or(storage_ptr(), make_raw_arithmetic(operand), order));
   }

   constexpr auto
   fetch_xor(auto operand, memory_order order = memory_order::seq_cst) -> T
      requires(is_integral<T> && !is_same<T, bool>)
   {
      if consteval {
         T observed = m_value;
         m_value =
            T(make_raw_arithmetic(observed) ^ make_raw_arithmetic(operand));
         return observed;
      }

      return T(__atomic_fetch_xor(storage_ptr(), make_raw_arithmetic(operand),
                                  order));
   }

   constexpr auto
   fetch_max(T operand, memory_order order = memory_order::seq_cst) -> T
      requires(!is_same<T, bool>)
   {
      return fetch_update(
         [operand](T observed) {
            return observed < operand ? operand : observed;
         },
         order);
   }

   constexpr auto
   fetch_min(T operand, memory_order order = memory_order::seq_cst) -> T
      requires(!is_same<T, bool>)
   {
      return fetch_update(
         [operand](T observed) {
            return operand < observed ? operand : observed;
         },
         order);
   }

   // P3008R6 IEEE 754-2019 floating-point min/max. `fmaximum`/`fminimum`
   // propagate NaN, while `*_num` treat NaN as missing data. All four order
   // `-0 < +0`.
   constexpr auto
   fetch_fmaximum(T operand, memory_order order = memory_order::seq_cst) -> T
      requires(is_floating_point<T>)
   {
      return fetch_update(
         [operand](T observed) {
            return detail::fp_maximum(observed, operand);
         },
         order);
   }

   constexpr auto
   fetch_fminimum(T operand, memory_order order = memory_order::seq_cst) -> T
      requires(is_floating_point<T>)
   {
      return fetch_update(
         [operand](T observed) {
            return detail::fp_minimum(observed, operand);
         },
         order);
   }

   constexpr auto
   fetch_fmaximum_num(T operand, memory_order order = memory_order::seq_cst)
      -> T
      requires(is_floating_point<T>)
   {
      return fetch_update(
         [operand](T observed) {
            return detail::fp_maximum_num(observed, operand);
         },
         order);
   }

   constexpr auto
   fetch_fminimum_num(T operand, memory_order order = memory_order::seq_cst)
      -> T
      requires(is_floating_point<T>)
   {
      return fetch_update(
         [operand](T observed) {
            return detail::fp_minimum_num(observed, operand);
         },
         order);
   }

   // P3111R8 atomic reduction operations: same effect as `fetch_<key>` but
   // return `void`, allowing hardware that supports "far" or destination-less
   // RMW (PTX `red`, Arm `STADD`, x86 RAO `AADD/AAND/AOR/AXOR`) to skip the
   // read-back. The conservative implementation forwards to `fetch_<key>`.
   constexpr void
   store_add(auto operand, memory_order order = memory_order::seq_cst)
      requires(!is_same<T, bool>)
   {
      if !consteval {
         detail::assert_store_order(order);
      }
      (void)fetch_add(operand, order);
   }

   constexpr void
   store_sub(auto operand, memory_order order = memory_order::seq_cst)
      requires(!is_same<T, bool>)
   {
      if !consteval {
         detail::assert_store_order(order);
      }
      (void)fetch_sub(operand, order);
   }

   constexpr void
   store_and(auto operand, memory_order order = memory_order::seq_cst)
      requires(is_integral<T> && !is_same<T, bool>)
   {
      if !consteval {
         detail::assert_store_order(order);
      }
      (void)fetch_and(operand, order);
   }

   constexpr void
   store_or(auto operand, memory_order order = memory_order::seq_cst)
      requires(is_integral<T> && !is_same<T, bool>)
   {
      if !consteval {
         detail::assert_store_order(order);
      }
      (void)fetch_or(operand, order);
   }

   constexpr void
   store_xor(auto operand, memory_order order = memory_order::seq_cst)
      requires(is_integral<T> && !is_same<T, bool>)
   {
      if !consteval {
         detail::assert_store_order(order);
      }
      (void)fetch_xor(operand, order);
   }

   constexpr void
   store_max(T operand, memory_order order = memory_order::seq_cst)
      requires(!is_same<T, bool>)
   {
      if !consteval {
         detail::assert_store_order(order);
      }
      (void)fetch_max(operand, order);
   }

   constexpr void
   store_min(T operand, memory_order order = memory_order::seq_cst)
      requires(!is_same<T, bool>)
   {
      if !consteval {
         detail::assert_store_order(order);
      }
      (void)fetch_min(operand, order);
   }

   constexpr void
   wait(T old, memory_order order = memory_order::seq_cst) const {
      detail::assert_load_order(order);
      while (load(order) == old) {
         detail::atomic_pause_once();
      }
   }

   constexpr void
   notify_one() {
   }

   constexpr void
   notify_all() {
   }

 private:
   template <typename AtomicQual, overflow_policies overflow_policy>
   friend class detail::atomic_overflow_reference;

   constexpr auto
   add_fetch(auto operand, memory_order order = memory_order::seq_cst) -> T
      requires(!is_same<T, bool>)
   {
      if constexpr (detail::atomic_default_overflow_policy<T>()
                    == overflow_policies::saturate) {
         return sat().add_fetch(operand, order);
      } else if constexpr (is_pointer<T> || is_floating_point<T>) {
         T observed = fetch_add(operand, order);
         return observed + operand;
      } else {
         return T(__atomic_add_fetch(storage_ptr(),
                                     make_raw_arithmetic(operand), order));
      }
   }

   constexpr auto
   sub_fetch(auto operand, memory_order order = memory_order::seq_cst) -> T
      requires(!is_same<T, bool>)
   {
      if constexpr (detail::atomic_default_overflow_policy<T>()
                    == overflow_policies::saturate) {
         return sat().sub_fetch(operand, order);
      } else if constexpr (is_pointer<T> || is_floating_point<T>) {
         T observed = fetch_sub(operand, order);
         return observed - operand;
      } else {
         return T(__atomic_sub_fetch(storage_ptr(),
                                     make_raw_arithmetic(operand), order));
      }
   }

   constexpr auto
   fetch_update(auto&& operation, memory_order order) -> T {
      if consteval {
         T observed = m_value;
         m_value = operation(observed);
         return observed;
      }

      memory_order failure_order = detail::cmpexch_failure_order(order);
      T observed = load(failure_order);
      for (;;) {
         T desired = operation(observed);
         T expected = observed;
         if (compare_exchange_weak(expected, desired, order, failure_order)) {
            return observed;
         }
         observed = expected;
      }
   }

   [[nodiscard]]
   constexpr auto
   storage_ptr(this auto& self) {
      if constexpr (requires { self.m_value.raw; }) {
         return &self.m_value.raw;
      } else {
         return &self.m_value;
      }
   }

   alignas(required_alignment) T m_value{};
};

// P3323R1: `atomic<T&>` supports `const T`. Only load, wait, compare, and
// read-only introspection are available.
template <typename T>
   requires(!is_volatile<T>)
class atomic<T&> {
 public:
   using value_type = remove_cv<T>;
   using raw_value = raw_arithmetic_type<T>;
   using difference_type =
      conditional<is_pointer<T>, __PTRDIFF_TYPE__, value_type>;

   static constexpr unsigned long
      required_alignment = sizeof(raw_value) > alignof(T) ? sizeof(raw_value)
                                                          : alignof(T);
   static constexpr bool is_always_lock_free =
      __atomic_always_lock_free(sizeof(raw_value), nullptr);

   // P3255R2: libCat's `notify_*` are no-ops (trivially lock-free) and `wait`
   // is a `pause`-based spin (signal-safe).
   static constexpr bool notify_is_always_lock_free = true;
   static constexpr bool wait_is_always_signal_safe = true;

   atomic() = delete;
   ~atomic() = default;

   constexpr atomic(T& value [[clang::lifetimebound]]) : m_p_value(&value) {
   }

   atomic(atomic const&) = default;

   // P3860R1: cv-conversion constructor. Allows e.g. `atomic<int const&>` to
   // be constructed from `atomic<int&>` when the underlying pointer conversion
   // is well-formed (cv-similar types with a valid `U* -> T*` conversion).
   template <typename U>
      requires(is_same<remove_cv<U>, remove_cv<T>> && is_convertible<U*, T*>)
   constexpr atomic(atomic<U&> const& other) noexcept
       : m_p_value(static_cast<T*>(other.m_p_value)) {
   }

   auto
   operator=(atomic const&)
      -> atomic& = delete ("`cat::atomic` references cannot be rebound!");

   constexpr
   operator value_type() const {
      return load();
   }

   constexpr auto
   operator=(value_type operand) -> value_type
      requires(!is_const<T>)
   {
      store(operand);
      return operand;
   }

   constexpr auto
   undef() & -> detail::atomic_overflow_reference<atomic,
                                                  overflow_policies::undefined>
      requires(!is_const<T> && !is_same<T, bool>)
   {
      return detail::atomic_overflow_reference<atomic,
                                               overflow_policies::undefined>(
         *this);
   }

   constexpr auto
   wrap() & -> detail::atomic_overflow_reference<atomic,
                                                 overflow_policies::wrap>
      requires(!is_const<T> && !is_same<T, bool>)
   {
      return detail::atomic_overflow_reference<atomic, overflow_policies::wrap>(
         *this);
   }

   constexpr auto
   sat() & -> detail::atomic_overflow_reference<atomic,
                                                overflow_policies::saturate>
      requires(!is_const<T> && is_integral<T> && !is_same<T, bool>)
   {
      return detail::atomic_overflow_reference<atomic,
                                               overflow_policies::saturate>(
         *this);
   }

   constexpr auto
   operator++(int) -> T
      requires(!is_const<T> && !is_same<T, bool>)
   {
      return fetch_add(1);
   }

   constexpr auto
   operator++() -> T
      requires(!is_const<T> && !is_same<T, bool>)
   {
      return add_fetch(1);
   }

   constexpr auto
   operator--(int) -> T
      requires(!is_const<T> && !is_same<T, bool>)
   {
      return fetch_sub(1);
   }

   constexpr auto
   operator--() -> T
      requires(!is_const<T> && !is_same<T, bool>)
   {
      return sub_fetch(1);
   }

   constexpr auto
   operator+=(auto operand) -> T
      requires(!is_const<T> && !is_same<T, bool>)
   {
      return add_fetch(operand);
   }

   constexpr auto
   operator-=(auto operand) -> T
      requires(!is_const<T> && !is_same<T, bool>)
   {
      return sub_fetch(operand);
   }

   constexpr auto
   operator&=(auto operand) -> T
      requires(!is_const<T> && is_integral<T> && !is_same<T, bool>)
   {
      return T(__atomic_and_fetch(storage_ptr(), make_raw_arithmetic(operand),
                                  int(memory_order::seq_cst)));
   }

   constexpr auto
   operator|=(auto operand) -> T
      requires(!is_const<T> && is_integral<T> && !is_same<T, bool>)
   {
      return T(__atomic_or_fetch(storage_ptr(), make_raw_arithmetic(operand),
                                 int(memory_order::seq_cst)));
   }

   constexpr auto
   operator^=(auto operand) -> T
      requires(!is_const<T> && is_integral<T> && !is_same<T, bool>)
   {
      return T(__atomic_xor_fetch(storage_ptr(), make_raw_arithmetic(operand),
                                  int(memory_order::seq_cst)));
   }

   [[nodiscard]]
   auto
   is_lock_free() const -> bool {
      return __atomic_is_lock_free(sizeof(raw_value), storage_ptr());
   }

   [[nodiscard]]
   static constexpr auto
   notify_is_lock_free() noexcept -> bool {
      return notify_is_always_lock_free;
   }

   [[nodiscard]]
   static constexpr auto
   wait_is_signal_safe() noexcept -> bool {
      return wait_is_always_signal_safe;
   }

   // P2835R7 (introduced) + P3936R0 (return type fixed to `void*`): expose
   // the referenced object's address for hashing, contention-aware data
   // structures, and indexing without leaking a typed pointer that would
   // tempt non-atomic access. P3323R1 propagates cv to the return type.
   [[nodiscard]]
   constexpr auto
   address() const noexcept -> copy_cv_from<T, void>* {
      return m_p_value;
   }

   constexpr void
   store(auto storing, memory_order operand = memory_order::seq_cst)
      requires(!is_const<T>)
   {
      if consteval {
         *m_p_value = T(storing);
         return;
      }

      memory_order test_value = operand & detail::mask;

      assert(test_value != memory_order::acquire);
      assert(test_value != memory_order::acq_rel);

      __atomic_store_n(storage_ptr(), make_raw_arithmetic(storing), operand);
   }

   constexpr auto
   load(memory_order order = memory_order::seq_cst) const -> value_type {
      if consteval {
         return *m_p_value;
      }

      memory_order test_value = order & detail::mask;

      assert(test_value != memory_order::release);
      assert(test_value != memory_order::acq_rel);

      return value_type(__atomic_load_n(storage_ptr(), order));
   }

   constexpr auto
   exchange(value_type operand, memory_order order = memory_order::seq_cst)
      -> value_type
      requires(!is_const<T>)
   {
      if consteval {
         value_type observed = *m_p_value;
         *m_p_value = operand;
         return observed;
      }

      return value_type(__atomic_exchange_n(
         storage_ptr(), make_raw_arithmetic(operand), order));
   }

   constexpr auto
   compare_exchange_weak(value_type& operand, value_type success_value,
                         memory_order success_order, memory_order failure_order)
      -> bool
      requires(!is_const<T>)
   {
      if consteval {
         if (*m_p_value == operand) {
            *m_p_value = success_value;
            return true;
         }
         operand = *m_p_value;
         return false;
      }

      memory_order test_value1 = success_order & detail::mask;
      memory_order test_value2 = failure_order & detail::mask;

      assert(test_value2 != memory_order::release);
      assert(test_value2 != memory_order::acq_rel);
      assert(test_value2 <= test_value1);

      raw_value observed = make_raw_arithmetic(operand);
      if constexpr (is_floating_point<T>) {
         raw_value desired = make_raw_arithmetic(success_value);
         bool const result =
            __atomic_compare_exchange(storage_ptr(), &observed, &desired, 1,
                                      success_order, failure_order);
         operand = value_type(observed);
         return result;
      } else {
         raw_value const desired = make_raw_arithmetic(success_value);
         bool const result = __atomic_compare_exchange_n(
            storage_ptr(), &observed, desired, 1, success_order, failure_order);
         operand = value_type(observed);
         return result;
      }
   }

   constexpr auto
   compare_exchange_weak(value_type& operand, value_type success_value,
                         memory_order order = memory_order::seq_cst) -> bool
      requires(!is_const<T>)
   {
      return compare_exchange_weak(operand, success_value, order,
                                   detail::cmpexch_failure_order(order));
   }

   constexpr auto
   compare_exchange_strong(value_type& operand, value_type success_value,
                           memory_order success_order,
                           memory_order failure_order) -> bool
      requires(!is_const<T>)
   {
      if consteval {
         if (*m_p_value == operand) {
            *m_p_value = success_value;
            return true;
         }
         operand = *m_p_value;
         return false;
      }

      memory_order test_value1 = success_order & detail::mask;
      memory_order test_value2 = failure_order & detail::mask;

      assert(test_value2 != memory_order::release);
      assert(test_value2 != memory_order::acq_rel);
      assert(test_value2 <= test_value1);

      raw_value observed = make_raw_arithmetic(operand);
      if constexpr (is_floating_point<T>) {
         raw_value desired = make_raw_arithmetic(success_value);
         bool const result =
            __atomic_compare_exchange(storage_ptr(), &observed, &desired, 0,
                                      success_order, failure_order);
         operand = value_type(observed);
         return result;
      } else {
         raw_value const desired = make_raw_arithmetic(success_value);
         bool const result = __atomic_compare_exchange_n(
            storage_ptr(), &observed, desired, 0, success_order, failure_order);
         operand = value_type(observed);
         return result;
      }
   }

   constexpr auto
   compare_exchange_strong(value_type& operand, value_type success_value,
                           memory_order order = memory_order::seq_cst) -> bool
      requires(!is_const<T>)
   {
      return compare_exchange_strong(operand, success_value, order,
                                     detail::cmpexch_failure_order(order));
   }

   // P4221R0: bitwise compare without writing back. Matches the requirements
   // of `compare_exchange_strong` minus the write, restricted to load
   // orderings on both success and failure paths.
   [[nodiscard]]
   constexpr auto
   compare(value_type expected, memory_order success,
           memory_order failure) const -> bool {
      if consteval {
         return *m_p_value == expected;
      }

      detail::assert_load_order(success);
      detail::assert_load_order(failure);
      assert((failure & detail::mask) <= (success & detail::mask));

      raw_value const observed = __atomic_load_n(storage_ptr(), success);
      return observed == make_raw_arithmetic(expected);
   }

   [[nodiscard]]
   constexpr auto
   compare(value_type expected,
           memory_order order = memory_order::seq_cst) const -> bool {
      return compare(expected, order, order);
   }

   // P4221R0: like `compare`, but writes the observed value into `expected`
   // on failure (matching `compare_exchange_strong`'s failure path).
   constexpr auto
   compare_load(value_type& expected, memory_order success,
                memory_order failure) const -> bool {
      if consteval {
         if (*m_p_value == expected) {
            return true;
         }
         expected = *m_p_value;
         return false;
      }

      detail::assert_load_order(success);
      detail::assert_load_order(failure);
      assert((failure & detail::mask) <= (success & detail::mask));

      raw_value const observed = __atomic_load_n(storage_ptr(), success);
      if (observed == make_raw_arithmetic(expected)) {
         return true;
      }
      expected = value_type(observed);
      return false;
   }

   constexpr auto
   compare_load(value_type& expected,
                memory_order order = memory_order::seq_cst) const -> bool {
      return compare_load(expected, order, order);
   }

   constexpr auto
   fetch_add(auto operand, memory_order order = memory_order::seq_cst) -> T
      requires(!is_const<T> && !is_same<T, bool>)
   {
      if consteval {
         T observed = *m_p_value;
         *m_p_value = T(observed + operand);
         return observed;
      }

      if constexpr (detail::atomic_default_overflow_policy<T>()
                    == overflow_policies::saturate) {
         return sat().fetch_add(operand, order);
      } else if constexpr (is_pointer<T> || is_floating_point<T>) {
         return fetch_update(
            [operand](T observed) {
               return observed + operand;
            },
            order);
      } else {
         return T(__atomic_fetch_add(storage_ptr(),
                                     make_raw_arithmetic(operand), order));
      }
   }

   constexpr auto
   fetch_sub(auto operand, memory_order order = memory_order::seq_cst) -> T
      requires(!is_const<T> && !is_same<T, bool>)
   {
      if consteval {
         T observed = *m_p_value;
         *m_p_value = T(observed - operand);
         return observed;
      }

      if constexpr (detail::atomic_default_overflow_policy<T>()
                    == overflow_policies::saturate) {
         return sat().fetch_sub(operand, order);
      } else if constexpr (is_pointer<T> || is_floating_point<T>) {
         return fetch_update(
            [operand](T observed) {
               return observed - operand;
            },
            order);
      } else {
         return T(__atomic_fetch_sub(storage_ptr(),
                                     make_raw_arithmetic(operand), order));
      }
   }

   constexpr auto
   fetch_and(auto operand, memory_order order = memory_order::seq_cst) -> T
      requires(!is_const<T> && is_integral<T> && !is_same<T, bool>)
   {
      if consteval {
         T observed = *m_p_value;
         *m_p_value =
            T(make_raw_arithmetic(observed) & make_raw_arithmetic(operand));
         return observed;
      }

      return T(__atomic_fetch_and(storage_ptr(), make_raw_arithmetic(operand),
                                  order));
   }

   constexpr auto
   fetch_or(auto operand, memory_order order = memory_order::seq_cst) -> T
      requires(!is_const<T> && is_integral<T> && !is_same<T, bool>)
   {
      if consteval {
         T observed = *m_p_value;
         *m_p_value =
            T(make_raw_arithmetic(observed) | make_raw_arithmetic(operand));
         return observed;
      }

      return T(
         __atomic_fetch_or(storage_ptr(), make_raw_arithmetic(operand), order));
   }

   constexpr auto
   fetch_xor(auto operand, memory_order order = memory_order::seq_cst) -> T
      requires(!is_const<T> && is_integral<T> && !is_same<T, bool>)
   {
      if consteval {
         T observed = *m_p_value;
         *m_p_value =
            T(make_raw_arithmetic(observed) ^ make_raw_arithmetic(operand));
         return observed;
      }

      return T(__atomic_fetch_xor(storage_ptr(), make_raw_arithmetic(operand),
                                  order));
   }

   constexpr auto
   fetch_max(T operand, memory_order order = memory_order::seq_cst) -> T
      requires(!is_const<T> && !is_same<T, bool>)
   {
      return fetch_update(
         [operand](T observed) {
            return observed < operand ? operand : observed;
         },
         order);
   }

   constexpr auto
   fetch_min(T operand, memory_order order = memory_order::seq_cst) -> T
      requires(!is_const<T> && !is_same<T, bool>)
   {
      return fetch_update(
         [operand](T observed) {
            return operand < observed ? operand : observed;
         },
         order);
   }

   // P3008R6 IEEE 754-2019 floating-point min/max. See the primary template
   // for notes.
   constexpr auto
   fetch_fmaximum(T operand, memory_order order = memory_order::seq_cst) -> T
      requires(!is_const<T> && is_floating_point<T>)
   {
      return fetch_update(
         [operand](T observed) {
            return detail::fp_maximum(observed, operand);
         },
         order);
   }

   constexpr auto
   fetch_fminimum(T operand, memory_order order = memory_order::seq_cst) -> T
      requires(!is_const<T> && is_floating_point<T>)
   {
      return fetch_update(
         [operand](T observed) {
            return detail::fp_minimum(observed, operand);
         },
         order);
   }

   constexpr auto
   fetch_fmaximum_num(T operand, memory_order order = memory_order::seq_cst)
      -> T
      requires(!is_const<T> && is_floating_point<T>)
   {
      return fetch_update(
         [operand](T observed) {
            return detail::fp_maximum_num(observed, operand);
         },
         order);
