   // P3111R8 atomic reduction operations. See the primary template for notes.
   constexpr void
   store_add(auto operand, memory_order order = memory_order::seq_cst)
      requires(!is_const<T> && !is_same<T, bool>)
   {
      if !consteval {
         detail::assert_store_order(order);
      }
      (void)fetch_add(operand, order);
   }

   constexpr void
   store_sub(auto operand, memory_order order = memory_order::seq_cst)
      requires(!is_const<T> && !is_same<T, bool>)
   {
      if !consteval {
         detail::assert_store_order(order);
      }
      (void)fetch_sub(operand, order);
   }

   constexpr void
   store_and(auto operand, memory_order order = memory_order::seq_cst)
      requires(!is_const<T> && is_integral<T> && !is_same<T, bool>)
   {
      if !consteval {
         detail::assert_store_order(order);
      }
      (void)fetch_and(operand, order);
   }

   constexpr void
   store_or(auto operand, memory_order order = memory_order::seq_cst)
      requires(!is_const<T> && is_integral<T> && !is_same<T, bool>)
   {
      if !consteval {
         detail::assert_store_order(order);
      }
      (void)fetch_or(operand, order);
   }

   constexpr void
   store_xor(auto operand, memory_order order = memory_order::seq_cst)
      requires(!is_const<T> && is_integral<T> && !is_same<T, bool>)
   {
      if !consteval {
         detail::assert_store_order(order);
      }
      (void)fetch_xor(operand, order);
   }

   constexpr void
   store_max(T operand, memory_order order = memory_order::seq_cst)
      requires(!is_const<T> && !is_same<T, bool>)
   {
      if !consteval {
         detail::assert_store_order(order);
      }
      (void)fetch_max(operand, order);
   }

   constexpr void
   store_min(T operand, memory_order order = memory_order::seq_cst)
      requires(!is_const<T> && !is_same<T, bool>)
   {
      if !consteval {
         detail::assert_store_order(order);
      }
      (void)fetch_min(operand, order);
   }

   constexpr void
   wait(value_type old, memory_order order = memory_order::seq_cst) const {
      detail::assert_load_order(order);
      while (load(order) == old) {
         detail::atomic_pause_once();
      }
   }

   constexpr void
   notify_one() const
      requires(!is_const<T>)
   {
   }

   constexpr void
   notify_all() const
      requires(!is_const<T>)
   {
   }

 private:
   template <typename AtomicQual, overflow_policies overflow_policy>
   friend class detail::atomic_overflow_reference;

   // P3860R1 converting ctor needs access to other cv-specializations' state.
   template <typename>
   friend class atomic;

   constexpr auto
   add_fetch(auto operand, memory_order order = memory_order::seq_cst) -> T
      requires(!is_const<T> && !is_same<T, bool>)
   {
      if constexpr (detail::atomic_default_overflow_policy<T>()
                    == overflow_policies::saturate) {
         return sat().add_fetch(operand, order);
      } else if constexpr (is_pointer<T> || is_floating_point<T>) {
         T observed = fetch_add(operand, order);
         return observed + operand;
      } else {
         return T(__atomic_add_fetch(storage_ptr(),
                                     make_raw_arithmetic(operand), order));
      }
   }

   constexpr auto
   sub_fetch(auto operand, memory_order order = memory_order::seq_cst) -> T
      requires(!is_const<T> && !is_same<T, bool>)
   {
      if constexpr (detail::atomic_default_overflow_policy<T>()
                    == overflow_policies::saturate) {
         return sat().sub_fetch(operand, order);
      } else if constexpr (is_pointer<T> || is_floating_point<T>) {
         T observed = fetch_sub(operand, order);
         return observed - operand;
      } else {
         return T(__atomic_sub_fetch(storage_ptr(),
                                     make_raw_arithmetic(operand), order));
      }
   }

   constexpr auto
   fetch_update(auto&& operation, memory_order order) -> T
      requires(!is_const<T>)
   {
      if consteval {
         T observed = *m_p_value;
         *m_p_value = operation(observed);
         return observed;
      }

      memory_order failure_order = detail::cmpexch_failure_order(order);
      T observed = load(failure_order);
      for (;;) {
         T desired = operation(observed);
         T expected = observed;
         if (compare_exchange_weak(expected, desired, order, failure_order)) {
            return observed;
         }
         observed = expected;
      }
   }

   [[nodiscard]]
   constexpr auto
   storage_ptr(this auto& self) {
      if constexpr (requires { self.m_p_value->raw; }) {
         return &self.m_p_value->raw;
      } else {
         return self.m_p_value;
      }
   }

   T* m_p_value;
};

using atomic_signed_lock_free = atomic<iword>;
