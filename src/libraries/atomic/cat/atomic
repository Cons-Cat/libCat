namespace detail {
// P3323R1: `atomic_ref_bound` mirrors `atomic<T&>` const handling.
template <typename T, memory_order memory_order_value>
   requires(!is_volatile<T>)
class atomic_ref_bound {
 public:
   using value_type = remove_cv<T>;
   using raw_value = raw_arithmetic_type<T>;
   using difference_type = atomic<T&>::difference_type;

   static constexpr memory_order memory_ordering = memory_order_value;
   static constexpr unsigned long
      required_alignment = sizeof(raw_value) > alignof(T) ? sizeof(raw_value)
                                                          : alignof(T);
   static constexpr bool is_always_lock_free =
      __atomic_always_lock_free(sizeof(raw_value), nullptr);

   // P3255R2: libCat's `notify_*` are no-ops (trivially lock-free) and `wait`
   // is a `pause`-based spin (signal-safe).
   static constexpr bool notify_is_always_lock_free = true;
   static constexpr bool wait_is_always_signal_safe = true;

   explicit constexpr atomic_ref_bound(T& value [[clang::lifetimebound]])
       : m_reference(value) {
   }

   atomic_ref_bound(atomic_ref_bound const&) = default;

   // P3860R1: cv-conversion constructor between bound atomic refs of the same
   // memory ordering and cv-similar `T`.
   template <typename U>
      requires(is_same<remove_cv<U>, remove_cv<T>> && is_convertible<U*, T*>)
   constexpr atomic_ref_bound(
      atomic_ref_bound<U, memory_order_value> const& other) noexcept
       : m_reference(other.m_reference) {
   }

   auto
   operator=(atomic_ref_bound const&) -> atomic_ref_bound& = delete;

   [[nodiscard]]
   auto
   is_lock_free() const -> bool {
      return m_reference.is_lock_free();
   }

   [[nodiscard]]
   static constexpr auto
   notify_is_lock_free() noexcept -> bool {
      return notify_is_always_lock_free;
   }

   [[nodiscard]]
   static constexpr auto
   wait_is_signal_safe() noexcept -> bool {
      return wait_is_always_signal_safe;
   }

   // P2835R7 + P3936R0: see the `atomic<T&>` overload for rationale.
   // P3323R1 propagates cv to the return type.
   [[nodiscard]]
   constexpr auto
   address() const noexcept -> copy_cv_from<T, void>* {
      return m_reference.address();
   }

   constexpr void
   store(value_type desired) const
      requires(!is_const<T>)
   {
      m_reference.store(desired, store_ordering);
   }

   constexpr auto
   operator=(value_type desired) const -> value_type
      requires(!is_const<T>)
   {
      store(desired);
      return desired;
   }

   [[nodiscard]]
   constexpr auto
   load() const -> value_type {
      return m_reference.load(load_ordering);
   }

   constexpr
   operator value_type() const {
      return load();
   }

   constexpr auto
   exchange(value_type desired) const -> value_type
      requires(!is_const<T>)
   {
      return m_reference.exchange(desired, memory_ordering);
   }

   constexpr auto
   compare_exchange_weak(value_type& expected, value_type desired) const -> bool
      requires(!is_const<T>)
   {
      return m_reference.compare_exchange_weak(expected, desired,
                                               memory_ordering, load_ordering);
   }

   constexpr auto
   compare_exchange_strong(value_type& expected, value_type desired) const
      -> bool
      requires(!is_const<T>)
   {
      return m_reference.compare_exchange_strong(
         expected, desired, memory_ordering, load_ordering);
   }

   // P4221R0: bitwise compare without writing back, using the bound load
   // ordering since `compare`/`compare_load` are load operations.
   [[nodiscard]]
   constexpr auto
   compare(value_type expected) const -> bool {
      return m_reference.compare(expected, load_ordering);
   }

   constexpr auto
   compare_load(value_type& expected) const -> bool {
      return m_reference.compare_load(expected, load_ordering);
   }

   constexpr auto
   fetch_add(auto operand) const -> T
      requires(!is_const<T> && !is_same<T, bool>)
   {
      if constexpr (atomic_default_overflow_policy<T>()
                    == overflow_policies::saturate) {
         return m_reference.sat().fetch_add(operand, memory_ordering);
      } else {
         return m_reference.wrap().fetch_add(operand, memory_ordering);
      }
   }

   constexpr auto
   fetch_sub(auto operand) const -> T
      requires(!is_const<T> && !is_same<T, bool>)
   {
      if constexpr (atomic_default_overflow_policy<T>()
                    == overflow_policies::saturate) {
         return m_reference.sat().fetch_sub(operand, memory_ordering);
      } else {
         return m_reference.wrap().fetch_sub(operand, memory_ordering);
      }
   }

   constexpr auto
   fetch_and(auto operand) const -> T
      requires(!is_const<T> && is_integral<T> && !is_same<T, bool>)
   {
      return m_reference.fetch_and(operand, memory_ordering);
   }

   constexpr auto
   fetch_or(auto operand) const -> T
      requires(!is_const<T> && is_integral<T> && !is_same<T, bool>)
   {
      return m_reference.fetch_or(operand, memory_ordering);
   }

   constexpr auto
   fetch_xor(auto operand) const -> T
      requires(!is_const<T> && is_integral<T> && !is_same<T, bool>)
   {
      return m_reference.fetch_xor(operand, memory_ordering);
   }

   constexpr auto
   fetch_max(T operand) const -> T
      requires(!is_const<T> && !is_same<T, bool>)
   {
      return fetch_update([operand](T observed) {
         return observed < operand ? operand : observed;
      });
   }

   constexpr auto
   fetch_min(T operand) const -> T
      requires(!is_const<T> && !is_same<T, bool>)
   {
      return fetch_update([operand](T observed) {
         return operand < observed ? operand : observed;
      });
   }

   // P3008R6 IEEE 754-2019 floating-point min/max.
   constexpr auto
   fetch_fmaximum(T operand) const -> T
      requires(!is_const<T> && is_floating_point<T>)
   {
      return fetch_update([operand](T observed) {
         return detail::fp_maximum(observed, operand);
      });
   }

   constexpr auto
   fetch_fminimum(T operand) const -> T
      requires(!is_const<T> && is_floating_point<T>)
   {
      return fetch_update([operand](T observed) {
         return detail::fp_minimum(observed, operand);
      });
   }

   constexpr auto
   fetch_fmaximum_num(T operand) const -> T
      requires(!is_const<T> && is_floating_point<T>)
   {
      return fetch_update([operand](T observed) {
         return detail::fp_maximum_num(observed, operand);
      });
   }

   constexpr auto
   fetch_fminimum_num(T operand) const -> T
      requires(!is_const<T> && is_floating_point<T>)
   {
      return fetch_update([operand](T observed) {
         return detail::fp_minimum_num(observed, operand);
      });
   }

   // P3111R8 atomic reduction operations. See the primary template for notes.
   // The bound ordering is used for stores when it is a valid store order, and
   // downgraded to `release` for `acq_rel`.
   constexpr void
   store_add(auto operand) const
      requires(!is_const<T> && !is_same<T, bool>)
   {
      (void)m_reference.fetch_add(operand, store_ordering);
   }

   constexpr void
   store_sub(auto operand) const
      requires(!is_const<T> && !is_same<T, bool>)
   {
      (void)m_reference.fetch_sub(operand, store_ordering);
   }

   constexpr void
   store_and(auto operand) const
      requires(!is_const<T> && is_integral<T> && !is_same<T, bool>)
   {
      (void)m_reference.fetch_and(operand, store_ordering);
   }

   constexpr void
   store_or(auto operand) const
      requires(!is_const<T> && is_integral<T> && !is_same<T, bool>)
   {
      (void)m_reference.fetch_or(operand, store_ordering);
   }

   constexpr void
   store_xor(auto operand) const
      requires(!is_const<T> && is_integral<T> && !is_same<T, bool>)
   {
      (void)m_reference.fetch_xor(operand, store_ordering);
   }

   constexpr void
   store_max(T operand) const
      requires(!is_const<T> && !is_same<T, bool>)
   {
      (void)m_reference.fetch_max(operand, store_ordering);
   }

   constexpr void
   store_min(T operand) const
      requires(!is_const<T> && !is_same<T, bool>)
   {
      (void)m_reference.fetch_min(operand, store_ordering);
   }

   constexpr auto
   operator++(int) const -> T
      requires(!is_const<T> && !is_same<T, bool>)
   {
      return fetch_add(1);
   }

   constexpr auto
   operator++() const -> T
      requires(!is_const<T> && !is_same<T, bool>)
   {
      return add_fetch(1);
   }

   constexpr auto
   operator--(int) const -> T
      requires(!is_const<T> && !is_same<T, bool>)
   {
      return fetch_sub(1);
   }

   constexpr auto
   operator--() const -> T
      requires(!is_const<T> && !is_same<T, bool>)
   {
      return sub_fetch(1);
   }

   constexpr auto
   operator+=(auto operand) const -> T
      requires(!is_const<T> && !is_same<T, bool>)
   {
      return add_fetch(operand);
   }

   constexpr auto
   operator-=(auto operand) const -> T
      requires(!is_const<T> && !is_same<T, bool>)
   {
      return sub_fetch(operand);
   }

   constexpr auto
   operator&=(auto operand) const -> T
      requires(!is_const<T> && is_integral<T> && !is_same<T, bool>)
   {
      raw_value const observed = make_raw_arithmetic(fetch_and(operand));
      raw_value const raw_operand =
         static_cast<raw_value>(make_raw_arithmetic(operand));
      return T(observed & raw_operand);
   }

   constexpr auto
   operator|=(auto operand) const -> T
      requires(!is_const<T> && is_integral<T> && !is_same<T, bool>)
   {
      raw_value const observed = make_raw_arithmetic(fetch_or(operand));
      raw_value const raw_operand =
         static_cast<raw_value>(make_raw_arithmetic(operand));
      return T(observed | raw_operand);
   }

   constexpr auto
   operator^=(auto operand) const -> T
      requires(!is_const<T> && is_integral<T> && !is_same<T, bool>)
   {
      raw_value const observed = make_raw_arithmetic(fetch_xor(operand));
      raw_value const raw_operand =
         static_cast<raw_value>(make_raw_arithmetic(operand));
      return T(observed ^ raw_operand);
   }

   constexpr void
   wait(value_type old) const {
      m_reference.wait(old, load_ordering);
   }

   constexpr void
   notify_one() const
      requires(!is_const<T>)
   {
      m_reference.notify_one();
   }

   constexpr void
   notify_all() const
      requires(!is_const<T>)
   {
      m_reference.notify_all();
   }

 private:
   // P3860R1 converting ctor needs access to other cv-specializations' state.
   template <typename U, memory_order other_order>
      requires(!is_volatile<U>)
   friend class atomic_ref_bound;

   static constexpr memory_order store_ordering =
      memory_order_value == memory_order::acq_rel ? memory_order::release
                                                  : memory_order_value;
   static constexpr memory_order load_ordering =
      memory_order_value == memory_order::acq_rel ? memory_order::acquire
                                                  : memory_order_value;

   constexpr auto
   add_fetch(auto operand) const -> T
      requires(!is_const<T>)
   {
      if constexpr (atomic_default_overflow_policy<T>()
                    == overflow_policies::saturate) {
         return m_reference.sat().add_fetch(operand, memory_ordering);
      } else {
         return m_reference.wrap().add_fetch(operand, memory_ordering);
      }
   }

   constexpr auto
   sub_fetch(auto operand) const -> T
      requires(!is_const<T>)
   {
      if constexpr (atomic_default_overflow_policy<T>()
                    == overflow_policies::saturate) {
         return m_reference.sat().sub_fetch(operand, memory_ordering);
      } else {
         return m_reference.wrap().sub_fetch(operand, memory_ordering);
      }
   }

   constexpr auto
   fetch_update(auto&& operation) const -> T
      requires(!is_const<T>)
   {
      T observed = load();
      for (;;) {
         T desired = operation(observed);
         T expected = observed;
         if (compare_exchange_weak(expected, desired)) {
            return observed;
         }
         observed = expected;
      }
   }

   mutable atomic<T&> m_reference;
};
