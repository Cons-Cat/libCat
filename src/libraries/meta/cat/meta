#include "implementations/constant_evaluate.tpp"

namespace cat {

template <typename T, typename U>
concept has_common_reference_with =
   is_same<common_reference<T, U>, common_reference<U, T>>
   && is_convertible<T, common_reference<T, U>>
   && is_convertible<U, common_reference<T, U>>;

// `boolean_testable` is adapted from the exposition-only concept
// boolean-testable.
template <typename T>
concept is_boolean_testable =
   is_convertible<T, bool> && requires(T&& b) {
                                 { !forward<T>(b) } -> is_convertible<bool>;
                              };

namespace detail {
template <typename T, typename U>
concept is_partially_ordered_with =
   requires(remove_reference<T> const& t, remove_reference<U> const& u) {
      { t < u } -> is_boolean_testable;
      { t > u } -> is_boolean_testable;
      { t <= u } -> is_boolean_testable;
      { t >= u } -> is_boolean_testable;
      { u < t } -> is_boolean_testable;
      { u > t } -> is_boolean_testable;
      { u <= t } -> is_boolean_testable;
      { u >= t } -> is_boolean_testable;
   };
}  // namespace detail

// Both orientations of `==`/`!=` must be well-formed and truthy or falsy.
template <typename T, typename U = T>
concept is_weakly_equality_comparable =
   requires(remove_reference<T> const& t, remove_reference<U> const& u) {
      { t == u } -> is_boolean_testable;
      { t != u } -> is_boolean_testable;
      { u == t } -> is_boolean_testable;
      { u != t } -> is_boolean_testable;
   };

// When `U = T`, this is the self-comparable case. With an explicit `U` it tests
// cross-type equality:
//
// Both sides must be self-comparable.
// Both must share a common reference whose own type is equality-comparable.
// Both must support weakly-equality-comparable cross-type `==`/`!=`.
//
// The common-reference refinement is what makes `T == U` transitive. Any two
// instances that compare equal to a shared common reference also compare equal
// to each other.
template <typename T, typename U = T>
concept is_equality_comparable =
   is_weakly_equality_comparable<T, T> && is_weakly_equality_comparable<U, U>
   && has_common_reference_with<remove_reference<T> const&,
                                remove_reference<U> const&>
   && is_weakly_equality_comparable<
      common_reference<remove_reference<T> const&, remove_reference<U> const&>,
      common_reference<remove_reference<T> const&, remove_reference<U> const&>>
   && is_weakly_equality_comparable<T, U>;

// clang-format off
template <typename T, typename U>
concept has_common_with =
   is_same<common_type<T, U>, common_type<U, T>>
   && requires {
         static_cast<common_type<T, U>>(declval<T>());
         static_cast<common_type<T, U>>(declval<U>());
   } && has_common_reference_with<add_lvalue_reference<T const>,
                                  add_lvalue_reference<U const>>
   && has_common_reference_with<add_lvalue_reference<common_type<T, U>>,
                                common_reference<add_lvalue_reference<T const>,
                                                 add_lvalue_reference<U const>>>;
// clang-format on

}  // namespace cat
