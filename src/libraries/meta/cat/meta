// These symbols must be declared in `std::` to enable some useful Clang
// features, such as move-semantics warnings, and preventing GDB from stepping
// into the functions. These must be declared in `<cat/meta>`, but they are
// implemented in `<cat/utility/detail/...>`.
// NOLINTBEGIN(bugprone-std-namespace-modification)
namespace std {

template <typename T>
[[nodiscard]]
constexpr auto
move(T&& input) -> cat::remove_reference<T>&& {
   return static_cast<cat::remove_reference<T>&&>(input);
}

template <typename T>
[[nodiscard, gnu::nodebug]]
constexpr auto
forward(cat::remove_reference<T>& input) -> T&& {
   return static_cast<T&&>(input);
}

template <typename T>
   requires(!cat::is_lvalue_reference<T>)
[[nodiscard, gnu::nodebug]]
constexpr auto
forward(cat::remove_reference<T>&& input) -> T&& {
   return static_cast<T&&>(input);
}

}  // namespace std

// NOLINTEND(bugprone-std-namespace-modification)

namespace cat {

// `forward()` and `move()` should be usable from within a libCat namespace.
// Only `std::` scoped versions produce Clang compiler warnings, so this allows
// `cat::move()` and `cat::forward()` to produce those warnings.
using std::forward;
using std::move;

#define $fwd(x) ::cat::forward<decltype(x)>(x)

// `is_forwarding_move` matches types that can move. Those are non-`const`
// r-value references. This is used to bind forwarding-reference parameters that
// must move. It can be used to prevent `const&&` footguns like:
//
//    type(is_forwarding_move auto&& other) {
//       // This constructor cannot shadow a copy constructor.
//    }
//
//    void func(this is_forwarding_move auto&& self) {
//       // `self` is a non-`const r-value reference.
//       // This is always a move.
//    }
//
//    auto non_danglng(this is_lvalue_reference auto&& self) -> T* {
//       // `self` is an l-value reference.
//       // This is never a move.
//    }
template <typename T>
concept is_forwarding_move = is_rvalue_reference<T&&> && !is_const<T>;

template <typename Callback, typename... Args>
concept is_invocable =
// Clang 23 does not support `__is_invocable` yet, unlike GCC.
#if __has_builtin(__is_invocable)
   __is_invocable(Callback, Args...);
#else
   requires(Callback callback, Args&&... arguments) {
      (void)__builtin_invoke($fwd(callback), $fwd(arguments)...);
   };
#endif

template <typename Callback, typename... Args>
concept is_nothrow_invocable =
// Clang 23 does not support `__is_nothrow_invocable` yet, unlike GCC.
#if __has_builtin(__is_nothrow_invocable)
   __is_nothrow_invocable(Callback, Args...);
#else
   // TODO: Properly implement `is_nothrow_invocable` for Clang.
   is_invocable<Callback, Args...>;
#endif

// Like `is_invocable`, but the result is contextually convertible to `bool`
// (return-type "boolean-testable" for predicates).
template <typename Callback, typename... Args>
concept is_predicate = requires(Callback c, Args&&... args) {
                          {
                             __builtin_invoke($fwd(c), $fwd(args)...)
                          } -> is_convertible<bool>;
                       };

// https://quuxplusone.github.io/blog/2019/02/06/arrow-proxy/
template <typename T>
struct proxy_arrow_result {
 private:
   T m_value;

 public:
   constexpr proxy_arrow_result(T const& value) noexcept(noexcept(T(value)))
       : m_value(value) {
   }

   constexpr proxy_arrow_result(T&& value) noexcept(noexcept(T($fwd(value))))
       : m_value($fwd(value)) {
   }

   [[gnu::returns_nonnull]]
   constexpr auto
   operator->() const noexcept -> T const* _Nonnull {
      return &m_value;
   }

   [[gnu::returns_nonnull]]
   constexpr auto
   operator->() noexcept -> T* _Nonnull {
      return &m_value;
   }
};

consteval auto
constant_evaluate(is_invocable auto value) -> decltype(auto);

consteval auto
constant_evaluate(auto value) -> decltype(auto);

template <typename T, typename U>
concept is_narrow_convertible = requires() { U({declval<T>()}); };

// `is_trivially_relocatable` can be overrided by partial template
// specializations, such as:
//
// template <> constexpr bool is_trivially_relocatable<MyClass> = true;
//
// Trivially-relocatable types can enable algorithms to make optimizations, such
// as relocating objects with `cat::copy_memory()` instead of `cat::move()`. By
// default, implicit-lifetime types are trivially-relocatable.
template <typename T>
inline constexpr bool is_trivially_relocatable = is_implicit_lifetime<T>;

// Remove `const` qualifier from types for the purposes of querying
// relocatability.
template <typename T>
inline constexpr bool is_trivially_relocatable<T const> =
   is_trivially_relocatable<T>;

namespace detail {

struct empty_type {};

template <typename...>
struct common_type_trait;

template <class... Args>
using common_type = common_type_trait<Args...>::type;

template <typename... Args>
struct common_type_trait
    : __builtin_common_type<common_type, identity_trait, empty_type, Args...> {
};

}

template <typename... Args>
using common_type = detail::common_type_trait<Args...>::type;

namespace detail {
// Splitting `reference_wrapper_impl<T>` out from the derived class allows us to
// easily specialize `reference_wrapper` for different types, which is used for
// algorithms.
template <typename T>
struct reference_wrapper_impl {
   T* _Nonnull m_p_target;

   constexpr reference_wrapper_impl(T& target [[clang::lifetimebound]])
       : m_p_target(__builtin_addressof(target)) {
   }

   constexpr reference_wrapper_impl(T&&) = delete (
      "Assigning an r-value to a `cat::reference_wrapper` would "
      "immediately dangle!");

   constexpr void
   rebind(T& target [[clang::lifetime_capture_by(this)]]) {
      m_p_target = __builtin_addressof(target);
   }

   constexpr void
   rebind(T&&) =
      delete ("Rebinding a `cat::reference_wrapper` to an r-value would "
              "immediately dangle!");

   [[nodiscard]]
   constexpr auto
   get() const -> T& {
      return *m_p_target;
   }

   constexpr
   operator T&() const {
      return *m_p_target;
   }
};
}  // namespace detail

template <typename T>
struct reference_wrapper : detail::reference_wrapper_impl<T> {
   using detail::reference_wrapper_impl<T>::reference_wrapper_impl;
};

template <typename T>
constexpr auto
ref(T& target [[clang::lifetimebound]]) -> reference_wrapper<T> {
   return reference_wrapper<T>{target};
}

template <typename T>
constexpr void
ref(T const&&) =
   delete ("Capturing the reference of an r-value would immediately dangle!");

template <typename T>
constexpr auto
cref(T const& target [[clang::lifetimebound]]) -> reference_wrapper<T const> {
   return reference_wrapper<T const>{target};
}

template <typename T>
constexpr void
cref(T const&&) =
   delete ("Capturing the reference of an r-value would immediately dangle!");

template <typename T>
concept is_reference_wrapper =
   is_specialization<remove_cvref<T>, reference_wrapper>;

}  // namespace cat

