namespace detail {
template <typename...>
inline constexpr bool is_signed_detail = false;

// Special-casing the `is_signed` trait for libCat arithmetic wrappers is
// necessary to prevent a circular template instantiation.
template <typename T, overflow_policies policy>
inline constexpr bool is_signed_detail<basic_int<T, policy>> =
   is_signed_detail<T>;

template <typename T, auto policy>
inline constexpr bool is_signed_detail<basic_float<T, policy>> =
   is_signed_detail<T>;

template <typename T, typename Storage, auto policy>
inline constexpr bool is_signed_detail<basic_intptr<T, Storage, policy>> =
   is_signed_detail<Storage>;

template <typename Storage>
inline constexpr bool is_signed_detail<basic_ualign<Storage>> = false;

// A signed type is less-than-comparable with a `bool` result. For example, this
// holds true for libCat arithmetic wrappers and false for `cat::simd`. We use
// `decltype(a < b)` instead of:
//    requires { { a < b } -> is_convertible<bool>; }
// because that operator lookup causes unbounded recursion on some libCat types.
template <typename T>
   requires(is_convertible<signed char, T>
            && is_convertible<decltype(declval<T>() < declval<T>()), bool>)
inline constexpr bool is_signed_detail<T> =
   constval<(T(static_cast<signed char>(-1)) < T(static_cast<signed char>(0)))>;
}  // namespace detail

