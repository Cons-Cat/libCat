#pragma once

#include <cat/allocator>
#include <cat/container>
#include <cat/iterable>
#include <cat/utility>

// TODO: Add an `intrusive_list`.

namespace cat {

namespace detail {
template <typename T>
struct list_node {
   list_node<T>* p_next_node = nullptr;
   list_node<T>* p_previous_node = nullptr;
   T storage;
};

template <typename T>
struct slist_node {
   slist_node<T>* p_next_node = nullptr;
   T storage;
};

template <typename, bool>
class list_stepanov_iterator;

template <typename T>
struct list_storage {
   using node = list_node<T>;

   detail::list_node<T>* m_p_head = nullptr;
   detail::list_node<T>* m_p_tail = nullptr;

   void
   reset() {
      m_p_head = nullptr;
      m_p_tail = nullptr;
   }
};

template <typename T>
struct slist_storage {
   using node = slist_node<T>;

   detail::slist_node<T>* m_p_head = nullptr;

   void
   reset() {
      m_p_head = nullptr;
   }
};

}  // namespace detail

template <typename T, is_allocator Allocator, bool is_doubly_linked>
class basic_list;

template <typename T, is_allocator Allocator>
using list = basic_list<T, Allocator, true>;

template <typename T, is_allocator Allocator>
using slist = basic_list<T, Allocator, false>;

template <typename T, is_allocator Allocator, bool is_doubly_linked>
class [[clang::preferred_name(list<T, Allocator>),
        clang::preferred_name(slist<T, Allocator>), gsl::Owner]]
basic_list
    : public container_interface<basic_list<T, Allocator, is_doubly_linked>, T>,
      public stepanov_iterable_interface<
         basic_list<T, Allocator, is_doubly_linked>,
         detail::list_stepanov_iterator, T, is_doubly_linked> {
   friend detail::list_stepanov_iterator<T, is_doubly_linked>;

   // Doubly-linked list factory functions:
   template <typename U, is_allocator A>
   friend auto
   make_list(A&) -> maybe<basic_list<U, A, true>>;

   template <typename U, is_allocator A, is_convertible<U> Arg,
             is_convertible<U>... Args>
   friend auto
   make_list(A&, Arg&&, Args&&...) -> maybe<basic_list<U, A, true>>;

   template <typename U, is_allocator A>
   friend auto
   make_list_filled(A&, idx, U const&) -> maybe<basic_list<U, A, true>>;

   // Singly-linked list factory functions:
   template <typename U, is_allocator A>
   friend auto
   make_slist(A&) -> maybe<basic_list<U, A, false>>;

   template <typename U, is_allocator A, is_convertible<U> Arg,
             is_convertible<U>... Args>
   friend auto
   make_slist(A&, Arg&&, Args&&...) -> maybe<basic_list<U, A, false>>;

   template <typename U, is_allocator A>
   friend auto
   make_slist_filled(A&, idx, U const&) -> maybe<basic_list<U, A, false>>;

   // TODO: Implement `slist_storage`.
   using storage_type = conditional<is_doubly_linked, detail::list_storage<T>,
                                    detail::slist_storage<T>>;
   using node_type = storage_type::node;

 public:
   using iterator = detail::list_stepanov_iterator<T, is_doubly_linked>;

   constexpr basic_list() = delete (
      "`cat::list` cannot be created without an allocator. Call "
      "`cat::make_list()` instead!");

   constexpr basic_list(basic_list&& other_list)
       : m_storage(other_list.m_storage),
         m_size(other_list.m_size),
         m_allocator(other_list.m_allocator) {
      other_list.m_storage.m_p_head = nullptr;
      if constexpr (is_doubly_linked) {
         other_list.m_storage.m_p_tail = nullptr;
      }
      other_list.m_size = 0u;
   }

   auto
   operator=(basic_list const&)
      -> basic_list& = delete ("Implicit copying of `cat::list` is forbidden. "
                               "Call `.clone() or move instead!");

   [[clang::reinitializes]]
   constexpr auto
   operator=(basic_list&& other_list) -> basic_list& {
      m_storage = other_list.m_storage;
      m_size = other_list.m_size;

      other_list.m_storage.m_p_head = nullptr;
      if constexpr (is_doubly_linked) {
         other_list.m_storage.m_p_tail = nullptr;
      }
      other_list.m_size = 0u;
      return *this;
   }

   constexpr ~basic_list() {
      clear();
   }

   constexpr void
   swap(basic_list& other) {
      assert(&m_allocator == &other.m_allocator);
      cat::swap(m_storage, other.m_storage);
      cat::swap(m_size, other.m_size);
   }

 protected:
   // Being `protected:` permits derived classes and friends to call these.

   constexpr basic_list(Allocator& allocator [[clang::lifetimebound]])
       : m_allocator(allocator) {
   }

   [[deprecated(
      "Implicit copying of `cat::list` is forbidden. Call `.clone() or move"
      "instead!")]]
   constexpr basic_list(basic_list const&) = default;

 public:
   // Get the count of elements stored in this `List`.
   [[nodiscard]]
   auto
   size() const -> idx {
      return m_size;
   }

   // Get the maximum possible count of elements stored in a `List`.
   [[nodiscard]]
   constexpr auto
   capacity() const -> idx {
      return m_size.max();
   }

   [[nodiscard]]
   auto
   front() [[clang::lifetimebound]] -> T& {
      return m_storage.m_p_head->storage;
   }

   [[nodiscard]]
   auto
   back() [[clang::lifetimebound]] -> T&
      requires(is_doubly_linked)
   {
      return m_storage.m_p_tail->storage;
   }

   [[clang::reinitializes]]
   constexpr void
   clear() {
      node_type* p_current = m_storage.m_p_head;
      while (p_current) {
         node_type* p_next = p_current->p_next_node;
         m_allocator.free(p_current);
         p_current = p_next;
      }
      m_storage.reset();
      m_size = 0u;
   }

 private:
   void
   place_initial_node(node_type& node) {
      node.p_next_node = nullptr;
      if constexpr (is_doubly_linked) {
         node.p_previous_node = nullptr;
      }
      m_storage.m_p_head = &node;
      if constexpr (is_doubly_linked) {
         m_storage.m_p_tail = &node;
      }
      m_size = 1u;
   }

   void
   place_node(iterator where, node_type& node) {
      // `.place_node()` should almost always be used for insertions in the
      // middle.
      if (where != this->begin() && where != this->end()) [[likely]] {
         // Place a node in the middle of this list.
         node.p_next_node = where.m_p_node;
         if constexpr (is_doubly_linked) {
            node.p_previous_node = where.m_p_node->p_previous_node;
         }

         node.p_next_node->p_previous_node = &node;
         if constexpr (is_doubly_linked) {
            node.p_previous_node->p_next_node = &node;
         }
      } else if (where == this->begin()) {
         // Place a node at the front of this list.
         node.p_next_node = m_storage.m_p_head;
         node.p_previous_node = nullptr;
         if constexpr (is_doubly_linked) {
            m_storage.m_p_head->p_previous_node = &node;
         }
         m_storage.m_p_head = &node;
      } else {
         // Place a node at the back of this list.
         // TODO: Consolidate this.
         if constexpr (is_doubly_linked) {
            node.p_previous_node = where.m_p_node->p_previous_node;
         }
         node.p_next_node = m_storage.m_p_tail;
         if constexpr (is_doubly_linked) {
            node.p_previous_node->p_next_node = &node;
         }
      }
      m_size++;
   }

   // Place a node at the front of this list.
   void
   place_node_front(node_type& node) {
      if (m_size > 0) [[likely]] {
         node.p_next_node = m_storage.m_p_head;
         if constexpr (is_doubly_linked) {
            node.p_previous_node = nullptr;
            node.p_next_node->p_previous_node = &node;
         }
         m_storage.m_p_head = &node;
         m_size++;
      } else {
         this->place_initial_node(node);
      }
   }

   // Place a node at the back of this list.
   void
   place_node_back(node_type& node)
      requires(is_doubly_linked)
   {
      if (m_size == 0) [[unlikely]] {
         this->place_initial_node(node);
      } else {
         node.p_next_node = nullptr;
         node.p_previous_node = m_storage.m_p_tail;
         node.p_previous_node->p_next_node = &node;
         m_storage.m_p_tail = &node;
         m_size++;
      }
   }

   template <typename U>
   auto
   append_new_node(node_type*& p_tail, U&& value) -> maybe<iterator> {
      node_type* p_node = $prop(m_allocator.template alloc<node_type>());
      p_node->p_next_node = nullptr;
      if constexpr (is_doubly_linked) {
         p_node->p_previous_node = p_tail;
      }
      p_node->storage = $fwd(value);

      if (m_size == 0u) {
         m_storage.m_p_head = p_node;
      } else {
         p_tail->p_next_node = p_node;
      }
      if constexpr (is_doubly_linked) {
         m_storage.m_p_tail = p_node;
      }
      p_tail = p_node;
      ++m_size;
      return iterator(p_node);
   }

   auto
   append_new_nodes([[maybe_unused]] node_type*& p_tail) -> maybe<void> {
      return monostate;
   }

   template <typename U, typename... Args>
   auto
   append_new_nodes(node_type*& p_tail, U&& value, Args&&... remaining)
      -> maybe<void> {
      // Previously, this was implemented by a singular multi-allocation to
      // reduce the number of allocator calls. That caused issues during
      // cleanup, when every node necessarily has its own `free()`, resulting in
      // double free errors. Now we recursively append instead.
      // TODO: We should look into this optimization again.
      $prop(this->append_new_node(p_tail, $fwd(value)));
      return this->append_new_nodes(p_tail, $fwd(remaining)...);
   }

 public:
   // Deep-copy the contents of this `list`.
   template <is_allocator NewAllocator>
   [[nodiscard]]
   auto
   clone(NewAllocator& allocator)
      -> maybe<basic_list<T, NewAllocator, is_doubly_linked>> {
      using new_list_type = basic_list<T, NewAllocator, is_doubly_linked>;
      new_list_type new_list(allocator);
      typename new_list_type::node_type* p_tail = nullptr;
      iterator it = this->begin();
      for (idx i = 0; i < m_size; ++i) {
         $prop(new_list.append_new_node(p_tail, *it));
         ++it;
      }
      return new_list;
   }

   // Allocate a node and insert it into this list before the position of
   // `where`.
   template <typename U>
      requires(is_implicitly_convertible<U, T>)
   auto
   insert(iterator where, U&& value) -> maybe<iterator> {
      node_type* p_node = $prop(m_allocator.template alloc<node_type>());
      node_type& node = *p_node;
      node.storage = $fwd(value);

      if (m_size == 0) [[unlikely]] {
         // If this list has nothing in it, `.insert()` must be special-cased.
         this->place_initial_node(node);
      } else {
         this->place_node(where, node);
      }
      return iterator(p_node);
   }

   // Allocate a node and insert it into this list before the position of
   // `where`, then construct it with arguments.
   template <typename... Args>
   auto
   emplace(iterator where, Args&&... arguments) -> maybe<iterator> {
      auto* p_node = $prop(m_allocator.template alloc<node_type>());
      node_type& node = *p_node;
      new (&node.storage) T($fwd(arguments)...);

      if (m_size == 0) [[unlikely]] {
         // If this list has nothing in it, `.emplace()` must be special-cased.
         this->place_initial_node(node);
      } else {
         this->place_node(where, node);
      }
      return iterator(p_node);
   }

   // Remove and deallocate an element from this list.
   auto
   erase(iterator where) -> iterator
      requires(is_doubly_linked)
   {
      if (m_size == 0) [[unlikely]] {
         // Prevent a segfault when the list is empty.
         return iterator(m_storage.m_p_head);
      }

      node_type& node = *where.m_p_node;
      iterator next = node.p_next_node;
      if (&node != m_storage.m_p_head && &node != m_storage.m_p_tail)
         [[likely]] {
         // Remove a node from the middle of this list.
         node.p_next_node->p_previous_node = node.p_previous_node;
         node.p_previous_node->p_next_node = node.p_next_node;
      } else if (&node == m_storage.m_p_head) {
         // Remove a node from the front of this list.
         node.p_next_node->p_previous_node = nullptr;
         m_storage.m_p_head = node.p_next_node;
      } else {
         // Remove a node from the back of this list.
         node.p_previous_node->p_next_node = nullptr;
         m_storage.m_p_tail = node.p_previous_node;
      }
      m_size.raw -= 1u;
      m_allocator.free(&node);
      return iterator(next);
   }

   void
   erase_after(is_allocator auto& allocator, iterator where) {
      node_type& node = *where.p_node;
      node_type* p_remove = node.p_next_node;
      node.p_next_node = p_remove->p_next_node;
      if constexpr (is_doubly_linked) {
         node.p_next_node->p_previous_node = &node;
      }

      allocator.free(p_remove);
   }

   // Allocate a node and insert it at the beginning of this list.
   template <typename U>
      requires(is_implicitly_convertible<U, T>)
   auto
   push_front(U const& value) -> maybe<iterator> {
      auto* p_node = $prop(m_allocator.template alloc<node_type>());
      node_type& node = *p_node;
      node.storage = static_cast<T>(value);
      this->place_node_front(node);

      return iterator(p_node);
   }

   // Allocate a node and insert it at the beginning of this list.
   template <typename... Args>
   auto
   emplace_front(Args&&... arguments) -> maybe<iterator> {
      auto* p_node = $prop(m_allocator.template alloc<node_type>());
      node_type& node = *p_node;
      new (&node.storage) T($fwd(arguments)...);
      this->place_node_front(node);

      return iterator(p_node);
   }

   // Remove an element from the front of this list.
   void
   pop_front() {
      if (m_size > 0) [[likely]] {
         node_type& node = *(this->begin().m_p_node);
         if constexpr (is_doubly_linked) {
            if (node.p_next_node != nullptr) [[likely]] {
               node.p_next_node->p_previous_node = nullptr;
            }
         }

         m_storage.m_p_head = node.p_next_node;
         m_size.raw -= 1u;
         m_allocator.free(&node);
      }

      if constexpr (is_doubly_linked) {
         if (m_size <= 1) {
            m_storage.m_p_tail = m_storage.m_p_head;
         }
      }
   }

   // TODO: rval-ref overload of `.push_back()`.

   // Allocate a node and insert it at the end of this list.
   template <typename U>
      requires(is_implicitly_convertible<U, T> && is_doubly_linked)
   auto
   push_back(U const& value) -> maybe<iterator> {
      node_type* p_node = $prop(m_allocator.template alloc<node_type>());

      p_node->storage = static_cast<T>(value);
      this->place_node_back(*p_node);

      return iterator(p_node);
   }

   // Allocate a node and insert it at the end of this list.
   template <typename... Args>
      requires(is_doubly_linked)
   auto
   emplace_back(Args&&... arguments) -> maybe<iterator> {
      auto* p_node = $prop(m_allocator.template alloc<node_type>());
      node_type& node = *p_node;
      new (&node.storage) T($fwd(arguments)...);
      this->place_node_back(node);

      return iterator(p_node);
   }

   // Remove and deallocate an element from the back of this list.
   void
   pop_back()
      requires(is_doubly_linked)
   {
      if (m_size > 0) [[likely]] {
         node_type& node = *(this->end().m_p_node);
         if (node.p_previous_node != nullptr) [[likely]] {
            node.p_previous_node->p_next_node = nullptr;
         }
         m_storage.m_p_tail = node.p_previous_node;
         m_size.raw -= 1u;
         m_allocator.free(&node);
      }
   }

   // Providing these four iterator getters generates the remaining eight
   // through the `container_interface`.
   [[nodiscard]]
   auto
   begin() -> iterator {
      return iterator(m_storage.m_p_head);
   }

   [[nodiscard]]
   auto
   end() -> iterator
      requires(is_doubly_linked)
   {
      return iterator(m_storage.m_p_tail);
   }

   [[nodiscard]]
   auto
   rbegin()
      requires(is_doubly_linked)
   {
      return cat::reverse_proxy_stepanov_iterator<iterator>{m_storage.m_p_tail};
   }

   [[nodiscard]]
   auto
   rend()
      requires(is_doubly_linked)
   {
      return cat::reverse_proxy_stepanov_iterator<iterator>{m_storage.m_p_head};
   }

   [[nodiscard]]
   auto
   rbegin() const
      requires(is_doubly_linked)
   {
      return cat::reverse_proxy_stepanov_iterator<iterator>{m_storage.m_p_tail};
   }

   [[nodiscard]]
   auto
   rend() const
      requires(is_doubly_linked)
   {
      return cat::reverse_proxy_stepanov_iterator<iterator>{m_storage.m_p_head};
   }

   template <typename Node, typename Element>
   class list_iteration_context {
      Node* m_p_node;

    public:
      using element_type = Element&;

      constexpr explicit list_iteration_context(Node* p_node)
          : m_p_node(p_node) {
      }

      list_iteration_context(list_iteration_context const&) = delete;
      list_iteration_context(list_iteration_context&&) = delete;
      auto
      operator=(list_iteration_context const&)
         -> list_iteration_context& = delete;
      auto
      operator=(list_iteration_context&&) -> list_iteration_context& = delete;

      template <typename Pred>
      constexpr auto
      run_while(Pred&& pred) -> iteration_result {
         while (m_p_node != nullptr) {
            Node* const p_node = m_p_node;
            m_p_node = m_p_node->p_next_node;
            if (!pred(p_node->storage)) {
               return iteration_result::incomplete;
            }
         }
         return iteration_result::complete;
      }
   };

   template <typename Node, typename Element>
   class list_reverse_iteration_context {
      Node* m_p_node;

    public:
      using element_type = Element&;

      constexpr explicit list_reverse_iteration_context(Node* p_node)
          : m_p_node(p_node) {
      }

      list_reverse_iteration_context(list_reverse_iteration_context const&) =
         delete;
      list_reverse_iteration_context(list_reverse_iteration_context&&) = delete;
      auto
      operator=(list_reverse_iteration_context const&)
         -> list_reverse_iteration_context& = delete;
      auto
      operator=(list_reverse_iteration_context&&)
         -> list_reverse_iteration_context& = delete;

      template <typename Pred>
      constexpr auto
      run_while(Pred&& pred) -> iteration_result {
         while (m_p_node != nullptr) {
            Node* const p_node = m_p_node;
            m_p_node = m_p_node->p_previous_node;
            if (!pred(p_node->storage)) {
               return iteration_result::incomplete;
            }
         }
         return iteration_result::complete;
      }
   };

   [[nodiscard]]
   constexpr auto
   iterate() -> list_iteration_context<node_type, T> {
      return list_iteration_context<node_type, T>{m_storage.m_p_head};
   }

   [[nodiscard]]
   constexpr auto
   iterate() const -> list_iteration_context<node_type const, T const> {
      return list_iteration_context<node_type const, T const>{
         m_storage.m_p_head,
      };
   }

   [[nodiscard]]
   constexpr auto
   reverse_iterate() -> list_reverse_iteration_context<node_type, T>
      requires(is_doubly_linked)
   {
      return list_reverse_iteration_context<node_type, T>{m_storage.m_p_tail};
   }

   [[nodiscard]]
   constexpr auto
   reverse_iterate() const
      -> list_reverse_iteration_context<node_type const, T const>
      requires(is_doubly_linked)
   {
      return list_reverse_iteration_context<node_type const, T const>{
         m_storage.m_p_tail,
      };
   }

 private:
   storage_type m_storage;
   idx m_size = 0;
   Allocator& m_allocator;
};

namespace detail {

template <typename T, bool is_doubly_linked>
class list_stepanov_iterator
    : public stepanov_iterator_interface<
         conditional<is_doubly_linked, bidirectional_iterator_tag,
                     forward_iterator_tag>,
         T> {
 public:
   using value_type = T;
   using const_value_type = T const;
   using reference = T&;
   using const_reference = T const&;

   using node_type = conditional<is_doubly_linked, list_node<T>, slist_node<T>>;

   // using container_type [[maybe_unused]] = list<T>;

   // TODO: This default constructor is deprecated due to the user-defined
   // constructor. Should this still exist?
   //    iterator(iterator const&) = default;

   list_stepanov_iterator(node_type* p_input) : m_p_node(p_input) {
   }

   auto
   increment() -> list_stepanov_iterator& {
      m_p_node = m_p_node->p_next_node;
      return *this;
   }

   auto
   decrement() -> list_stepanov_iterator&
      requires(is_doubly_linked)
   {
      m_p_node = m_p_node->p_previous_node;
      return *this;
   }

   auto
   dereference() const -> T& {
      assert(m_p_node);
      return m_p_node->storage;
   }

   auto
   equal_to(list_stepanov_iterator const& it) const -> bool {
      return it.m_p_node == m_p_node;
   }

   node_type* m_p_node;
};

}  // namespace detail

// These factory functions require access to the `protected` constructor, which
// is marked `[[deprecated]]`.
#pragma clang diagnostic push
#pragma clang diagnostic ignored "-Wdeprecated-declarations"

// Make an empty `list`.
template <typename T, is_allocator Allocator>
[[nodiscard]]
auto
make_list(Allocator& allocator [[clang::lifetimebound]])
   -> maybe<list<T, Allocator>> {
   return list<T, Allocator>(allocator);
}

// Make a `list` initialized by a pack.
template <typename T, is_allocator Allocator, is_convertible<T> U,
          is_convertible<T>... Args>
[[nodiscard]]
auto
make_list(Allocator& allocator [[clang::lifetimebound]], U&& value,
          Args&&... remaining) -> maybe<list<T, Allocator>> {
   list<T, Allocator> new_list(allocator);
   using node = detail::list_node<T>;
   node* p_tail = nullptr;

   $prop(new_list.append_new_nodes(p_tail, $fwd(value), $fwd(remaining)...));

   return new_list;
}

// Make a `list` initialized by a pack.
template <is_allocator Allocator, typename... Args>
[[nodiscard]]
auto
make_list(Allocator& allocator [[clang::lifetimebound]], Args&&... arguments) {
   using common = common_type<Args...>;
   return make_list<common>(allocator, static_cast<common>($fwd(arguments))...);
}

// Make a `list` initialized to `value`.
template <typename T, is_allocator Allocator>
[[nodiscard]]
auto
make_list_filled(Allocator& allocator [[clang::lifetimebound]], idx count,
                 T const& value) -> maybe<list<T, Allocator>> {
   list<T, Allocator> new_list(allocator);
   using node = detail::list_node<T>;
   node* p_tail = nullptr;
   for (idx i = 0u; i < count; ++i) {
      $prop(new_list.append_new_node(p_tail, value));
   }

   return new_list;
}

// Make an empty `slist`.
template <typename T, is_allocator Allocator>
[[nodiscard]]
auto
make_slist(Allocator& allocator [[clang::lifetimebound]])
   -> maybe<slist<T, Allocator>> {
   return slist<T, Allocator>(allocator);
}

// Make a `slist` initialized by a pack.
template <typename T, is_allocator Allocator, is_convertible<T> U,
          is_convertible<T>... Args>
[[nodiscard]]
auto
make_slist(Allocator& allocator [[clang::lifetimebound]], U&& value,
           Args&&... remaining) -> maybe<slist<T, Allocator>> {
   slist<T, Allocator> new_slist(allocator);
   using node = detail::slist_node<T>;
   node* p_tail = nullptr;

   $prop(new_slist.append_new_nodes(p_tail, $fwd(value), $fwd(remaining)...));

   return new_slist;
}

// Make an `slist` initialized by a pack.
template <is_allocator Allocator, typename... Args>
[[nodiscard]]
auto
make_slist(Allocator& allocator [[clang::lifetimebound]], Args&&... arguments) {
   using common = common_type<Args...>;
   return make_slist<common>(allocator,
                             static_cast<common>($fwd(arguments))...);
}

// Make an `slist` initialized to `value`.
template <typename T, is_allocator Allocator>
[[nodiscard]]
auto
make_slist_filled(Allocator& allocator [[clang::lifetimebound]], idx count,
                  T const& value) -> maybe<slist<T, Allocator>> {
   slist<T, Allocator> new_slist(allocator);
   using node = detail::slist_node<T>;
   node* p_tail = nullptr;
   for (idx i = 0u; i < count; ++i) {
      $prop(new_slist.append_new_node(p_tail, value));
   }

   return new_slist;
}

