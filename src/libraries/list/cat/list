namespace detail {

template <typename T>
class list_stepanov_iterator
    : public stepanov_iterator_interface<bidirectional_iterator_tag, T> {
 public:
   using value_type = T;
   using const_value_type = T const;
   using reference = T&;
   using const_reference = T const&;

   using node_type = list_node<T>;

   // Construct iterator from a node pointer.
   constexpr list_stepanov_iterator(node_type* _Nullable p_input)
       : m_p_node(p_input) {
   }

   // Move iterator to next node.
   constexpr auto
   increment() -> list_stepanov_iterator& {
      m_p_node = m_p_node->p_next_node;
      return *this;
   }

   // Move iterator to previous node.
   constexpr auto
   decrement() -> list_stepanov_iterator& {
      m_p_node = m_p_node->p_previous_node;
      return *this;
   }

   // Access element referenced by iterator.
   constexpr auto
   dereference() const -> T& {
      assert(m_p_node);
      return m_p_node->storage;
   }

   // Compare iterator equality by node pointer.
   constexpr auto
   equal_to(list_stepanov_iterator const& it) const -> bool {
      return it.m_p_node == m_p_node;
   }

   node_type* _Nullable m_p_node;
};

// Return true when `cat::basic_list` represents a value or is empty.
template <typename T>
constexpr auto
maybe_list_has_value(basic_list<T> const& value) -> bool {
   return value.m_storage.m_p_head != nullptr || value.m_size == 0u;
}

// Construct a nullopt-like `cat::basic_list` sentinel value.
template <typename T>
constexpr auto
maybe_list_nullopt() -> basic_list<T> {
   basic_list<T> value;
   value.m_storage.m_p_head = nullptr;
   value.m_size = 1u;
   return value;
}

