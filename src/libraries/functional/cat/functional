#pragma once

#include <cat/meta>
#include <cat/utility>

namespace cat {
   template <typename Callback, typename... Args>
requires is_invocable<Callback, Args...>
// noexcept(is_nothrow_invocable<Callback, Args...>)
constexpr auto
invoke(Callback&& callback, Args&&... arguments) noexcept(
   noexcept(__builtin_invoke(
      forward<Callback>(callback), forward<Args>(arguments)...)))
   -> decltype(__builtin_invoke(
      forward<Callback>(callback), forward<Args>(arguments)...)) {
   return __builtin_invoke(
      forward<Callback>(callback), forward<Args>(arguments)...);
}

template <typename ReturnT, typename Callback, typename... Args>
// requires is_invocable_r<ReturnT, Callback, Args...>
constexpr auto
invoke_r(Callback&& callback, Args&&... arguments) -> ReturnT
// noexcept(is_nothrow_invocable_r<ReturnT, Callback, Args...>)
{
   if constexpr (is_void<ReturnT>) {
      invoke(fwd(callback), fwd(arguments)...);
   } else {
      return invoke(fwd(callback), fwd(arguments)...);
   }
}

}  // namespace cat
