// No-op functions are provided when asan is not available.
inline void
__asan_poison_memory_region(void const volatile* _Nonnull /*unused*/,
                            uword /*unused*/) {
}

inline void
__asan_unpoison_memory_region(void const volatile* _Nonnull /*unused*/,
                              uword /*unused*/) {
