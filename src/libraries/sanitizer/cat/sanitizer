// Annotate a contiguous container's live element range. ASan poisons every
// byte outside `[p_begin, p_new_mid)` and unpoisons everything inside it,
// while reporting accesses into `[p_new_mid, p_end)` as out-of-bounds.
// `p_old_mid` is the previous live boundary so ASan can transition state
// efficiently. Used by `cat::vec` and other contiguous containers to
// distinguish live elements from raw capacity inside an allocator-owned
// buffer.
void
__sanitizer_annotate_contiguous_container(void const* _Nonnull p_begin,
                                          void const* _Nonnull p_end,
                                          void const* _Nonnull p_old_mid,
                                          void const* _Nonnull p_new_mid);

