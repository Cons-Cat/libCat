template <typename T>
[[gnu::nodebug, gnu::always_inline]]
constexpr void
poison_memory_region([[maybe_unused]] T const volatile* _Nonnull p_address,
                     [[maybe_unused]] uword size) {
#if __has_feature(address_sanitizer)
   if !consteval {
      __asan_poison_memory_region(
         reinterpret_cast<void const volatile*>(p_address), size);
   }
#endif
}

template <typename T>
[[gnu::nodebug, gnu::always_inline]]
constexpr void
unpoison_memory_region([[maybe_unused]] T const volatile* _Nonnull p_address,
                       [[maybe_unused]] uword size) {
#if __has_feature(address_sanitizer)
   if !consteval {
      __asan_unpoison_memory_region(
         reinterpret_cast<void const volatile*>(p_address), size);
   }
#endif
}

template <typename T>
[[gnu::nodebug, gnu::always_inline]]
constexpr void
annotate_contiguous_container([[maybe_unused]] T const* _Nullable p_begin,
                              [[maybe_unused]] T const* _Nullable p_end,
                              [[maybe_unused]] T const* _Nullable p_old_mid,
                              [[maybe_unused]] T const* _Nullable p_new_mid) {
#if __has_feature(address_sanitizer)
   if !consteval {
      if (p_begin != nullptr) {
         __sanitizer_annotate_contiguous_container(
            static_cast<void const*>(p_begin), static_cast<void const*>(p_end),
            static_cast<void const*>(p_old_mid),
            static_cast<void const*>(p_new_mid));
      }
   }
#endif
}

