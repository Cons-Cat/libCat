template <is_signed_integral T>
[[nodiscard]]
constexpr auto
abs(T value) -> T {
   if constexpr (sizeof(T) == 8) {
      return __builtin_labs(make_raw_arithmetic(value));
   } else {
      // `__builtin_abs()` returns `int`, so its type must be coerced to `T`.
      return T(__builtin_abs(make_raw_arithmetic(value)));
   }
}

[[nodiscard]]
constexpr auto
abs(is_unsigned_integral auto value) {
   return value;
}

template <is_floating_point T>
[[nodiscard]]
constexpr auto
abs(T value) -> T {
   // `__builtin_fabs()` returns `double`, so its type must be coerced to `T`.
   return T(__builtin_fabs(make_raw_arithmetic(value)));
}

// TODO: Support floating point here.
// `index - integral` is `signed_distance`, not `index`. Keep rounding in raw
// space so `div_ceil(idx, u)` stays `idx`.
template <typename T, is_integral U>
   requires(cat::detail::is_idx<T>)
[[nodiscard]]
constexpr auto
div_ceil(T dividend, U divisor) -> T {
   auto const dv = make_raw_arithmetic(divisor);
   return T(static_cast<typename T::raw_type>((dividend.raw + dv - 1u) / dv));
}

template <is_integral T, is_integral U>
   requires(!cat::detail::is_idx<T>)
[[nodiscard]]
constexpr auto
div_ceil(T dividend, U divisor) {
   return (dividend + divisor - 1u) / divisor;
}

