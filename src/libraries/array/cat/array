#pragma once

#include <cat/algorithm>
#include <cat/collection>
#include <cat/compare>
#include <cat/memory>

namespace cat {

// An `array` represents an array of `T` with a `constexpr` length. It stores
// its elements within itself, so this array can be constructed on the stack.
// It is random-access iterable.
template <typename T, idx length>
class [[clang::trivial_abi, gsl::Owner(T)]]
// It is not possible to make this an aggregate class while using CRTP classes.
array : public collection_interface<array<T, length>, T>,
        public random_access_iterable_interface<T> {
 public:
   // Implicit copy/move (rule of Zero), except `array()` defaulted because this
   // forwarding constructor suppresses implicit default construction
   constexpr array() = default;

   template <typename... Args>
      requires(sizeof...(Args) == length)
   constexpr array(Args&&... arguments)
       : m_data(static_cast<T>(fwd(arguments))...) {
   }

   // Lexicographic ordering and element-wise equality, matching `std::array`.
   [[nodiscard]]
   constexpr auto
   operator<=>(array const& other) const -> auto {
      return cat::lexicographical_compare_three_way(this->begin(), this->end(),
                                                    other.begin(), other.end());
   }

   [[nodiscard]]
   constexpr auto
   operator==(array const& other) const -> bool
      requires(is_equality_comparable<T>)
   {
      for (idx i; i < length; ++i) {
         if (!(m_data[i.raw] == other.m_data[i.raw])) {
            return false;
         }
      }
      return true;
   }

   template <typename U>
      requires(is_implicitly_convertible<U, T>)
   constexpr auto
   fill(U value) -> array& {
      // TODO: This `set_memory()` segfaults with optimizations enabled. Is it
      // even necessary?
      //
      // if (!is_constant_evaluated() && sizeof(T) <= 8) {
      //     // set_memory(this->storage, value, length);
      // } else {
      for (unsigned long long i = 0u; i < length; ++i) {
         this->m_data[i] = static_cast<T>(value);
      }
      // }
      return *this;
   }

   // Get the non-`const` address of this `array`'s internal array.
   [[nodiscard]]
   constexpr auto
   data() [[clang::lifetimebound]] -> T* {
      return this->m_data;
   }

   // Get the `const` address of this `array`'s internal array.
   [[nodiscard]]
   constexpr auto
   data() const [[clang::lifetimebound]] -> T const* {
      return this->m_data;
   }

   // Get the number of elements contained in this `array`.
   [[nodiscard]]
   static constexpr auto
   size() -> idx {
      return length;
   }

   template <idx i>
   constexpr auto
   get(this auto&& self [[clang::lifetimebound]]) -> decltype(auto) {
      return fwd(self).m_data[i.raw];
   }

 private:
   T m_data[length]; // NOLINT We need a raw array to implement this.
};

// Construct an `array<int, 3>` as: `array a = {0, 1, 2};`
template <typename T, typename... Args>
array(T, Args...) -> array<T, sizeof...(Args) + 1u>;

// Make a `cat::array` with a deduced `value_type`.
template <typename... Ts, idx length = sizeof...(Ts)>
[[nodiscard]]
constexpr auto
make_array(Ts&&... ts) -> array<common_type<Ts...>, length> {
   return array{static_cast<common_type<Ts...>>(ts)...};
}

// Make a `cat::array<T>`.
template <typename T, typename... Ts, idx length = sizeof...(Ts)>
[[nodiscard]]
constexpr auto
make_array(Ts&&... ts) -> array<T, length> {
   return array{static_cast<T>(ts)...};
}

// Make a `cat::array<T>` initialized with `value`.
template <idx length, typename T>
[[nodiscard]]
constexpr auto
make_array_filled(T const& value) -> array<T, length> {
   array<T, length> array;
   for (idx i; i < length; ++i) {
      array[i] = value;
   }
   return array;
}

// Analogous to the proposed `std::aggr::get` in the P2141 paper
template <idx in_index, typename T, idx length>
   requires(in_index < length)
[[nodiscard]]
constexpr auto
get(array<T, length>& a) noexcept -> T& {
   return a[in_index];
}

template <idx in_index, typename T, idx length>
   requires(in_index < length)
[[nodiscard]]
constexpr auto
get(array<T, length> const& a) noexcept -> T const& {
   return a[in_index];
}

template <idx in_index, typename T, idx length>
   requires(in_index < length)
[[nodiscard]]
constexpr auto
get(array<T, length>&& a) noexcept -> T&& {
   return cat::move(a[in_index]);
}

}  // namespace cat

// Tuple protocol: `std::tuple_size` / `tuple_element` for generic code, index
// access via `cat::get`
namespace std {

template <typename T, ::cat::idx length>
struct tuple_size<::cat::array<T, length>> : ::cat::constant<length.raw> {};

template <typename T, ::cat::idx length>
struct tuple_size<::cat::array<T, length> const>
    : tuple_size<::cat::array<T, length>> {};

template <__SIZE_TYPE__ in_index, typename T, ::cat::idx length>
struct tuple_element<in_index, ::cat::array<T, length>> {
   using type = T;
};

template <__SIZE_TYPE__ in_index, typename T, ::cat::idx length>
struct tuple_element<in_index, ::cat::array<T, length> const> {
   using type = T const;
};

template <__SIZE_TYPE__ in_index, typename T, ::cat::idx length>
struct tuple_element<in_index, ::cat::array<T, length> volatile> {
   using type = T volatile;
};

template <__SIZE_TYPE__ in_index, typename T, ::cat::idx length>
struct tuple_element<in_index, ::cat::array<T, length> const volatile> {
   using type = T const volatile;
};

}  // namespace std
