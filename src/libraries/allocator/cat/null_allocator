// -*- mode: c++ -*-
// vim: set ft=cpp:
#pragma once

#include <cat/allocator>

// TODO: Should we remove deriving from `allocator_interface` and require
// wrapping in `allocator_ref` to reduce template monomorphization?

namespace cat {

class null_allocator : public allocator_interface<null_allocator> {
 private:
   friend allocator_interface<null_allocator>;
   template <typename>
   friend class allocator_ref;

   template <typename T>
   struct null_memory_handle : detail::base_memory_handle<T> {
      // `null_allocator` always fails its allocations, so this stays
      // `nullptr` for the lifetime of the handle. It is kept to match the
      // aggregate-init shape used by `make_handle` and `access` in the
      // other allocators.
      T* _Nullable p_storage;

      // TODO: Simplify with CRTP or deducing-this.
      auto
      get() -> decltype(auto) {
         return *this;
      }

      auto
      get() const -> decltype(auto) {
         return *this;
      }
   };

 public:
   constexpr null_allocator() = default;
   constexpr null_allocator(null_allocator const&) = default;
   constexpr null_allocator(null_allocator&&) = default;

   // `null_allocator` never hands out memory, so it can claim the strongest
   // possible static alignment guarantee without ever being wrong. Use
   // `page_size` since that is the strongest alignment any allocator in the
   // library produces.
   static constexpr ualign min_alignment = page_size;

   // `null_allocator` is a global allocator with no instance state, so all
   // dispatch hooks are `static`. `cat::allocator_ref<null_allocator>` folds
   // to zero size as a result.

   // This allocation always fails.
   [[gnu::malloc, clang::ownership_returns(libcat)]]
   static auto
   allocate(idx /*unused*/) -> void* _Nullable {
      return nullptr;
   }

   // Deallocation is no-op.
   [[clang::ownership_takes(libcat, 1)]]
   static void
   deallocate(void const* _Nullable /*unused*/, idx /*unused*/) {
   }

   // Produce a handle to allocated memory.
   template <typename T>
   [[clang::ownership_holds(libcat, 1)]]
   static constexpr auto
   make_handle(T* _Nonnull p_handle_storage) -> null_memory_handle<T> {
      return null_memory_handle<T>{{}, p_handle_storage};
   }

   // Access a page(s) of virtual memory.
   template <typename T>
   [[gnu::returns_nonnull]]
   static auto
   access(null_memory_handle<T>& memory) -> T* _Nonnull {
      return memory.p_storage;
   }

   // TODO: This unconditionally returns `nullptr` instead of mirroring the
   // non-`const` overload's `memory.p_storage`. Confirm intent.
   template <typename T>
   static auto
   access(null_memory_handle<T> const& /*unused*/) -> T const* _Nullable {
      return nullptr;
   }

   // `null_allocator` never hands out memory, so it holds and manages nothing.
   [[nodiscard]]
   static auto
   bytes_used() -> idx {
      return 0u;
   }

   [[nodiscard]]
   static auto
   bytes_capacity() -> idx {
      return 0u;
   }

   // `.reset()` is a no-op provided by `allocator_interface`.
};

[[nodiscard]]
constexpr auto
make_null_allocator() -> null_allocator {
   return {};
}

}  // namespace cat
