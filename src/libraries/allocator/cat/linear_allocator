// -*- mode: c++ -*-
// vim: set ft=cpp:
#pragma once

#include <cat/allocator>

// TODO: Should we remove deriving from `allocator_interface` and require
// wrapping in `allocator_ref` to reduce template monomorphization?

namespace cat {

class linear_allocator : public allocator_interface<linear_allocator> {
 private:
   friend allocator_interface<linear_allocator>;
   friend struct dyn_allocator_friend;
   template <typename>
   friend class allocator_ref;
   // `resizable_allocator` constructs `linear_allocator` instances in place
   // over each chunk's post-header storage and therefore needs access to the
   // private `(uintptr<void>, idx)` constructor.
   template <is_allocator, is_allocator, idx, idx>
   friend class resizable_allocator;

   // Friend factory functions.
   friend constexpr auto
   make_linear_allocator(uintptr<void> p_address, idx arena_bytes)
      -> linear_allocator;

   friend constexpr auto
   make_linear_allocator(span<byte>& span [[clang::lifetimebound]])
      -> linear_allocator;

   // Initialize a `linear_allocator`. This should only be called from
   // `cat::make_linear_allocator`.
   constexpr linear_allocator(uintptr<void> p_address, idx arena_bytes)
       : m_p_arena_begin(p_address + arena_bytes), m_p_arena_end(p_address) {
      this->reset();
   }

   template <typename T>
   struct linear_memory_handle : detail::base_memory_handle<T> {
      T* _Nonnull p_storage;

      // TODO: Simplify with CRTP or deducing-this.
      auto
      get() -> decltype(auto) {
         return *this;
      }

      auto
      get() const -> decltype(auto) {
         return *this;
      }
   };

 public:
   // `linear_allocator` is move-only.
   constexpr linear_allocator(linear_allocator const&) = delete (
      "`linear_allocator` owns bump-pointer arena state that must not alias. "
      "Create allocators through `make_linear_allocator` instead of copying.");
   constexpr linear_allocator(linear_allocator&&) = default;

   // Reset the bumped pointer to the beginning of this arena.
   // NOLINTNEXTLINE
   constexpr void
   reset() {
      poison_memory_region(static_cast<void const*>(m_p_arena_end),
                           m_p_arena_begin - m_p_arena_end);
      m_p_arena_current = m_p_arena_begin;
   }

 private:
   auto
   allocation_bytes(ualign alignment, idx allocation_bytes)
      -> maybe_non_zero<idx> {
      uintptr<void> allocation =
         align_down(m_p_arena_current - allocation_bytes, alignment);

      // The allocation size is the difference between the current pointer and
      // the new pointer.
      if (allocation >= m_p_arena_end) {
         return static_cast<idx>(m_p_arena_current - allocation);
      }
      return nullopt;
   }

   // Try to allocate memory and bump the pointer down.
   [[gnu::malloc, clang::ownership_returns(libcat)]]
   auto
   allocate(idx allocation_bytes) -> void* _Nullable {
      if (m_p_arena_current - allocation_bytes >= m_p_arena_end) {
         m_p_arena_current -= allocation_bytes;
         // Return a pointer that is then used to in-place construct a `T`.
         return static_cast<void*>(m_p_arena_current);
      }
      return nullptr;
   }

   // Try to allocate memory aligned to some boundary and bump the pointer down.
   [[gnu::malloc, clang::ownership_returns(libcat)]]
   auto
   aligned_allocate(ualign alignment, idx allocation_bytes) -> void* _Nullable {
      uintptr<void> allocation =
         align_down(m_p_arena_current - allocation_bytes, alignment);

      if (allocation >= m_p_arena_end) {
         m_p_arena_current = allocation;
         // Return a pointer that is then used for in-place construction.
         return static_cast<void*>(allocation);
      }
      return nullptr;
   }

   // Try to allocate memory and bump the pointer down, and return the memory
   // with size allocated.
   auto
   aligned_allocate_feedback(ualign alignment, idx allocation_bytes)
      -> maybe_sized_allocation<void*> {
      uintptr<void> allocation =
         align_down(m_p_arena_current - allocation_bytes, alignment);

      if (allocation >= m_p_arena_end) {
         uword bytes_allocated = m_p_arena_current - allocation;
         m_p_arena_current = allocation;

         // TODO: We shouldn't require the `tuple{}` here, and it seems
         // `tuple()` form doesn't work either. Likely a `tuple` constructor
         // bug.
         return maybe_sized_allocation<void*>(tuple{
            // Return a pointer that is then used for in-place construction.
            static_cast<void*>(m_p_arena_current),
            narrow_cast<idx>(bytes_allocated).assert()});
      }
      return nullopt;
   }

   // In general, memory cannot be deallocated in a linear allocator, so this
   // function is no-op.
   [[clang::ownership_takes(libcat, 2)]]
   void
   deallocate(void const* _Nonnull /*unused*/, uword /*unused*/) {
   }

   // Address-stable in-place grow. `allocation` is the existing block (pointer
   // and its byte size). The arena is a downward-growing bump, so an in-place
   // grow would have to move the allocation's start address to a lower
   // address, and `grow` cannot signal a new pointer. Grow therefore always
   // fails and the caller is expected to fall back to allocate + copy +
   // deallocate.
   //
   // Shrink is honored in place. The released tail bytes cannot rejoin
   // the bump pool without segmenting the arena, so they stay reserved
   // until `reset()`. The allocation and its first `new_bytes` bytes remain
   // valid.
   auto
   grow(span<byte> allocation, idx new_bytes) -> maybe<void> {
      if (new_bytes <= allocation.size()) {
         return monostate;
      }
      return nullopt;
   }

   // Feedback variant of `grow`. Mirrors `grow` but reports the exact number
   // of bytes the request settled on.
   auto
   grow_feedback(span<byte> allocation, idx new_bytes) -> maybe_non_zero<idx> {
      if (!this->grow(allocation, new_bytes).has_value()) {
         return nullopt;
      }
      return new_bytes;
   }

   // Produce a handle to allocated memory.
   template <typename T>
   [[clang::ownership_holds(libcat, 2)]]
   constexpr auto
   make_handle(T* _Nonnull p_handle_storage) -> linear_memory_handle<T> {
      return linear_memory_handle<T>{{}, p_handle_storage};
   }

   // Access some memory.
   template <typename T>
   [[gnu::returns_nonnull]]
   auto
   access(linear_memory_handle<T>& memory) -> T* _Nonnull {
      return memory.p_storage;
   }

   template <typename T>
   [[gnu::returns_nonnull]]
   auto
   access(linear_memory_handle<T> const& memory) const -> T const* _Nonnull {
      return memory.p_storage;
   }

 public:
   // A bare linear allocator over a `span<byte>` has no special alignment
   // guarantee beyond the byte boundary the caller asked for.
   static constexpr ualign min_alignment = 1u;

   // NOLINTNEXTLINE
   [[nodiscard]]
   auto
   bytes_used() const -> idx {
      return static_cast<idx>(m_p_arena_begin - m_p_arena_current);
   }

   // NOLINTNEXTLINE
   [[nodiscard]]
   auto
   bytes_capacity() const -> idx {
      return static_cast<idx>(m_p_arena_begin - m_p_arena_end);
   }

   // Two linear allocators are equivalent when they govern the same arena.
   // NOLINTNEXTLINE
   [[nodiscard]]
   auto
   is_equivalent(linear_allocator const& other) const -> bool {
      return m_p_arena_begin == other.m_p_arena_begin
             && m_p_arena_end == other.m_p_arena_end;
   }

 private:
   uintptr<void> const m_p_arena_begin;
   uintptr<void> const m_p_arena_end;
   uintptr<void> m_p_arena_current = m_p_arena_begin;
};

[[nodiscard]]
constexpr auto
make_linear_allocator(uintptr<void> p_address, idx arena_bytes)
   -> linear_allocator {
   return {p_address, arena_bytes};
}

[[nodiscard]]
constexpr auto
make_linear_allocator(span<byte>& span [[clang::lifetimebound]])
   -> linear_allocator {
   return {span.data(), span.size()};
}

[[nodiscard,
  deprecated(
     "Creating a `cat::linear_allocator` with a pr-value may "
     "unintentionally leak memory. Copy an l-value `cat::span` instead.")]]
constexpr auto
make_linear_allocator(span<byte>&& span) -> linear_allocator {
   return make_linear_allocator(span);
}

}  // namespace cat
