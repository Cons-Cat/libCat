// Every allocator inherits from `allocator_interface<Self>` via CRTP.
template <typename T>
concept is_allocator = requires {
                          // `allocator_interface` contains this tag. The
                          // `is_base_of` trait compiles slowly here, so this
                          // shortcut is taken instead.
                          typename T::allocator_interface_tag;
                       };

template <typename T>
concept mem = requires(T handle) {
                 handle.is_inline_handle;
                 handle.is_multi_handle;
                 handle.size();
                 handle.raw_size();
                 handle.is_inline();
              };

// TODO: Handles' `.get()` should be only visible to allocators.
namespace detail {

// `base_memory_handle` is an opaque memory handle. allocators are to define and
// produce a memory handle type which derives from this. These handles contain
// absolutely arbitrary storage (such as a `T*`, or an `ssize` address offset).
// Handles must provide a `.get()` method to return whatever that storage is.
template <typename T>
struct base_memory_handle {
   static constexpr bool is_inline_handle = false;
   static constexpr bool is_multi_handle = false;
   // Non-inline handles have no inline buffer size.
   static constexpr idx inline_size = 0;
   using allocation_type = T;

   // Number of `T`s allocated. This is always 1 if the call is not intercepted
   // by a `multi_memory_handle`.
   [[nodiscard]]
   constexpr auto
   size() const -> idx {
      return 1u;
   }

   // If `.set_count()` is no-op if it is not intercepted by a
   // `multi_memory_handle`.
   constexpr void
   set_count(iword /*unused*/) {
   }

   // Number of bytes allocated. This is always the size of `T` if the call is
   // not intercepted by a `multi_memory_handle`.
   [[nodiscard]]
   constexpr auto
   raw_size() const -> idx {
      return sizeof(T);
   }

   // `is_inline()` always holds false if the call is not intercepted by an
   // `inline_memory_handle`.
   [[nodiscard]]
   constexpr auto
   is_inline() const -> bool {
      return false;
   }
};

// A `multi_memory_handle` wraps another memory handle for `*_multi`
// allocations. It effectively overrides `Handle`'s `.size()` and
// `.raw_size()` methods with the length of an allocated array.
template <typename Handle>
struct multi_memory_handle {
   static constexpr bool is_inline_handle = Handle::is_inline_handle;
   static constexpr bool is_multi_handle = true;
   static constexpr idx inline_size = Handle::inline_size;
   using allocation_type = Handle::allocation_type;
   Handle handle;

   // How large this allocation was, in terms of `allocation_type`.
   idx array_length;

   multi_memory_handle() = default;

   multi_memory_handle(Handle input_handle) : handle(input_handle) {
   }

   // TODO: Variadic emplace.
   constexpr void
   set_inline_storage(allocation_type value) {
      this->handle.set_inline_storage(value);
   }

   constexpr void
   set_inlined(bool inlined) {
      this->handle.set_inlined(inlined);
   }

   // Intercept a propagating call to `.set_count()`.
   constexpr void
   set_count(idx count) {
      // This conversion to `idx` is safe, because `count` is always positive.
      this->array_length = count;
   }

   // Intercept a propagating call to `.size()`.
   [[nodiscard]]
   auto
   size() const -> idx {
      return this->array_length;
   }

   // Intercept a propagating call to `.raw_size()`.
   [[nodiscard]]
   auto
   raw_size() const -> idx {
      return this->array_length * sizeof(allocation_type);
   }

   [[nodiscard]]
   constexpr auto
   is_inline() const -> bool {
      return this->handle.is_inline();
   }

   // Get the allocator-specific handle type.
   auto
   get() & -> decltype(auto) {
      return this->handle.get();
   }

   // Get the allocator-specific handle type.
   auto
   get() const& -> decltype(auto) {
      return this->handle.get();
   }

   auto
   get_inline() & -> allocation_type& {
      return this->handle.get_inline();
   }

   auto
   get_inline() const& -> allocation_type const& {
      return this->handle.get_inline();
   }
};

// An `inline_memory_handle` wraps another memory handle for `inline_*`
// allocations. It extends the storage of this handle to at least
// `inline_size_param` bytes, and if the memory allocated fits within that, it
// is stored inside the handle instead of inside an allocator. It effectively
// overrides the `.is_inline()` method of the handle that it wraps.
template <typename Handle, idx inline_size_param>
struct inline_memory_handle {
   static constexpr bool is_inline_handle = true;
   static constexpr bool is_multi_handle = Handle::is_multi_handle;
   static constexpr idx inline_size = inline_size_param;
   using allocation_type = Handle::allocation_type;

   union {
      Handle handle;
      allocation_type inline_storage;
      // Reserve `inline_size` bytes to make the size of this handle
      // predictable.
      byte empty[inline_size];
   };

   bool is_on_stack;

   // Value-initialize `handle` so the union has an active member before
   // `set_count` / other mutators run. Required for constant evaluation.
   constexpr inline_memory_handle() : handle(), is_on_stack(false) {
   }

   constexpr inline_memory_handle(Handle input_handle)
       : handle(input_handle), is_on_stack(handle.is_inline()) {
   }

   constexpr ~inline_memory_handle() {
      if (this->is_on_stack) {
         inline_storage.~allocation_type();
      }
   }

   // Intercept a propagating call to `.set_inline_storage()`.
   // TODO: Variadic emplace.
   constexpr void
   set_inline_storage(allocation_type value) {
      inline_storage = value;
   }

   // Intercept a propagating call to `.set_inlined()`.
   constexpr void
   set_inlined(bool inlined) {
      this->is_on_stack = inlined;
   }

   constexpr void
   set_count(idx count) {
      this->handle.set_count(count);
   }

   [[nodiscard]]
   auto
   size() const -> idx {
      return handle.size();
   }

   [[nodiscard]]
   auto
   raw_size() const -> idx {
      return handle.raw_size();
   }

   [[nodiscard]]
   constexpr auto
   is_inline() const -> bool {
      return this->is_on_stack;
   }

   // Get the allocator-specific handle type.
   auto
   get() & -> decltype(auto) {
      return this->handle.get();
   }

   // Get the allocator-specific handle type.
   auto
   get() const& -> decltype(auto) {
      return this->handle.get();
   }

   // Intercept calls to `.get_inline()`.
   auto
   get_inline() & -> allocation_type& {
      return inline_storage;
   }

   // Intercept calls to `.get_inline()`.
   auto
   get_inline() const& -> allocation_type const& {
      return inline_storage;
   }
};

}  // namespace detail

template <is_pointer T>
using sized_allocation = tuple<T, idx>;

namespace detail {
// Engaged whenever the allocation pointer is non-null, so any null pointer is
// the empty niche regardless of the reported byte count. This lets fallible
// sized allocations return `{nullptr, any_size}` without a separate null check.
template <is_pointer T>
constexpr auto
sized_allocation_engaged(sized_allocation<T> const& allocation) -> bool {
   return allocation.first() != nullptr;
}
}  // namespace detail

template <is_pointer T>
using maybe_sized_allocation =
   maybe<compact<sized_allocation<T>, &detail::sized_allocation_engaged<T>,
                 sized_allocation<T>{nullptr, 0u}>>;

template <typename Derived>
class allocator_interface {
 public:
   // Designates `is_allocator<T>`. Inherited by every allocator without fully
   // instantiating the base.
   using allocator_interface_tag = void;

   // Default static lower bound on allocation alignment. Concrete allocators
   // may shadow this with a higher alignment guarantee.
   static constexpr uword min_alignment = 1u;

 private:
   constexpr allocator_interface() = default;
   friend Derived;

   static constexpr bool has_allocate =
      requires(Derived& allocator) { allocator.allocate(1u); };

   static constexpr bool has_aligned_allocate =
      requires(Derived& allocator) { allocator.aligned_allocate(1u, 1u); };

   static constexpr bool has_allocation_bytes =
      requires(Derived& allocator) { allocator.allocation_bytes(1u, 1u); };

   static constexpr bool has_allocate_feedback =
      requires(Derived& allocator) { allocator.allocate_feedback(1u); };

   static constexpr bool has_aligned_allocate_feedback = requires(
      Derived& allocator) { allocator.aligned_allocate_feedback(1u, 1u); };

   static constexpr bool has_max_allocation_bytes =
      requires { Derived::max_allocation_bytes; };

   static constexpr bool has_grow =
      requires(Derived& allocator, span<byte> allocation, idx new_bytes) {
         allocator.grow(allocation, new_bytes);
      };

   static constexpr bool has_grow_feedback =
      requires(Derived& allocator, span<byte> allocation, idx new_bytes) {
         allocator.grow_feedback(allocation, new_bytes);
      };

   static constexpr bool has_reallocate =
      requires(Derived& allocator, span<byte> allocation, idx new_bytes) {
         allocator.reallocate(allocation, new_bytes);
      };

   static constexpr bool has_reallocate_feedback =
      requires(Derived& allocator, span<byte> allocation, idx new_bytes) {
         allocator.reallocate_feedback(allocation, new_bytes);
      };

   // The `calloc` family routes through these zeroed allocate hooks when the
   // allocator provides them, letting the allocator skip or minimize the
   // zero-fill (e.g. anonymous `mmap` pages are demand-zero), the same
   // optimization musl malloc's `calloc` makes.
   static constexpr bool has_allocate_zeroed =
      requires(Derived& allocator, idx allocation_bytes) {
         allocator.allocate_zeroed(allocation_bytes);
      };

   static constexpr bool has_allocate_zeroed_feedback =
      requires(Derived& allocator, idx allocation_bytes) {
         allocator.allocate_zeroed_feedback(allocation_bytes);
      };

   static constexpr bool has_aligned_allocate_zeroed =
      requires(Derived& allocator, uword alignment, idx allocation_bytes) {
         allocator.aligned_allocate_zeroed(alignment, allocation_bytes);
      };

   static constexpr bool has_aligned_allocate_zeroed_feedback =
      requires(Derived& allocator, uword alignment, idx allocation_bytes) {
         allocator.aligned_allocate_zeroed_feedback(alignment,
                                                    allocation_bytes);
      };

   // Whether the allocator exposes the zeroed allocate hook matching a given
   // alignment and feedback shape. The `calloc` family routes through it and
   // then skips its zero-fill.
   template <bool is_aligned, bool has_feedback>
   static constexpr bool has_zeroed_hook =
      is_aligned
         ? (has_feedback ? has_aligned_allocate_zeroed_feedback
                         : has_aligned_allocate_zeroed)
         : (has_feedback ? has_allocate_zeroed_feedback : has_allocate_zeroed);

   static constexpr bool has_bytes_used =
      requires(Derived const& allocator) { allocator.bytes_used(); };

   static constexpr bool has_bytes_capacity =
      requires(Derived const& allocator) { allocator.bytes_capacity(); };

   static constexpr bool has_is_equivalent =
      requires(Derived const& allocator, Derived const& other) {
         allocator.is_equivalent(other);
      };

   static constexpr bool has_name =
      requires(Derived const& allocator) { allocator.name(); };

   // `meta_alloc` flags:
   // `is_fail_safe` maps allocation failure to maybe-style results,
   // `is_aligned` selects aligned allocation entry points, `is_multiple`
   // allocates arrays (span handles) instead of one `T`, `is_zeroed` uses
   // implicit-lifetime zeroing instead of constructor args, `has_feedback`
   // returns sized byte counts when the allocator supports them. `inline_size`
   // is the inline-buffer size in bytes -- nonzero enables SBO (try the inline
   // buffer before the heap), zero disables it.
   template <typename T, bool is_fail_safe, bool is_aligned, bool is_multiple,
             bool is_zeroed, bool has_feedback, idx inline_size = 0,
             typename... Args>
      requires((!is_multiple || (sizeof...(Args) <= 0))
               // Multi-allocations must be default-constructed. Zeroed-out
               // allocations must not take constructor arguments and must use a
               // trivial object type.
               && (!is_zeroed || (sizeof...(Args) == 0))
               && (!is_zeroed || is_implicit_lifetime<T>))
   constexpr auto
   meta_alloc(uword allocation_alignment, idx allocation_count,
              Args&&... arguments);

   // Handle and return types implied by the same flags as `meta_alloc`.
   template <typename T, bool is_fail_safe, bool is_multiple, bool has_feedback,
             idx inline_size = 0>
   struct meta_alloc_alias_types;

   template <bool has_feedback>
   using meta_alloc_raw_maybe_allocation =
      conditional<has_feedback, maybe_sized_allocation<void* _Nonnull>,
                  maybe_ptr<void>>;

   template <typename T, bool is_fail_safe, bool is_aligned, bool is_multiple,
             bool is_zeroed, bool has_feedback, idx inline_size = 64u,
             typename... Args>
   [[gnu::no_sanitize_address]]
   constexpr auto
   meta_alloc_inline_stack_allocate(idx allocation_bytes, idx allocation_count,
                                    Args&&... arguments);

   [[gnu::no_sanitize_address]]
   constexpr auto
   meta_alloc_aligned_feedback(uword allocation_alignment, idx allocation_bytes)
      -> maybe_sized_allocation<void* _Nonnull>;

   [[gnu::no_sanitize_address]]
   constexpr auto
   meta_alloc_aligned(uword allocation_alignment, idx allocation_bytes)
      -> maybe_ptr<void>;

   [[gnu::no_sanitize_address]]
   constexpr auto
   meta_alloc_unaligned_feedback(uword allocation_alignment,
                                 idx allocation_bytes)
      -> maybe_sized_allocation<void* _Nonnull>;

   [[gnu::no_sanitize_address]]
   constexpr auto
   meta_alloc_unaligned(idx allocation_bytes) -> maybe_ptr<void>;

   // Finish a runtime allocation: unpoison, optionally zero, placement-new the
   // elements, and wrap into the requested return shape. When `inline_size`
   // is non-0 this is the inline-overflow path (heap-backed `inline_*` call)
   // and the result is wrapped in an `inline_memory_handle`. Otherwise the
   // raw span/pointer/sized shape is returned.
   template <typename T, bool is_fail_safe, bool is_aligned, bool is_multiple,
             bool is_zeroed, bool has_feedback, idx inline_size = 0,
             typename... Args>
   [[gnu::no_sanitize_address]]
   constexpr auto
   meta_alloc_construct(
      meta_alloc_raw_maybe_allocation<has_feedback> maybe_memory,
      idx allocation_bytes, idx allocation_count, Args&&... arguments);

 public:
   // If this allocator has pointer stability, try to allocate a `T`, and
   // provide a pointer handle.
   template <typename T, typename... Args>
      requires(is_constructible<T, Args...>)
   [[nodiscard]]
   constexpr auto
   alloc(Args&&... arguments) {
      if constexpr (alignof(T) > 1) {
         // If the alignment of `T` is greater than 1, it should have implied
         // strong alignment guarantees.
         return align_alloc<T>(alignof(T), $fwd(arguments)...);
      } else {
         return unalign_alloc<T>($fwd(arguments)...);
      }
   }

   // If this allocator has pointer stability, allocate a `T`, and provide a
   // pointer handle.
   template <typename T, typename... Args>
      requires(is_constructible<T, Args...>)
   [[nodiscard, gnu::malloc, gnu::returns_nonnull,
     clang::ownership_returns(libcat)]]
   constexpr auto
   xalloc(Args&&... arguments) -> T* _Nonnull {
      if constexpr (alignof(T) > 1) {
         // If the alignment of `T` is greater than 1, it should have implied
         // strong alignment guarantees.
         return align_xalloc<T>(alignof(T), $fwd(arguments)...);
      } else {
         return unalign_xalloc<T>($fwd(arguments)...);
      }
   }

   // If this allocator has pointer stability, try to allocate an array of `T`,
   // and provide a pointer handle.
   template <typename T>
   [[nodiscard]]
   constexpr auto
   alloc_multi(idx count) {
      if constexpr (alignof(T) > 1) {
         // If the alignment of `T` is greater than 1, it should have implied
         // strong alignment guarantees.
         return align_alloc_multi<T>(alignof(T), count);
      } else {
         return unalign_alloc_multi<T>(count);
      }
   }

   // If this allocator has pointer stability, allocate an array of `T`, and
   // provide a pointer handle.
   template <typename T>
   [[nodiscard, clang::malloc_span]]
   constexpr auto
   xalloc_multi(idx count) -> span<T> {
      if constexpr (alignof(T) > 1) {
         // If the alignment of `T` is greater than 1, it should have implied
         // strong alignment guarantees.
         return align_xalloc_multi<T>(alignof(T), count);
      } else {
         return unalign_xalloc_multi<T>(count);
      }
   }

   // If this allocator has pointer stability, try to allocate a `T` with an
   // alignment guarantee, and provide a pointer handle.
   template <typename T, typename... Args>
      requires(is_constructible<T, Args...>)
   [[nodiscard]]
   constexpr auto
   align_alloc(uword alignment, Args&&... arguments) {
      return meta_alloc<T, true, true, false, false, false>(alignment, 1u,
                                                            $fwd(arguments)...);
   }

   // If this allocator has pointer stability, allocate a `T` with an alignment
   // guarantee, and provide a pointer handle.
   template <typename T, typename... Args>
      requires(is_constructible<T, Args...>)
   [[nodiscard, gnu::malloc, gnu::returns_nonnull,
     clang::ownership_returns(libcat)]]
   constexpr auto
   align_xalloc(uword alignment, Args&&... arguments) -> T* _Nonnull {
      return meta_alloc<T, false, true, false, false, false>(
         alignment, 1u, $fwd(arguments)...);
   }

   // If this allocator has pointer stability, try to allocate a `T` with no
   // alignment guarantee, and provide a pointer handle.
   template <typename T, typename... Args>
      requires(is_constructible<T, Args...>)
   [[nodiscard]]
   constexpr auto
   unalign_alloc(Args&&... arguments) {
      return meta_alloc<T, true, false, false, false, false>(
         1u, 1u, $fwd(arguments)...);
   }

   // If this allocator has pointer stability, allocate a `T` with no alignment
   // guarantee, and provide a pointer handle.
   template <typename T, typename... Args>
      requires(is_constructible<T, Args...>)
   [[nodiscard, gnu::malloc, gnu::returns_nonnull,
     clang::ownership_returns(libcat)]]
   constexpr auto
   unalign_xalloc(Args&&... arguments) -> T* _Nonnull {
      return meta_alloc<T, false, false, false, false, false>(
         1u, 1u, $fwd(arguments)...);
   }

   // If this allocator has pointer stability, try to allocate an array of `T`
   // with an alignment guarantee, and provide a pointer handle.
   template <typename T>
   [[nodiscard]]
   constexpr auto
   align_alloc_multi(uword alignment, idx count) {
      return meta_alloc<T, true, true, true, false, false>(alignment, count);
   }

   // If this allocator has pointer stability, allocate an array of `T` with an
   // alignment guarantee, and provide a pointer handle.
   template <typename T>
   [[nodiscard, clang::malloc_span]]
   constexpr auto
   align_xalloc_multi(uword alignment, idx count) -> span<T> {
      return meta_alloc<T, false, true, true, false, false>(alignment, count);
   }

   // If this allocator has pointer stability, try to allocate an array of `T`
   // with no alignment guarantee, and provide a pointer handle.
   template <typename T>
   [[nodiscard]]
   constexpr auto
   unalign_alloc_multi(idx count) {
      return meta_alloc<T, true, false, true, false, false>(1u, count);
   }

   // If this allocator has pointer stability, allocate an array of `T` with no
   // alignment guarantee, and provide a pointer handle.
   template <typename T>
   [[nodiscard, clang::malloc_span]]
   constexpr auto
   unalign_xalloc_multi(idx count) -> span<T> {
      return meta_alloc<T, false, false, true, false, false>(1u, count);
   }

   // Try to allocate a small-size optimized `T`. `inline_size` is the
   // inline-buffer size; defaults to `64u`.
   template <typename T, idx inline_size = 64u, typename... Args>
      requires(is_constructible<T, Args...>)
   [[nodiscard]]
   constexpr auto
   inline_alloc(Args&&... arguments) {
      if constexpr (alignof(T) > 1) {
         // If the alignment of `T` is greater than 1, it should have implied
         // strong alignment guarantees.
         return inline_align_alloc<T, inline_size>(alignof(T),
                                                   $fwd(arguments)...);
      } else {
         return inline_unalign_alloc<T, inline_size>($fwd(arguments)...);
      }
   }

   // Allocate a small-size optimized `T`.
   template <typename T, idx inline_size = 64u, typename... Args>
      requires(is_constructible<T, Args...>)
   [[nodiscard]]
   constexpr auto
   inline_xalloc(Args&&... arguments) {
      if constexpr (alignof(T) > 1) {
         // If the alignment of `T` is greater than 1, it should have implied
         // strong alignment guarantees.
         return inline_align_xalloc<T, inline_size>(alignof(T),
                                                    $fwd(arguments)...);
      } else {
         return inline_unalign_xalloc<T, inline_size>($fwd(arguments)...);
      }
   }

   // Try to allocate a small-size optimized array of `T`.
   template <typename T, idx inline_size = 64u>
   [[nodiscard]]
   constexpr auto
   inline_alloc_multi(idx count) {
      if constexpr (alignof(T) > 1) {
         // If the alignment of `T` is greater than 1, it should have implied
         // strong alignment guarantees.
         return inline_align_alloc_multi<T, inline_size>(alignof(T), count);
      } else {
         return inline_unalign_alloc_multi<T, inline_size>(count);
      }
   }

   // Allocate a small-size optimized array of `T`.
   template <typename T, idx inline_size = 64u>
   [[nodiscard]]
   constexpr auto
   inline_xalloc_multi(idx count) {
      if constexpr (alignof(T) > 1) {
         // If the alignment of `T` is greater than 1, it should have implied
         // strong alignment guarantees.
         return inline_align_xalloc_multi<T, inline_size>(alignof(T), count);
      } else {
         return inline_unalign_xalloc_multi<T, inline_size>(count);
      }
   }

   // Try to allocate a small-size optimized `T` with an alignment guarantee.
   template <typename T, idx inline_size = 64u, typename... Args>
   [[nodiscard]]
   constexpr auto
   inline_align_alloc(uword alignment, Args&&... arguments) {
      return meta_alloc<T, true, true, false, false, false, inline_size>(
         alignment, 1u, $fwd(arguments)...);
   }

   // Allocate a small-size optimized `T` with an alignment guarantee.
   template <typename T, idx inline_size = 64u, typename... Args>
   [[nodiscard]]
   constexpr auto
   inline_align_xalloc(uword alignment, Args&&... arguments) {
      return meta_alloc<T, false, true, false, false, false, inline_size>(
         alignment, 1u, $fwd(arguments)...);
   }

   // Try to allocate a small-size optimized `T` with no alignment guarantee.
   template <typename T, idx inline_size = 64u, typename... Args>
   [[nodiscard]]
   constexpr auto
   inline_unalign_alloc(Args&&... arguments) {
      return meta_alloc<T, true, false, false, false, false, inline_size>(
         1u, 1u, $fwd(arguments)...);
   }

   // Allocate a small-size optimized `T` with no alignment guarantee.
   template <typename T, idx inline_size = 64u, typename... Args>
   [[nodiscard]]
   constexpr auto
   inline_unalign_xalloc(Args&&... arguments) {
      return meta_alloc<T, false, false, false, false, false, inline_size>(
         1u, 1u, $fwd(arguments)...);
   }

   // Try to allocate a small-size optimized array of `T` with an alignment
   // guarantee.
   template <typename T, idx inline_size = 64u>
   [[nodiscard]]
   constexpr auto
   inline_align_alloc_multi(uword alignment, idx count) {
      return meta_alloc<T, true, true, true, false, false, inline_size>(
         alignment, count);
   }

   // Allocate a small-size optimized array of `T` with an alignment guarantee.
   template <typename T, idx inline_size = 64u>
   [[nodiscard]]
   constexpr auto
   inline_align_xalloc_multi(uword alignment, idx count) {
      return meta_alloc<T, false, true, true, false, false, inline_size>(
         alignment, count);
   }

   // Try to allocate a small-size optimized array of `T` with no alignment
   // guarantee.
   template <typename T, idx inline_size = 64u>
   [[nodiscard]]
   constexpr auto
   inline_unalign_alloc_multi(idx count) {
      return meta_alloc<T, true, false, true, false, false, inline_size>(1u,
                                                                         count);
   }

   // Allocate a small-size optimized array of `T` with no alignment guarantee.
   template <typename T, idx inline_size = 64u>
   [[nodiscard]]
   constexpr auto
   inline_unalign_xalloc_multi(idx count) {
      return meta_alloc<T, false, false, true, false, false, inline_size>(
         1u, count);
   }

   // Try to get the number of bytes that allocating a `T` would reserve.
   template <typename T>
   [[nodiscard]]
   constexpr auto
   nalloc() -> maybe_non_zero<idx> {
      return align_nalloc<T>(alignof(T));
   }

   // Get the number of bytes that allocating a `T` would reserve.
   template <typename T>
   [[nodiscard]]
   constexpr auto
   xnalloc() -> idx {
      return align_xnalloc<T>(alignof(T));
   }

   // Try to get the number of bytes that allocating an array of `T` would
   // reserve.
