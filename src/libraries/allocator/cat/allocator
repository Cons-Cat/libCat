   // `meta_alloc` default-constructs `T` in `*p_destination`. Replace that
   // object by relocating from `source` into the same address without relying
   // on move-assignment into live storage.
   template <typename T>
   constexpr void
   relocate_disjoint_reserved_storage(T* _Nonnull p_destination, T& source) {
      if !consteval {
         uword const extent = sizeof(T);
         assert(!is_memory_overlapping(__builtin_addressof(source), extent,
                                       p_destination, extent));
      }
      if constexpr (is_trivially_relocatable<T>) {
         copy_memory(__builtin_addressof(source), p_destination, sizeof(T));
      } else {
         p_destination->~T();
         ::new (static_cast<void*>(p_destination)) T{move(source)};
      }
   }

   // Take a generic allocation method, invoke it on an allocator with a generic
   // memory handle, and free the original handle if that allocation suceeded.
   template <auto alloc_function, bool is_fail_safe, bool has_feedback,
             bool pass_old_to_alloc = true, typename... Args>
   constexpr auto
   meta_realloc(auto& allocator, auto& old_handle, Args&&... arguments) {
      auto allocation = [&]() -> decltype(auto) {
         if constexpr (pass_old_to_alloc) {
            return (allocator.*alloc_function)(
               // Possible alignment and/or count arguments.
               $fwd(arguments)...,
               // Move the data from this handle.
               move(this->get(old_handle)));
         } else {
            return (allocator.*alloc_function)($fwd(arguments)...);
         }
      }();

      if constexpr (is_fail_safe) {
         if (!allocation.has_value()) {
            return allocation;
         }
      }

      if constexpr (!pass_old_to_alloc) {
         if constexpr (mem<decltype(old_handle)>) {
            if constexpr (is_fail_safe) {
               if constexpr (has_feedback) {
                  this->relocate_inline_handle(old_handle,
                                               allocation.value().first());
               } else {
                  this->relocate_inline_handle(old_handle, allocation.value());
               }
            } else {
               if constexpr (has_feedback) {
                  this->relocate_inline_handle(old_handle, allocation.first());
               } else {
                  this->relocate_inline_handle(old_handle, allocation);
               }
            }
         } else {
            if constexpr (is_fail_safe) {
               if constexpr (has_feedback) {
                  this->relocate_disjoint_reserved_storage(
                     allocation.value().first(), this->get(old_handle));
               } else {
                  this->relocate_disjoint_reserved_storage(
                     allocation.value(), this->get(old_handle));
               }
            } else {
               if constexpr (has_feedback) {
                  this->relocate_disjoint_reserved_storage(
                     allocation.first(), this->get(old_handle));
               } else {
                  this->relocate_disjoint_reserved_storage(
                     allocation, this->get(old_handle));
               }
            }
         }
      }

      this->free(old_handle);
      return allocation;
   }

   // Move data from `handle` into `allocation`. Allocators used with this
   // interface supply non-overlapping destination storage for this transfer.
   constexpr void
   relocate_inline_handle(mem auto& handle, mem auto& allocation) {
      using allocation_type = remove_cvref<decltype(handle)>::allocation_type;
      if !consteval {
         assert(!is_memory_overlapping(this->get_ptr(handle), handle.raw_size(),
                                       this->get_ptr(allocation),
                                       allocation.raw_size()));
      }
      if constexpr (is_trivially_relocatable<allocation_type>) {
         copy_memory(this->get_ptr(handle), this->get_ptr(allocation),
                     handle.raw_size());
      } else {
         for (idx i; i < handle.size(); ++i) {
            *(__builtin_addressof(this->get(allocation)) + i) =
               move(*(__builtin_addressof(this->get(handle)) + i));
         }
      }
   }

   // Copy data from `p_old_handle` into `p_new_handle`.
   template <typename T>
   constexpr void
   relocate_ptr_handle(T* _Nonnull p_old_handle, T* _Nonnull p_new_handle,
                       idx old_count) {
      // TODO: Use a `relocate()` function to streamline this.
      if !consteval {
         assert(p_new_handle != nullptr);
         idx const transfer_bytes = old_count * sizeof(T);
         assert(!is_memory_overlapping(p_old_handle, transfer_bytes,
                                       p_new_handle, transfer_bytes));
         if constexpr (is_trivially_relocatable<T>) {
            copy_memory(p_old_handle, p_new_handle, transfer_bytes);
         }
         return;
      }
      for (idx i; i < old_count; ++i) {
         *(p_new_handle + i) = move(*(p_old_handle + i));
      }
   }

   // Copy data from `p_old_handle` into `allocation`. This `span` overload
   // exists to simplify calling this with the output of both `_multi` and
   // non-`_multi` functions.
   template <typename T>
   constexpr void
   relocate_ptr_handle(auto* _Nonnull p_old_handle, span<T> new_handle,
                       idx old_count) {
      // TODO: Use a `relocate()` function to streamline this.
      if !consteval {
         // TODO: Remove the `consteval` requirement here.
         assert(new_handle.data() != nullptr);

         idx const transfer_bytes = old_count * sizeof(T);
         assert(!is_memory_overlapping(p_old_handle, transfer_bytes,
                                       new_handle.data(), transfer_bytes));

         unpoison_memory_region(p_old_handle, transfer_bytes);

         if constexpr (is_trivially_relocatable<T>) {
            copy_memory(p_old_handle, new_handle.data(), transfer_bytes);
         }
         return;
      }
      for (idx i; i < old_count; ++i) {
         new_handle[i] = move(*(p_old_handle + i.raw));
      }
   }

   // Reallocate opaque memory handles.
   template <auto alloc_function, bool is_fail_safe, bool has_feedback,
             typename... Args>
      requires(sizeof...(Args) <= 1)
   constexpr auto
   inline_meta_realloc_multi(auto& allocator, mem auto& old_handle,
                             idx new_count, Args&&... arguments) {
      // Zero or one optional alignment argument before the new count.
      auto new_handle =
         (allocator.*alloc_function)($fwd(arguments)..., new_count);

      if constexpr (is_fail_safe) {
         if (!new_handle.has_value()) {
            return new_handle;
         }

         if constexpr (has_feedback) {
            this->relocate_inline_handle(old_handle,
                                         new_handle.value().first());
         } else {
            this->relocate_inline_handle(old_handle, new_handle.value());
         }
      } else {
         if constexpr (has_feedback) {
            this->relocate_inline_handle(old_handle, new_handle.first());
         } else {
            this->relocate_inline_handle(old_handle, new_handle);
         }
      }

      // This can be an opaque handle.
      this->free(old_handle);
      return new_handle;
   }

   // Reallocate pointer memory handles.
   template <auto alloc_function, bool is_fail_safe, bool has_feedback,
             bool is_zeroed = false, typename... Args>
      requires(sizeof...(Args) <= 1)
   constexpr auto
   meta_realloc_multi(auto& allocator, auto* _Nonnull p_old_handle,
                      idx old_count, idx new_count, Args&&... arguments) {
      using element_type = remove_cvref<decltype(*p_old_handle)>;

      // Optional optimization: when the allocator can relocate the block in a
      // single step (e.g. `mremap`) and the element type is trivially
      // relocatable and implicit-lifetime, let it move the storage instead of
      // the manual allocate + copy + free below. This is the may-move
      // `reallocate` hook, distinct from the address-stable `grow`. It falls
      // back to the manual path when the hook is absent, the requested
      // alignment exceeds the allocator's guarantee, or the hook declines.
      constexpr bool can_reallocate =
         is_trivially_relocatable<element_type>
         && is_implicit_lifetime<element_type>
         && (requires(span<byte> bytes, idx count) {
                allocator.reallocate(bytes, count);
             } || requires(span<byte> bytes, idx count) {
                allocator.reallocate_feedback(bytes, count);
             });
      if constexpr (can_reallocate) {
         if !consteval {
            bool alignment_ok = true;
            if constexpr (sizeof...(Args) == 1) {
               uword const requested_alignment =
                  (static_cast<uword>(arguments), ...);
               alignment_ok =
                  requested_alignment
                  <= remove_cvref<decltype(allocator)>::min_alignment;
            }

            if (alignment_ok) {
               span<byte> const old_allocation{
                  reinterpret_cast<byte*>(p_old_handle),
                  old_count * sizeof(element_type)};
               idx const new_bytes = new_count * sizeof(element_type);

               element_type* _Nullable p_new = nullptr;
               idx settled_bytes = new_bytes;
               if constexpr (requires(span<byte> bytes, idx count) {
                                allocator.reallocate_feedback(bytes, count);
                             }) {
                  if (auto const moved = allocator.reallocate_feedback(
                         old_allocation, new_bytes);
                      moved.has_value()) {
                     p_new =
                        reinterpret_cast<element_type*>(moved.value().first());
                     settled_bytes = moved.value().second();
                  }
               } else {
                  if (auto const moved =
                         allocator.reallocate(old_allocation, new_bytes);
                      moved.has_value()) {
                     p_new = reinterpret_cast<element_type*>(moved.value());
                  }
               }

               if (p_new != nullptr) {
                  unpoison_memory_region(p_new, settled_bytes);
                  // Zero only the grown tail for the `calloc` family. The old
                  // elements are preserved in place by the relocation.
                  if constexpr (is_zeroed) {
                     idx const settled_count =
                        settled_bytes / sizeof(element_type);
                     if (settled_count > old_count) {
                        zero_memory_scalar_explicit(
                           p_new + old_count.raw,
                           (settled_count - old_count) * sizeof(element_type));
                     }
                  }
                  using new_handle_type = decltype((allocator.*alloc_function)(
                     arguments..., new_count));
                  if constexpr (has_feedback) {
                     return new_handle_type(tuple{
                        span<element_type>(p_new, new_count), settled_bytes});
                  } else {
                     return new_handle_type(
                        span<element_type>(p_new, new_count));
                  }
               }
            }
         }
      }

      // Manual path: allocate fresh storage, relocate the elements, free old.
      // Zero or one optional alignment argument before the new count.
      auto new_handle =
         (allocator.*alloc_function)($fwd(arguments)..., new_count);

      if constexpr (is_fail_safe) {
         if (!new_handle.has_value()) {
            return new_handle;
         }

         if constexpr (has_feedback) {
            this->relocate_ptr_handle(p_old_handle, new_handle.value().first(),
                                      old_count);
         } else {
            this->relocate_ptr_handle(p_old_handle, new_handle.value(),
                                      old_count);
         }
      } else {
         if constexpr (has_feedback) {
            this->relocate_ptr_handle(p_old_handle, new_handle.first(),
                                      old_count);
         } else {
            this->relocate_ptr_handle(p_old_handle, new_handle, old_count);
         }
      }

      this->free_multi(
         span<remove_cvref<decltype(*p_old_handle)>>(p_old_handle, old_count));
      return new_handle;
   }
};

