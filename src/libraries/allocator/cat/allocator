   // Try to grow or shrink `allocation` (its existing pointer and byte size)
   // to `new_bytes` without relocating it. This is address-stable: on success
   // the allocation's pointer is unchanged. The result is engaged only when
   // the allocator can complete the request in place. Allocators that cannot
   // satisfy this hook return `nullopt` and the caller is expected to fall
   // back to an `allocate` + `copy` + `deallocate` sequence.
   [[nodiscard]]
   constexpr auto
   alloc_grow([[maybe_unused]] span<byte> allocation,
              [[maybe_unused]] idx new_bytes) -> maybe<void> {
      if constexpr (has_grow) {
         return this->self().grow(allocation, new_bytes);
      }
      return nullopt;
   }

   // Feedback variant of `alloc_grow`. Returns the actual byte count of
   // the new allocation on success, which may exceed `new_bytes` when the
   // allocator over-allocates, or `nullopt` on failure.
   [[nodiscard]]
   constexpr auto
   alloc_grow_feedback([[maybe_unused]] span<byte> allocation,
                       [[maybe_unused]] idx new_bytes) -> maybe_non_zero<idx> {
      if constexpr (has_grow_feedback) {
         return this->self().grow_feedback(allocation, new_bytes);
      } else if constexpr (has_grow) {
         if (this->self().grow(allocation, new_bytes).has_value()) {
            return new_bytes;
         }
         return nullopt;
      } else {
         return nullopt;
      }
   }

   // Value-equality hook. Two allocators are considered equal when each
   // can correctly deallocate or reset memory handed out by the other. The
   // default recognizes stateless allocators via `__is_empty` and otherwise
   // falls back to instance identity. Allocators may shadow this to opt in
   // to richer equality.
   [[nodiscard]]
   constexpr auto
   is_equivalent(Derived const& other) const -> bool {
      if constexpr (__is_empty(Derived)) {
         static_cast<void>(other);
         return true;
      } else {
         return __builtin_addressof(this->self()) == __builtin_addressof(other);
      }
   }

   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   friend constexpr auto
   operator==(Derived const& a, Derived const& b) -> bool {
      return a.is_equivalent(b);
   }

