// -*- mode: c++ -*-
// vim: set ft=cpp:
#pragma once

#include <cat/allocator>
#include <cat/linux>
#include <cat/maybe>

// TODO: Should we remove deriving from `allocator_interface` and require
// wrapping in `allocator_ref` to reduce template monomorphization?

namespace cat {

// TODO: Support forcibly allocating huge pages.
// Allocate pages from the kernel in userspace.
class page_allocator : public allocator_interface<page_allocator> {
 private:
   friend allocator_interface<page_allocator>;
   friend struct dyn_allocator_friend;
   template <typename>
   friend class allocator_ref;

   template <typename T>
   struct page_memory_handle : detail::base_memory_handle<T> {
      T* _Nonnull p_storage;

      // TODO: Simplify with CRTP or deducing-this.
      auto
      get() -> decltype(auto) {
         return *this;
      }

      auto
      get() const -> decltype(auto) {
         return *this;
      }
   };

 public:
   constexpr page_allocator() = default;
   constexpr page_allocator(page_allocator const&) = default;
   constexpr page_allocator(page_allocator&&) = default;

   // `page_allocator` is a global stateless allocator, so all dispatch hooks
   // are `static`.

   // Allocations are always sized in a multiple of pages.
   static auto
   allocation_bytes(ualign alignment, idx allocation_bytes)
      -> maybe_non_zero<idx> {
      // Pages cannot be aligned by greater than 4 kibibytes.
      assert(alignment <= 4_uki);
      // Round `allocation_bytes` up to the nearest 4 kibibytes.
      return (allocation_bytes / 4_uki + 1u) * 4_uki;
   }

   // Allocate memory in multiples of a page-size. A page is `4_uki` large on
   // x86-64. If fewer than 4096 bytes are allocated, that amount will be
   // rounded up to 4096.
   [[gnu::malloc, clang::ownership_returns(libcat)]]
   static auto
   allocate(idx allocation_bytes) -> void* _Nullable {
      scaredy result = nix::sys_mmap(
         nullptr, allocation_bytes, nix::memory_protection_flags::read_write,
         nix::memory_flags::privately
            | nix::memory_flags::populate
            | nix::memory_flags::anonymous,
         // Anonymous pages (non-files) must have -1.
         nix::file_descriptor(-1),
         // Anonymous pages (non-files) must have 0.
         0u
      );
      if (result.has_value()) {
         // mmap returns page-aligned memory. Tell the optimizer so the
         // page-aligned guarantee survives across the `maybe_ptr` wrapping.
         return __builtin_assume_aligned(result.value(), page_size.raw);
      }
      return nullptr;
   }

   // Allocate a page(s) of virtual memory that is guaranteed to align to any
   // power of 2, but less than `4_uki`.
   [[gnu::malloc, clang::ownership_returns(libcat)]]
   static auto
   aligned_allocate(ualign alignment, idx allocation_bytes) -> void* _Nullable {
      // Pages cannot be aligned by greater than 4 kibibytes.
      // TODO: We can try hint addresses or over-allocation to make this work.
      // Or maybe `MAP_FIXED_NOREPLACE`.
      assert(alignment <= 4_uki);
      // A normal page allocation already has strong alignment guarantees.
      return allocate(allocation_bytes);
   }

   // Anonymous `mmap` pages are demand-zero, so a fresh allocation is already
   // zeroed. The `calloc` family routes here to skip its zero-fill, the same
   // optimization musl malloc's `calloc` makes for mmap-backed chunks.
   [[gnu::malloc, clang::ownership_returns(libcat)]]
   static auto
   allocate_zeroed(idx allocation_bytes) -> void* _Nullable {
      return allocate(allocation_bytes);
   }

   // Feedback variant of `allocate_zeroed`.
   static auto
   allocate_zeroed_feedback(idx allocation_bytes) -> sized_allocation<void*> {
      void* _Nullable p_result = allocate(allocation_bytes);
      // Propagating nullptr is handled correctly by `maybe_sized_allocation`.
      return {p_result, round_up_to_multiple_of(allocation_bytes, page_size)};
   }

   // Aligned variant of `allocate_zeroed`.
   [[gnu::malloc, clang::ownership_returns(libcat)]]
   static auto
   aligned_allocate_zeroed(ualign alignment, idx allocation_bytes)
      -> void* _Nullable {
      return aligned_allocate(alignment, allocation_bytes);
   }

   // Aligned feedback variant of `allocate_zeroed`.
   static auto
   aligned_allocate_zeroed_feedback(ualign alignment, idx allocation_bytes)
      -> sized_allocation<void*> {
      void* _Nullable p_result = aligned_allocate(alignment, allocation_bytes);
      // Propagating nullptr is handled correctly by `maybe_sized_allocation`.
      return {p_result, round_up_to_multiple_of(allocation_bytes, page_size)};
   }

   // Unmap a pointer handle to page(s) of virtual memory.
   [[clang::ownership_takes(libcat, 1)]]
   static void
   deallocate(void const* _Nonnull p_storage, idx allocation_bytes) {
      nix::sys_munmap(p_storage, allocation_bytes).assert();
   }

   // `page_allocator::resize` checks whether the kernel can deliver
   // at least `minimum_bytes`, rounded up to a whole-page multiple. It
   // makes a `sys_mmap`/`sys_munmap` round trip without writing so that
   // the address space is not actually grown.
   static auto
   resize(idx minimum_bytes) -> maybe_non_zero<idx> {
      // Round `minimum_bytes` up to a whole-page multiple. `page_size`
      // is a power of two, so this lowers to a single mask.
      idx const page_bytes = round_up_to_multiple_of(minimum_bytes, page_size);
      scaredy maybe_pages = nix::sys_mmap(
         nullptr, page_bytes,
         nix::memory_protection_flags::read_write
            | nix::memory_protection_flags::execute,
         nix::memory_flags::privately | nix::memory_flags::anonymous,
         nix::file_descriptor(-1), 0u
      );
      void* _Nonnull p_new_pages = $prop_as(maybe_pages, nullopt);
      auto _ = nix::sys_munmap(p_new_pages, page_bytes);
      return page_bytes;
   }

   // Address-stable in-place grow via `sys_mremap` without `may_move`. The
   // kernel resizes the page mapping at the same address or fails.
   static auto
   grow(span<byte> allocation, idx new_bytes) -> maybe<void> {
      idx const from_size =
         round_up_to_multiple_of(allocation.size(), page_size);
      idx const to_size = round_up_to_multiple_of(new_bytes, page_size);
      scaredy result = nix::sys_mremap(
         allocation.data(), from_size, to_size, nix::mremap_flags::none
      );
      if (!result.has_value()) {
         return nullopt;
      }
      return monostate;
   }

   // Feedback variant of `grow`. Reports the page-rounded byte count of the
   // resized mapping, which may exceed `new_bytes`.
   static auto
   grow_feedback(span<byte> allocation, idx new_bytes) -> maybe_non_zero<idx> {
      idx const from_size =
         round_up_to_multiple_of(allocation.size(), page_size);
      idx const to_size = round_up_to_multiple_of(new_bytes, page_size);
      scaredy result = nix::sys_mremap(
         allocation.data(), from_size, to_size, nix::mremap_flags::none
      );
      if (!result.has_value()) {
         return nullopt;
      }
      return to_size;
   }

   // May-move reallocation via `mremap` with `may_move`. Unlike `grow`, the
   // kernel is free to relocate the mapping, so the returned pointer can
   // differ from `allocation.data()`. The pages are moved without a userspace
   // copy, and the old mapping is consumed. Both sizes round up to whole pages.
   static auto
   reallocate(span<byte> allocation, idx new_bytes) -> void* _Nullable {
      idx const from_size =
         round_up_to_multiple_of(allocation.size(), page_size);
      idx const to_size = round_up_to_multiple_of(new_bytes, page_size);
      scaredy result = nix::sys_mremap(
         allocation.data(), from_size, to_size, nix::mremap_flags::may_move
      );
      if (result.has_value()) {
         return __builtin_assume_aligned(result.value(), page_size.raw);
      }
      return nullptr;
   }

   // Feedback variant of `reallocate`. Reports the page-rounded byte count of
   // the resized mapping alongside its (possibly relocated) pointer.
   static auto
   reallocate_feedback(span<byte> allocation, idx new_bytes)
      -> sized_allocation<void*> {
      idx const from_size =
         round_up_to_multiple_of(allocation.size(), page_size);
      idx const to_size = round_up_to_multiple_of(new_bytes, page_size);
      scaredy result = nix::sys_mremap(
         allocation.data(), from_size, to_size, nix::mremap_flags::may_move
      );
      // Propagating nullptr is handled correctly by `maybe_sized_allocation`.
      return {
         result.has_value()
            ? __builtin_assume_aligned(result.value(), page_size.raw)
            : nullptr,
         to_size
      };
   }

   // `.reset()` is a no-op provided by `allocator_interface`.

   // Produce a handle to allocated memory.
   template <typename T>
   [[clang::ownership_holds(libcat, 1)]]
   static constexpr auto
   make_handle(T* _Nonnull p_handle_storage) -> page_memory_handle<T> {
      return page_memory_handle<T>{{}, p_handle_storage};
   }

   // Access a page(s) of virtual memory.
   template <typename T>
   [[gnu::returns_nonnull]]
   static auto
   access(page_memory_handle<T>& memory) -> T* _Nonnull {
      return memory.p_storage;
   }

   template <typename T>
   [[gnu::returns_nonnull]]
   static auto
   access(page_memory_handle<T> const& memory) -> T const* _Nonnull {
      return memory.p_storage;
   }

   // `mmap` always returns page-aligned memory, so the static alignment
   // guarantee is one full page (4 KiB).
   static constexpr ualign min_alignment = page_size;

   // Process-wide private anonymous rw RSS from the detailed memory-map file.
   [[nodiscard]]
   static auto
   bytes_used() -> idx;

   // Process-wide non-file-backed mapped size from the detailed memory-map
   // file. Note that this is not idempotent.
   [[nodiscard]]
   static auto
   bytes_capacity() -> idx;
};

[[nodiscard]]
constexpr auto
make_page_allocator() -> page_allocator {
   return {};
}

}  // namespace cat
