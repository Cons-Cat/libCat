#pragma once

#include <cat/allocator>
#include <cat/dyn>

// `dyn_allocator` and `allocator_ref` are the primary interfaces for function
// parameters to consume libCat allocators. They enable functions to support
// both dynamic and static dispatch on memory allocators while encouraging
// overload resolution to default to dynamic dispatch to minimize code
// generation.
//
// They can be used in parameters as:
//    template<is_allocator A>
//    auto function(allocator_ref<A> allocator) -> span<int4> {
//       return allocator.alloc<int4>(1024).verify();
//    }
//
//    auto function(dyn_allocator allocator) -> span<int4> {
//       // Wrap the `function` specialization in `dyn_allocator`.
//       return function<dyn_allocator>(allocator);
//    }
//
// When `function` is called as `function(allocator)`, the call resolves to the
// `dyn_allocator` overload, which specializes the static-dispatch overload with
// one pointer indirection.
//
// When `function` is called as `function<A>(allocator)`, the call resolves to
// the static-dispatch overload, which directly calls `allocator`'s member
// functions with no indirection.
//
// This design is largely inspired by Zig's success defaulting to
// dynamic-dispatch memory allocation. The `dyn_allocator` can often
// devirtualize function calls, but unlike Zig, we trivially support opt-in
// static-dispatch as well with that very simple pattern.

namespace cat {

// Grants `dyn_allocator`'s `Method` tags access to potentially `private`
// underlying allocator hooks. Allocator implementations should `friend` this
// type. If the allocator's members are `public`, that is not required.
struct dyn_allocator_friend {
   template <typename T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   allocate(T& self, idx allocation_bytes)
      -> decltype(self.allocate(allocation_bytes)) {
      return self.allocate(allocation_bytes);
   }

   template <typename T>
   [[gnu::always_inline, gnu::nodebug, clang::ownership_takes(libcat, 2)]]
   static auto
   deallocate(T& self, void const* _Nonnull p_storage, idx allocation_bytes)
      -> decltype(self.deallocate(p_storage, allocation_bytes)) {
      return self.deallocate(p_storage, allocation_bytes);
   }

   template <typename T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   reset(T& self) -> decltype(self.reset()) {
      return self.reset();
   }

   template <typename T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   aligned_allocate(T& self, uword alignment, idx allocation_bytes)
      -> decltype(self.aligned_allocate(alignment, allocation_bytes)) {
      return self.aligned_allocate(alignment, allocation_bytes);
   }

   template <typename T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   allocate_feedback(T& self, idx allocation_bytes)
      -> decltype(self.allocate_feedback(allocation_bytes)) {
      return self.allocate_feedback(allocation_bytes);
   }

   template <typename T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   aligned_allocate_feedback(T& self, uword alignment, idx allocation_bytes)
      -> decltype(self.aligned_allocate_feedback(alignment, allocation_bytes)) {
      return self.aligned_allocate_feedback(alignment, allocation_bytes);
   }

   template <typename T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   resize(T& self, idx minimum_bytes) -> decltype(self.resize(minimum_bytes)) {
      return self.resize(minimum_bytes);
   }

   template <typename T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   grow(T& self, span<byte> allocation, idx new_bytes)
      -> decltype(self.grow(allocation, new_bytes)) {
      return self.grow(allocation, new_bytes);
   }

   template <typename T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   grow_feedback(T& self, span<byte> allocation, idx new_bytes)
      -> decltype(self.grow_feedback(allocation, new_bytes)) {
      return self.grow_feedback(allocation, new_bytes);
   }

   template <typename T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   reallocate(T& self, span<byte> allocation, idx new_bytes)
      -> decltype(self.reallocate(allocation, new_bytes)) {
      return self.reallocate(allocation, new_bytes);
   }

   template <typename T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   reallocate_feedback(T& self, span<byte> allocation, idx new_bytes)
      -> decltype(self.reallocate_feedback(allocation, new_bytes)) {
      return self.reallocate_feedback(allocation, new_bytes);
   }

   template <typename T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   allocate_zeroed(T& self, idx allocation_bytes)
      -> decltype(self.allocate_zeroed(allocation_bytes)) {
      return self.allocate_zeroed(allocation_bytes);
   }

   template <typename T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   allocate_zeroed_feedback(T& self, idx allocation_bytes)
      -> decltype(self.allocate_zeroed_feedback(allocation_bytes)) {
      return self.allocate_zeroed_feedback(allocation_bytes);
   }

   template <typename T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   aligned_allocate_zeroed(T& self, uword alignment, idx allocation_bytes)
      -> decltype(self.aligned_allocate_zeroed(alignment, allocation_bytes)) {
      return self.aligned_allocate_zeroed(alignment, allocation_bytes);
   }

   template <typename T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   aligned_allocate_zeroed_feedback(T& self, uword alignment,
                                    idx allocation_bytes)
      -> decltype(self.aligned_allocate_zeroed_feedback(alignment,
                                                        allocation_bytes)) {
      return self.aligned_allocate_zeroed_feedback(alignment, allocation_bytes);
   }

   template <typename T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   bytes_used(T const& self) -> decltype(self.bytes_used()) {
      return self.bytes_used();
   }

   template <typename T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   bytes_capacity(T const& self) -> decltype(self.bytes_capacity()) {
      return self.bytes_capacity();
   }

   template <typename T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   is_equivalent(T const& self, T const& other)
      -> decltype(self.is_equivalent(other)) {
      return self.is_equivalent(other);
   }

   template <typename T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   name(T const& self) -> decltype(self.name()) {
      return self.name();
   }

   template <typename T, typename Storage>
   [[gnu::always_inline, gnu::nodebug, clang::ownership_holds(libcat, 2)]]
   static auto
   make_handle(T& self, Storage* _Nonnull p_handle_storage)
      -> decltype(self.template make_handle<Storage>(p_handle_storage)) {
      return self.template make_handle<Storage>(p_handle_storage);
   }

   template <typename T, typename Handle>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   access(T& self, Handle& memory) -> decltype(self.access(memory)) {
      return self.access(memory);
   }

   template <typename T, typename Handle>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   access(T const& self, Handle const& memory)
      -> decltype(self.access(memory)) {
      return self.access(memory);
   }
};

namespace detail {

// Per-hook capability predicates. The `dyn_allocator` `Method` tags pivot on
// these to pick the native dispatch path when the underlying allocator
// implements the hook, and to fall back to a synthesised shim otherwise.
// They route through `dyn_allocator_friend` so the predicate is satisfied iff
// the friend can reach the hook, even when it is `private`.
template <typename T>
concept has_allocate =
   requires(T& allocator, idx allocation_bytes) {
      dyn_allocator_friend::allocate(allocator, allocation_bytes);
   };

template <typename T>
concept has_deallocate =
   requires(T& allocator, void const* _Nonnull p_storage,
            idx allocation_bytes) {
      dyn_allocator_friend::deallocate(allocator, p_storage, allocation_bytes);
   };

template <typename T>
concept has_reset =
   requires(T& allocator) { dyn_allocator_friend::reset(allocator); };

template <typename T>
concept has_aligned_allocate =
   requires(T& allocator, uword alignment, idx allocation_bytes) {
      dyn_allocator_friend::aligned_allocate(allocator, alignment,
                                             allocation_bytes);
   };

template <typename T>
concept has_allocate_feedback =
   requires(T& allocator, idx allocation_bytes) {
      dyn_allocator_friend::allocate_feedback(allocator, allocation_bytes);
   };

template <typename T>
concept has_aligned_allocate_feedback =
   requires(T& allocator, uword alignment, idx allocation_bytes) {
      dyn_allocator_friend::aligned_allocate_feedback(allocator, alignment,
                                                      allocation_bytes);
   };

template <typename T>
concept has_resize = requires(T& allocator, idx minimum_bytes) {
                        dyn_allocator_friend::resize(allocator, minimum_bytes);
                     };

template <typename T>
concept has_grow =
   requires(T& allocator, span<byte> allocation, idx new_bytes) {
      dyn_allocator_friend::grow(allocator, allocation, new_bytes);
   };

template <typename T>
concept has_grow_feedback =
   requires(T& allocator, span<byte> allocation, idx new_bytes) {
      dyn_allocator_friend::grow_feedback(allocator, allocation, new_bytes);
   };

template <typename T>
concept has_reallocate =
   requires(T& allocator, span<byte> allocation, idx new_bytes) {
      dyn_allocator_friend::reallocate(allocator, allocation, new_bytes);
   };

template <typename T>
concept has_reallocate_feedback =
   requires(T& allocator, span<byte> allocation, idx new_bytes) {
      dyn_allocator_friend::reallocate_feedback(allocator, allocation,
                                                new_bytes);
   };

template <typename T>
concept has_allocate_zeroed =
   requires(T& allocator, idx allocation_bytes) {
      dyn_allocator_friend::allocate_zeroed(allocator, allocation_bytes);
   };

template <typename T>
concept has_allocate_zeroed_feedback =
   requires(T& allocator, idx allocation_bytes) {
      dyn_allocator_friend::allocate_zeroed_feedback(allocator,
                                                     allocation_bytes);
   };

template <typename T>
concept has_aligned_allocate_zeroed =
   requires(T& allocator, uword alignment, idx allocation_bytes) {
      dyn_allocator_friend::aligned_allocate_zeroed(allocator, alignment,
                                                    allocation_bytes);
   };

template <typename T>
concept has_aligned_allocate_zeroed_feedback =
   requires(T& allocator, uword alignment, idx allocation_bytes) {
      dyn_allocator_friend::aligned_allocate_zeroed_feedback(
         allocator, alignment, allocation_bytes);
   };

template <typename T>
concept has_bytes_used = requires(T const& allocator) {
                            dyn_allocator_friend::bytes_used(allocator);
                         };

template <typename T>
concept has_bytes_capacity = requires(T const& allocator) {
                                dyn_allocator_friend::bytes_capacity(allocator);
                             };

template <typename T>
concept has_is_equivalent =
   requires(T const& allocator, T const& other) {
      dyn_allocator_friend::is_equivalent(allocator, other);
   };

template <typename T>
concept has_name =
   requires(T const& allocator) { dyn_allocator_friend::name(allocator); };

struct dyn_allocate {
   using signature = auto(idx) -> maybe_ptr<void>;

   template <has_allocate T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   do_invoke(T& self, idx allocation_bytes) -> maybe_ptr<void> {
      return dyn_allocator_friend::allocate(self, allocation_bytes);
   }
};

struct dyn_deallocate {
   using signature = void(void const* _Nonnull, idx);

   template <has_deallocate T>
   [[gnu::always_inline, gnu::nodebug, clang::ownership_takes(libcat, 2)]]
   static void
   do_invoke(T& self, void const* _Nonnull p_storage, idx allocation_bytes) {
      dyn_allocator_friend::deallocate(self, p_storage, allocation_bytes);
   }
};

struct dyn_reset {
   using signature = void();

   template <has_reset T>
   [[gnu::always_inline, gnu::nodebug]]
   static void
   do_invoke(T& self) {
      dyn_allocator_friend::reset(self);
   }
};

struct dyn_aligned_allocate {
   using signature = auto(uword, idx) -> maybe_ptr<void>;

   template <has_allocate T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   do_invoke(T& self, uword alignment, idx allocation_bytes)
      -> maybe_ptr<void> {
      if constexpr (has_aligned_allocate<T>) {
         return dyn_allocator_friend::aligned_allocate(self, alignment,
                                                       allocation_bytes);
      } else {
         // If the allocator doesn't implement `aligned_allocate`, we generate a
         // shim.
         maybe_ptr<void> result =
            dyn_allocator_friend::allocate(self, allocation_bytes);
         if (result.has_value()
             && !cat::is_aligned(result.value(), alignment)) {
            dyn_allocator_friend::deallocate(self, result.value(),
                                             allocation_bytes);
            return nullopt;
         }
         return result;
      }
   }
};

struct dyn_allocate_feedback {
   using signature = auto(idx) -> maybe_sized_allocation<void*>;

   template <has_allocate T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   do_invoke(T& self, idx allocation_bytes) -> maybe_sized_allocation<void*> {
      if constexpr (has_allocate_feedback<T>) {
         return dyn_allocator_friend::allocate_feedback(self, allocation_bytes);
      } else {
         // If the allocator doesn't implement `allocate_feedback`, we generate
         // a shim.
         maybe_ptr<void> result =
            dyn_allocator_friend::allocate(self, allocation_bytes);
         if (!result.has_value()) {
            return nullopt;
         }
         return maybe_sized_allocation<void*>(
            tuple{result.value(), allocation_bytes});
      }
   }
};

struct dyn_aligned_allocate_feedback {
   using signature = auto(uword, idx) -> maybe_sized_allocation<void*>;

   template <has_allocate T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   do_invoke(T& self, uword alignment, idx allocation_bytes)
      -> maybe_sized_allocation<void*> {
      if constexpr (has_aligned_allocate_feedback<T>) {
         return dyn_allocator_friend::aligned_allocate_feedback(
            self, alignment, allocation_bytes);
      } else {
         // If the allocator doesn't implement `aligned_allocate_feedback`, we
         // generate a shim.
         maybe_ptr<void> result;
         if constexpr (has_aligned_allocate<T>) {
            result = dyn_allocator_friend::aligned_allocate(self, alignment,
                                                            allocation_bytes);
         } else {
            result = dyn_allocator_friend::allocate(self, allocation_bytes);
            if (result.has_value()
                && !cat::is_aligned(result.value(), alignment)) {
               dyn_allocator_friend::deallocate(self, result.value(),
                                                allocation_bytes);
               return nullopt;
            }
         }
         if (!result.has_value()) {
            return nullopt;
         }
         return maybe_sized_allocation<void*>(
            tuple{result.value(), allocation_bytes});
      }
   }
};

struct dyn_resize {
   using signature = auto(idx) -> maybe_non_zero<idx>;

   template <has_allocate T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   do_invoke(T& self, idx minimum_bytes) -> maybe_non_zero<idx> {
      if constexpr (has_resize<T>) {
         return dyn_allocator_friend::resize(self, minimum_bytes);
      } else {
         static_cast<void>(self);
         static_cast<void>(minimum_bytes);
         return nullopt;
      }
   }
};

struct dyn_grow {
   using signature = auto(span<byte>, idx) -> maybe<void>;

   template <has_allocate T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   do_invoke([[maybe_unused]] T& self, [[maybe_unused]] span<byte> allocation,
             [[maybe_unused]] idx new_bytes) -> maybe<void> {
      if constexpr (has_grow<T>) {
         return dyn_allocator_friend::grow(self, allocation, new_bytes);
      } else {
         return nullopt;
      }
   }
};

struct dyn_grow_feedback {
   using signature = auto(span<byte>, idx) -> maybe_non_zero<idx>;

   template <has_allocate T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   do_invoke([[maybe_unused]] T& self, [[maybe_unused]] span<byte> allocation,
             [[maybe_unused]] idx new_bytes) -> maybe_non_zero<idx> {
      if constexpr (has_grow_feedback<T>) {
         return dyn_allocator_friend::grow_feedback(self, allocation,
                                                    new_bytes);
      } else if constexpr (has_grow<T>) {
         if (dyn_allocator_friend::grow(self, allocation, new_bytes)
                .has_value()) {
            return new_bytes;
         }
         return nullopt;
      } else {
         return nullopt;
      }
   }
};

struct dyn_reallocate {
   using signature = auto(span<byte>, idx) -> maybe_ptr<void>;

   template <has_allocate T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   do_invoke([[maybe_unused]] T& self, [[maybe_unused]] span<byte> allocation,
             [[maybe_unused]] idx new_bytes) -> maybe_ptr<void> {
      if constexpr (has_reallocate<T>) {
         return dyn_allocator_friend::reallocate(self, allocation, new_bytes);
      } else {
         return nullopt;
      }
   }
};

struct dyn_reallocate_feedback {
   using signature = auto(span<byte>, idx) -> maybe_sized_allocation<void*>;

   template <has_allocate T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   do_invoke([[maybe_unused]] T& self, [[maybe_unused]] span<byte> allocation,
             [[maybe_unused]] idx new_bytes) -> maybe_sized_allocation<void*> {
      if constexpr (has_reallocate_feedback<T>) {
         return dyn_allocator_friend::reallocate_feedback(self, allocation,
                                                          new_bytes);
      } else if constexpr (has_reallocate<T>) {
         maybe_ptr<void> result =
            dyn_allocator_friend::reallocate(self, allocation, new_bytes);
         if (!result.has_value()) {
            return nullopt;
         }
         return maybe_sized_allocation<void*>(tuple{result.value(), new_bytes});
      } else {
         return nullopt;
      }
   }
};

struct dyn_bytes_used {
   using signature = auto() const -> idx;

   template <typename T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   do_invoke(T const& self) -> idx {
      if constexpr (has_bytes_used<T>) {
         return dyn_allocator_friend::bytes_used(self);
      } else {
         static_cast<void>(self);
         return idx(0u);
      }
   }
};

struct dyn_bytes_capacity {
   using signature = auto() const -> idx;

   template <typename T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   do_invoke(T const& self) -> idx {
      if constexpr (has_bytes_capacity<T>) {
         return dyn_allocator_friend::bytes_capacity(self);
      } else {
         static_cast<void>(self);
         return idx(0u);
      }
   }
};

// `dyn_equals` is the type-erased value-equality hook. Callers must guarantee
// that `p_other` points to a `T`, which is checked at the `dyn_allocator`
// equality entry point via type-id comparison.
struct dyn_equals {
   using signature = auto(void const* _Nonnull) const -> bool;

   template <typename T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   do_invoke(T const& self, void const* _Nonnull p_other) -> bool {
      T const& other = *static_cast<T const*>(p_other);
      if constexpr (has_is_equivalent<T>) {
         return dyn_allocator_friend::is_equivalent(self, other);
      } else if constexpr (__is_empty(T)) {
         static_cast<void>(self);
         static_cast<void>(other);
         return true;
      } else {
         return __builtin_addressof(self) == __builtin_addressof(other);
      }
   }
};

struct dyn_name {
   using signature = auto() const -> str_view;

   template <typename T>
   [[gnu::always_inline, gnu::nodebug]]
   static auto
   do_invoke(T const& self) -> str_view {
      if constexpr (has_name<T>) {
         return dyn_allocator_friend::name(self);
      } else {
         static_cast<void>(self);
         return str_view{};
      }
   }
};

}  // namespace detail

// Non-owning, dynamic-dispatch handle to an `Allocator`. This erases the type
// of underlying allocators to minimize code generation. Functions' overloads
// are encouraged to resolve this parameter unless explicitly specified.
class [[gsl::Owner]] dyn_allocator : public allocator_interface<dyn_allocator> {
   friend allocator_interface<dyn_allocator>;
   friend struct dyn_allocator_friend;
   template <typename>
   friend class allocator_ref;

 private:
   template <typename T>
   struct dyn_memory_handle : detail::base_memory_handle<T> {
      T* _Nonnull p_storage;

      auto
      get() -> decltype(auto) {
         return *this;
      }

      auto
      get() const -> decltype(auto) {
         return *this;
      }
   };

   dyn_ptr<detail::dyn_allocate, detail::dyn_deallocate, detail::dyn_reset,
           detail::dyn_aligned_allocate, detail::dyn_allocate_feedback,
           detail::dyn_aligned_allocate_feedback, detail::dyn_resize,
           detail::dyn_grow, detail::dyn_grow_feedback, detail::dyn_reallocate,
           detail::dyn_reallocate_feedback, detail::dyn_bytes_used,
           detail::dyn_bytes_capacity, detail::dyn_equals, detail::dyn_name>
      m_p_allocator;

   [[gnu::always_inline, gnu::nodebug]]
   auto
   allocate(idx allocation_bytes) -> maybe_ptr<void> {
      return dyn_invoke<detail::dyn_allocate>(*m_p_allocator, allocation_bytes);
   }

   [[gnu::always_inline, gnu::nodebug, clang::ownership_takes(libcat, 2)]]
   void
   deallocate(void const* _Nonnull p_storage, idx allocation_bytes) {
      dyn_invoke<detail::dyn_deallocate>(*m_p_allocator, p_storage,
                                         allocation_bytes);
   }

   [[gnu::always_inline, gnu::nodebug]]
   auto
   aligned_allocate(uword alignment, idx allocation_bytes) -> maybe_ptr<void> {
      return dyn_invoke<detail::dyn_aligned_allocate>(*m_p_allocator, alignment,
                                                      allocation_bytes);
   }

   [[gnu::always_inline, gnu::nodebug]]
   auto
   allocate_feedback(idx allocation_bytes) -> maybe_sized_allocation<void*> {
      return dyn_invoke<detail::dyn_allocate_feedback>(*m_p_allocator,
                                                       allocation_bytes);
   }

   [[gnu::always_inline, gnu::nodebug]]
   auto
   aligned_allocate_feedback(uword alignment, idx allocation_bytes)
      -> maybe_sized_allocation<void*> {
      return dyn_invoke<detail::dyn_aligned_allocate_feedback>(
         *m_p_allocator, alignment, allocation_bytes);
   }

   [[gnu::always_inline, gnu::nodebug]]
   auto
   resize(idx minimum_bytes) -> maybe_non_zero<idx> {
      return dyn_invoke<detail::dyn_resize>(*m_p_allocator, minimum_bytes);
   }

   [[gnu::always_inline, gnu::nodebug]]
   auto
   grow(span<byte> allocation, idx new_bytes) -> maybe<void> {
      return dyn_invoke<detail::dyn_grow>(*m_p_allocator, allocation,
                                          new_bytes);
   }

   [[gnu::always_inline, gnu::nodebug]]
   auto
   grow_feedback(span<byte> allocation, idx new_bytes) -> maybe_non_zero<idx> {
      return dyn_invoke<detail::dyn_grow_feedback>(*m_p_allocator, allocation,
                                                   new_bytes);
   }

   [[gnu::always_inline, gnu::nodebug]]
   auto
   reallocate(span<byte> allocation, idx new_bytes) -> maybe_ptr<void> {
      return dyn_invoke<detail::dyn_reallocate>(*m_p_allocator, allocation,
                                                new_bytes);
   }

   [[gnu::always_inline, gnu::nodebug]]
   auto
   reallocate_feedback(span<byte> allocation, idx new_bytes)
      -> maybe_sized_allocation<void*> {
      return dyn_invoke<detail::dyn_reallocate_feedback>(*m_p_allocator,
                                                         allocation, new_bytes);
   }

   template <typename T>
   [[gnu::always_inline, gnu::nodebug, clang::ownership_holds(libcat, 2)]]
   constexpr auto
   make_handle(T* _Nonnull p_handle_storage) -> dyn_memory_handle<T> {
      return dyn_memory_handle<T>{{}, p_handle_storage};
   }

   template <typename T>
   [[gnu::returns_nonnull, gnu::always_inline, gnu::nodebug]]
   auto
   access(dyn_memory_handle<T>& memory) -> T* _Nonnull {
      return memory.p_storage;
   }

   template <typename T>
   [[gnu::returns_nonnull, gnu::always_inline, gnu::nodebug]]
   auto
   access(dyn_memory_handle<T> const& memory) const -> T const* _Nonnull {
      return memory.p_storage;
   }

 public:
   dyn_allocator() = delete ("`dyn_allocator` cannot be default-constructed! "
                             "Pass an allocator l-value instead.");

   // Bind to any concrete allocator. Constructing a `dyn_allocator` from
   // another `dyn_allocator` would otherwise add superfluous indirections.
   template <is_allocator Allocator>
      requires(is_neither<Allocator, dyn_allocator>)
   [[gnu::always_inline, gnu::nodebug]] dyn_allocator(Allocator& allocator
                                                      [[clang::lifetimebound]]
                                                      )
