// -*- mode: c++ -*-
// vim: set ft=cpp:
#pragma once

#include <cat/allocator>

// TODO: Should we remove deriving from `allocator_interface` and require
// wrapping in `allocator_ref` to reduce template monomorphization?

namespace cat {

template <idx max_node_bytes>
class pool_allocator
    : public allocator_interface<pool_allocator<max_node_bytes>> {
 private:
   friend allocator_interface<pool_allocator>;
   friend struct dyn_allocator_friend;
   template <typename>
   friend class allocator_ref;
   template <is_allocator, is_allocator, idx, idx>
   friend class resizable_allocator;

   // Friend factory functions.
   template <idx in_max_node_bytes>
   friend constexpr auto
   make_pool_allocator(uintptr<void> p_address, idx arena_bytes)
      -> pool_allocator<in_max_node_bytes>;

   template <idx in_max_node_bytes>
   friend constexpr auto
   make_pool_allocator(span<byte>& span [[clang::lifetimebound]])
      -> pool_allocator<in_max_node_bytes>;

   // Initialize a `pool_allocator`. This should only be called from
   // `cat::make_pool_allocator`.
   constexpr pool_allocator(uintptr<void> p_address, idx arena_bytes)
       : m_nodes(
            span<node_union>(
               // Pun the opaque `p_address` to the internal `node_union` type.
               __builtin_bit_cast(node_union*, p_address.raw),
               arena_bytes / sizeof(node_union)
            )
         ) {
      // Initialize the free list.
      this->reset();
   }

   template <typename T>
   struct pool_memory_handle : detail::base_memory_handle<T> {
      T* _Nonnull p_storage;

      // TODO: Simplify with CRTP or deducing-this.
      auto
      get() -> decltype(auto) {
         return *this;
      }

      auto
      get() const -> decltype(auto) {
         return *this;
      }
   };

 public:
   // `pool_allocator` is move-only.
   constexpr pool_allocator(pool_allocator const&) =
      delete ("`cat::pool_allocator` should be constructed using "
              "`cat::make_pool_allocator`.");
   constexpr pool_allocator(pool_allocator&&) = default;

   // Reset the bumped pointer to the beginning of this arena.
   constexpr void
   reset() {
      for (idx i; i < m_nodes.size() - 1u; ++i) {
         m_nodes[i].p_next = &(m_nodes[i + 1u]);
      }
      // Mark the final node.
      m_nodes.back().p_next = nullptr;
      m_p_head = &m_nodes.front();
   }

 private:
   auto
   allocation_bytes(ualign, idx) -> maybe_non_zero<idx> {
      return max_node_bytes;
   }

   [[gnu::malloc, clang::ownership_returns(libcat)]]
   auto
   allocate(idx /*unused*/) -> void* _Nullable {
      // If there is a next node in the free list, make that the head and
      // allocate the current head to the user. Otherwise, do not allocate
      // anything.
      if (m_p_head == nullptr) {
         return nullptr;
      }

      node_union* p_alloc = m_p_head;
      m_p_head = m_p_head->p_next;

      return static_cast<void*>(p_alloc);
   }

   [[clang::ownership_takes(libcat, 2)]]
   void
   deallocate(void const* _Nonnull p_allocation, idx /*unused*/) {
      // Swap the head for this newly freed allocation.
      node_union* p_new_head = __builtin_bit_cast(node_union*, p_allocation);
      p_new_head->p_next = m_p_head;
      m_p_head = p_new_head;
   }

   // Produce a handle to allocated memory.
   template <typename T>
   [[clang::ownership_holds(libcat, 2)]]
   constexpr auto
   make_handle(T* _Nonnull p_handle_storage) -> pool_memory_handle<T> {
      return pool_memory_handle<T>{{}, p_handle_storage};
   }

   // Access some memory.
   template <typename T>
   [[gnu::returns_nonnull]]
   auto
   access(pool_memory_handle<T>& memory) -> T* _Nonnull {
      return memory.p_storage;
   }

   template <typename T>
   [[gnu::returns_nonnull]]
   auto
   access(pool_memory_handle<T> const& memory) const -> T const* _Nonnull {
      return memory.p_storage;
   }

 public:
   // Do not allocate larger than this size of one node.
   static constexpr idx max_allocation_bytes = max_node_bytes;

   union node_union {
      node_union* _Nullable p_next = nullptr;
      array<byte, max_node_bytes> storage;
   };

   static constexpr ualign min_alignment = alignof(node_union);

   [[nodiscard]]
   auto
   bytes_used() const -> idx {
      idx free_nodes = 0u;
      for (node_union const* p_walk = m_p_head; p_walk != nullptr;
           p_walk = p_walk->p_next) {
         ++free_nodes;
      }
      idx const used_nodes = static_cast<idx>(m_nodes.size() - free_nodes);
      return used_nodes * max_node_bytes;
   }

   [[nodiscard]]
   auto
   bytes_capacity() const -> idx {
      return m_nodes.size() * max_node_bytes;
   }

   // Two pools are equivalent when they alias the same memory.
   [[nodiscard]]
   auto
   is_equivalent(pool_allocator const& other) const -> bool {
      return m_nodes.data() == other.m_nodes.data()
             && m_nodes.size() == other.m_nodes.size();
   }

 private:
   span<node_union> m_nodes;
   node_union* _Nullable m_p_head;
};

template <idx max_node_bytes>
[[nodiscard]]
constexpr auto
make_pool_allocator(uintptr<void> p_address, idx arena_bytes)
   -> pool_allocator<max_node_bytes> {
   return pool_allocator<max_node_bytes>(p_address, arena_bytes);
}

template <idx max_node_bytes>
[[nodiscard]]
constexpr auto
make_pool_allocator(span<byte>& span [[clang::lifetimebound]])
   -> pool_allocator<max_node_bytes> {
   return pool_allocator<max_node_bytes>(span.data(), span.size());
}

template <idx max_node_bytes>
[[nodiscard,
  deprecated(
     "Creating a `cat::pool_allocator` with a pr-value may "
     "unintentionally leak memory. Copy an l-value `cat::span` instead."
  )]]
constexpr auto
make_pool_allocator(span<byte>&& span) -> pool_allocator<max_node_bytes> {
   return make_pool_allocator<max_node_bytes>(span);
}

}  // namespace cat
