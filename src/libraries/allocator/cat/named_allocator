#pragma once

#include <cat/allocator_parameters>

// `named_allocator<Allocator>` is an allocator adaptor that adds a non-owning
// name to any allocator. This shadows its default `.name()` method. This is
// primarily intended as a debugging label. This feature is inspired by EASTL
// named allocators.

namespace cat {

template <is_allocator Allocator>
class named_allocator : public allocator_ref<Allocator> {
   using base = allocator_ref<Allocator>;

   str_view m_name;

 public:
   constexpr named_allocator(Allocator& inner [[clang::lifetimebound]],
                             str_view debug_name [[clang::lifetimebound]])
       : base(inner), m_name(debug_name) {
   }

   // Override the `.name()` method to return the debug label.
   [[nodiscard]]
   auto
   name() const -> str_view {
      return m_name;
   }

   // Two allocators compare equal when they wrap the same underlying
   // allocator. The label is ignored, as it is a debug-only detail and
   // doesn't necessarily differentiate two equivalent allocators.
   [[nodiscard]]
   auto
   is_equivalent(named_allocator const& other) const -> bool {
      return base::is_equivalent(other);
   }
};

}  // namespace cat
