#pragma once

#include <cat/algorithm>
#include <cat/allocator>
#include <cat/allocator_parameters>
#include <cat/array>
#include <cat/container>
#include <cat/math>
#include <cat/sanitizer>
#include <cat/utility>

#include "./detail/vec_storage.hpp"

namespace cat {

inline namespace manual {

template <typename T, vec_flags flags = {}>
class basic_vec;

template <typename T, vec_flags flags = {}>
using vec = basic_vec<T, flags>;

template <typename T, idx inline_count = 4u, vec_flags flags = {}>
using small_vec = basic_vec<T, flags | vec_flags::inline_storage(inline_count)>;

}  // namespace manual

namespace detail {
// `maybe_vec<T>`'s is disengaged when `data() == nullptr` and `size() != 0`.
// Every `basic_vec<T>` value either has a non-null buffer or a zero
// size, so this bit pattern is unambiguously the empty state.
template <typename T, vec_flags flags>
constexpr auto
maybe_vec_has_value(basic_vec<T, flags> const& value) -> bool;

template <typename T, vec_flags flags>
constexpr auto
maybe_vec_nullopt() -> basic_vec<T, flags>;
}  // namespace detail

inline namespace manual {

template <typename T, vec_flags flags>
class [[clang::preferred_name(vec<T, flags>), gsl::Owner]]
basic_vec : public container_interface<basic_vec<T, flags>, T>,
            public random_access_stepanov_iterable_interface<T> {
 public:
   constexpr basic_vec() = default;

   constexpr basic_vec(basic_vec&& other)
       : m_storage(cat::move(other.m_storage)) {
   }

   constexpr basic_vec(basic_vec const&) =
      delete ("Implicit copying of `cat::basic_vec` is forbidden. Call "
              "`.clone()` or move instead!");

   auto
   operator=(basic_vec const&)
      -> basic_vec& = delete ("Implicit copying of `cat::basic_vec` is "
                              "forbidden. Call `.clone()` or move instead!");

   [[clang::reinitializes]]
   constexpr auto
   operator=(basic_vec&& other) -> basic_vec& {
      if (this == &other) {
         return *this;
      }
      if !consteval {
         cat::assert(
            data() == nullptr,
            "basic_vec move-assigned over while still owning storage. "
            "Call .free(allocator) first."
         );
      }
      m_storage = cat::move(other.m_storage);
      return *this;
   }

   // The manual `basic_vec` does not own its storage, so its destructor
   // only invokes element destructors via `.reset()`. To deallocate
   // immediately, call `.free(allocator)`. This is strongly encouraged for
   // non-trivially-destructible `T`.
   constexpr ~basic_vec() {
      if consteval {
         delete[] data();
      } else {
         reset();
         m_storage.disarm_inline();
      }
   }

   [[nodiscard]]
   constexpr auto
   operator==(basic_vec const& rhs) const -> bool
      requires(is_equality_comparable<remove_cv<T>>)
   {
      return span<T const>(*this) == span<T const>(rhs);
   }

   [[nodiscard]]
   constexpr auto
   operator<=>(basic_vec const& rhs) const
      requires(requires(remove_cv<T> const& left, remove_cv<T> const& right) {
                  { left < right } -> is_convertible<bool>;
                  { right < left } -> is_convertible<bool>;
               })
   {
      return span<T const>(*this) <=> span<T const>(rhs);
   }

   constexpr void
   swap(basic_vec& other) {
      basic_vec temporary(cat::move(*this));
      *this = cat::move(other);
      other = cat::move(temporary);
   }

 private:
   template <is_allocator CallAllocator>
   constexpr auto
   internal_allocate(
      allocator_ref<CallAllocator> allocator, idx minimum_capacity
   ) -> maybe<tuple<span<T>, idx>> {
      if constexpr (detail::vec_storage<T, flags>::is_inline) {
         if (!m_storage.m_has_handle) {
            auto [handle, allocation_bytes] = $prop(
               (allocator.template inline_salloc_multi<
                  T, flags.inline_storage_count * sizeof(T)>(minimum_capacity))
            );
            m_storage.m_handle = cat::move(handle);
            m_storage.m_has_handle = true;
            return tuple<span<T>, idx>{
               allocator.get(m_storage.m_handle),
               allocation_bytes,
            };
         }
         auto [handle, allocation_bytes] =
            $prop(allocator.inline_resalloc_multi(
               m_storage.m_handle, minimum_capacity
            ));
         m_storage.m_handle = cat::move(handle);
         m_storage.m_has_handle = true;
         return tuple<span<T>, idx>{
            allocator.get(m_storage.m_handle),
            allocation_bytes,
         };
      } else {
         if (data() == nullptr) {
            return allocator.template salloc_multi<T>(minimum_capacity);
         }
         return allocator.resalloc_multi(data(), capacity(), minimum_capacity);
      }
   }

   template <is_allocator CallAllocator>
   constexpr void
   free_inline_storage(allocator_ref<CallAllocator> allocator) {
      if (m_storage.m_has_handle) {
         if (!m_storage.m_handle.is_inline()) {
            m_storage.m_handle.set_count(size());
         }
         allocator.free(m_storage.m_handle);
         m_storage.disarm_inline();
         m_storage.m_handle =
            typename detail::vec_storage<T, flags>::handle_type{};
      }
   }

   template <is_allocator CallAllocator>
   constexpr void
   cfree_inline_storage(allocator_ref<CallAllocator> allocator) {
      if (m_storage.m_has_handle) {
         if (!m_storage.m_handle.is_inline()) {
            m_storage.m_handle.set_count(size());
         }
         allocator.cfree(m_storage.m_handle);
         m_storage.disarm_inline();
         m_storage.m_handle =
            typename detail::vec_storage<T, flags>::handle_type{};
      }
   }

   // Reallocate memory, or make an initial allocation.
   constexpr void
   annotate_size_change(idx old_size, idx new_size) const {
      annotate_contiguous_container(
         data(), data() + capacity(), data() + old_size, data() + new_size
      );
   }

   // Reallocate this `vec`'s memory if it is exceeded, in a non-`constexpr`
   // context.
   template <is_allocator CallAllocator>
   constexpr auto
   increase_storage(allocator_ref<CallAllocator> allocator) -> maybe<void> {
      constexpr idx initial_capacity = detail::vec_storage<T, flags>::is_inline
                                          ? flags.inline_storage_count
                                          : 4u;
      idx const minimum_capacity = max(capacity() * 2u, initial_capacity);

      if consteval {
         T* _Nonnull p_new = new T[minimum_capacity];
         for (idx i = 0u; i < size(); ++i) {
            new (p_new + i) T(move(data()[i]));
         }
         for (idx i = size() + 1u; i < minimum_capacity; ++i) {
            new (p_new + i) T;
         }
         idx const old_size = size();
         delete[] data();
         m_storage.set_layout(p_new, old_size, minimum_capacity);
      } else {
         idx const old_size = size();
         annotate_size_change(old_size, capacity());
         auto [alloc_span, alloc_bytes] =
            $prop(internal_allocate(allocator, minimum_capacity));
         m_storage.set_layout(
            alloc_span.data(), old_size, alloc_bytes / sizeof(T)
         );
         annotate_size_change(capacity(), old_size);
      }

      return monostate;
   }

 public:
   // Returns `nullptr` when this `vec` is default-constructed or moved-from.
   [[nodiscard]]
   constexpr auto
   data() [[clang::lifetimebound]] -> T* _Nullable {
      return m_storage.data();
   }

   // Returns `nullptr` when this `vec` is default-constructed or moved-from.
   [[nodiscard]]
   constexpr auto
   data() const [[clang::lifetimebound]] -> T const* _Nullable {
      return m_storage.data();
   }

   [[nodiscard]]
   constexpr auto
   size() const -> idx {
      return m_storage.size();
   }

   [[nodiscard]]
   constexpr auto
   capacity() const -> idx {
      return m_storage.capacity();
   }

   // Destroy every element of this `vec`. Storage is left allocated, the
   // capacity is unchanged, and the size is reset to zero. Memory must be
   // deallocated separately through `.free(allocator)`.
   [[clang::reinitializes]]
   constexpr void
   reset() {
      if constexpr (!is_trivially_destructible<T>) {
         for (idx i = 0; i < size(); ++i) {
            data()[i].~T();
         }
      }
      annotate_size_change(size(), 0u);
      m_storage.set_size(0u);
   }

   // Deallocate this `vec`'s storage from `allocator`.
   template <is_allocator CallAllocator>
   [[clang::reinitializes]]
   constexpr void
   free(allocator_ref<CallAllocator> allocator) {
      if consteval {
         delete[] data();
      } else {
         if constexpr (detail::vec_storage<T, flags>::is_inline) {
            if (m_storage.m_has_handle && m_storage.m_handle.is_inline()) {
               reset();
            } else if (m_storage.m_has_handle) {
               annotate_size_change(size(), capacity());
            }
            free_inline_storage(allocator);
         } else if (data() != nullptr) {
            annotate_size_change(size(), capacity());
            allocator.free_multi(span<T>(data(), size()));
            poison_memory_region(data(), capacity());
         }
      }
      m_storage.set_layout(nullptr, 0u, 0u);
   }

   // Deallocate this `vec`'s storage from `allocator`.
   [[clang::reinitializes, gnu::always_inline, gnu::nodebug]]
   constexpr void
   free(dyn_allocator allocator) {
      return free<dyn_allocator>(allocator);
   }

   // Deallocate this `vec`'s storage from `allocator`.
   template <is_allocator CallAllocator>
   [[clang::reinitializes]]
   constexpr void
   cfree(allocator_ref<CallAllocator> allocator) {
      if consteval {
         delete[] data();
      } else {
         if constexpr (detail::vec_storage<T, flags>::is_inline) {
            if (m_storage.m_has_handle && m_storage.m_handle.is_inline()) {
               reset();
            } else if (m_storage.m_has_handle) {
               annotate_size_change(size(), capacity());
            }
            cfree_inline_storage(allocator);
         } else if (data() != nullptr) {
            annotate_size_change(size(), capacity());
            allocator.cfree_multi(span<T>(data(), size()));
            poison_memory_region(data(), capacity());
         }
      }
      m_storage.set_layout(nullptr, 0u, 0u);
   }

   // Deallocate this `vec`'s storage from `allocator`.
   [[clang::reinitializes, gnu::always_inline, gnu::nodebug]]
   constexpr void
   cfree(dyn_allocator allocator) {
      return cfree<dyn_allocator>(allocator);
   }

   // Try to allocate storage for at least `minimum_capacity` number of `T`s.
   template <is_allocator CallAllocator>
   [[nodiscard]]
   constexpr auto
   reserve(allocator_ref<CallAllocator> allocator, idx minimum_capacity)
      -> maybe<void> {
      if (minimum_capacity > capacity()) {
         if consteval {
            idx const old_size = size();
            delete[] data();
            T* _Nonnull const p_data = new T[minimum_capacity];
            m_storage.set_layout(p_data, old_size, minimum_capacity);

            for (idx i = size() + 1u; i < capacity(); ++i) {
               new (data() + i) T();
            }
         } else {
            idx const old_size = size();
            annotate_size_change(old_size, capacity());

            auto [alloc_span, alloc_bytes] =
               $prop(internal_allocate(allocator, minimum_capacity));

            m_storage.set_layout(
               alloc_span.data(), old_size, alloc_bytes / sizeof(T)
            );
            annotate_size_change(capacity(), old_size);
         }
      }

      // If the new capacity is not larger, do nothing.
      return monostate;
   }

   // Try to allocate storage for at least `minimum_capacity` number of `T`s.
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr auto
   reserve(dyn_allocator allocator, idx minimum_capacity) -> maybe<void> {
      return reserve<dyn_allocator>(allocator, minimum_capacity);
   }

   // Try to change the size of this `vec`.
   template <is_allocator CallAllocator>
      requires(is_default_constructible<T>)
   [[nodiscard]]
   constexpr auto
   resize(allocator_ref<CallAllocator> allocator, idx size) -> maybe<void> {
      if (size > capacity()) {
         // This sets `this->current_capacity` and `this->p_storage`.
         $prop(this->reserve(allocator, size));
      }

      if !consteval {
         if (size > this->size()) {
            annotate_size_change(this->size(), size);
            for (idx i = this->size(); i < size; ++i) {
               new (data() + i) T();
            }
         } else if constexpr (!is_trivially_destructible<T>) {
            for (idx i = size; i < this->size(); ++i) {
               data()[i].~T();
            }
            annotate_size_change(this->size(), size);
         } else if (size < this->size()) {
            annotate_size_change(this->size(), size);
         }
      }

      m_storage.set_size(size);
      return monostate;
   }

   // Try to change the size of this `vec`.
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr auto
   resize(dyn_allocator allocator, idx size) -> maybe<void> {
      return resize<dyn_allocator>(allocator, size);
   }

   // Try to change the size of this `vec`, copy-constructing any new
   // elements from `value`.
   template <is_allocator CallAllocator>
      requires(is_copy_constructible<T>)
   [[nodiscard]]
   constexpr auto
   resize(allocator_ref<CallAllocator> allocator, idx size, T const& value)
      -> maybe<void> {
      if (size > capacity()) {
         $prop(this->reserve(allocator, size));
      }

      if (size > this->size()) {
         annotate_size_change(this->size(), size);
         for (idx i = this->size(); i < size; ++i) {
            if !consteval {
               new (data() + i) T(value);
            } else {
               data()[i] = value;
            }
         }
      } else if constexpr (!is_trivially_destructible<T>) {
         if !consteval {
            for (idx i = size; i < this->size(); ++i) {
               data()[i].~T();
            }
            annotate_size_change(this->size(), size);
         }
      } else if (size < this->size()) {
         annotate_size_change(this->size(), size);
      }

      m_storage.set_size(size);
      return monostate;
   }

   // Try to change the size of this `vec`, copy-constructing any new
   // elements from `value`.
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr auto
   resize(dyn_allocator allocator, idx size, T const& value) -> maybe<void> {
      return resize<dyn_allocator>(allocator, size, value);
   }

   // De-allocate excess storage.
   template <is_allocator CallAllocator>
   [[nodiscard]]
   constexpr auto
   shrink_to_fit(allocator_ref<CallAllocator> allocator) -> maybe<void> {
      if (capacity() == size()) {
         return monostate;
      }

      if consteval {
         idx const old_size = size();
         T* _Nonnull p_new = new T[old_size];
         for (idx i = 0u; i < old_size; ++i) {
            new (p_new + i) T(move(data()[i]));
         }
         delete[] data();
         m_storage.set_layout(p_new, old_size, old_size);
      } else {
         idx const old_size = size();
         annotate_size_change(old_size, capacity());

         if constexpr (!detail::vec_storage<T, flags>::is_inline) {
            // Ask the allocator to shrink the existing block in place.
            span<byte> const old_allocation{
               reinterpret_cast<byte*>(data()),
               capacity() * sizeof(T),
            };
            if (
               maybe const settled = allocator.alloc_grow_feedback(
                  old_allocation, old_size * sizeof(T)
               );
               settled.has_value()
            ) {
               m_storage.set_layout(
                  data(), old_size, settled.value() / sizeof(T)
               );
               annotate_size_change(capacity(), old_size);
               return monostate;
            }

            auto [alloc_span, alloc_bytes] =
               $prop(allocator.resalloc_multi(data(), old_size, old_size));
            m_storage.set_layout(
               alloc_span.data(), old_size, alloc_bytes / sizeof(T)
            );
         }
         annotate_size_change(capacity(), old_size);
      }

      return monostate;
   }

   // De-allocate excess storage.
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr auto
   shrink_to_fit(dyn_allocator allocator) -> maybe<void> {
      return shrink_to_fit<dyn_allocator>(allocator);
   }

   // Deep-copy the contents of this `vec`.
   template <is_allocator NewAllocator>
   [[nodiscard]]
   constexpr auto
   clone(
      allocator_ref<NewAllocator> allocator
   ) const& -> maybe<basic_vec<T, flags>> {
      // TODO: When allocators gain .remap(), prefer it when allocators compare
      // equal and the allocator can do better than allocate then copy.
      basic_vec<T, flags> new_vector;
      $prop(new_vector.reserve(allocator, max(capacity(), 4u)));
      new_vector.annotate_size_change(0u, size());
      new_vector.m_storage.set_size(size());
      relocate(this->begin(), this->end(), new_vector.begin());

      return move(new_vector);
   }

   // Deep-copy the contents of this `vec`.
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr auto
   clone(dyn_allocator allocator) const& -> maybe<basic_vec<T, flags>> {
      return clone<dyn_allocator>(allocator);
   }

   template <is_allocator CallAllocator>
      requires(is_copy_constructible<T>)
   [[nodiscard]]
   constexpr auto
   push_back(allocator_ref<CallAllocator> allocator, T const& value)
      -> maybe<void> {
      if (size() + 1 > capacity()) {
         $prop(this->increase_storage(allocator));
      }

      idx const old_size = size();
      annotate_size_change(old_size, old_size + 1u);
      data()[old_size] = value;
      m_storage.set_size(old_size + 1u);
      return monostate;
   }

   template <is_allocator CallAllocator>
      requires(is_move_constructible<T>)
   [[nodiscard]]
   constexpr auto
   push_back(allocator_ref<CallAllocator> allocator, T&& value) -> maybe<void> {
      if (size() + 1 > capacity()) {
         $prop(this->increase_storage(allocator));
      }

      idx const old_size = size();
      annotate_size_change(old_size, old_size + 1u);
      data()[old_size] = cat::move(value);
      m_storage.set_size(old_size + 1u);
      return monostate;
   }

   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr auto
   push_back(dyn_allocator allocator, T const& value) -> maybe<void> {
      return push_back<dyn_allocator>(allocator, value);
   }

   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr auto
   push_back(dyn_allocator allocator, T&& value) -> maybe<void> {
      return push_back<dyn_allocator>(allocator, cat::move(value));
   }

   template <is_allocator CallAllocator, typename... Args>
      requires(is_constructible<T, Args...>)
   [[nodiscard]]
   constexpr auto
   emplace_back(allocator_ref<CallAllocator> allocator, Args&&... arguments)
      [[clang::lifetimebound]] -> maybe<T&> {
      if (size() + 1 > capacity()) {
         $prop(this->increase_storage(allocator));
      }

      idx const old_size = size();
      annotate_size_change(old_size, old_size + 1u);
      T* _Nonnull const p_slot = data() + old_size;
      if consteval {
         p_slot->~T();
      }
      new (p_slot) T($fwd(arguments)...);
      m_storage.set_size(old_size + 1u);
      return *p_slot;
   }

   template <typename... Args>
      requires(is_constructible<T, Args...>)
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr auto
   emplace_back(dyn_allocator allocator, Args&&... arguments)
      [[clang::lifetimebound]] -> maybe<T&> {
      return emplace_back<dyn_allocator>(allocator, $fwd(arguments)...);
   }

   // Remove and return the last element. Returns `nullopt` when the vec
   // is empty.
   [[nodiscard]]
   constexpr auto
   pop_back() -> maybe<T>
      requires(is_move_constructible<T>)
   {
      if (size() == 0u) {
         return nullopt;
      }
      idx const new_size = idx(size() - 1u);
      m_storage.set_size(new_size);
      T result = cat::move(data()[new_size]);
      if constexpr (!is_trivially_destructible<T>) {
         data()[new_size].~T();
      }
      annotate_size_change(new_size + 1u, new_size);
      return result;
   }

   // Destroy every element of this `vec`. Storage is left allocated and the
   // capacity is unchanged. Equivalent to `.reset()`, named for std parity.
   [[clang::reinitializes]]
   constexpr void
   clear() {
      reset();
   }

   // Remove the element at `index`, shifting subsequent elements left.
   constexpr void
   erase(idx index)
      requires(is_move_assignable<T>)
   {
      if !consteval {
         cat::assert(index < size());
      }
      T* _Nonnull const p_dst = data() + index;
      T* _Nonnull const p_src = p_dst + 1;
      T* _Nonnull const p_end = data() + size();
      cat::move(p_src, p_end, p_dst);
      idx const new_size = idx(size() - 1u);
      m_storage.set_size(new_size);
      if constexpr (!is_trivially_destructible<T>) {
         data()[new_size].~T();
      }
      annotate_size_change(new_size + 1u, new_size);
   }

   // Remove the elements in the half-open range `[start, end)`, shifting
   // subsequent elements left.
   constexpr void
   erase(idx start, idx end)
      requires(is_move_assignable<T>)
   {
      if !consteval {
         cat::assert(start <= end);
         cat::assert(end <= size());
      }
      auto const count = end - start;
      if (count == 0u) {
         return;
      }

      T* _Nonnull const p_dst = data() + start;
      T* _Nonnull const p_src = data() + end;
      T* _Nonnull const p_data_end = data() + size();
      cat::move(p_src, p_data_end, p_dst);
      idx const old_size = size();
      idx const new_size = idx(old_size - count);
      m_storage.set_size(new_size);
      if constexpr (!is_trivially_destructible<T>) {
         for (idx i = new_size; i < old_size; ++i) {
            data()[i].~T();
         }
      }
      annotate_size_change(old_size, new_size);
   }

   // Append every element of `range` to the end of this `vec`.
   template <is_allocator CallAllocator, typename Range>
   [[nodiscard]]
   constexpr auto
   append_range(allocator_ref<CallAllocator> allocator, Range const& range)
      -> maybe<void> {
      if constexpr (requires { range.size(); }) {
         $prop(this->reserve(allocator, size() + idx(range.size())));
      }
      for (T const& value : range) {
         $prop(this->push_back(allocator, value));
      }
      return monostate;
   }

   // Append every element of `range` to the end of this `vec`.
   template <typename Range>
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr auto
   append_range(dyn_allocator allocator, Range const& range) -> maybe<void> {
      return append_range<dyn_allocator>(allocator, range);
   }

   // Maximum number of elements this `vec` can theoretically hold, bounded
   // by the address space rather than any allocator's actual ceiling.
   [[nodiscard]]
   static constexpr auto
   max_size() -> idx {
      return idx::max() / sizeof(T);
   }

 private:
   template <typename U, vec_flags other_flags>
   friend constexpr auto
   detail::maybe_vec_has_value(basic_vec<U, other_flags> const&) -> bool;

   template <typename U, vec_flags other_flags>
   friend constexpr auto
   detail::maybe_vec_nullopt() -> basic_vec<U, other_flags>;

   detail::vec_storage<T, flags> m_storage;
};

}  // namespace manual

namespace detail {
template <typename T, vec_flags flags>
constexpr auto
maybe_vec_has_value(basic_vec<T, flags> const& value) -> bool {
   return value.m_storage.has_value();
}

template <typename T, vec_flags flags>
constexpr auto
maybe_vec_nullopt() -> basic_vec<T, flags> {
   basic_vec<T, flags> value;
   value.m_storage.set_niche();
   return value;
}

}  // namespace detail

template <typename T, vec_flags flags>
struct default_compact_trait<basic_vec<T, flags>>
    : identity_trait<compact<
         basic_vec<T, flags>, detail::maybe_vec_has_value<T, flags>,
         detail::maybe_vec_nullopt<T, flags>>> {};

inline namespace manual {

template <typename T, is_allocator Allocator, vec_flags flags = {}>
[[nodiscard]] constexpr auto
   make_vec(allocator_ref<Allocator> allocator, initializer_list<T> values)
      -> maybe<basic_vec<T, flags>> {
   basic_vec<T, flags> new_vector;
   $prop(new_vector.reserve(allocator, max(values.size(), 4u)));
   for (T const& value : values) {
      $prop(new_vector.push_back(allocator, value));
   }
   return new_vector;
}

template <typename T, vec_flags flags = {}>
[[nodiscard, gnu::always_inline, gnu::nodebug]] constexpr auto
   make_vec(dyn_allocator allocator, initializer_list<T> values)
      -> maybe<basic_vec<T, flags>> {
   return make_vec<T, dyn_allocator, flags>(allocator, values);
}

template <typename T, is_allocator Allocator, vec_flags flags = {}>
[[nodiscard]] constexpr auto
   make_vec_reserved(allocator_ref<Allocator> allocator, idx capacity)
      -> maybe<basic_vec<T, flags>> {
   basic_vec<T, flags> new_vector;
   $prop(new_vector.reserve(allocator, max(capacity, 4u)));
   return new_vector;
}

template <typename T, vec_flags flags = {}>
[[nodiscard, gnu::always_inline, gnu::nodebug]] constexpr auto
   make_vec_reserved(dyn_allocator allocator, idx capacity)
      -> maybe<basic_vec<T, flags>> {
   return make_vec_reserved<T, dyn_allocator, flags>(allocator, capacity);
}

template <typename T, is_allocator Allocator, vec_flags flags = {}>
[[nodiscard]] constexpr auto make_vec_filled(
   allocator_ref<Allocator> allocator, idx count, T const& value
) -> maybe<basic_vec<T, flags>> {
   basic_vec<T, flags> new_vector =
      $prop((make_vec_reserved<T, Allocator, flags>(allocator, count)));
   for (idx i = 0u; i < count; ++i) {
      $prop(new_vector.push_back(allocator, value));
   }
   return new_vector;
}

template <typename T, vec_flags flags = {}>
[[nodiscard, gnu::always_inline, gnu::nodebug]] constexpr auto
   make_vec_filled(dyn_allocator allocator, idx count, T const& value)
      -> maybe<basic_vec<T, flags>> {
   return make_vec_filled<T, dyn_allocator, flags>(allocator, count, value);
}

}  // namespace manual

}  // namespace cat

