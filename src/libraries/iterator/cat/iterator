// -*- mode: c++ -*-
// vim: set ft=cpp:
#pragma once

// `cat::iterator_interface` is a mixin class for generating conventional
// iterator boilerplate from a minimal set of user-written functions. It is
// closely based on the proposed P2727R4 `std::iterator_interface`. You can also
// generate proxy iterators with `cat::proxy_iterator_interface`.
//
// We also provide helpers for generating reverse and const iterators, as well
// as simple adaptors for iterating over ranges like `cat::as_reverse` and
// `cat::as_const_reverse`. With this model, problems such as P2836 disappear.
//
// Iterator `concept`s mirror C++20 iterator concepts. Several refinement
// hierarchies apply:
//
// Incrementability refinements:
//    `cat::is_weakly_incrementable`
//    `cat::is_incrementable`
//
// Shared floor for iterators with `*` and `++`:
//    `cat::is_input_or_output_iterator`
//
// Readable traversal refinements (`is_forward_iterator` also requires
// `is_incrementable`):
//    `cat::is_indirectly_readable`
//    `cat::is_input_iterator`
//    `cat::is_forward_iterator`
//    `cat::is_bidirectional_iterator`
//    `cat::is_random_access_iterator`
//    `cat::is_contiguous_iterator`
//
// Writable traversal refinements:
//    `cat::is_indirectly_writable`
//    `cat::is_output_iterator`
//
// Raw pointers can model random access or contiguous iterators without forward
// or bidirectional `iterator_interface` tags
//
// Iterable containers:
//    `cat::is_iterable`
//    `cat::is_bidi_iterable`
//

namespace cat {
struct iterator_interface_access {
   template <typename Derived>
   static constexpr auto
   base(Derived& derived) -> decltype(derived.base_reference())
      requires requires { derived.base_reference(); }
   {
      return derived.base_reference();
   }

   template <typename Derived>
   static constexpr auto
   base(Derived const& derived) -> decltype(derived.base_reference())
      requires requires { derived.base_reference(); }
   {
      return derived.base_reference();
   }
};

template <typename Reference>
using proxy_iterator_pointer = proxy_arrow_result<remove_cvref<Reference>>;

namespace detail {
template <typename Iterator>
concept has_increment = requires(Iterator it) { it.increment(); };

template <typename Iterator>
concept has_decrement = requires(Iterator it) { it.decrement(); };

template <typename Iterator>
concept has_distance_to = requires(Iterator it) { it.distance_to(it); };

template <typename Iterator>
concept has_equal_to = requires(Iterator it) {
                          { it.equal_to(it) } -> is_convertible<bool>;
                       };

template <typename T>
concept is_object_pointer_iterator =
   is_pointer<remove_cvref<T>> && __is_object(remove_pointer<remove_cvref<T>>);

// If `.distance_to()` is not provided, default the `difference_type` to
// `iword`:
template <typename>
struct infer_difference_trait {
   using type = iword;
};

// If `iterator` provides `.distance_to()`, infer `difference_type` from
// that.
template <detail::has_distance_to Iterator>
struct infer_difference_trait<Iterator> {
   static Iterator const& it;
   using type = decltype(it.distance_to(it));
};

template <detail::is_object_pointer_iterator T>
struct infer_difference_trait<T> {
   using type = iword;
};

template <typename Iterator>
concept has_advance =
   requires(Iterator it, infer_difference_trait<Iterator>::type offset) {
      it.advance(offset);
   };

template <typename Iterator>
concept has_random_access = has_advance<Iterator> && has_distance_to<Iterator>;

template <typename Iterator>
concept has_bidirectional =
   has_random_access<Iterator> || has_decrement<Iterator>;

template <typename Argument, typename Iterator>
concept is_difference_type =
   is_convertible<Argument, typename infer_difference_trait<Iterator>::type>;

// Matches C++20 `movable` except the `swappable` clause. `move_constructible`
// and `assignable_from<T&, T>` subsume libCat iterator use cases.
template <typename Iterator>
concept is_iterator_movable =
   is_move_constructible<Iterator> && is_assignable<Iterator&, Iterator>;

template <typename T>
concept is_signed_integer_like = is_signed<T> && is_integral<T>;

template <typename T>
concept is_iterator_copyable =
   is_iterator_movable<T> && is_copy_constructible<T> && is_copy_assignable<T>;

template <typename T>
concept is_iterator_semiregular =
   is_iterator_copyable<T> && is_default_constructible<T>;

template <typename T>
concept is_iterator_regular =
   is_equality_comparable<T> && is_iterator_semiregular<T>;
}  // namespace detail

template <typename Iterator>
using infer_difference_type = detail::infer_difference_trait<Iterator>::type;

template <typename T>
using iterator_difference_type =
   typename detail::infer_difference_trait<T>::type;

struct random_access_iterator_tag {};

struct bidirectional_iterator_tag {};

struct forward_iterator_tag {};

struct input_iterator_tag {};

struct output_iterator_tag {};

struct contiguous_iterator_tag {};

struct default_sentinel_t {
   explicit constexpr default_sentinel_t() = default;
};

inline constexpr default_sentinel_t default_sentinel{};

namespace detail {

template <typename I>
concept iter_has_member_value_type =
   requires { typename remove_cvref<I>::value_type; };

template <typename I>
struct iter_value_trait;

template <typename I>
   requires(is_object_pointer_iterator<I>)
struct iter_value_trait<I> {
   using type = remove_cvref<remove_pointer<remove_cvref<I>>>;
};

template <typename I>
   requires(!is_object_pointer_iterator<I> && iter_has_member_value_type<I>)
struct iter_value_trait<I> {
   using type = remove_cvref<typename remove_cvref<I>::value_type>;
};

template <typename I>
   requires(!is_object_pointer_iterator<I> && !iter_has_member_value_type<I>)
struct iter_value_trait<I> {
   using type = void;
};

}  // namespace detail

template <typename I>
using iter_value_t = typename detail::iter_value_trait<I>::type;

// `cat::iterator_interface` is a mixin class for generating conventional
// iterator boilerplate from a minimal set of user-written functions. It is
// closely based on the proposed P2727r4 `std::iterator_interface`. Derived
// classes provide core operations for their iterator category.
//
//   Output (`output_iterator_tag`): supply `.dereference()` for * (and writes
// through * where applicable), plus either `.increment()` or `.advance(one)`
// so ++ works
//
//   Forward / input-style (often `forward_iterator_tag` or `input_iterator_tag`
// here): `.increment()` or `.advance(one)` for ++, and either
// `.equal_to(other)` or random-access hooks so == / != exist (see below)
//
//   Bidirectional (`bidirectional_iterator_tag`): add `.decrement()` unless you
// already provide random-access hooks, then `has_bidirectional` follows from
// `advance` + `distance_to`
//
//   Random access (`random_access_iterator_tag`): `.advance(offset)` using the
// inferred `difference_type` and `.distance_to(other)` so -, ordering,
// +/-/*/[], and == via zero distance compose
//
// These tags are specified rather than inferred because that could
// over-constrain implementations. For instance, a linked list iterator might
// want to provide a random-access API for convenience, but only advertise that
// it is fundamentally bidirectional or forward for algorithms to utilize
// performantly.
//
// `element_type` supplies `value_type`, `reference_type`, `pointer_type`, and
// `difference` default from it. Override them when `reference` or `pointer` are
// proxy types.
template <typename IteratorConceptTag, typename Element,
          typename Reference = Element&, typename Pointer = Element*,
          typename Difference = iword>
class iterator_interface : public iterator_interface_base {
 public:
   using iterator_concept = IteratorConceptTag;
   using value_type =
      conditional<is_void<Element>, void, remove_const<Element>>;
   using reference = Reference;
   using pointer = Pointer;
   using difference_type = Difference;
   using const_value_type =
      conditional<is_void<value_type>, void, add_const<value_type>>;
   using const_reference =
      conditional<is_void<value_type>, void,
                  add_lvalue_reference<add_const<value_type>>>;

   // If the derived iterator does not have `.advance_to()`, generate it.
   constexpr auto
   advance_to(this auto&& self,
              remove_cvref<decltype(self)> const& other_iterator)
      -> remove_cvref<decltype(self)> const& {
      if (other_iterator > self) {
         while (other_iterator > self) {
            ++self;
         }
      } else if (other_iterator < self) {
         while (other_iterator < self) {
            --self;
         }
      }
      return self;
   }

   constexpr auto
   operator*(this auto&& self) -> decltype(auto) {
      if constexpr (requires { iterator_interface_access::base(self); }) {
         return *iterator_interface_access::base(self);
      } else {
         return self.dereference();
      }
   }

   constexpr auto
   operator->(this auto const& self) -> pointer
      requires(!is_same<pointer, void>)
   {
      decltype(auto) ref = *self;
      if constexpr (is_reference<decltype(ref)>) {
         return static_cast<pointer>(__builtin_addressof(ref));
      } else {
         return static_cast<pointer>(proxy_arrow_result(move(ref)));
      }
   }

   constexpr auto
   operator+=(this auto&& self, auto offset) -> decltype(auto)
      requires(detail::is_difference_type<decltype(offset),
                                          remove_cvref<decltype(self)>>)
   {
      if constexpr (detail::has_advance<remove_cvref<decltype(self)>>) {
         self.advance(
            static_cast<typename remove_cvref<decltype(self)>::difference_type>(
               offset));
      } else {
         for (idx i; i < offset; ++i) {
            self.increment();
         }
      }
      return self;
   }

   constexpr auto
   operator++(this auto&& self) -> decltype(auto) {
      if constexpr (detail::has_increment<remove_cvref<decltype(self)>>) {
         self.increment();
      } else {
         self.advance(
            static_cast<typename remove_cvref<decltype(self)>::difference_type>(
               1));
      }
      return self;
   }

   constexpr auto
   operator++(this auto&& self, int) -> remove_cvref<decltype(self)> {
      auto copy = self;
      ++self;
      return copy;
   }

   constexpr auto
   operator--(this auto&& self) -> decltype(auto)
      requires(detail::has_bidirectional<remove_cvref<decltype(self)>>)
   {
      if constexpr (detail::has_decrement<remove_cvref<decltype(self)>>) {
         self.decrement();
      } else {
         self.advance(
            static_cast<typename remove_cvref<decltype(self)>::difference_type>(
               -1));
      }
      return self;
   }

   constexpr auto
   operator--(this auto&& self, int) -> remove_cvref<decltype(self)>
      requires(detail::has_bidirectional<remove_cvref<decltype(self)>>)
   {
      auto copy = self;
      --self;
      return copy;
   }

   constexpr auto
   operator[](this auto const& self [[clang::lifetimebound]], auto offset)
      -> decltype(auto)
      requires(detail::has_advance<remove_cvref<decltype(self)>>
               && detail::is_difference_type<decltype(offset),
                                             remove_cvref<decltype(self)>>)
   {
      return *(self + offset);
   }
};

template <typename IteratorConceptTag, typename Element,
          typename Reference = Element, typename Difference = iword>
using proxy_iterator_interface =
   iterator_interface<IteratorConceptTag, Element, Reference,
                      proxy_iterator_pointer<Reference>, Difference>;

template <typename Iterator>
using infer_iterator_pointer =
   conditional<is_lvalue_reference<typename Iterator::reference>,
               add_pointer<remove_reference<typename Iterator::reference>>,
               proxy_iterator_pointer<typename Iterator::reference>>;

template <typename Derived>
   requires(is_base_of<iterator_interface_base, remove_cvref<Derived>>)
constexpr auto
operator==(Derived const& left, Derived const& right) -> bool {
   using iter = remove_cvref<Derived>;
   if constexpr (detail::has_equal_to<iter>) {
      return left.equal_to(right);
   } else if constexpr (detail::has_distance_to<iter>) {
      return left.distance_to(right)
             == static_cast<infer_difference_type<iter>>(0);
   } else {
      __builtin_unreachable();
   }
}

template <typename Derived>
   requires(is_base_of<iterator_interface_base, remove_cvref<Derived>>
            && detail::has_distance_to<remove_cvref<Derived>>)
constexpr auto
operator<=>(Derived const& left, Derived const& right) {
   using iter = remove_cvref<Derived>;
   using diff = infer_difference_type<iter>;
   return (left - right) <=> static_cast<diff>(0);
}

template <typename Derived>
   requires(is_base_of<iterator_interface_base, remove_cvref<Derived>>)
constexpr auto
operator+(Derived const& left, auto offset) -> remove_cvref<Derived>
   requires(detail::is_difference_type<decltype(offset), remove_cvref<Derived>>)
{
   using iter = remove_cvref<Derived>;
   iter new_iterator = left;
   if constexpr (detail::has_advance<iter>) {
      new_iterator.advance(static_cast<typename iter::difference_type>(offset));
   } else {
      for (idx i; i < offset; ++i) {
         ++new_iterator;
      }
   }
   return new_iterator;
}

template <typename Derived>
   requires(is_base_of<iterator_interface_base, remove_cvref<Derived>>)
constexpr auto
operator+(auto offset, Derived const& right) -> remove_cvref<Derived>
   requires(detail::is_difference_type<decltype(offset), remove_cvref<Derived>>)
{
   using iter = remove_cvref<Derived>;
   iter new_iterator = right;
   if constexpr (detail::has_advance<iter>) {
      new_iterator.advance(static_cast<typename iter::difference_type>(offset));
   } else {
      for (idx i; i < offset; ++i) {
         ++new_iterator;
      }
   }
   return new_iterator;
}

template <typename Derived>
   requires(is_base_of<iterator_interface_base, remove_cvref<Derived>>)
constexpr auto
operator-(Derived const& left, auto offset) -> remove_cvref<Derived>
   requires(detail::is_difference_type<decltype(offset), remove_cvref<Derived>>)
{
   using iter = remove_cvref<Derived>;
   iter new_iterator = left;
   if constexpr (detail::has_advance<iter>) {
      new_iterator.advance(
         -static_cast<typename iter::difference_type>(offset));
   } else {
      for (idx i; i < offset; ++i) {
         --new_iterator;
      }
   }
   return new_iterator;
}

template <typename Derived>
   requires(is_base_of<iterator_interface_base, remove_cvref<Derived>>)
constexpr auto
operator-=(Derived& left, auto offset) -> remove_cvref<Derived>&
   requires(detail::is_difference_type<decltype(offset), remove_cvref<Derived>>)
{
   using iter = remove_cvref<Derived>;
   if constexpr (detail::has_advance<iter>) {
      left.advance(-static_cast<typename iter::difference_type>(offset));
   } else {
      for (idx i; i < offset; ++i) {
         --left;
      }
   }
   return left;
}

template <typename Derived>
   requires(is_base_of<iterator_interface_base, remove_cvref<Derived>>
            && detail::has_distance_to<remove_cvref<Derived>>)
constexpr auto
operator-(Derived const& left, Derived const& right)
   -> infer_difference_type<remove_cvref<Derived>> {
   return right.distance_to(left);
}

template <typename Iterator>
class reverse_proxy_iterator
    : public iterator_interface<
         random_access_iterator_tag, typename Iterator::value_type,
         typename Iterator::reference, infer_iterator_pointer<Iterator>,
         infer_difference_type<Iterator>> {
 private:
   using self_type = reverse_proxy_iterator<Iterator>;

 public:
   using value_type = Iterator::value_type;
   using const_value_type = Iterator::const_value_type;
   using reference = Iterator::reference;
   using const_reference = Iterator::const_reference;

   constexpr reverse_proxy_iterator(Iterator const& other)
       : m_internal_iterator(other) {
   }

   // Forward any constructor to the `internal_iterator`.
   template <typename... Args>
   constexpr reverse_proxy_iterator(Args&&... arguments)
       : m_internal_iterator(fwd(arguments)...) {
   }

   constexpr auto
   dereference() -> decltype(auto) {
      return m_internal_iterator.dereference();
   }

   constexpr auto
   dereference() const -> decltype(auto) {
      return m_internal_iterator.dereference();
   }

   constexpr void
   advance(iword offset)
      requires(detail::has_advance<Iterator>)
   {
      m_internal_iterator.advance(-offset);
   }

   constexpr void
   increment() {
      --m_internal_iterator;
   }

   constexpr void
   decrement() {
      ++m_internal_iterator;
   }

   constexpr auto
   distance_to(self_type const& other) const
      requires(detail::has_distance_to<Iterator>)
   {
      // Reverse the polarity of `distance_to()`.
      return -m_internal_iterator.distance_to(other.m_internal_iterator);
   }

 private:
   Iterator m_internal_iterator;
};

template <template <typename, auto...> typename Iterator, typename T,
          auto... args>
using const_proxy_iterator = Iterator<T const, args...>;

// TODO: More iterable related `concept`s.
template <typename T>
concept is_iterable = requires(T it) {
                         it.begin();
                         it.end();
                      };

template <typename T>
concept is_bidi_iterable = requires(T it) {
                              it.begin();
                              it.end();
                              it.rbegin();
                              it.rend();
                           };

template <typename T>
concept is_weakly_incrementable =
   detail::is_iterator_movable<remove_cvref<T>>
   && detail::is_signed_integer_like<iterator_difference_type<T>>
   && detail::is_iterator_movable<iterator_difference_type<T>>
   && requires(remove_cvref<T> it) {
         { ++it } -> is_same<remove_cvref<T>&>;
         it++;
      };

template <typename T>
concept is_incrementable =
   is_weakly_incrementable<T>
   && requires(remove_cvref<T> it) {
         { it++ } -> is_same<remove_cvref<T>>;
      } && (detail::is_object_pointer_iterator<T> || detail::is_iterator_regular<remove_cvref<T>>);

template <typename T>
using iterator_reference = decltype(*declval<T&>());

template <typename T>
using iter_reference_t = iterator_reference<T>;

template <typename T>
using iter_rvalue_reference_t = decltype(move(*declval<T&>()));

template <typename T>
using iter_difference_t = iterator_difference_type<T>;

template <typename T>
concept is_input_or_output_iterator =
   requires(T it) { *it; } && is_weakly_incrementable<T>;

// [iterator.concept.readable]
template <typename In>
concept is_indirectly_readable = requires(remove_cvref<In> const in) {
                                    typename iter_value_t<remove_cvref<In>>;
                                    { *in };
                                 };

// [iterator.concept.input]
template <typename T>
concept is_input_iterator =
   is_input_or_output_iterator<T> && is_indirectly_readable<T>
   && is_equality_comparable<T>;

template <typename T>
concept is_random_access_iterator =
   detail::is_object_pointer_iterator<T>
   || (is_base_of<iterator_interface_base, remove_cvref<T>>
       && is_same<typename remove_cvref<T>::iterator_concept,
                  random_access_iterator_tag>);

template <typename T>
concept is_contiguous_iterator =
   is_random_access_iterator<T>
   && (detail::is_object_pointer_iterator<T>
       || (is_base_of<iterator_interface_base, remove_cvref<T>>
           && is_same<typename remove_cvref<T>::iterator_concept,
                      contiguous_iterator_tag>));

template <typename T>
concept is_bidirectional_iterator =
   is_random_access_iterator<T>
   || (is_base_of<iterator_interface_base, remove_cvref<T>>
       && is_same<typename remove_cvref<T>::iterator_concept,
                  bidirectional_iterator_tag>);

namespace detail {

template <typename T>
concept iter_has_forward_capacity_tag =
   is_base_of<iterator_interface_base, remove_cvref<T>>
   && (is_same<typename remove_cvref<T>::iterator_concept, forward_iterator_tag>
       || is_same<typename remove_cvref<T>::iterator_concept,
                  bidirectional_iterator_tag>
       || is_same<typename remove_cvref<T>::iterator_concept,
                  random_access_iterator_tag>
       || is_same<typename remove_cvref<T>::iterator_concept,
                  contiguous_iterator_tag>);

template <typename T>
concept iter_is_pure_input_interface_iterator =
   is_base_of<iterator_interface_base, remove_cvref<T>>
   && is_same<typename remove_cvref<T>::iterator_concept, input_iterator_tag>;

}  // namespace detail

// [iterator.concept.forward]
template <typename T>
concept is_forward_iterator =
   is_input_iterator<T> && is_incrementable<T>
   && (detail::is_object_pointer_iterator<T>
       || (detail::iter_has_forward_capacity_tag<T>
           && !detail::iter_is_pure_input_interface_iterator<T>));

template <typename Outputter, typename Value>
concept is_indirectly_writable =
   requires(Outputter&& output_iterator, Value&& value) {
      *output_iterator = fwd(value);
      *fwd(output_iterator) = fwd(value);
      const_cast<iterator_reference<Outputter> const&&>(*output_iterator) =
         fwd(value);
      const_cast<iterator_reference<Outputter> const&&>(*fwd(output_iterator)) =
         fwd(value);
   };

template <typename Outputter, typename Value>
concept is_output_iterator =
   is_input_or_output_iterator<Outputter>
   && is_indirectly_writable<Outputter, Value>
   && requires(Outputter iterator, Value&& value) { *iterator++ = fwd(value); };

// With a similar syntax to `as_const()`, this wrapper takes an iterable
// container and inverts its iterator's forwards and backwards movement.
template <is_bidi_iterable Collection>
struct as_reverse : Collection {
   constexpr as_reverse(Collection& base) : Collection(base) {
   }

   constexpr as_reverse(Collection&& base)
      requires(is_rvalue_reference<decltype(base)>)
       : Collection(move(base)) {
   }

   constexpr auto
   begin() {
      return static_cast<Collection*>(this)->rbegin();
   }

   constexpr auto
   end() {
      return static_cast<Collection*>(this)->rend();
   }

   constexpr auto
   begin() const {
      return static_cast<Collection*>(this)->rbegin();
   }

   constexpr auto
   end() const {
      return static_cast<Collection*>(this)->rend();
   }

   constexpr auto
   cbegin() const {
      return static_cast<Collection*>(this)->crbegin();
   }

   constexpr auto
   cend() const {
      return static_cast<Collection*>(this)->crend();
   }

   constexpr auto
   rbegin() {
      return static_cast<Collection*>(this)->begin();
   }

   constexpr auto
   rend() {
      return static_cast<Collection*>(this)->end();
   }

   constexpr auto
   rbegin() const {
      return static_cast<Collection*>(this)->cbegin();
   }

   constexpr auto
   rend() const {
      return static_cast<Collection*>(this)->cend();
   }

   constexpr auto
   crbegin() const {
      return static_cast<Collection*>(this)->cbegin();
   }

   constexpr auto
   crend() const {
      return static_cast<Collection*>(this)->cend();
   }
};

// With a similar syntax to `as_const()`, this wrapper takes an iterable
// container, makes its iterator `const`, and inverts its forwards and backwards
// movement.
template <is_bidi_iterable Collection>
struct as_const_reverse : Collection {
   constexpr as_const_reverse(Collection& base) : Collection(base) {
   }

   constexpr as_const_reverse(Collection&& base)
      requires(is_rvalue_reference<decltype(base)>)
       : Collection(move(base)) {
   }

   constexpr auto
   begin() const {
      return static_cast<Collection const*>(this)->rbegin();
   }

   constexpr auto
   end() const {
      return static_cast<Collection const*>(this)->rend();
   }

   constexpr auto
   cbegin() const {
      return static_cast<Collection const*>(this)->crbegin();
   }

   constexpr auto
   cend() const {
      return static_cast<Collection const*>(this)->crend();
   }

   constexpr auto
   rbegin() const {
      return static_cast<Collection const*>(this)->cbegin();
   }

   constexpr auto
   rend() const {
      return static_cast<Collection const*>(this)->cend();
   }

   constexpr auto
   crbegin() const {
      return static_cast<Collection const*>(this)->cbegin();
   }

   constexpr auto
   crend() const {
      return static_cast<Collection const*>(this)->cend();
   }
};

}  // namespace cat
