// While libCat supports Stepanov-like iterators, algorithmic composition is
// generally done with a model closely inspired by the Flux v2
// "sequence-orientated programming model" proposed by Tristan Brindle.
// https://tristanbrindle.com/posts/the-road-to-flux-10
//
// Iteration is defined by two complementary protocols:
//
// `is_iterable`    Single-pass internal iteration via an
//                  `iteration_context`. The context owns the loop and
//                  fuses read-and-advance, which structurally rules
//                  dangling iteration state.

// `is_collection`  Multi-pass position-based access. A "position" is a
//                  regular, totally-ordered value, and reads always go
//                  through the parent collection so dangling is not a
//                  category of bug.
//
// An `iteration_context` can model any type of collection. It exposes a
// `.run_while(callback)` member that returns a `cat::iteration_result`.
// Iteration contexts are non-copyable and non-movable to enforce that they
// cannot outlive their parent and cannot be aliased against it.
//
// A "collection" models multipass access using Flux v2 customization points
// (`cat::begin_pos()`, `cat::end_pos()`, `cat::inc_pos()`,
// `cat::read_at_unchecked()`), and other refinements. A model usually
// implements these as members, which these CPOs call by default. The `position`
// type is `is_regular` and totally ordered. All collections are iterables.
//
// Collections are automatically iterable by `cat::collection_iteration_context`
// or `cat::reverse_collection_iteration_context`.
//
// A container, for example, could be either a collection or merely iterable.
//
// Either of these can "pipe" into a function pipeline. If this iterable
// implements the `cat::iterable_interface`, then a dot-chaining fluent API may
// be used instead. However, this design is not user-extensible, whereas the
// pipe-chaining API is.
//
// Iterables pipe into "views", which model lazily evaluated functions.
// Pipelines end in a "terminal", which eagerly evaluates.
//
// Views take ownership of their base by value. An r-value argument is moved
// into its view. A trivially-copyable lvalue is copied, but
// non-trivially-copyable lvalues are rejected. They must be passed through
// `cat::ref` or `cat::cref` explicitly to opt in to non-owning aliasing. This
// makes accidental dangling references against temporaries impossible.
//
// `is_collection` refines into a small hierarchy:
//
//    `is_collection`                - position + `read_at_unchecked` CPOs.
//    `is_bidirectional_collection`  - `dec_pos` CPO.
//    `is_random_access_collection`  - `offset_pos` and `distance` CPOs
//
// A bidirectional collection auto-derives `reverse_iterate(data)` via a
// `reverse_collection_iteration_context`, so `data | cat::reverse()` works by
// default.
//
// On the random-access leaf we also expose four bounds-checked accessors:
// `read_at`, `try_read_at`, `slice`, and `as_span` (the last only for
// collections that already carry contiguous storage).

namespace cat {

// A `run_while` loop returns `iteration_result` to signal its status.
enum class iteration_result : bool {
   incomplete = false,  // The loop was suspened.
   complete = true,     // The loop completed.
};

}  // namespace cat

// Member-call mixin and contiguous position helpers live in
// <cat/detail/iterable_interface.hpp>. Iterable member implementations are
// included from the bottom of this header.

namespace cat::detail {
// Peel `reference_wrapper` so adapters and range-for see the wrapped iterable.
template <typename T>
constexpr auto
unwrap_ref(T& value) -> T& {
   return value;
}

template <typename T>
constexpr auto
unwrap_ref(::cat::reference_wrapper<T>& borrow) -> T& {
   return borrow.get();
}

template <typename T>
constexpr auto
unwrap_ref(::cat::reference_wrapper<T> const& borrow) -> T& {
   return borrow.get();
}
}  // namespace cat::detail

namespace cat {

// A `position` is a handle to a collection element. It is regular and strictly
// totally ordered. The strict total order is what lets us bounds-check
// arbitrary slices in constant time.
template <typename P>
concept is_position = requires(P const& left, P const& right) {
                         P{};
                         P{left};
                         { left == right } -> is_convertible<bool>;
                         { left < right } -> is_convertible<bool>;
                      };

template <typename Collection>
[[nodiscard]]
constexpr auto
begin_pos(Collection const& collection) {
   return collection.begin_pos();
}

template <typename Collection>
[[nodiscard]]
constexpr auto
end_pos(Collection const& collection) {
   return collection.end_pos();
}

template <typename Collection, typename Position>
constexpr void
inc_pos(Collection const& collection, Position& position) {
   collection.inc_pos(position);
}

template <typename Collection, typename Position>
constexpr void
dec_pos(Collection const& collection, Position& position) {
   collection.dec_pos(position);
}

template <typename Collection, typename Position>
[[nodiscard]]
constexpr auto
read_at_unchecked(Collection& collection, Position const& position)
   -> decltype(auto) {
   return collection.read_at_unchecked(position);
}

template <typename Collection, typename Position>
[[nodiscard]]
constexpr auto
read_at_unchecked(Collection const& collection, Position const& position)
   -> decltype(auto) {
   return collection.read_at_unchecked(position);
}

template <typename Collection, typename Position>
constexpr void
offset_pos(Collection const& collection, Position& position, iword offset) {
   collection.offset_pos(position, offset);
}

template <typename Collection, typename Position>
[[nodiscard]]
constexpr auto
distance(Collection const& collection, Position const& from, Position const& to)
   -> iword {
   return collection.distance(from, to);
}

namespace detail {
template <typename T>
concept is_contiguous_position_model =
   is_base_of<contiguous_position_interface<remove_cv<T>>, remove_cv<T>>;

// Private hooks on the contiguous default are not `requires`able as members, so
// that model is detected by base-class. All other collections still use the
// public `begin_pos` / `end_pos` member spellings here.
template <typename T>
concept has_position_protocol =
   is_contiguous_position_model<T> || (requires(T const& c) {
                                          c.begin_pos();
                                          c.end_pos();
                                       });
}  // namespace detail

template <detail::has_position_protocol T>
using position_type = remove_cvref<decltype(begin_pos(declval<T const&>()))>;

// `is_collection` holds when the Flux CPOs `inc_pos` and `read_at_unchecked`
// (non-const collection on the first argument for the read) exist for a model.
template <typename T>
concept is_collection =
   detail::has_position_protocol<T> && is_position<position_type<T>>
   && requires(T& c, position_type<T>& p, position_type<T> const& r) {
         inc_pos(c, p);
         read_at_unchecked(c, r);
      };

// `is_bidirectional_collection` adds `dec_pos` for reverse walks.
template <typename T>
concept is_bidirectional_collection =
   is_collection<T>
   && requires(T const& c, position_type<T>& p) { dec_pos(c, p); };

// `is_random_access_collection` adds in-place `offset_pos` and `distance` CPOs
// (satisfied by members on the default contiguous adapters).
template <typename T>
concept is_random_access_collection =
   is_bidirectional_collection<T>
   && requires(T const& c, position_type<T>& p, position_type<T> const& a,
               position_type<T> const& b, iword offset) {
         offset_pos(c, p, offset);
         { distance(c, a, b) } -> is_convertible<iword>;
      };

// `collection_iteration_context<T>` is the default iterable adapter for any
// collection: walk positions from `begin_pos` to `end_pos` and read through
// `read_at_unchecked`. It is non-copyable and non-movable, so it cannot be
// hoisted out of its parent's scope.
template <typename T>
class collection_iteration_context {
   T* m_p_collection;
   position_type<T> m_position;
   position_type<T> m_stop;

 public:
   using element_type = decltype(read_at_unchecked(
      declval<T&>(), declval<position_type<T> const&>()));

   constexpr collection_iteration_context(T* p_collection,
                                          position_type<T> begin_position,
                                          position_type<T> end_position)
       : m_p_collection(p_collection),
         m_position(begin_position),
         m_stop(end_position) {
   }

   collection_iteration_context(collection_iteration_context const&) = delete;
   collection_iteration_context(collection_iteration_context&&) = delete;
   auto
   operator=(collection_iteration_context const&)
      -> collection_iteration_context& = delete;
   auto
   operator=(collection_iteration_context&&)
      -> collection_iteration_context& = delete;

   template <is_predicate<element_type> LoopBody>
   constexpr auto
   run_while(LoopBody&& loop_body) -> iteration_result {
      while (m_position < m_stop) {
         auto const position_before_advance = m_position;
         inc_pos(*m_p_collection, m_position);
         if (!loop_body(
                read_at_unchecked(*m_p_collection, position_before_advance))) {
            return iteration_result::incomplete;
         }
      }
      return iteration_result::complete;
   }
};

// `reverse_collection_iteration_context<T>` walks a bidirectional collection
// backwards. The loop holds a position one past the next element to read.
// Before each call to `read_at_unchecked` it steps `.dec_pos(p)` so the
// position lands on the element being read. This is why the context only
// requires `.dec_pos(p)` from `T`. It never needs to step "before begin".
template <typename T>
class reverse_collection_iteration_context {
   T* m_p_collection;
   position_type<T> m_position;
   position_type<T> m_stop;

 public:
   using element_type = decltype(read_at_unchecked(
      declval<T&>(), declval<position_type<T> const&>()));

   constexpr reverse_collection_iteration_context(
      T* p_collection, position_type<T> begin_position,
      position_type<T> end_position)
       : m_p_collection(p_collection),
         m_position(begin_position),
         m_stop(end_position) {
   }

   reverse_collection_iteration_context(
      reverse_collection_iteration_context const&) = delete;
   reverse_collection_iteration_context(
      reverse_collection_iteration_context&&) = delete;
   auto
   operator=(reverse_collection_iteration_context const&)
      -> reverse_collection_iteration_context& = delete;
   auto
   operator=(reverse_collection_iteration_context&&)
      -> reverse_collection_iteration_context& = delete;

   template <is_predicate<element_type> LoopBody>
   constexpr auto
   run_while(LoopBody&& loop_body) -> iteration_result {
      while (m_stop < m_position) {
         dec_pos(*m_p_collection, m_position);
         if (!loop_body(read_at_unchecked(*m_p_collection, m_position))) {
            return iteration_result::incomplete;
         }
      }
      return iteration_result::complete;
   }
};

