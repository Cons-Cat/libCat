namespace x64 {
namespace detail {
template <cat::is_unsigned T>
[[nodiscard]]
constexpr auto
extract_bits_fallback(T from, cat::uint1 offset, cat::idx length) -> T {
   constexpr cat::idx bits = sizeof(T) * 8u;
   auto raw_from = cat::make_raw_arithmetic(from);

   if (offset >= bits || length == 0u) {
      return 0u;
   }

   raw_from >>= offset.raw;
   auto const remaining_bits = bits - offset;
   if (length >= remaining_bits) {
      return T(raw_from);
   }

   using raw_type = cat::raw_arithmetic_type<T>;
   raw_type const mask = (raw_type(1u) << length.raw) - 1u;
   return T(raw_from & mask);
}

template <cat::is_unsigned_integral T, cat::is_unsigned_integral U>
   requires(sizeof(T) == sizeof(U))
[[nodiscard]]
constexpr auto
parallel_extract_bits_fallback(T value, U mask) -> T {
   T result = 0u;
   auto raw_value = cat::make_raw_arithmetic(value);
   auto raw_mask = cat::make_raw_arithmetic(mask);
   cat::raw_arithmetic_type<T> count = 0u;

   while (raw_mask != 0u) {
      if (raw_mask & 1) {
         result >>= 1;
         result |= T(raw_value << ((sizeof(T) * 8u) - 1u));
         ++count;
      }
      raw_value >>= 1;
      raw_mask >>= 1;
   }

   result >>= ((sizeof(T) * 8u) - count) * (count > 0u);
   return result;
}

template <cat::is_unsigned_integral T, cat::is_unsigned_integral U>
   requires(sizeof(T) == sizeof(U))
[[nodiscard]]
constexpr auto
deposit_bits_mask_fallback(T value, U mask) -> T {
   T result = 0u;
   auto raw_value = cat::make_raw_arithmetic(value);
   auto raw_mask = cat::make_raw_arithmetic(mask);
   cat::raw_arithmetic_type<T> count = 0u;

   while (raw_mask != 0u) {
      result >>= 1;
      if (raw_mask & 1) {
         result |= T(raw_value << ((sizeof(T) * 8u) - 1u));
         raw_value >>= 1;
      }
      raw_mask >>= 1;
      ++count;
   }

   result >>= ((sizeof(T) * 8u) - count) * (count > 0u);
   return result;
}

template <cat::is_unsigned_integral T>
[[nodiscard]]
constexpr auto
zero_high_bits_at_fallback(T source, cat::uint4 bit_index) -> T {
   constexpr cat::idx bits = sizeof(T) * 8u;
   if (bit_index == 0u) {
      return 0u;
   }
   if (bit_index >= bits) {
      return source;
   }

   using raw_type = cat::raw_arithmetic_type<T>;
   raw_type const mask = (raw_type(1u) << bit_index.raw) - 1u;
   return T(cat::make_raw_arithmetic(source) & mask);
}

template <cat::is_unsigned_integral T, cat::is_unsigned_integral U>
   requires(sizeof(T) == sizeof(U))
[[nodiscard]]
constexpr auto
and_not_fallback(T left, U right) -> T {
   return T(~cat::make_raw_arithmetic(left) & cat::make_raw_arithmetic(right));
}

template <cat::is_unsigned_integral T>
[[nodiscard]]
constexpr auto
extract_lowest_bit_fallback(T value) -> T {
   using raw_type = cat::raw_arithmetic_type<T>;
   raw_type const raw_value = cat::make_raw_arithmetic(value);
   return T(raw_value & raw_type(0u - raw_value));
}

template <cat::is_unsigned_integral T>
[[nodiscard]]
constexpr auto
mask_through_lowest_bit_fallback(T value) -> T {
   using raw_type = cat::raw_arithmetic_type<T>;
   raw_type const raw_value = cat::make_raw_arithmetic(value);
   return T(raw_value ^ raw_type(raw_value - 1u));
}

template <cat::is_unsigned_integral T>
[[nodiscard]]
constexpr auto
reset_lowest_bit_fallback(T value) -> T {
   using raw_type = cat::raw_arithmetic_type<T>;
   raw_type const raw_value = cat::make_raw_arithmetic(value);
   return T(raw_value & raw_type(raw_value - 1u));
}

template <cat::is_unsigned_integral T>
[[nodiscard]]
constexpr auto
shift_left_by_fallback(T value, cat::uword count) -> T {
   constexpr cat::idx bits = sizeof(T) * 8u;
   if (count >= bits) {
      return 0u;
   }
   return T(cat::make_raw_arithmetic(value) << count.raw);
}

template <cat::is_unsigned_integral T>
[[nodiscard]]
constexpr auto
shift_right_by_fallback(T value, cat::uword count) -> T {
   constexpr cat::idx bits = sizeof(T) * 8u;
   if (count >= bits) {
      return 0u;
   }
   return T(cat::make_raw_arithmetic(value) >> count.raw);
