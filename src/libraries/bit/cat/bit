// Reverse every bit in an unsigned integer.
template <is_unsigned_integral T>
   requires(!is_idx<T>)  // TODO: Support `idx` without setting its high bit.
[[nodiscard]]
constexpr auto
bit_reverse(T value) -> T {
   auto raw_value = make_raw_arithmetic(value);
   if constexpr (sizeof(raw_value) == 1) {
      return T(__builtin_bitreverse8(static_cast<unsigned char>(raw_value)));
   } else if constexpr (sizeof(raw_value) == 2) {
      return T(__builtin_bitreverse16(static_cast<unsigned short>(raw_value)));
   } else if constexpr (sizeof(raw_value) == 4) {
      return T(__builtin_bitreverse32(static_cast<unsigned int>(raw_value)));
   } else if constexpr (sizeof(raw_value) == 8) {
      return T(
         __builtin_bitreverse64(static_cast<unsigned long long>(raw_value))
      );
   }
}

// Repeat the first `pattern_bits` count of low bits in `value` across the
// result as many times as they fits. If they fit unevenly,
template <is_unsigned_integral T>
   requires(!is_idx<T>)  // TODO: Support `idx` without setting its high bit.
[[nodiscard]]
constexpr auto
bit_repeat(T value, idx pattern_bits) -> T {
   if !consteval {
      assert(pattern_bits > 0u);
   }
   constexpr idx bits = limits<T>::digits;
   if (pattern_bits >= bits) {
      return value;
   }
   T result = 0u;
   for (idx bit_index = 0u; bit_index < bits; ++bit_index) {
      idx const source_bit = bit_index % pattern_bits;
      if ((shift_right(value, source_bit) % T(2u)) != 0u) {
         result += shift_left(T(1u), bit_index);
      }
   }
   return result;
}

// Pack source bits selected by `mask` contiguously toward the low bit.
template <is_unsigned_integral T>
   requires(!is_idx<T>)  // TODO: Support `idx` without setting its high bit.
[[nodiscard]]
constexpr auto
bit_compress(T value, T mask) -> T {
   return ::x64::parallel_extract_bits(value, mask);
}

// Scatter low source bits into the one-bit positions of `mask`.
template <is_unsigned_integral T>
   requires(!is_idx<T>)  // TODO: Support `idx` without setting its high bit.
[[nodiscard]]
constexpr auto
bit_expand(T value, T mask) -> T {
   return ::x64::deposit_bits_mask(value, mask);
}

