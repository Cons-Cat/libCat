// Returns the number of one bits in `value`.
template <is_unsigned_integral T>
[[nodiscard]]
constexpr auto
popcount(T value) -> uint1 {
   // This intrinsic returns `int` but it can't exceed 64 so it's safe to cast.
   return uint1(__builtin_popcountg(make_raw_arithmetic(value)));
}

// Returns whether `value` has exactly one set bit. For zero, returns false.
template <is_unsigned_integral T>
[[nodiscard]]
constexpr auto
has_single_bit(T value) -> bool {
   return __builtin_stdc_has_single_bit(make_raw_arithmetic(value));
}

// Returns the largest power of two less than or equal to `value`. For zero,
// returns zero.
template <is_unsigned_integral T>
[[nodiscard]]
constexpr auto
bit_floor(T value) -> T {
   return T(__builtin_stdc_bit_floor(make_raw_arithmetic(value)));
}

// Returns the smallest power of two greater than or equal to `value`. For zero,
// returns one. Undefined behavior if the result is not representable.
template <is_unsigned_integral T>
[[nodiscard]]
constexpr auto
bit_ceil(T value) -> T {
   return T(__builtin_stdc_bit_ceil(make_raw_arithmetic(value)));
}

// Returns `value` rotated left by `shift` positions. Shifts wrap around the bit
// width of `T`.
template <is_unsigned_integral T>
   requires(!detail::is_idx<T>)  // TODO: Support `idx`.
[[nodiscard]]
constexpr auto
rotate_left(T value, uword shift) -> T {
   return T(__builtin_stdc_rotate_left(make_raw_arithmetic(value), shift.raw));
}

// Returns `value` rotated left by `shift` positions. Shifts wrap around the bit
// width of `T`. Negative shifts rotate right by the same magnitude value.
template <is_unsigned_integral T>
   requires(!detail::is_idx<T>)
[[nodiscard]]
constexpr T
rotate_left(T value, iword shift) {
   // Unsigned wrap is intentional so the most-negative value has a magnitude.
   uword magnitude = 0u - shift;
   return rotate_right(value, magnitude);
}

template <is_unsigned_integral T>
   requires(!detail::is_idx<T>)
[[nodiscard]]
constexpr auto
rotate_right(T value, uword shift) -> T;

// Returns `value` rotated left by `shift` positions. Shifts wrap around the bit
// width of `T`.
template <is_unsigned_integral T>
   requires(!detail::is_idx<T>)
[[nodiscard]]
constexpr T
rotate_left(T value, iword shift)
   // When a signed positive shift constant is inputted, forward to
   // `cat::rotate_right()`.
   __attribute__((enable_if(shift.raw >= 0, ""))) {
   // Unsigned wrap is intentional so the most-negative value has a magnitude.
   uword magnitude = 0u - shift;
   return rotate_right(value, uword(magnitude));
}

// Returns `value` rotated right by `shift` positions. Shifts wrap around the
// bit width of `T`.
template <is_unsigned_integral T>
   requires(!detail::is_idx<T>)  // TODO: Support `idx`.
[[nodiscard]]
constexpr auto
rotate_right(T value, uword shift) -> T {
   return T(__builtin_stdc_rotate_right(make_raw_arithmetic(value), shift.raw));
}

// Returns `value` rotated right by `shift` positions. Shifts wrap around the
// bit width of `T`. Negative shifts rotate left by the same magnitude value.
template <is_unsigned_integral T>
   requires(!detail::is_idx<T>)
[[nodiscard]]
constexpr T
rotate_right(T value, iword shift) {
   // Unsigned wrap is intentional so the most-negative value has a magnitude.
   uword magnitude = 0u - shift;
   return rotate_left(value, magnitude);
}

// Returns `value` rotated right by `shift` positions. Shifts wrap around the
// bit width of `T`.
template <is_unsigned_integral T>
   requires(!detail::is_idx<T>)
[[nodiscard]]
constexpr T
rotate_right(T value, iword shift)
   // When a signed positive shift constant is inputted, forward to
   // `cat::rotate_left()`.
   __attribute__((enable_if(shift.raw >= 0, ""))) {
   // Unsigned wrap is intentional so the most-negative value has a magnitude.
   uword magnitude = 0u - shift;
   return rotate_left(value, uword(magnitude));
}

