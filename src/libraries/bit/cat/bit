// Count the number of leading zero bits (counting "leftwards") before the first
// found zero bit. When the input is zero, this returns the bit width of `T`.
template <is_unsigned_integral T>
   requires(!detail::is_idx<T>)
[[nodiscard]]
constexpr auto
countl_zero(T value) -> uint1 {
   return uint1(__builtin_stdc_leading_zeros(make_raw_arithmetic(value)));
}

// The overloads of `countl_zero_raw()` are implemented in
// `../implementations/bit_raw.tpp`.

// When a constant 0 is inputted, this function is disabled.
template <is_unsigned_integral T>
   requires(!detail::is_idx<T>)
[[nodiscard]]
consteval maybe<uint1>
countl_zero_raw(T value) __attribute__((enable_if(
   value == 0u,
   "Input must be non-zero! Consider `cat::countl_zero()` instead for "
   "known 0 input. If you must use this version, consider wrapping "
   "input in `cat::deconst()`."))) = delete;

// Count the number of leading one bits (counting "leftwards") before the first
// found zero bit. When the input is zero, this returns zero.
template <is_unsigned_integral T>
   requires(!detail::is_idx<T>)
[[nodiscard]]
constexpr auto
countl_one(T value) -> uint1 {
   return uint1(__builtin_stdc_leading_ones(make_raw_arithmetic(value)));
}

// The overloads of `countl_one_raw()` are implemented in
// `../implementations/bit_raw.tpp`.

// When a constant zero is inputted, this function is disabled.
template <is_unsigned_integral T>
   requires(!detail::is_idx<T>)
[[nodiscard]]
consteval maybe<uint1>
countl_one_raw(T value) __attribute__((
   enable_if(value == 0u,
             "Input must be non-zero! Consider `cat::countl_one()` instead for "
             "known 0 input. If you must use this version, consider "
             "wrapping input in `cat::deconst()`."))) = delete;

// Count the number of trailing zero bits (counting "rightwards") before the
// first found one bit. When the input is zero, this returns the bit width of
// `T`.
template <is_unsigned_integral T>
[[nodiscard]]
constexpr auto
countr_zero(T value) -> uint1 {
   return uint1(__builtin_stdc_trailing_zeros(make_raw_arithmetic(value)));
}

// The overloads of `countr_zero_raw()` are implemented in
