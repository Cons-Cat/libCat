   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr auto
   bit_reverse() const -> byte {
      return byte(cat::bit_reverse(value));
   }

   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr auto
   bit_repeat(idx pattern_bits) const -> byte {
      return byte(cat::bit_repeat(value, pattern_bits));
   }

   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr auto
   bit_compress(byte mask) const -> byte {
      return byte(cat::bit_compress(value, mask.value));
   }

   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr auto
   bit_expand(byte mask) const -> byte {
      return byte(cat::bit_expand(value, mask.value));
   }
};

