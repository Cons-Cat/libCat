// `byte` is a storage type which enables bitwise operations but not arithmetic.
// TODO: Add some member functions.
struct byte : bitwise_interface<byte> {
   constexpr byte() = default;

   uint1 value;

   template <typename T>
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr explicit
   operator T()
      requires(sizeof(T) == 1)
   {
      return __builtin_bit_cast(T, value);
   }

   // Generate `operator&`.
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr auto
   bit_and(is_integral auto from) const -> byte {
      return this->value & from;
   }

   // Generate `operator|`.
   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr auto
   bit_or(is_integral auto from) const -> byte {
      return this->value | from;
   }

   // Generate `operator<<`.
   template <is_arithmetic U>
   [[nodiscard, gnu::always_inline, gnu::nodebug, gnu::always_inline,
     gnu::nodebug]]
   constexpr auto
   shift_left_by(U operand) const -> byte {
      return value << operand;
   }

   template <is_arithmetic U>
   [[nodiscard, gnu::always_inline, gnu::nodebug, gnu::always_inline,
     gnu::nodebug]]
   constexpr auto
   shift_left_into(U other) const -> U {
      return other << value;
   }

   // Generate `operator>>`.
   template <is_arithmetic U>
   [[nodiscard, gnu::always_inline, gnu::nodebug, gnu::always_inline,
     gnu::nodebug]]
   constexpr auto
   shift_right_by(U operand) const -> byte {
      return value >> operand;
   }

   template <is_arithmetic U>
   [[nodiscard, gnu::always_inline, gnu::nodebug, gnu::always_inline,
     gnu::nodebug]]
   constexpr auto
   shift_right_into(U other) const -> U {
      return other >> value;
   }

   [[nodiscard, gnu::always_inline, gnu::nodebug]]
   constexpr auto
   has_single_bit() const -> bool {
      return __builtin_stdc_has_single_bit(make_raw_arithmetic(value));
   }
};

static_assert(is_implicit_lifetime<cat::byte>);

template <is_integral T>
   requires(!is_unsigned_integral<T>)
[[nodiscard]]
constexpr auto
has_single_bit(T value) -> bool {
   return __builtin_stdc_has_single_bit(
      static_cast<make_unsigned_type<raw_arithmetic_type<T>>>(
         make_raw_arithmetic(value)));
}

[[nodiscard]]
constexpr auto
has_single_bit(byte value) -> bool {
   return value.has_single_bit();
}

template <typename>
struct enum_flag_trait : false_trait {};

template <typename T>
concept is_enum_flag = enum_flag_trait<T>::value;

}  // namespace cat

template <cat::is_enum_flag T>
[[nodiscard]]
constexpr auto
operator|(T flag_1, T flag_2) -> T {
   using U = cat::underlying_type<T>;
   return static_cast<T>(static_cast<U>(flag_1) | static_cast<U>(flag_2));
}

template <cat::is_enum_flag T>
constexpr auto
operator|=(T& self, T other) -> T& {
   self = self | other;
   return self;
}

// TODO: Enable selective compatibility between multiple enum flag types.
// For example, `nix::open_mode` and `nix::open_flags`.
template <cat::is_enum_flag T>
[[nodiscard]]
constexpr auto
operator&(T flag_1, T flag_2) -> T {
   using U = cat::underlying_type<T>;
   return static_cast<T>(static_cast<U>(flag_1) & static_cast<U>(flag_2));
}

template <cat::is_enum_flag T>
constexpr auto
operator&=(T& self, T other) -> T& {
   self = self & other;
   return self;
}

// Re-introduce the global enum-flag operators inside `cat::` so unqualified
// lookup from inside `cat::` finds them alongside other `cat::operator|`.
// Without the using-declarations the namespace-scoped overload would shadow the
// global one and these would never resolve.
//
// TODO: This is still a problem in user namespaces.
namespace cat {
using ::operator|;
using ::operator|=;
using ::operator&;
using ::operator&=;
}  // namespace cat

