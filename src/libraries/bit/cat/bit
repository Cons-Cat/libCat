      __has_builtin(__builtin_ia32_bextr_u64) && sizeof(T) == 8
   ) {
      return __builtin_ia32_bextr_u64(raw_from, offset.raw | (raw_length << 8));
   } else {
      return extract_bits_fallback(from, offset, length);
