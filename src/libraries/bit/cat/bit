namespace detail {
// Count set bits in a byte buffer at runtime.
[[nodiscard]]
auto
popcount_bytes_runtime(byte const* _Nonnull p_bytes, idx bytes) -> idx;

// Count set bits in a word buffer at runtime.
[[nodiscard]]
auto
popcount_words_runtime(
   uword const* _Nonnull p_words, idx words, uword tail_mask
) -> idx;
}  // namespace detail

// Count set bits across a byte span.
template <idx fixed_extent>
[[nodiscard]]
constexpr auto
popcount(span<byte const, fixed_extent> bytes) -> idx {
   if consteval {
      idx count = 0u;
      for (idx i = 0u; i < bytes.size(); ++i) {
         count += popcount(bytes[i]);
      }
      return count;
   } else {
      return detail::popcount_bytes_runtime(bytes.data(), bytes.size());
   }
}

// Count set bits across a word span.
template <is_unsigned_integral Word, idx fixed_extent>
[[nodiscard]]
constexpr auto
popcount(span<Word const, fixed_extent> words) -> idx {
   if consteval {
      idx count = 0u;
      for (idx i = 0u; i < words.size(); ++i) {
         count += popcount(words[i]);
      }
      return count;
   } else {
      if constexpr (is_same<remove_cv<Word>, uword>) {
         if (words.size() < 64u) {
            idx count = 0u;
            for (idx i = 0u; i < words.size(); ++i) {
               count += popcount(words[i]);
            }
            return count;
         }
         return detail::popcount_words_runtime(
            words.data(), words.size(), ~uword(0u)
         );
      } else {
         idx count = 0u;
         for (idx i = 0u; i < words.size(); ++i) {
            count += popcount(words[i]);
         }
         return count;
      }
   }
}

template <typename Words>
concept is_unsigned_word_container =
   requires(Words const& words) {
      typename remove_cvref<Words>::value_type;
      words.data();
      words.size();
   }
   && is_unsigned_integral<typename Words::value_type>
   // Is not a `cat::simd` or `cat::simd_mask`:
   && !requires { typename Words::element_type; }
   && !requires { typename Words::abi_type; };

// Count set bits across a contiguous container of unsigned words.
template <is_unsigned_word_container Words>
[[nodiscard]]
constexpr auto
popcount(Words const& words) -> idx {
   using word_type = remove_cv<typename remove_cvref<Words>::value_type>;
   return popcount(
      span<word_type const, idx::max()>{words.data(), words.size()}
   );
}

