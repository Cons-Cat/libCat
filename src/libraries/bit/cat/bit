template <cat::is_signed_integral T>
[[nodiscard]]
constexpr auto
shift_right_arithmetic_by_fallback(T value, cat::uword count) -> T {
   constexpr cat::idx bits = sizeof(T) * 8u;
   if (count >= bits) {
      return value < 0 ? T(-1) : T(0);
   }
   return T(cat::make_raw_arithmetic(value) >> count.raw);
}

template <cat::is_unsigned_integral T>
[[nodiscard]]
constexpr auto
rotate_right_by_fallback(T value, cat::uword count) -> T {
   constexpr cat::idx bits = sizeof(T) * 8u;
   cat::uword const reduced_count = count % bits;
   if (reduced_count == 0u) {
      return value;
   }
   auto const raw_value = cat::make_raw_arithmetic(value);
   return T(
      (raw_value >> reduced_count.raw)
      | (raw_value << (cat::make_raw_arithmetic(bits - reduced_count)))
   );
}

