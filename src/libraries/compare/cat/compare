// NOLINTBEGIN(bugprone-std-namespace-modification)

namespace std {

namespace detail {
enum class [[clang::enum_extensibility(closed)]] order : signed char {
   less = -1,
   equivalent = 0,
   equal = 0,
   greater = 1,
   nonequivalent = 1,
   nonequal = 1,
};

enum class [[clang::enum_extensibility(closed)]] partial_order : signed char {
   less = static_cast<signed char>(order::less),
   equivalent = static_cast<signed char>(order::equivalent),
   greater = static_cast<signed char>(order::greater),
   unordered = -127,
};
}  // namespace detail

class partial_ordering {
 private:
   detail::partial_order m_value;

   constexpr explicit partial_ordering(detail::partial_order value) noexcept
       : m_value(value) {
   }

   friend class weak_ordering;
   friend class strong_ordering;

 public:
   static partial_ordering const less;
   static partial_ordering const equivalent;
   static partial_ordering const greater;
   static partial_ordering const unordered;

   friend constexpr auto
   operator==(partial_ordering, partial_ordering) -> bool = default;

   friend constexpr auto
   operator<(partial_ordering lhs, partial_ordering rhs) -> bool {
      return static_cast<signed char>(lhs.m_value)
             < static_cast<signed char>(rhs.m_value);
   }

   friend constexpr auto
   operator<=(partial_ordering lhs, partial_ordering rhs) -> bool {
      return static_cast<signed char>(lhs.m_value)
             <= static_cast<signed char>(rhs.m_value);
   }

   friend constexpr auto
   operator>(partial_ordering lhs, partial_ordering rhs) -> bool {
      return static_cast<signed char>(lhs.m_value)
             > static_cast<signed char>(rhs.m_value);
   }

   friend constexpr auto
   operator>=(partial_ordering lhs, partial_ordering rhs) -> bool {
      return static_cast<signed char>(lhs.m_value)
             >= static_cast<signed char>(rhs.m_value);
   }

   // 0 is the only integer literal which can implicitly convert to `nullptr`.

   friend constexpr auto
   operator==(partial_ordering partial, decltype(nullptr)) -> bool {
      return partial.m_value == detail::partial_order::equivalent;
   }

   friend constexpr auto
   operator==(decltype(nullptr), partial_ordering partial) -> bool {
      return partial.m_value == detail::partial_order::equivalent;
   }

   friend constexpr auto
   operator!=(partial_ordering partial, decltype(nullptr)) -> bool {
      return partial.m_value != detail::partial_order::equivalent;
   }

   friend constexpr auto
   operator!=(decltype(nullptr), partial_ordering partial) -> bool {
      return partial.m_value != detail::partial_order::equivalent;
   }

   friend constexpr auto
   operator<(partial_ordering partial, decltype(nullptr)) -> bool {
      return partial.m_value == detail::partial_order::less;
   }

   friend constexpr auto
   operator<(decltype(nullptr), partial_ordering partial) -> bool {
      return partial.m_value == detail::partial_order::greater;
   }

   friend constexpr auto
   operator<=(partial_ordering partial, decltype(nullptr)) -> bool {
      return partial.m_value == detail::partial_order::equivalent
             || partial.m_value == detail::partial_order::less;
   }

   friend constexpr auto
   operator<=(decltype(nullptr), partial_ordering partial) -> bool {
      return partial.m_value == detail::partial_order::equivalent
             || partial.m_value == detail::partial_order::greater;
   }

   friend constexpr auto
   operator>(partial_ordering partial, decltype(nullptr)) -> bool {
      return partial.m_value == detail::partial_order::greater;
   }

   friend constexpr auto
   operator>(decltype(nullptr), partial_ordering partial) -> bool {
      return partial.m_value == detail::partial_order::less;
   }

   friend constexpr auto
   operator>=(partial_ordering partial, decltype(nullptr)) -> bool {
      return partial.m_value == detail::partial_order::equivalent
             || partial.m_value == detail::partial_order::greater;
   }

   friend constexpr auto
   operator>=(decltype(nullptr), partial_ordering partial) -> bool {
      return partial.m_value == detail::partial_order::equivalent
             || partial.m_value == detail::partial_order::less;
   }

   friend constexpr auto
   operator<=>(partial_ordering lhs, decltype(nullptr)) -> partial_ordering {
      return lhs;
   }

   friend constexpr auto
   operator<=>(decltype(nullptr), partial_ordering rhs) -> partial_ordering {
      return rhs.m_value == detail::partial_order::less
                ? partial_ordering::greater
                : (rhs.m_value == detail::partial_order::greater
                      ? partial_ordering::less
                      : rhs);
   }
};

// Initializing these values inside of `partial_ordering` is not possible, since
// it would be an incomplete type in that context. They are initialized
// afterwards, here, instead.
inline constexpr partial_ordering
   partial_ordering::less(detail::partial_order::less);
inline constexpr partial_ordering
   partial_ordering::equivalent(detail::partial_order::equivalent);
inline constexpr partial_ordering
   partial_ordering::greater(detail::partial_order::greater);
inline constexpr partial_ordering
   partial_ordering::unordered(detail::partial_order::unordered);

class weak_ordering {
 private:
   signed char m_value;

   constexpr explicit weak_ordering(detail::order value) noexcept
       : m_value(static_cast<signed char>(value)) {
   }

   friend class strong_ordering;

 public:
   static weak_ordering const less;
   static weak_ordering const equivalent;
   static weak_ordering const greater;

   constexpr
   operator partial_ordering() const {
      return m_value == 0 ? partial_ordering::equivalent
                          : (m_value < 0 ? partial_ordering::less
                                         : partial_ordering::greater);
   }

   friend constexpr auto
   operator==(weak_ordering, weak_ordering) -> bool = default;

   friend constexpr auto
   operator<(weak_ordering lhs, weak_ordering rhs) -> bool {
      return lhs.m_value < rhs.m_value;
   }

   friend constexpr auto
   operator<=(weak_ordering lhs, weak_ordering rhs) -> bool {
      return lhs.m_value <= rhs.m_value;
   }

   friend constexpr auto
   operator>(weak_ordering lhs, weak_ordering rhs) -> bool {
      return lhs.m_value > rhs.m_value;
   }

   friend constexpr auto
   operator>=(weak_ordering lhs, weak_ordering rhs) -> bool {
      return lhs.m_value >= rhs.m_value;
   }

   friend constexpr auto
   operator==(weak_ordering value, decltype(nullptr)) -> bool {
      return value.m_value
             == static_cast<signed char>(detail::order::equivalent);
   }

   friend constexpr auto
   operator==(decltype(nullptr), weak_ordering value) -> bool {
      return value.m_value
             == static_cast<signed char>(detail::order::equivalent);
   }

   friend constexpr auto
   operator!=(weak_ordering value, decltype(nullptr)) -> bool {
      return value.m_value
             != static_cast<signed char>(detail::order::equivalent);
   }

   friend constexpr auto
   operator!=(decltype(nullptr), weak_ordering value) -> bool {
      return value.m_value
             != static_cast<signed char>(detail::order::equivalent);
   }

   friend constexpr auto
   operator<(weak_ordering value, decltype(nullptr)) -> bool {
      return value.m_value == static_cast<signed char>(detail::order::less);
   }

   friend constexpr auto
   operator<(decltype(nullptr), weak_ordering value) -> bool {
      return value.m_value == static_cast<signed char>(detail::order::greater);
   }

   friend constexpr auto
   operator<=(weak_ordering value, decltype(nullptr)) -> bool {
      return value.m_value
                == static_cast<signed char>(detail::order::equivalent)
             || value.m_value == static_cast<signed char>(detail::order::less);
   }

   friend constexpr auto
   operator<=(decltype(nullptr), weak_ordering value) -> bool {
      return value.m_value
                == static_cast<signed char>(detail::order::equivalent)
             || value.m_value
                   == static_cast<signed char>(detail::order::greater);
   }

   friend constexpr auto
   operator>(weak_ordering value, decltype(nullptr)) -> bool {
      return value.m_value == static_cast<signed char>(detail::order::greater);
   }

   friend constexpr auto
   operator>(decltype(nullptr), weak_ordering value) -> bool {
      return value.m_value == static_cast<signed char>(detail::order::less);
   }

   friend constexpr auto
   operator>=(weak_ordering value, decltype(nullptr)) -> bool {
      return value.m_value
                == static_cast<signed char>(detail::order::equivalent)
             || value.m_value
                   == static_cast<signed char>(detail::order::greater);
   }

   friend constexpr auto
   operator>=(decltype(nullptr), weak_ordering value) -> bool {
      return value.m_value
                == static_cast<signed char>(detail::order::equivalent)
             || value.m_value == static_cast<signed char>(detail::order::less);
   }

   friend constexpr auto
   operator<=>(weak_ordering lhs, decltype(nullptr)) -> weak_ordering {
      return lhs;
   }

   friend constexpr auto
   operator<=>(decltype(nullptr), weak_ordering rhs) -> weak_ordering {
      return rhs.m_value < 0 ? weak_ordering::greater
                             : (rhs.m_value > 0 ? weak_ordering::less : rhs);
   }
};

// Initializing these values inside of `weak_ordering` is not possible, since it
// would be an incomplete type in that context. They are initialized afterwards,
// here, instead.
inline constexpr weak_ordering weak_ordering::less(detail::order::less);
inline constexpr weak_ordering
   weak_ordering::equivalent(detail::order::equivalent);
inline constexpr weak_ordering weak_ordering::greater(detail::order::greater);

class strong_ordering {
 private:
   signed char m_value;

   constexpr explicit strong_ordering(detail::order value) noexcept
       : m_value(static_cast<signed char>(value)) {
   }

 public:
   static strong_ordering const less;
   static strong_ordering const equal;
   static strong_ordering const equivalent;
   static strong_ordering const greater;

   [[gnu::always_inline]]
   constexpr
   operator partial_ordering() const {
      return m_value == 0 ? partial_ordering::equivalent
                          : (m_value < 0 ? partial_ordering::less
                                         : partial_ordering::greater);
   }

   [[gnu::always_inline]]
   constexpr
   operator weak_ordering() const {
      return m_value == 0
                ? weak_ordering::equivalent
                : (m_value < 0 ? weak_ordering::less : weak_ordering::greater);
   }

   [[gnu::always_inline]]
   friend constexpr auto
   operator==(strong_ordering, strong_ordering) -> bool = default;

   [[gnu::always_inline]]
   friend constexpr auto
   operator<(strong_ordering lhs, strong_ordering rhs) -> bool {
      return lhs.m_value < rhs.m_value;
   }

   [[gnu::always_inline]]
   friend constexpr auto
   operator<=(strong_ordering lhs, strong_ordering rhs) -> bool {
      return lhs.m_value <= rhs.m_value;
   }

   [[gnu::always_inline]]
   friend constexpr auto
   operator>(strong_ordering lhs, strong_ordering rhs) -> bool {
      return lhs.m_value > rhs.m_value;
   }

   [[gnu::always_inline]]
   friend constexpr auto
   operator>=(strong_ordering lhs, strong_ordering rhs) -> bool {
      return lhs.m_value >= rhs.m_value;
   }

   friend constexpr auto
   operator==(strong_ordering value, decltype(nullptr)) -> bool {
      return value.m_value
             == static_cast<signed char>(detail::order::equivalent);
   }

   [[gnu::always_inline]]
   friend constexpr auto
   operator==(decltype(nullptr), strong_ordering value) -> bool {
      return value.m_value
             == static_cast<signed char>(detail::order::equivalent);
   }

   [[gnu::always_inline]]
   friend constexpr auto
   operator!=(strong_ordering value, decltype(nullptr)) -> bool {
      return value.m_value
             != static_cast<signed char>(detail::order::equivalent);
   }

   [[gnu::always_inline]]
   friend constexpr auto
   operator!=(decltype(nullptr), strong_ordering value) -> bool {
      return value.m_value
             != static_cast<signed char>(detail::order::equivalent);
   }

   [[gnu::always_inline]]
   friend constexpr auto
   operator<(strong_ordering value, decltype(nullptr)) -> bool {
      return value.m_value == static_cast<signed char>(detail::order::less);
   }

   [[gnu::always_inline]]
   friend constexpr auto
   operator<(decltype(nullptr), strong_ordering value) -> bool {
      return value.m_value == static_cast<signed char>(detail::order::greater);
   }

   [[gnu::always_inline]]
   friend constexpr auto
   operator<=(strong_ordering value, decltype(nullptr)) -> bool {
      return value.m_value
                == static_cast<signed char>(detail::order::equivalent)
             || value.m_value == static_cast<signed char>(detail::order::less);
   }

   [[gnu::always_inline]]
   friend constexpr auto
   operator<=(decltype(nullptr), strong_ordering value) -> bool {
      return value.m_value
                == static_cast<signed char>(detail::order::equivalent)
             || value.m_value
                   == static_cast<signed char>(detail::order::greater);
   }

   [[gnu::always_inline]]
   friend constexpr auto
   operator>(strong_ordering value, decltype(nullptr)) -> bool {
      return value.m_value == static_cast<signed char>(detail::order::greater);
   }

   [[gnu::always_inline]]
   friend constexpr auto
   operator>(decltype(nullptr), strong_ordering value) -> bool {
      return value.m_value == static_cast<signed char>(detail::order::less);
   }

   [[gnu::always_inline]]
   friend constexpr auto
   operator>=(strong_ordering value, decltype(nullptr)) -> bool {
      return value.m_value
                == static_cast<signed char>(detail::order::equivalent)
             || value.m_value
                   == static_cast<signed char>(detail::order::greater);
   }

   [[gnu::always_inline]]
   friend constexpr auto
   operator>=(decltype(nullptr), strong_ordering value) -> bool {
      return value.m_value
                == static_cast<signed char>(detail::order::equivalent)
             || value.m_value == static_cast<signed char>(detail::order::less);
   }

   [[gnu::always_inline]]
   friend constexpr auto
   operator<=>(strong_ordering lhs, decltype(nullptr)) -> strong_ordering {
      return lhs;
   }

   [[gnu::always_inline]]
   friend constexpr auto
   operator<=>(decltype(nullptr), strong_ordering rhs) -> strong_ordering {
      return rhs.m_value < 0 ? strong_ordering::greater
                             : (rhs.m_value > 0 ? strong_ordering::less : rhs);
   }
};

