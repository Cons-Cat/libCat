namespace detail {
// Classification used by `common_comparison_category`. Any value other
// than `none` is the ordering's "strength rank": larger means weaker.
// Mirrors libc++'s `__comp_detail::_ClassifyCompCategory`.
enum class [[clang::enum_extensibility(
   closed
)]] comp_category_kind : unsigned char {
   none = 0,
   strong = 1,
   weak = 2,
   partial = 3,
};

template <typename T>
consteval auto
classify_comp_category() -> comp_category_kind {
   if constexpr (cat::is_same<T, partial_ordering>) {
      return comp_category_kind::partial;
   } else if constexpr (cat::is_same<T, weak_ordering>) {
      return comp_category_kind::weak;
   } else if constexpr (cat::is_same<T, strong_ordering>) {
      return comp_category_kind::strong;
   } else {
      return comp_category_kind::none;
   }
}

template <__SIZE_TYPE__ size>
consteval auto
fold_comp_category(comp_category_kind const (&kinds)[size])
   -> comp_category_kind {
   comp_category_kind result = comp_category_kind::strong;
   for (comp_category_kind k : kinds) {
      if (k == comp_category_kind::none) {
         return comp_category_kind::none;
      }
      if (static_cast<unsigned char>(k) > static_cast<unsigned char>(result)) {
         result = k;
      }
   }
   return result;
}

// Computes the common comparison category of `Ts...` and returns a value
// of that type, or `void()` when any argument is not a comparison
// category. The actual type is recovered by `decltype` in the trait
// below. The `strong_ordering` identity for the empty pack is folded in
// here by prepending it to the classification array.
template <typename... Ts>
consteval auto
common_comp_value() {
   constexpr comp_category_kind kinds[] = {
      comp_category_kind::strong, classify_comp_category<Ts>()...
   };
   constexpr comp_category_kind result = fold_comp_category(kinds);
   if constexpr (result == comp_category_kind::partial) {
      return partial_ordering::equivalent;
   } else if constexpr (result == comp_category_kind::weak) {
      return weak_ordering::equivalent;
   } else if constexpr (result == comp_category_kind::strong) {
      return strong_ordering::equivalent;
   } else {
      return;
   }
}
}  // namespace detail

// `[cmp.common]` common comparison category type. When every `Ts` is a
// comparison category, `type` is the weakest among them (with
// `strong_ordering` as the identity for an empty pack). When any `Ts` is
// not a comparison category, `type` is `void`. Mirrors libc++'s approach
// of computing the result through a `constexpr` fold function and
// recovering the type via `decltype`.
template <typename... Ts>
struct common_comparison_category {
   using type = decltype(detail::common_comp_value<Ts...>());
};

template <typename... Ts>
using common_comparison_category_t = common_comparison_category<Ts...>::type;

}  // namespace std

namespace cat {

using std::partial_ordering;
using std::strong_ordering;
using std::weak_ordering;

template <typename T>
concept is_common_comparison_category =
   is_either<T, strong_ordering, weak_ordering, partial_ordering>;

}  // namespace cat

