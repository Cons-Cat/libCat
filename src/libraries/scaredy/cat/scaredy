#pragma once

#include <cat/array>
#include <cat/string>
#include <cat/variant>

namespace cat {
namespace detail {
template <typename T, typename... Errors>
struct scaredy_variant_storage {
   using value_type = conditional<is_void<T>, monostate_type, T>;

   // `T` might have been provided `monostate_storage`, so we cannot use
   // `is_void<T>` here.
   static constexpr bool is_wrapping_void = is_monostate<value_type>;

   template <typename U>
   static constexpr bool is_value =
      // `U` must be converted to the value type.
      is_implicitly_convertible<U, value_type> &&
      // `U` must not be one of the errors.
      !type_list<Errors...>::template has_type<U>;

   template <typename U>
   static constexpr bool is_error =
      // `U` must not be the value type.
      !is_same<U, value_type> &&
      // `U` must be one of the errors.
      type_list<Errors...>::template has_type<U>;

   // `value_type` and error types must have separate constructors and
   // operators, because `cat::variant` cannot have implicit conversions in its
   // own constructors or operators. So an explicit conversion is required to
   // implicitly convert a value type without accidentally converting error
   // types.

   constexpr scaredy_variant_storage() = default;

   // Convert and copy-construct a value.
   template <typename U>
      requires(is_value<U>)
   constexpr scaredy_variant_storage(U const& input)
       : m_storage(static_cast<value_type>(input)) {
   }

   // Convert and move-construct a value.
   template <is_forwarding_move U>
      requires(is_value<U>)
   // `is_forwarding_move` sufficiently constrains this constructor.
   // NOLINTNEXTLINE
   constexpr scaredy_variant_storage(U&& input) : m_storage(move(input)) {
   }

   // Convert and copy-construct an error.
   template <typename Error>
      requires(is_error<Error>)
   constexpr scaredy_variant_storage(Error const& error) : m_storage(error) {
   }

   // Convert and move-construct an error.
   template <is_forwarding_move Error>
      requires(is_error<Error>)
   // `is_forwarding_move` sufficiently constrains this constructor.
   // NOLINTNEXTLINE
   constexpr scaredy_variant_storage(Error&& error) : m_storage(move(error)) {
   }

   // Forward `monostate` into `storage`.
   constexpr scaredy_variant_storage(monostate_type /*monostate*/)
       : m_storage(monostate) {
   }

   // Copy-assign and convert a value to `storage`.
   template <typename U>
      requires(is_value<U>)
   constexpr auto
   operator=(U const& operand) -> scaredy_variant_storage<T, Errors...>& {
      m_storage = static_cast<T>(operand);
      return *this;
   }

   // Move-assign and convert a value to `storage`.
   template <is_forwarding_move U>
      requires(is_value<U>)
   constexpr auto
   operator=(U&& operand) -> scaredy_variant_storage<T, Errors...>& {
      // `is_forwarding_move` sufficiently constrains this constructor.
      // NOLINTNEXTLINE
      m_storage = move(operand);
      return *this;
   }

   // Copy-assign and convert an error to `storage`.
   template <typename Error>
      requires(is_error<Error>)
   constexpr auto
   operator=(Error const& operand) -> scaredy_variant_storage<T, Errors...>& {
      m_storage = operand;
      return *this;
   }

   // Move-assign and convert a value to `storage`.
   template <is_forwarding_move Error>
      requires(is_error<Error>)
   constexpr auto
   operator=(Error&& operand) -> scaredy_variant_storage<T, Errors...>& {
      // `is_forwarding_move` sufficiently constrains this constructor.
      // NOLINTNEXTLINE
      m_storage = move(operand);
      return *this;
   }

   [[nodiscard]]
   constexpr auto
   has_value() const -> bool {
      return m_storage.template is<value_type>();
   }

   constexpr auto
   value(this auto&& self) -> auto&&
      requires(!is_void<T>)
   {
      return $fwd(self).m_storage.template get<value_type>();
   }

   template <typename Error>
   constexpr auto
   error() -> Error {
      return m_storage.template get<Error>();
   }

   template <typename Error>
   constexpr auto
   error() const -> Error {
      return m_storage.template get<Error>();
   }

   template <typename U>
   [[nodiscard]]
   constexpr auto
   is() const -> bool {
      return m_storage.template is<U>();
   }

   template <typename U>
   constexpr auto
   is(U&& in_value) const -> bool {
      return m_storage.template is<U>($fwd(in_value));
   }

   variant<value_type, Errors...> m_storage;
};

// `T` is a `compact_scaredy<type, predicate>`.
template <typename T, typename Error>
struct scaredy_compact_storage {
   using value_type = T::type;

   // `T` might have been provided `monostate_storage`, so we cannot use
   // `is_void<T>` here.
   static constexpr bool is_wrapping_void = is_monostate<value_type>;

   template <typename U>
   static constexpr bool is_value =
      // `U` must be converted to the value type.
      is_implicitly_convertible<U, value_type> &&
      // `U` must not be one of the errors.
      !is_same<Error, U>;

   template <typename U>
   static constexpr bool is_error =
      // `U` must not be the value type.
      !is_same<U, value_type> &&
      // `U` must be one of the errors.
      is_same<Error, U>;

   constexpr scaredy_compact_storage() = default;

   template <typename U>
      requires(is_value<U>)
   constexpr scaredy_compact_storage(U const& input)
       : m_storage(static_cast<value_type>(input)) {
   }

   template <is_forwarding_move U>
      requires(is_value<U>)
   constexpr scaredy_compact_storage(U&& input) : m_storage($fwd(input)) {
   }

   constexpr scaredy_compact_storage(Error const& error) : m_error_code(error) {
   }

   constexpr scaredy_compact_storage(Error&& error)
       : m_error_code(move(error)) {
   }

   // It does not make sense for this class to have a `monostate_type`
   // constructor, since `T` cannot be `void`.

   template <typename U>
      requires(is_value<U>)
   constexpr auto
   operator=(U const& operand) -> scaredy_compact_storage& {
      m_storage = static_cast<T>(operand);
      return *this;
   }

   template <typename U>
      requires(is_value<U>)
   constexpr auto
   operator=(U&& operand) -> scaredy_compact_storage& {
      m_storage = $fwd(operand);
      return *this;
   }

   constexpr auto
   operator=(Error const& operand) -> scaredy_compact_storage& {
      m_error_code = operand;
      return *this;
   }

   constexpr auto
   operator=(Error&& operand) -> scaredy_compact_storage& {
      m_error_code = move(operand);
      return *this;
   }

   constexpr auto
   value(this auto&& self) -> auto&& {
      return $fwd(self).m_storage;
   }

   // `this_type` is variadic to give it a homogenous interface with other
   // `scaredy`'s.
   template <typename...>
   constexpr auto
   error() -> Error {
      return m_error_code;
   }

   // `this_type` is variadic to give it a homogenous interface with other
   // `scaredy`'s.
   template <typename...>
   constexpr auto
   error() const -> Error {
      return m_error_code;
   }

   [[nodiscard]]
   constexpr auto
   has_value() const -> bool {
      return T::predicate_function(m_storage);
   }

   // Compare the type `U` against `value_type` or `error_type`.
   template <typename U>
   [[nodiscard]]
   constexpr auto
   is() const -> bool {
      if constexpr (is_same<U, value_type>) {
         return this->has_value();
      } else if constexpr (is_same<U, Error>) {
         return !this->has_value();
      } else {
         // Any type besides `value_type` and `error_type` can never hold true.
         return false;
      }
   }

   // `value_type` comparison against either `m_storage` or `m_error_code`.
   template <typename U>
   constexpr auto
   is(U&& in_value) const -> bool {
      if (this->has_value()) {
         return static_cast<value_type>($fwd(in_value)) == m_storage;
      }
      return static_cast<Error>($fwd(in_value)) == m_error_code;
   }

   constexpr auto
   get_index() const {
      if (this->has_value()) {
         return 0;
      }
      return 1;
   }

   union {
      value_type m_storage;
      Error m_error_code;
   };
};
}  // namespace detail

// TODO: Support reference types in a `scaredy`.

template <typename T, typename... Errors>
   requires(
      // `scaredy` cannot hold C arrays.
      (!is_array<Errors> && ...) &&
      // `scaredy` should have at least one error type.
      sizeof...(Errors) > 0)
class [[nodiscard]] scaredy {
 private:
   using storage_type =
      conditional<requires { T::predicate_function; },
                  detail::scaredy_compact_storage<T, Errors...[0]>,
                  detail::scaredy_variant_storage<T, Errors...>>;

 public:
   using value_type = storage_type::value_type;
   using errors_list = type_list<Errors...>;

 private:
   // These two templates must be declared here to be used in the below atomic
   // constraints.

   template <typename U>
   static constexpr bool is_value =
      // `U` must be converted to the value type.
      is_implicitly_convertible<U, value_type> &&
      // `U` must not be one of the errors.
      !type_list<Errors...>::template has_type<U>;

   template <typename U>
   static constexpr bool is_error =
      // `U` must not be the value type.
      !is_same<U, value_type> &&
      // `U` must be one of the errors.
      type_list<Errors...>::template has_type<U>;

   template <typename Self>
   [[gnu::always_inline, gnu::nodebug]]
   constexpr auto
   as_base(this Self&& self) -> copy_cvref_from<Self&&, scaredy> {
      // C-cast preserves cvref while upcasting through the inheritance
      // chain, so callers reach `scaredy`'s overload set instead of a
      // derived class's shadowing overloads.
      // NOLINTNEXTLINE
      return (copy_cvref_from<Self&&, scaredy>)$fwd(self);
   }

   // `storage_type` constructors are used by the monadic member functions to
   // propagate errors.
   constexpr scaredy(storage_type const& in_storage) : m_storage(in_storage) {
   }

   constexpr scaredy(storage_type&& in_storage) : m_storage(move(in_storage)) {
   }

 public:
   constexpr scaredy() = default;

   // TODO: Construct from a subset of `Errors`.

   // Copy and convert the storage of a convertible `scaredy`.
   template <typename U>
      requires(is_implicitly_convertible<U, value_type>)
   constexpr scaredy(scaredy<U, Errors...> const& scaredy)
       : m_storage(scaredy.m_storage) {
   }

   // Move and convert the storage of a convertible `scaredy`.
   template <typename U>
      requires(is_implicitly_convertible<U, value_type>)
   constexpr scaredy(scaredy<U, Errors...>&& scaredy)
       : m_storage(move(scaredy).storage) {
   }

   // Forward a value into the storage.
   template <typename U>
      requires(is_value<U>)
   constexpr scaredy(U const& input) : m_storage(input) {
   }

   template <is_forwarding_move U>
      requires(is_value<U>)
   // `is_forwarding_move` sufficiently constrains this constructor.
   // NOLINTNEXTLINE
   constexpr scaredy(U&& input) : m_storage(input) {
   }

   // Forward an error into the storage.
   template <typename U>
      requires(is_error<U>)
   constexpr scaredy(U const& error) : m_storage(error) {
   }

   // Forward an error into the storage.
   template <is_forwarding_move U>
      requires(is_error<U>)
   // `is_forwarding_move` sufficiently constrains this constructor.
   // NOLINTNEXTLINE
   constexpr scaredy(U&& error) : m_storage($fwd(error)) {
   }

   // Forward a `monostate` into the storage if there is no value type.
   constexpr scaredy(monostate_type /*monostate*/)
      requires(is_void<value_type> || is_same<value_type, monostate_type>)
       : m_storage(monostate) {
   }

   // Copy-assign and convert a `scaredy`.
   template <typename U, typename... OtherErrors>
      requires(is_value<U> && (is_error<OtherErrors> && ...))
   [[clang::reinitializes]]
   constexpr auto
   operator=(scaredy<U, Errors...> const& operand) -> scaredy& {
      m_storage = operand.m_storage;
      return *this;
   }

   // Move-assign and convert a `scaredy`.
   template <typename U, typename... OtherErrors>
      requires(is_value<U> && (is_error<OtherErrors> && ...))
   [[clang::reinitializes]]
   constexpr auto
   operator=(scaredy<U, Errors...>&& operand) -> scaredy& {
      m_storage = operand.m_storage;
      return *this;
   }

   // Copy-assign and convert a value to `storage`.
   template <typename U>
      requires(is_value<U>)
   [[clang::reinitializes]]
   constexpr auto
   operator=(U const& operand) -> scaredy& {
      m_storage = static_cast<value_type>(operand);
      return *this;
   }

   // Move-assign and convert a value to `storage`.
   template <is_forwarding_move U>
      requires(is_value<U>)
   [[clang::reinitializes]]
   constexpr auto
   operator=(U&& operand) -> scaredy& {
      m_storage = static_cast<value_type&&>(operand);
      return *this;
   }

   // Copy-assign and convert an error to `storage`.
   template <typename Error>
      requires(is_error<Error>)
   [[clang::reinitializes]]
   constexpr auto
   operator=(Error const& operand) -> scaredy& {
      m_storage = operand;
      return *this;
   }

   // Move-assign and convert an error to `storage`.
   template <is_forwarding_move Error>
      requires(is_error<Error>)
   [[clang::reinitializes]]
   constexpr auto
   operator=(Error&& operand) -> scaredy& {
      // `is_forwarding_move` sufficiently constrains this constructor.
      // NOLINTNEXTLINE
      m_storage = move(operand);
      return *this;
   }

   [[nodiscard]]
   constexpr auto
   has_value() const -> bool {
      return m_storage.has_value();
   }

   // If the value should be discarded, consume the `maybe` with `auto _ =`
   // instead.
   [[nodiscard]]
   constexpr auto
   value(this auto&& self) -> auto&&
      requires(!storage_type::is_wrapping_void)
   {
      return $fwd(self).as_base().m_storage.value();
   }

   // Special discard-able overload for `maybe<void>`.
   // NOLINTNEXTLINE This should not be `[[nodiscard]]`.
   constexpr auto
   value() const -> monostate_type
      requires(storage_type::is_wrapping_void)
   {
      return monostate;
   }

   // Get the value of some error when its type is known to the caller.
   template <typename Error>
   [[nodiscard]]
   constexpr auto
   error() {
      return m_storage.template error<Error>();
   }

   // Get the value of some error when its type is known to the caller.
   template <typename Error>
   [[nodiscard]]
   constexpr auto
   error() const {
      return m_storage.template error<Error>();
   }

   // If there is only one error type, a template argument is not required.
   [[nodiscard]]
   constexpr auto
   error()
      requires(sizeof...(Errors) == 1)
   {
      return m_storage.template error<Errors...>();
   }

   // If there is only one error type, a template argument is not required.
   [[nodiscard]]
   constexpr auto
   error() const
      requires(sizeof...(Errors) == 1)
   {
      return m_storage.template error<Errors...>();
   }

   [[nodiscard]]
   constexpr auto
   value_or(this auto&& self, value_type fallback) {
      auto&& base = $fwd(self).as_base();
      if (base.m_storage.has_value()) {
         return $fwd(base).m_storage.value();
      }
      return fallback;
   }

   // Returns a pointer to the held value when this `scaredy` is engaged, or
   // `nullptr` when it holds an error. For `scaredy<T*, ...>` the held
   // pointer is forwarded directly so the result type is `T*` rather than
   // `T**`.
   [[nodiscard]]
   constexpr auto
   get_ptr(this auto&& self)
      requires(!storage_type::is_wrapping_void)
   {
      auto&& base = $fwd(self).as_base();
      if constexpr (is_pointer<value_type>) {
         if (base.m_storage.has_value()) {
            return $fwd(base).m_storage.value();
         }
         return static_cast<value_type>(nullptr);
      } else {
         using ptr_type =
            decltype(__builtin_addressof($fwd(base).m_storage.value()));
         if (base.m_storage.has_value()) {
            return __builtin_addressof($fwd(base).m_storage.value());
         }
         return ptr_type{nullptr};
      }
   }

   // TODO: Make the `.assert()` and `.verify()` getters `constexpr`.
   // TODO: Add overloads which take a `str_view` for an error message.

   auto
   assert(this auto&& self,
          void (*p_assert_handler)(source_location const&) = assert_handler,
          source_location const& callsite = source_location::current())
      -> auto&&
      requires(!storage_type::is_wrapping_void)
   {
      auto&& base = $fwd(self).as_base();
      cat::assert(base.has_value(), p_assert_handler, callsite);
      return $fwd(base).value();
   }

   // Special discard-able overload for `maybe<void>`.
   // NOLINTNEXTLINE This should not be `[[nodiscard]]`.
   auto
   assert(void (*p_assert_handler)(source_location const&) = assert_handler,
          source_location const& callsite = source_location::current()) const
      -> monostate_type
      requires(storage_type::is_wrapping_void)
   {
      cat::assert(has_value(), p_assert_handler, callsite);
      return monostate;
   }

   auto
   verify(this auto&& self,
          void (*p_assert_handler)(source_location const&) = assert_handler,
          source_location const& callsite = source_location::current())
      -> auto&&
      requires(!storage_type::is_wrapping_void)
   {
      auto&& base = $fwd(self).as_base();
      cat::verify(base.has_value(), p_assert_handler, callsite);
      return $fwd(base).value();
   }

   // Special discard-able overload for `maybe<void>`.
   // NOLINTNEXTLINE This should not be `[[nodiscard]]`.
   auto
   verify(void (*p_assert_handler)(source_location const&) = assert_handler,
          source_location const& callsite = source_location::current()) const
      -> monostate_type
      requires(storage_type::is_wrapping_void)
   {
      cat::verify(has_value(), p_assert_handler, callsite);
      return monostate;
   }

   // Holds true if this `scaredy` currently has some value of the type `U`.
   // `this_type` method allows `scaredy` to be used in `match` statements.
   template <typename U>
   [[nodiscard]]
   constexpr auto
   is() const -> bool {
      return m_storage.template is<U>();
   }

   // Holds true if this `scaredy` currently has some value convertible and
   // equivalent to `in_value`. `this_type` method allows `scaredy` to be used
   // in `match` statements.
   template <typename U>
   [[nodiscard]]
   constexpr auto
   is(U&& in_value) const -> bool {
      return m_storage.is($fwd(in_value));
   }

   // Member access syntax pattern matching for `cat::match()`.
   template <typename... Patterns>
      requires(is_specialization<Patterns, detail::pattern_invocable> && ...)
   constexpr void
   match(Patterns&&... patterns) {
      detail::match_patterns (*this)($fwd(patterns)...);
   }

   // If this non-`const`-qualified `scaredy` holds a value, transform it with
   // a callback. Otherwise, propagate the error value.
   template <is_invocable<value_type> Callback>
   [[nodiscard]]
   constexpr auto
   transform(this auto&& self, Callback&& callback) {
      using this_type = scaredy<T, Errors...>;
      auto&& base = $fwd(self).as_base();
      if (base.has_value()) {
         return this_type($fwd(callback)($fwd(base).value()));
      }
      return this_type($fwd(base).m_storage);
   }

   template <is_invocable<value_type> Callback>
   [[nodiscard]]
   constexpr auto
   and_then(this auto&& self, Callback&& callback) {
      using this_type = scaredy<T, Errors...>;
      auto&& base = $fwd(self).as_base();
      return base.has_value() ? $fwd(callback)($fwd(base).value())
                              : this_type($fwd(base).m_storage);
   }

   template <is_invocable Callback>
   constexpr auto
   or_else(this auto&& self, Callback&& callback) {
      using U = decltype(callback());
      static_assert(is_void<U> || is_specialization<U, scaredy>);

      auto&& base = $fwd(self).as_base();
      if (!base.has_value()) {
         if constexpr (is_void<U>) {
            $fwd(callback)();
         } else {
            return $fwd(callback)();
         }
      }

      if constexpr (is_void<U>) {
         return;
      } else {
         return $fwd(base);
      }
   }

   auto
   or_exit(this auto&& self, iword exit_code = 1) {
      auto&& base = $fwd(self).as_base();
      if (base.has_value()) [[likely]] {
         if constexpr (!is_void<T>) {
            return $fwd(base).value();
         } else {
            return;
         }
      }
      exit(exit_code);
      __builtin_unreachable();
   }

   auto
   or_exit(this auto&& self, str_view error_message, iword exit_code = 1) {
      auto&& base = $fwd(self).as_base();
      if (base.has_value()) [[likely]] {
         if constexpr (!is_void<T>) {
            return $fwd(base).value();
         } else {
            return;
         }
      } else {
         auto _ = eprintln(error_message);
         exit(exit_code);
      }
   }

 private:
   storage_type m_storage;
};

template <typename T>
concept is_scaredy = requires(T t) {
                        // T::value_type;
                        // T::Errors;
                        cat::maybe<decltype(t.value())>();
                     } && !requires(T t) { t = cat::nullopt; };

auto
propagate_error(is_scaredy auto const& scaredy) {
   return scaredy.error();
}

}  // namespace cat
