// -*- mode: c++ -*-
// vim: set ft=cpp:
#pragma once

// `cat::maybe` is analogous to `std::optional`, used for failure handling
// throughout libCat. It wraps either a value of type `T` or no value. It
// supports a fully monadic API, is iterable as a range, and supports opt-in
// programmable niche-value optimization.
//
// `cat::maybe<void>` represents an optional unit value. It is effectively a
// monadic abstraction over returning `bool`.
//
// `cat::maybe<T&>` represents an optional reference with rebinding assignment.
//
// `cat::compact` is a hook to niche-value optimization. It takes a value type
// and a predicate function. The predicate evaluates true when the `maybe` holds
// a value, otherwise false. This design deliberately encodes the optimization
// in the `maybe`'s type, not the value's type, which is maximally flexible and
// ergonomic.
//
// The `cat::maybe` interface is also informed by the following papers:
//
// P0798R8   Monadic operations for `std::optional`. `transform`, `and_then`,
//           and `or_else` chain computations.
//
// P2988R12  `std::optional<T&>`. Assignment to a `maybe<T&>` rebinds the
//           held pointer rather than assigning through to the referent,
//           bindings to temporaries are deleted, and `value_or` returns by
//           value to avoid dangling on a temporary fallback.
//
// P3836R2   Trivially-copyable `std::optional<T&>`. `cat::maybe<T&>` has
//           pointer layout and is trivially copyable.
//
// P3168R1   Range support for `std::optional`. `cat::maybe<T>` models a
//           contiguous range of size 0 or 1 via `begin()` and `end()`.
//
// Rather than use partial template specializations, `cat::maybe` storage is
// selected internally, and supports:
//
//    maybe<void>            -> maybe_value_storage<monostate_type>
//    maybe<compact<...>>    -> maybe_compact_storage<...>  (niche-using,
//                              sizeof(maybe) == sizeof(T))
//    maybe<T&>              -> maybe_reference_storage<T>  (pointer-sized,
//                              trivially copyable)
//    maybe<T>               -> maybe_value_storage<T>      (value plus a
//                              `bool` engagement flag)
//
// The `cat::compact` hint takes a `value_type`, a predicate function, and
// either a value representing `nullopt` or a function returning some value to
// represent `nullopt`. There are convenience `maybe` types using `compact`
// storage:
//
//    maybe_ptr<T>           -> maybe<sentinel<T*, nullptr>>
//    maybe_span<T>          -> maybe<compact<span<T>, ...>>
//    maybe_non_zero<T>      -> maybe<sentinel<T, T(0)>>
//    maybe_non_negative<T>  -> maybe<compact<T, ..., -1>>
//
// Addtionally, a type can opt-in to using `maybe`'s `compact` storage by
// default by specializing `default_compact_trait<T>` for itself. `cat::idx`
// does this to re-use the inaccessible word high bit of an `idx` as its niche
// value.
//
// Accessors are unchecked by default. The unchecked observer is `.value()`,
// with `.p_value()` for the address of the held value. Checked observers are
// `.assert()`, `.verify()`, and `.or_exit()`.
//
// `cat::maybe` intentionally not provide `operator*`, `operator->`, or implicit
// conversion to `bool`. Truthiness testing can be replaced by `.has_value()`,
// and it otherwise causes many subtle type safety concerns, such as:
// https://brevzin.github.io/c++/2023/01/18/optional-construction/
//
// Construct a `maybe` directly with the wrapped type's constructors, with
// `cat::nullopt`, with `cat::monostate` (for `maybe<void>`), with the
// `cat::in_place` tag, or via the `cat::make_maybe(value)` and
// `cat::make_maybe<T>(arguments...)` factories.

namespace cat {
namespace detail {
// A `nullopt_type` is consumed by an `maybe` constructor to prevent
// initializing its `value` member.
struct nullopt_type {};
}  // namespace detail

// `nullopt` is consumed by `maybe` to represent an empty value.
inline constexpr detail::nullopt_type nullopt;
}  // namespace cat

#include <cat/match>
#include <cat/memory>
#include <cat/runtime>
#include <cat/utility>

namespace cat {
// Forward declarations.

namespace detail {
template <typename>
struct is_maybe_impl {
   static constexpr bool value = false;
};

template <typename U>
struct is_maybe_impl<maybe<U>> {
   static constexpr bool value = true;
};
}  // namespace detail

template <typename T>
concept is_maybe = detail::is_maybe_impl<remove_cvref<T>>::value;

// Customization point for default niche-value storage in `maybe<T>`.
// `operator-` Default:
// `type = T` (no compact storage) `operator-` Specialize to `compact<...>`:
// `maybe<T>` stores `nullopt` in a niche.
template <typename T>
struct default_compact_trait : identity_trait<T> {};

// True when `default_compact_trait<T>::type` is a compact type.
template <typename T>
concept has_default_compact =
   requires { default_compact_trait<T>::type::nullopt_state(); };

namespace detail {
// Mirrors the `converts-from-any-cvref` exposition concept used by
// `std::optional` to disambiguate the converting-`maybe` constructors and
// assignment operators when `value_type` is itself constructible or convertible
// from a `maybe<U>` (see LWG 3836 and Barry Revzin, "Getting in trouble with
// mixed construction",
// https://brevzin.github.io/c++/2023/01/18/optional-construction/). `T` is the
// engaging element type and `W` is the full source `maybe<U>`.
template <typename T, typename W>
concept maybe_converts_from_any_cvref =
   is_constructible<T, W&> || is_convertible<W&, T> || is_constructible<T, W>
   || is_convertible<W, T> || is_constructible<T, W const&>
   || is_convertible<W const&, T> || is_constructible<T, W const>
   || is_convertible<W const, T>;
}  // namespace detail

template <typename CharT, bool null_terminated>
   requires(sizeof(CharT) == 1)
class basic_str_span;

using str_view = basic_str_span<char const, false>;

// `maybe_value_storage` holds a non-reference, non-pointer, non-`void` type `T`
// and a `bool` flag to represent holding a value or not.
template <typename T>
struct maybe_value_storage {
   using value_type = T;

   constexpr maybe_value_storage() : m_dummy{} {
   }

   // If `T` is forwarded arguments by the `in_place` `maybe` constructor, then
   // construct it in-place with those arguments.
   template <typename... Args>
   constexpr maybe_value_storage(Args... arguments) {
      this->construct(arguments...);
   }

   // If `T` is trivially-copy-constructible, use this simple copy constructor.
   constexpr maybe_value_storage(T const& in_value)
      requires(is_trivially_copy_constructible<T>)
       : m_storage(in_value), m_has_some(true) {
   }

   // If `T` is not trivially-copy-constructible, then manually construct it
   // in-place.
   constexpr maybe_value_storage(T const& in_value)
      requires(is_copy_constructible<T> && !is_trivially_copy_constructible<T>)
   {
      this->construct(in_value);
   }

   // If `T` is not copy-constructible, delete this copy constructor.
   constexpr maybe_value_storage(T const& in_value)
      requires(!is_copy_constructible<T>)
   = delete;

   // If `T` is trivially-move-constructible, use this simple move constructor.
   constexpr maybe_value_storage(T&& in_value)
      requires(is_trivially_move_constructible<T>)
       : m_storage($fwd(in_value)), m_has_some(true) {
   }

   // If `T` is not trivially-move-constructible, then manually invoke `move` on
   // it.
   constexpr maybe_value_storage(T&& in_value)
      requires(is_move_constructible<T> && !is_trivially_move_constructible<T>)
   {
      this->construct(move(in_value));
      m_has_some = true;
   }

   // If `T` is not move-constructible, delete this move constructor.
   constexpr maybe_value_storage(T&& in_value)
      requires(!is_move_constructible<T>)
   = delete;

   // `nullopt` initializes this without a value.
   constexpr maybe_value_storage(detail::nullopt_type) : m_dummy{} {
   }

   // If other destructors are not conditionally specialized by their
   // `requires`, they should be `default` or deleted.
   constexpr ~maybe_value_storage() = default;

   // If `T` is not trivially-destructible, then manually invoke its destructor.
   constexpr ~maybe_value_storage()
      requires(!is_trivially_destructible<T>)
   {
      if constexpr (requires { m_storage.~T(); }) {
         if (m_has_some) {
            m_storage.~T();
            m_has_some = false;
         }
      }
   }

   // If `T` is trivially-copy-assignable, then forward this value.
   constexpr auto
   operator=(T const& in_value) -> maybe_value_storage&
      requires(is_trivially_copy_assignable<T>)
   {
      m_storage = in_value;
      m_has_some = true;
      return *this;
   }

   // If `T` is non-trivially-copy-assignable, then manually construct it
   // in-place.
   constexpr auto
   operator=(T const& in_value) -> maybe_value_storage&
      requires(is_copy_assignable<T> && !is_trivially_copy_assignable<T>)
   {
      this->assign(in_value);
      return *this;
   }

   // If `T` is not copy-assignable, delete this assignment operator to prevent
   // ambiguous overload resolution.
   constexpr auto
   operator=(T const& in_value) -> maybe_value_storage&
      requires(!is_copy_assignable<T>)
   = delete;

   // If `T` is trivially-move-assignable, then forward this value.
   constexpr auto
   operator=(T&& in_value) -> maybe_value_storage&
      requires(is_trivially_move_assignable<T>)
   {
      m_storage = $fwd(in_value);
      m_has_some = true;
      return *this;
   }

   // If `T` is non-trivially-move-assignable, then manually invoke `move()` on
   // it.
   constexpr auto
   operator=(T&& in_value) -> maybe_value_storage&
      requires(is_move_assignable<T> && !is_trivially_move_assignable<T>)
   {
      this->assign(move(in_value));
      return *this;
   }

   // If `T` is not move-assignable, delete this assignment operator to prevent
   // ambiguous overload resolution.
   constexpr auto
   operator=(T&& in_value) -> maybe_value_storage&
      requires(!is_move_assignable<T>)
   = delete;

   // The following methods are homogenous to all `maybe...storage_type`.

   [[nodiscard]]
   constexpr auto
   value(this auto&& self) -> auto&& {
      return $fwd(self).m_storage;
   }

   [[nodiscard]]
   constexpr auto
   has_value() const -> bool {
      return m_has_some;
   }

   // Destroy the storage unconditionally.
   constexpr void
   hard_reset() {
      m_storage.~T();
      m_has_some = false;
   }

   // Construct an object at the address of the held `storage`.
   template <typename... Args>
   constexpr void
   construct(Args&&... arguments) {
      new (__builtin_addressof(m_storage)) T($fwd(arguments)...);
      m_has_some = true;
   }

   constexpr void
   assign(value_type const& maybe) {
      if (this->has_value()) {
         this->hard_reset();
      }
      m_storage = maybe;
      m_has_some = true;
   }

   constexpr void
   assign(value_type&& maybe) {
      if (this->has_value()) {
         this->hard_reset();
      }
      m_storage = move(maybe);
      m_has_some = true;
   }

   // If this is assigned an `maybe` which wraps a type that can be converted to
   // `T`, then convert that storage to this type implicitly.
   template <is_maybe Maybe>
   constexpr void
   assign(Maybe&& maybe) {
      if (maybe.has_value()) {
         assign($fwd(maybe).value());
      } else {
         if (this->has_value()) {
            hard_reset();
         }
      }
   }

   // A `union` member will not be default-constructed.
   union {
      // `m_dummy` is initialized in a `constexpr` context by both the default
      // and the `nullopt` constructors. This prevents `T`'s default constructor
      // from being called there. One member must be initialized in a
      // `constexpr` context. If `T` is trivial, a dummy member is not required.
      monostate_type m_dummy;
      T m_storage;
   };

   bool m_has_some = false;
};

// `maybe_reference_storage` is a non-owning, trivially-copyable wrapper around
// a pointer to `T`. It models `optional<T&>`. Assignment always rebinds and
// never destroys the referent, and the wrapper itself is trivially-copyable so
// `cat::maybe<T&>` is too.
//
// P2988R12 `optional<T&>`. Reference rebinding semantics.
// https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2025/p2988r12.pdf P3836R2
// Trivially-copyable `optional<T&>`.
// https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2025/p3836r2.html
template <typename T>
struct maybe_reference_storage {
   using value_type = T;

   constexpr maybe_reference_storage() = default;
   constexpr maybe_reference_storage(maybe_reference_storage const&) = default;
   constexpr maybe_reference_storage(maybe_reference_storage&&) = default;
   constexpr auto
   operator=(maybe_reference_storage const&)
      -> maybe_reference_storage& = default;
   constexpr auto
   operator=(maybe_reference_storage&&) -> maybe_reference_storage& = default;
   constexpr ~maybe_reference_storage() = default;

   constexpr maybe_reference_storage(detail::nullopt_type)
       : p_storage(nullptr) {
   }

   template <typename U>
      requires(is_implicitly_convertible<add_lvalue_reference<U>, value_type>)
   constexpr maybe_reference_storage(U& in_value)
       : p_storage(__builtin_addressof(static_cast<value_type>(in_value))) {
   }

   // Rebind the held pointer. The referent is never destroyed, even when the
   // wrapper transitions through `nullopt`.
   constexpr auto
   operator=(value_type option) -> maybe_reference_storage& {
      this->p_storage = __builtin_addressof(option);
      return *this;
   }

   [[nodiscard]]
   constexpr auto
   value(this auto&& self) -> value_type& {
      return *(self.p_storage);
   }

   [[nodiscard]]
   constexpr auto
   has_value() const -> bool {
      return this->p_storage != nullptr;
   }

   // Disengage. The referent is never destroyed.
   constexpr void
   hard_reset() {
      this->p_storage = nullptr;
   }

   // References cannot be constructed in place (no place to put a temporary).
   // Bind the held pointer to `referent` instead.
   template <typename U>
      requires(is_implicitly_convertible<add_lvalue_reference<U>, value_type>)
   constexpr void
   construct(U& referent) {
      this->p_storage = __builtin_addressof(static_cast<value_type>(referent));
   }

   // Copy or clear the held pointer based on whether `maybe` is engaged. The
   // referent is never destroyed.
   template <is_maybe Maybe>
   constexpr void
   assign(Maybe&& maybe) {
      if (maybe.has_value()) {
         this->p_storage =
            __builtin_addressof(static_cast<value_type>(maybe.value()));
      } else {
         this->p_storage = nullptr;
      }
   }

   remove_reference<T>* p_storage = nullptr;
};

// `T` is a `compact<T, predicate, nullopt_value>`.
template <typename T>
struct maybe_compact_storage {
   using value_type = decltype(T::nullopt_state());

   constexpr maybe_compact_storage() = default;

   // Enable copy and move constructors iff `maybe_compact_storage` supports
   // them.

   // If `value_type` is trivially-copy-constructible, use this simple copy
   // constructor.
   constexpr maybe_compact_storage(value_type const& in_value)
      requires(is_trivially_copy_constructible<value_type>)
       : m_storage(in_value) {
   }

   // If `value_type` is not trivially-copy-constructible, then manually
   // construct it in-place.
   constexpr maybe_compact_storage(value_type const& in_value)
      requires(is_copy_constructible<value_type>
               && !is_trivially_copy_constructible<value_type>)
   {
      this->construct(in_value);
   }

   // If `value_type` is not copy-constructible, delete this copy constructor.
   constexpr maybe_compact_storage(value_type const& in_value)
      requires(!is_copy_constructible<value_type>)
   = delete;

   // If `value_type` is trivially-move-constructible, use this simple move
   // constructor.
   constexpr maybe_compact_storage(value_type&& in_value)
      requires(is_trivially_move_constructible<value_type>)
       : m_storage(move(in_value)) {
   }

   // If `value_type` is not trivially-move-constructible, then manually invoke
   // `move` on it.
   constexpr maybe_compact_storage(value_type&& in_value)
      requires(is_move_constructible<value_type>
               && !is_trivially_move_constructible<value_type>)
   {
      this->construct(move(in_value));
   }

   // If `value_type` is not move-constructible, delete this move constructor.
   constexpr maybe_compact_storage(value_type&& in_value)
      requires(!is_move_constructible<value_type>)
   = delete;

   // If other destructors are not conditionally specialized by their
   // `requires`, they should be `default` or deleted.
   constexpr ~maybe_compact_storage() = default;

   // If `value_type` is not trivially-destructible, then manually invoke its
   // destructor.
   constexpr ~maybe_compact_storage()
      requires(!is_trivially_destructible<value_type>)
   {
      if constexpr (requires { m_storage.~value_type(); }) {
         if (this->has_value()) {
            m_storage.~value_type();
         }
      }
   }

   constexpr maybe_compact_storage(detail::nullopt_type)
       : m_storage(T::nullopt_state()) {
   }

   // If other assignment operators are not conditionally specialized by their
   // `requires`, they should be `default` or deleted.

   // If `value_type` is trivially-copy-assignable, then forward this value.
   constexpr auto
   operator=(value_type const& in_value) -> maybe_compact_storage&
      requires(is_trivially_copy_assignable<value_type>)
   {
      m_storage = in_value;
      return *this;
   }

   // If `value_type` is non-trivially-copy-assignable, then manually construct
   // it in-place.
   constexpr auto
   operator=(value_type const& in_value) -> maybe_compact_storage&
      requires(is_copy_assignable<value_type>
               && !is_trivially_copy_assignable<value_type>)
   {
      this->assign(in_value);
      return *this;
   }

   // If `value_type` is not copy-assignable, delete this assignment operator to
   // prevent ambiguous overload resolution.
   constexpr auto
   operator=(value_type const& in_value) -> maybe_compact_storage&
      requires(!is_copy_assignable<value_type>)
   = delete;

   // If `value_type` is trivially-move-assignable, then forward this value.
   constexpr auto
   operator=(value_type&& in_value) -> maybe_compact_storage&
      requires(is_trivially_move_assignable<value_type>)
   {
      m_storage = $fwd(in_value);
      return *this;
   }

   // If `value_type` is non-trivially-move-assignable, then manually invoke
   // `move()` on it.
   constexpr auto
   operator=(value_type&& in_value) -> maybe_compact_storage&
      requires(is_move_assignable<value_type>
               && !is_trivially_move_assignable<value_type>)
   {
      this->assign($fwd(in_value));
      return *this;
   }

   // If `value_type` is not move-assignable, delete this assignment operator to
   // prevent ambiguous overload resolution.
   constexpr auto
   operator=(value_type&& in_value) -> maybe_compact_storage&
      requires(!is_move_assignable<value_type>)
   = delete;

   // The following methods are homogenous to all `maybe...storage_type` types.
   [[nodiscard]]
   constexpr auto
   value(this auto&& self) -> auto&& {
      return $fwd(self).m_storage;
   }

   [[nodiscard]]
   constexpr auto
   has_value() const -> bool {
      return T::has_value(m_storage);
   }

   // Destroy the storage unconditionally.
   constexpr void
   hard_reset() {
      m_storage.~value_type();
      m_storage = T::nullopt_state();
   }

   // Construct an object at the address of the held `storage`.
   template <typename... Args>
   constexpr void
   construct(Args&&... arguments) {
      new (__builtin_addressof(m_storage)) value_type($fwd(arguments)...);
   }

   // If this is assigned an `maybe` which wraps a type that can be converted to
   // `T`, then convert that storage to this type implicitly.
   template <is_maybe Maybe>
   constexpr void
   assign(Maybe&& maybe) {
      if (this->has_value()) {
         if (maybe.has_value()) {
            m_storage = $fwd(maybe).value();
         } else {
            // If the incoming `maybe` is empty, then empty this one.
            this->hard_reset();
         }
      } else {
         if (maybe.has_value()) {
            this->construct(maybe.value());
         }
         // If both `maybe`s are empty, nothing happens.
      }
   }

   // A `union` member will not be default-constructed.
   union {
      monostate_type _;
      value_type m_storage;
   };
};

namespace detail {
template <typename T, bool is_void_type = is_void<T>,
          bool is_reference_type = is_reference<T>>
struct maybe_storage_selector;

template <typename T>
struct maybe_storage_selector<T, true, false> {
   using type = maybe_value_storage<monostate_type>;
};

template <typename T>
struct maybe_storage_selector<T, false, true> {
   using type = maybe_reference_storage<T>;
};

template <typename T>
struct maybe_storage_selector<T, false, false> {
   using maybe_niche_type = typename default_compact_trait<T>::type;

   using type = conditional<has_default_compact<T>,
                            maybe_compact_storage<maybe_niche_type>,
                            maybe_value_storage<T>>;
};
}  // namespace detail

template <typename T>
class [[nodiscard]] maybe {
 private:
   using storage_type = detail::maybe_storage_selector<T>::type;

 public:
   using value_type = storage_type::value_type;

   // All `maybe`s are default-constructed as empty.
   constexpr maybe() : m_storage(nullopt) {
   }

   // `maybe`s can be constructed with `in_place` to have their storage
   // constructed, unless they are reference types. Without this tag, the
   // storage would be uninitialized.
   template <typename... Args>
      requires(!is_reference<value_type>)
   constexpr maybe(in_place_type, Args... arguments) {
      m_storage.construct(arguments...);
   }

   // Forward all constructors to the `storage` member.

   // A reference type cannot be copy-constructed, but other types can.
   template <typename U>
      requires(!is_reference<value_type>
               && is_implicitly_convertible<U, value_type>
               && is_copy_constructible<value_type>)
   constexpr maybe(U& input) : m_storage(static_cast<value_type>(input)) {
   }

   template <typename U>
      requires(!is_reference<value_type>
               && is_implicitly_convertible<U, value_type>
               && is_copy_constructible<value_type>)
   constexpr maybe(U const& input) : m_storage(static_cast<value_type>(input)) {
   }

   // Produce an error message if `value_type` is not copy-constructible.
   template <typename U>
      requires(!is_reference<value_type>
               && is_implicitly_convertible<U, value_type>
               && !is_copy_constructible<value_type>)
   constexpr maybe(U const& input) = delete;

   // Rebinding converting reference constructor. The dangling-temporary check
   // rejects bindings that would create a temporary referent, and the
   // conditional `explicit` mirrors `std::optional<T&>`.
   //
   // P2988R12 `optional<T&>`. Converting reference constructor.
   // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2025/p2988r12.pdf
   template <typename U>
      requires(is_reference<value_type>
               && is_implicitly_convertible<add_lvalue_reference<U>, value_type>
               && !__reference_constructs_from_temporary(value_type, U&))
   constexpr explicit(!__is_convertible(U&, value_type)) maybe(U& input)
       : m_storage(static_cast<value_type>(input)) {
   }

   // Reject reference binding to a temporary or r-value. A deleted overload is
   // preferred to a SFINAE failure for clearer diagnostics.
   //
   // P2988R12 `optional<T&>`. Dangling-temporary protection.
   // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2025/p2988r12.pdf
   template <typename U>
      requires(is_reference<value_type>
               && __reference_constructs_from_temporary(value_type, U))
   constexpr maybe(U&&) = delete;

   // Move constructor.
   template <rvalue U>
      requires(!is_reference<value_type>
               && is_implicitly_convertible<U, value_type>)
   // NOLINTNEXTLINE `rvalue` sufficiently constrains this constructor.
   constexpr maybe(U&& input) : m_storage(move(input)) {
   }

   // `maybe` can be constructed by another `maybe`. The
   // `maybe_converts_from_any_cvref` guard prevents these converting overloads
   // from hijacking nested cases like `maybe<maybe<int>>` from `maybe<int>`,
   // where the value constructor should win.
   template <typename U>
      requires(is_implicitly_convertible<U, value_type>
               && !detail::maybe_converts_from_any_cvref<value_type, maybe<U>>)
   constexpr maybe(maybe<U>& input) {
      m_storage.assign(input);
   }

   template <typename U>
      requires(is_implicitly_convertible<U, value_type>
               && !detail::maybe_converts_from_any_cvref<value_type, maybe<U>>)
   constexpr maybe(maybe<U> const& input) {
      m_storage.assign(input);
   }

   template <rvalue U>
      requires(is_implicitly_convertible<U, value_type>
               && !detail::maybe_converts_from_any_cvref<value_type, maybe<U>>)
   constexpr maybe(maybe<U>&& input) {
      m_storage.assign(move(input));
   }

   // Consuming `nullopt` is forwarded to `storage`.
   constexpr maybe(detail::nullopt_type) : m_storage(nullopt) {
   }

   // Consuming `monostate` default-initializes the `maybe`.
   constexpr maybe(monostate_type)
      requires(is_void<value_type>)
       : m_storage(value_type()) {
   }

   // Any `maybe` can convert into another.
   template <typename U>
      requires(!is_same<U, T> && is_implicitly_convertible<value_type, U>)
   constexpr
   operator maybe<U>() {
      if (this->has_value()) {
         if constexpr (is_same<U, void>) {
            return monostate;
         } else {
            return maybe<U>{
               static_cast<typename maybe<U>::value_type>(this->value())};
         }
      }
      return maybe<U>{nullopt};
   }

   // Forward all assignment operators to `storage`, except when assigning
   // `nullopt`. They should convert any implicitly convertible type into
   // `value_type`.

   // Non-reference converting copy assignment operator.
   template <typename U>
      requires(is_implicitly_convertible<U, value_type>
               && !is_reference<value_type> && is_copy_assignable<value_type>)
   constexpr auto
   operator=(U const& value) -> class maybe& {
      m_storage = static_cast<value_type const&>(value);
      return *this;
   }

   // Non-reference converting move assignment operator.
   template <typename U>
      requires(is_implicitly_convertible<U, value_type>
               && !is_reference<value_type> && is_move_assignable<value_type>)
   constexpr auto
   operator=(U&& value) -> class maybe& {
      m_storage = static_cast<value_type&&>($fwd(value));
      return *this;
   }

   // Rebinding converting reference assignment operator.
   template <typename U>
      requires((is_implicitly_convertible<add_lvalue_reference<U>, value_type>)
               && is_reference<value_type>)
   constexpr auto
   operator=(U& value) -> class maybe& {
      m_storage = static_cast<value_type&>(value);
      return *this;
   }

   // Rebinding converting `maybe` copy assignment operator.
   template <typename U>
      requires(is_implicitly_convertible<U, value_type>
               && !is_reference<value_type> && !is_reference<U>
               && !detail::maybe_converts_from_any_cvref<value_type, maybe<U>>)
   constexpr auto
   operator=(maybe<U> const& maybe) -> class maybe& {
      m_storage.assign(maybe);
      return *this;
   }

   // Rebinding converting `maybe` move assignment operator.
   template <typename U>
      requires(is_implicitly_convertible<U, value_type>
               && is_move_assignable<value_type>
               && !detail::maybe_converts_from_any_cvref<value_type, maybe<U>>)
   constexpr auto
   operator=(maybe<U>&& maybe) -> class maybe& {
      m_storage.assign(move(maybe));
      return *this;
   }

   // Rebinding converting `maybe` reference assignment operator.
   template <typename U>
      requires(is_implicitly_convertible<U, value_type>
               && !detail::maybe_converts_from_any_cvref<value_type, maybe<U>>)
   constexpr auto
   operator=(maybe<U>& maybe) -> class maybe& {
      m_storage.assign(maybe);
      return *this;
   }

   // Assigning `nullopt` destroys any value.
   constexpr auto
   operator=(detail::nullopt_type) -> class maybe& {
      m_storage.hard_reset();
      return *this;
   }

   // TODO: Consider and test this API more carefully.
   // https://brevzin.github.io/c++/2018/12/09/mixed-comparisons/ Comparison
   // operator.
   template <typename U>
      requires(is_implicitly_convertible<U, value_type>)
   [[nodiscard]]
   constexpr auto
   operator==(U const& other) const {
      return m_storage.value() == static_cast<T>(other);
   }

   [[nodiscard]]
   constexpr auto
   operator==(detail::nullopt_type) const {
      return !this->has_value();
   }

   [[nodiscard]]
   constexpr auto
   has_value() const -> bool {
      return m_storage.has_value();
   }

   // Holds true if this `maybe` currently has some value of the type `U`. This
   // method allows `maybe` to be used in `match` statements.
   template <typename U>
   [[nodiscard]]
   constexpr auto
   is() const -> bool {
      // Since this storage can only hold either `value_type` or `nullopt`, this
      // can be expressed in terms of `.has_value()`.
      if constexpr (is_same<U, value_type>) {
         return this->has_value();
      } else {
         return false;
      }
   }

   // Member access syntax pattern matching for `cat::match()`.
   template <typename... Patterns>
      requires(is_specialization<Patterns, detail::pattern_invocable> && ...)
   constexpr void
   match(Patterns&&... patterns) {
      cat::match (*this)($fwd(patterns)...);
   }

   // Holds true if this `maybe` currently has some value convertible and
   // equivalent to `in_value`. This method allows `maybe` to be used in `match`
   // statements.
   template <typename U>
      requires(is_implicitly_convertible<U, value_type>)
   [[nodiscard]]
   constexpr auto
   is(U&& in_value) const -> bool {
      if (this->has_value()) {
         return static_cast<value_type>($fwd(in_value)) == this->value();
      }
      return false;
   }

   // Special overload for `nullopt`.
   [[nodiscard]]
   constexpr auto
   is(detail::nullopt_type) const -> bool {
      return !this->has_value();
   }

   // Get the `storage` unconditionally. If the value should be discarded,
   // consume the `maybe` with `auto _ =` instead.
   [[nodiscard]]
   constexpr auto
   value(this auto&& self) -> decltype(auto)
      requires(!is_void<T>)
   {
      return $fwd(self).m_storage.value();
   }

   // Special discard-able overload for `maybe<void>`.
   // NOLINTNEXTLINE This should not be `[[nodiscard]]`.
   constexpr auto
   value() const -> monostate_type
      requires(is_void<T>)
   {
      return monostate;
   }

   // Get the value held by a `maybe`, or a fallback value if it does not hold a
   // value. For `maybe<T&>`, the fallback is taken by forwarding reference and
   // the result is returned by value. Returning a reference would dangle when
   // the fallback is a temporary.
   //
   // P2988R12 `optional<T&>`. `value_or` returns by value.
   // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2025/p2988r12.pdf
   [[nodiscard]]
   constexpr auto
   value_or(this auto&& self, value_type fallback) -> value_type
      requires(!is_reference<value_type> && !is_void<value_type>)
   {
      if (self.m_storage.has_value()) {
         return $fwd(self).m_storage.value();
      }
      return fallback;
   }

   template <typename U = remove_cvref<value_type>>
      requires(is_reference<value_type>
               && is_implicitly_convertible<U, remove_cvref<value_type>>)
   [[nodiscard]]
   constexpr auto
   value_or(this auto&& self, U&& fallback) -> remove_cvref<value_type> {
      if (self.m_storage.has_value()) {
         return $fwd(self).m_storage.value();
      }
      return static_cast<remove_cvref<value_type>>($fwd(fallback));
   }

   // Get a pointer to the data owned by this `maybe`. If `maybe` holds a raw
   // pointer, this is equivalent to `.value()`, otherwise this is equivalent to
   // `__builtin_addressof(maybe.value())`.
   [[nodiscard]]
   constexpr auto
   p_value(this auto&& self) {
      if constexpr (is_pointer<value_type>) {
         return $fwd(self).m_storage.value();
      } else {
         return __builtin_addressof($fwd(self).m_storage.value());
      }
   }

   // TODO: Make the `.assert()` and `.verify()` getters `constexpr`.
   // TODO: Add overloads which take a `string const` for an error message.

   // Fail a `cat::assert` check if this `maybe` is empty, otherwise return its
   // value.
   auto
   assert(this auto&& self,
          void (*p_assert_handler)(source_location const&) = assert_handler,
          source_location const& callsite = source_location::current())
      -> decltype(auto)
      requires(!is_void<value_type>)
   {
      cat::assert(self.has_value(), p_assert_handler, callsite);
      return $fwd(self).value();
   }

   // Special discard-able overload for `maybe<void>`.
   // NOLINTNEXTLINE This should not be `[[nodiscard]]`.
   auto
   assert(void (*p_assert_handler)(source_location const&) = assert_handler,
          source_location const& callsite = source_location::current()) const
      -> monostate_type
      requires(is_void<value_type>)
   {
      cat::assert(has_value(), p_assert_handler, callsite);
      return monostate;
   }

   // Fail a `cat::verify` check if this `maybe` is empty, otherwise return its
   // value.
   auto
   verify(this auto&& self,
          void (*p_assert_handler)(source_location const&) = assert_handler,
          source_location const& callsite = source_location::current())
      -> decltype(auto)
      requires(!is_void<value_type>)
   {
      cat::verify(self.has_value(), p_assert_handler, callsite);
      return $fwd(self).value();
   }

   // Special discard-able overload for `maybe<void>`.
   auto
   verify(void (*p_assert_handler)(source_location const&) = assert_handler,
          source_location const& callsite = source_location::current()) const
      -> monostate_type
      requires(is_void<value_type>)
   {
      cat::verify(has_value(), p_assert_handler, callsite);
      return monostate;
   }

   // Monadic methods:

   // If this `maybe` holds a value, transform it by a function. Otherwise,
   // propagate an empty `maybe`. For `maybe<void>`, the callable is invoked
   // with no arguments, matching `tl::optional<void>`.
   //
   // P0798R8 Monadic operations for `std::optional`.
   // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2021/p0798r8.html
   template <typename Callback>
   [[nodiscard]]
   constexpr auto
   transform(this auto&& self, Callback&& callback) -> decltype(auto) {
      if constexpr (is_void<T>) {
         using U = decltype(callback());
         static_assert(!is_specialization<U, maybe>);

         if constexpr (is_void<U>) {
            if (self.has_value()) {
               $fwd(callback)();
               return maybe<void>{monostate};
            }
            return maybe<void>{nullopt};
         } else {
            if (self.has_value()) {
               return maybe<U>{$fwd(callback)()};
            }
            return maybe<U>{nullopt};
         }
      } else {
         using U = decltype(callback($fwd(self).value()));
         static_assert(!is_specialization<U, maybe>);

         if constexpr (is_void<U>) {
            if (self.has_value()) {
               $fwd(callback)($fwd(self).value());
               return maybe<void>{monostate};
            }
            return maybe<void>{nullopt};
         } else {
            if (self.has_value()) {
               return maybe<U>{$fwd(callback)($fwd(self).value())};
            }
            return maybe<U>{nullopt};
         }
      }
   }

   // Invoke a callback returning a `maybe` on the value of this `maybe`, and
   // propagate the result. For `maybe<void>`, the callback is invoked with no
   // arguments.
   template <typename Callback>
   constexpr auto
   and_then(this auto&& self, Callback&& callback) {
      if constexpr (is_void<T>) {
         using ret = decltype(callback());
         static_assert(is_specialization<ret, maybe>,
                       "The callback parameter of `and_then` must return a "
                       "specialization of `cat::maybe`.");
         if (self.has_value()) {
            return $fwd(callback)();
         }
         return ret{nullopt};
      } else {
         using ret = decltype(callback($fwd(self).value()));
         static_assert(is_specialization<ret, maybe>,
                       "The callback parameter of `and_then` must return a "
                       "specialization of `cat::maybe`.");
         if (self.has_value()) {
            return $fwd(callback)($fwd(self).value());
         }
         return ret{nullopt};
      }
   }

   // Invoke a callback if this `maybe` holds no value. The callback must return
   // either `void` or a `maybe`. When it returns a `maybe`, `*this` is
   // propagated when a value is held.
   //
   // P0798R8 Monadic operations for `std::optional`.
   // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2021/p0798r8.html
   template <is_invocable Callback>
   constexpr auto
   or_else(this auto&& self, Callback&& callback) {
      using return_type = decltype(callback());
      static_assert(is_void<return_type> || is_maybe<return_type>,
                    "The callback parameter `callback` must return either "
                    "`void` or a specialization of `cat::maybe`.");

      if constexpr (is_void<return_type>) {
         if (!self.has_value()) {
            $fwd(callback)();
         }
         return;
      } else {
         if (self.has_value()) {
            return return_type{$fwd(self)};
         }
         return $fwd(callback)();
      }
   }

   // If this `maybe` is empty, terminate the running process immediately.
   // Otherwise, return its value.
   auto
   or_exit(this auto&& self, iword exit_code = 1)
      requires(!is_void<T>)
   {
      if (self.has_value()) [[likely]] {
         return $fwd(self).value();
      } else {
         exit(exit_code);
      }
      __builtin_unreachable();  // This prevents a build warning.
   }

   // Special discard-able overload for `maybe<void>`.
   // NOLINTNEXTLINE This should not be `[[nodiscard]]`.
   auto
   or_exit(iword exit_code = 1) const -> monostate_type
      requires(is_void<T>)
   {
      if (!this->has_value()) [[unlikely]] {
         exit(exit_code);
      }
      return monostate;
   }

   // If this `maybe` is empty, print an error message and terminate the running
   // process immediately. Otherwise, return its value. These are implemented in
   // `<cat/string>`.
   auto
   or_exit(str_view error_message, iword exit_code = 1) &;
   // This should not be `[[nodiscard]]`, because it might return a `void`
   // wrapper.
   auto
   or_exit(str_view error_message, iword exit_code = 1) const&;  // NOLINT
   auto
   or_exit(str_view error_message, iword exit_code = 1) &&;
   // This should not be `[[nodiscard]]`, because it might return a `void`
   // wrapper.
   auto
   or_exit(str_view error_message, iword exit_code = 1) const&&;  // NOLINT

   // Construct the value in-place and destroy the held value iff it exists. For
   // `maybe<T&>`, this rebinds the held pointer.
   //
   // P2988R12 `optional<T&>`. `emplace` rebinds the held pointer.
   // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2025/p2988r12.pdf
   template <typename... Args>
      requires(!is_void<T>)
   constexpr auto
   emplace(Args&&... arguments) -> value_type& {
      *this = nullopt;
      m_storage.construct($fwd(arguments)...);
      return m_storage.value();
   }

   // Disengage. For `maybe<T&>` this clears the held pointer without destroying
   // the referent.
   //
   // P2988R12 `optional<T&>`. `reset` does not destroy the referent.
   // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2025/p2988r12.pdf
   constexpr void
   reset() {
      m_storage.hard_reset();
   }

   // Swap the engagement and value of two `maybe`s. For `maybe<T&>` the held
   // pointers are exchanged. The referents themselves are never touched.
   //
   // P2988R12 `optional<T&>`. Swap rebinds pointers.
   // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2025/p2988r12.pdf
   constexpr void
   swap(maybe& other)
      requires(!is_void<value_type>)
   {
      if constexpr (is_reference<value_type>) {
         auto* const p_temp = m_storage.p_storage;
         m_storage.p_storage = other.m_storage.p_storage;
         other.m_storage.p_storage = p_temp;
      } else {
         bool const has_a = this->has_value();
         bool const has_b = other.has_value();
         if (has_a && has_b) {
            value_type temp = move(m_storage.value());
            m_storage.value() = move(other.m_storage.value());
            other.m_storage.value() = move(temp);
         } else if (has_a) {
            other.m_storage.construct(move(m_storage.value()));
            m_storage.hard_reset();
         } else if (has_b) {
            m_storage.construct(move(other.m_storage.value()));
            other.m_storage.hard_reset();
         }
      }
   }

   // Range support. A `maybe<T>` models a contiguous range of size 0 or 1, so
   // iteration is just a bare pointer pair. `maybe<void>` has no traversable
   // value and therefore no `begin`/`end`.
   //
   // P3168R1 Give `std::optional` range support.
   // https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2024/p3168r1.html
   //
   // TODO: When the ranges library lands, add the deferred operators:
   // `operator==` / <=> between two `maybe`s, the range pipe `operator|`, and
   // the view-adapter `operator&`.
   [[nodiscard]]
   constexpr auto
   begin(this auto&& self)
      requires(!is_void<value_type>)
   {
      using ptr_type = decltype(__builtin_addressof(self.m_storage.value()));
      if (self.has_value()) {
         return __builtin_addressof(self.m_storage.value());
      }
      return ptr_type{nullptr};
   }

   [[nodiscard]]
   constexpr auto
   end(this auto&& self)
      requires(!is_void<value_type>)
   {
      using ptr_type = decltype(__builtin_addressof(self.m_storage.value()));
      if (self.has_value()) {
         return __builtin_addressof(self.m_storage.value()) + 1;
      }
      return ptr_type{nullptr};
   }

 private:
   storage_type m_storage;
};

// This deduction guide is required for deducing references.
template <typename T>
maybe(T) -> maybe<T>;

// `maybe<T&>` is trivially-copyable and has the same layout as a pointer. These
// static checks document and enforce that invariant against future regressions.
//
// P3836R2 Trivially-copyable `optional<T&>`.
// https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2025/p3836r2.html
static_assert(__is_trivially_copyable(maybe<int&>));
static_assert(__is_trivially_copyable(maybe<int const&>));
static_assert(sizeof(maybe<int&>) == sizeof(int*));

// `make_maybe(value)` deduces the value type, like `std::make_optional`.
// `make_maybe<T>(arguments).` constructs `maybe<T>` in place. There is no
// `make_maybe<T&>().` overload because constructing a `maybe<T&>` from a
// temporary is forbidden, and partial-order ranking makes the argument-deducing
// form pick up l-values unambiguously, so callers should just write
// `maybe<T&>{lvalue}` directly.
//
// P2988R12 `optional<T&>`. No reference factories.
// https://www.open-std.org/jtc1/sc22/wg21/docs/papers/2025/p2988r12.pdf
template <typename T>
[[nodiscard]]
constexpr auto
make_maybe(T&& value) -> maybe<remove_cvref<T>> {
   return maybe<remove_cvref<T>>{$fwd(value)};
}

template <typename T, typename... Args>
   requires(!is_reference<T> && !is_void<T>)
[[nodiscard]]
constexpr auto
make_maybe(Args&&... arguments) -> maybe<T> {
   return maybe<T>{in_place, $fwd(arguments)...};
}

template <typename T>
   requires(is_void<T>)
[[nodiscard]]
constexpr auto
make_maybe() -> maybe<void> {
   return maybe<void>{monostate};
}

template <typename T>
auto
propagate_error(maybe<T> const&) -> detail::nullopt_type {
   return nullopt;
}

// TODO: Support `void*`.
// Simplify nullable pointers.
template <typename T>
using maybe_ptr = maybe<sentinel<T*, nullptr>>;

namespace detail {
template <is_integral T>
constexpr auto
is_non_negative(T value) -> bool {
   return value >= 0;
}
}  // namespace detail

// Simplify non-negative signed integers.
template <is_integral T>
using maybe_non_negative =
   // A lambda here causes clangd 14 to crash.
   maybe<compact<T, detail::is_non_negative<T>, -1>>;

// Simplify non-zero numbers.
template <typename T>
using maybe_non_zero = maybe<sentinel<T, T(0)>>;

}  // namespace cat

