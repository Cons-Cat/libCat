// Itanium C++ ABI 3.3.2 thread-safe static initialisation. The compiler
// emits a fast `if (guard_byte_0 == 0)` check at the call site, then
// only calls `__cxa_guard_acquire` when the static hasn't been
// initialised yet. The guard is a 64-bit object whose byte 0 tracks
// "init complete" and whose byte 1 we use as a spin lock.
extern "C" [[nodiscard]]
auto
// NOLINTNEXTLINE
__cxa_guard_acquire(cat::uword* _Nonnull p_guard) -> int;

extern "C" void
// NOLINTNEXTLINE
__cxa_guard_release(cat::uword* _Nonnull p_guard);

extern "C" void
// NOLINTNEXTLINE
__cxa_guard_abort(cat::uword* _Nonnull p_guard);

class jmp_buffer {
   // This buffer layout should vary by all ISAs.

 private:
   // %rbx, %rbp, %r12, %r13, %r14, %r15.
   [[maybe_unused]]
   cat::uword m_registers[6];
   // %rsp:
   [[maybe_unused]]
   cat::uword m_stack_pointer;
};

[[gnu::naked, gnu::returns_twice]]
auto
