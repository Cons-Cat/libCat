// `syscall0..6` are non-volatile asm helpers. The compiler is allowed to
// reorder, hoist, and combine these calls. Use only for syscalls that have no
// caller-observable side effects.
[[gnu::no_sanitize_address]]
auto syscall0(cat::iword) -> cat::iword;
[[gnu::no_sanitize_address]]
auto syscall1(cat::iword, cat::no_type) -> cat::iword;
[[gnu::no_sanitize_address]]
auto syscall2(cat::iword, cat::no_type, cat::no_type) -> cat::iword;
[[gnu::no_sanitize_address]]
auto
   syscall3(cat::iword, cat::no_type, cat::no_type, cat::no_type) -> cat::iword;
[[gnu::no_sanitize_address]]
auto
   syscall4(cat::iword, cat::no_type, cat::no_type, cat::no_type, cat::no_type)
      -> cat::iword;
[[gnu::no_sanitize_address]]
auto syscall5(
   cat::iword, cat::no_type, cat::no_type, cat::no_type, cat::no_type,
   cat::no_type
) -> cat::iword;
[[gnu::no_sanitize_address]]
auto syscall6(
   cat::iword, cat::no_type, cat::no_type, cat::no_type, cat::no_type,
   cat::no_type, cat::no_type
) -> cat::iword;

// Volatile counterparts of `syscall0..6`. The compiler must emit each call
// exactly once at its source position. Required for syscalls with externally
// observable side effects (`write`, `mmap`, `futex`, signal delivery, etc.).
[[gnu::no_sanitize_address]]
auto syscall0_volatile(cat::iword) -> cat::iword;
[[gnu::no_sanitize_address]]
auto syscall1_volatile(cat::iword, cat::no_type) -> cat::iword;
[[gnu::no_sanitize_address]]
auto syscall2_volatile(cat::iword, cat::no_type, cat::no_type) -> cat::iword;
[[gnu::no_sanitize_address]]
auto syscall3_volatile(cat::iword, cat::no_type, cat::no_type, cat::no_type)
   -> cat::iword;
[[gnu::no_sanitize_address]]
auto syscall4_volatile(
   cat::iword, cat::no_type, cat::no_type, cat::no_type, cat::no_type
) -> cat::iword;
[[gnu::no_sanitize_address]]
auto syscall5_volatile(
   cat::iword, cat::no_type, cat::no_type, cat::no_type, cat::no_type,
   cat::no_type
) -> cat::iword;
[[gnu::no_sanitize_address]]
auto syscall6_volatile(
   cat::iword, cat::no_type, cat::no_type, cat::no_type, cat::no_type,
   cat::no_type, cat::no_type
) -> cat::iword;

// `syscall<T>` is the default syscall wrapper. Use it for syscalls without
// externally observable side effects.
template <typename T, typename... Args>
auto
syscall(cat::iword call, Args... parameters) -> nix::scaredy_nix<T>
   requires(sizeof...(Args) < 7);

// `syscall_volatile<T>` mirrors `syscall<T>` but uses the volatile asm
// helpers. Required for side-effectful syscalls.
template <typename T, typename... Args>
auto
syscall_volatile(cat::iword call, Args... parameters) -> nix::scaredy_nix<T>
   requires(sizeof...(Args) < 7);

