// vim: set ft=cpp:
#pragma once

#include <cat/linux>

// TODO: Get this basically working.

namespace cat {

enum class file_open_mode : unsigned char {
   read,
   write,
   append,
};

enum class file_seek_mode : unsigned char {
   set,
   current,
   end,
};

class raw_type_file {
 public:
   constexpr raw_type_file() = default;
   constexpr raw_type_file(raw_type_file const&) = default;
   constexpr raw_type_file(raw_type_file&&) = default;

   auto
   open(zstr_view const path, file_open_mode mode = file_open_mode::read)
      -> scaredy<void, nix::linux_error> {
      nix::open_mode file_mode = nix::open_mode::read_only;
      nix::open_flags flags = nix::open_flags(0);

      switch (mode) {
         case file_open_mode::read:
            file_mode = nix::open_mode::read_only;
            break;
         case file_open_mode::write:
            file_mode = nix::open_mode::write_only;
            flags = nix::open_flags::create | nix::open_flags::truncate;
            break;
         case file_open_mode::append:
            file_mode = nix::open_mode::write_only;
            flags = nix::open_flags::create | nix::open_flags::append_file;
            break;
      }

      if (!is_closed()) {
         $prop(close());
      }

      // Get the status of the opened file.
      nix::file_descriptor file_descriptor =
         $prop(nix::sys_open(path, file_mode, flags));
      scaredy fstat_result = nix::sys_fstat(file_descriptor);
      if (!fstat_result.has_value()) {
         nix::linux_error error = fstat_result.error();
         auto _ = nix::sys_close(file_descriptor);
         return error;
      }

      nix::file_status status = fstat_result.value();
      m_file_descriptor = file_descriptor;
      m_open_mode = file_mode;
      m_file_size = status.file_size;
      m_block_size = status.block_size;

      return {};
   }

   auto
   close() -> scaredy<void, nix::linux_error> {
      if (is_closed()) {
         return scaredy<void, nix::linux_error>{};
      }

      $prop(nix::sys_close(m_file_descriptor));
      m_file_descriptor = nix::file_descriptor{-1};
      m_open_mode = nix::open_mode::read_only;
      m_file_size = 0u;
      m_block_size = 0u;
      return scaredy<void, nix::linux_error>{};
   }

   [[nodiscard]]
   constexpr auto
   is_closed() const -> bool {
      // When closed, `file_descriptor` is set to -1.
      return m_file_descriptor.value == -1;
   }

   constexpr auto
   is_readable() const -> bool {
      // `open_mode` is an enumerated value, not a bitfield, so `read_only`
      // (zero) cannot be tested with a bitwise mask.
      if (is_closed()) {
         return false;
      }
      return m_open_mode == nix::open_mode::read_only
             || m_open_mode == nix::open_mode::read_write;
   }

   constexpr auto
   is_writeable() const -> bool {
      if (is_closed()) {
         return false;
      }
      return m_open_mode == nix::open_mode::write_only
             || m_open_mode == nix::open_mode::read_write;
   }

 private:
   [[maybe_unused]]
   nix::file_descriptor m_file_descriptor{-1};
   nix::open_mode m_open_mode = nix::open_mode::read_only;
   idx m_file_size = 0u;
   idx m_block_size = 0u;
};

}  // namespace cat
