// vim: set ft=cpp:
#pragma once

#include <cat/allocator>
#include <cat/allocator_parameters>
#include <cat/linux>

namespace cat {

inline namespace manual {

struct thread {
 public:
   thread() {
      m_handle.add_clone_flag(nix::clone_flags::thread);
      // `clone_flags::child_set_tid` pairs with `clone_flags::child_clear_tid`
      // (already in `nix::process::default_flags`) so the kernel publishes the
      // tid into `m_clone_child_clear_tid_for_kernel` before user code runs.
      // `join` waits on that word with `futex_command::wait`.
      m_handle.add_clone_flag(nix::clone_flags::child_set_tid);
   }

   thread(thread const&) = delete;

   // TODO: Default or delete a move constructor and assignment operator?

   template <typename... Args>
   auto
   spawn(
      is_allocator auto& allocator, idx stack_size,
      is_invocable<Args...> auto&& callback, Args&&... arguments
   ) -> maybe<void> {
      scaredy result = m_handle.spawn(
         allocator, stack_size, $fwd(callback), $fwd(arguments)...
      );
      if (result.has_value()) {
         return monostate;
      }
      return nullopt;
   }

   [[nodiscard]]
   auto
   join() const -> maybe<void> {
      scaredy result = m_handle.wait();
      if (result.has_value()) {
         return monostate;
      }
      return nullopt;
   }

   [[nodiscard]]
   constexpr auto
   has_stack() const -> bool {
      return m_handle.has_stack();
   }

   // Deallocate this `thread`'s stack from `allocator`. Call after `join()`.
   template <is_allocator Allocator>
   [[clang::reinitializes]]
   void
   free(allocator_ref<Allocator> allocator) {
      m_handle.free(allocator);
   }

   // Deallocate this `thread`'s stack from `allocator`. Call after `join()`.
   [[clang::reinitializes, gnu::always_inline, gnu::nodebug]]
   void
   free(dyn_allocator allocator) {
      free<dyn_allocator>(allocator);
   }

 private:
   // This is platform-specific hidden code.
   nix::process m_handle;
};

}  // namespace manual

// TODO: Move this elsewhere.
inline void
relax_cpu() {
   asm volatile("pause" ::
                   : "memory");
}

}  // namespace cat
