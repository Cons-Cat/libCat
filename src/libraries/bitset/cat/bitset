#pragma once

#include <cat/array>
#include <cat/bit>
#include <cat/math>
#include <cat/maybe>
#include <cat/meta>
#include <cat/span>

namespace cat {

template <is_unsigned_integral Storage>
class bit_span;

namespace detail {
template <typename... Arguments>
concept are_bitset_arguments_same_size =
   ((sizeof(Arguments...[0]) == sizeof(Arguments)) && ...);
}  // namespace detail

template <idx bits_count>
class [[clang::trivial_abi, gsl::Owner]]
bitset : public bitwise_interface<bitset<bits_count>>,
         public bit_collection_interface<bitset<bits_count>> {
 private:
   template <is_unsigned_integral>
   friend class bit_span;

   template <idx, is_unsigned_integral... Arguments>
      requires(detail::are_bitset_arguments_same_size<Arguments...>)
   friend constexpr auto
   make_bitset(Arguments... arguments);

   // Store the smallest number of bytes needed for `bits_count`. If that is 8
   // bytes or fewer, use that many bytes. If it is larger, use an array of
   // 8-byte integers. Divide the bits by 8, rounding up.
   static constexpr idx total_bytes = div_ceil(bits_count, 8u);

   using array_type = conditional<
      total_bytes <= 8u,
      // `uint_fixed` will not compile here if it is larger than 8
      // or it is not a power of 2. This is an `array` of one
      // element to make it iterable.
      array<uint_fixed<min(bit_ceil(total_bytes), 8u)>, 1u>,
      array<uint8, div_ceil(total_bytes, 8u)>>;

   using array_type_element = array_type::value_type;

 public:
   using storage_type = array_type_element;
   using value_type = bit_value;
   using const_value_type = bit_value const;
   using reference = bit_reference<array_type_element>;
   using const_reference = bit_reference<array_type_element const>;
   using pointer = bit_ptr<array_type_element>;
   using const_pointer = bit_ptr<array_type_element const>;
   using size_type = idx;
   using difference_type = iword;
   using iterator = bit_stepanov_iterator<typename array_type::iterator>;
   using const_iterator =
      bit_stepanov_iterator<typename array_type::const_iterator>;
   using reverse_iterator =
      bit_stepanov_iterator<typename array_type::reverse_iterator>;
   using const_reverse_iterator =
      bit_stepanov_iterator<typename array_type::const_reverse_iterator>;

   static constexpr idx storage_array_size = array_type::size();

   static constexpr idx storage_element_size = sizeof(array_type_element);

   // The number of bits NOT counted in the first 1, 2, 4, or 8 bytes of this
   // bitset.
   static constexpr idx leading_skipped_bits =
      // The number of bits in the entire storage, minus the bits declared for
      // use.
      sizeof(array_type) * 8u - bits_count;

   // The number of bits counted in the first 1, 2, 4, or 8 bytes of this
   // bitset.
   static constexpr idx leading_bytes_bits =
      // Size of this storage, 64 bits or fewer.
      idx(
         storage_element_size * 8u -
         // Minus the number of unused bits in this bitset.
         leading_skipped_bits
      );

   constexpr bitset() = default;
   constexpr bitset(bitset const&) = default;
   constexpr bitset(bitset&&) = default;

   constexpr auto
   operator=(bitset const&) -> bitset& = default;
   constexpr auto
   operator=(bitset&&) -> bitset& = default;

   [[nodiscard]]
   static constexpr auto
   size() -> idx {
      return bits_count;
   }

   constexpr void
   swap(bitset& other) {
      m_data.swap(other.m_data);
   }

   // Construct a `bitset` from a bit-string at compile time.
   template <__SIZE_TYPE__ bitstring_size>
   consteval bitset(char const (&bitstring)[bitstring_size]) {
      [[assume(bitstring[bitstring_size - 1] == '\0')]];
      bitset<bits_count> new_bitset;
      for (__SIZE_TYPE__ i = 0; i < bits_count; ++i) {
         [[assume(bitstring[i] == '0' || bitstring[i] == '1')]];
         new_bitset[i] = (bitstring[i] == '1');
      }
      *this = new_bitset;
   }

   // `= default` cannot be used because `bitwise_interface` is a base class
   // without a viable `operator==`. Compare the storage array directly.
   [[nodiscard]]
   constexpr auto
   operator==(bitset const& other) const -> bool {
      return m_data == other.m_data;
   }

   // Count set bits in this bitset.
   [[nodiscard]]
   constexpr auto
   popcount() const -> idx {
      return cat::popcount(
         span<array_type_element const>{m_data.data(), m_data.size()}
      );
   }

   [[nodiscard]]
   constexpr auto
   has_single_bit() const -> bool {
      return popcount() == 1u;
   }

   // Index into this bit-set from the right-most bit.
   [[nodiscard]]
   constexpr auto
   operator[](idx index_bit) [[clang::lifetimebound]]
   -> bit_reference<array_type_element> {
      if !consteval {
         assert(index_bit < bits_count);
      }

      idx const array_word = idx(
         m_data.size() - 1u - ((index_bit + leading_skipped_bits) / word_bits)
      );
      array_type_element& index_byte = m_data[array_word];

      uword bit_offset = index_bit + leading_skipped_bits;
      if constexpr (total_bytes > word_bytes) {
         // If the bitset is larger than a word, wrap the bit offset by the size
         // of a word.
         bit_offset.raw &= word_bits.raw - 1u;
      }

      return make_bit_reference_from_offset(index_byte, bit_offset);
   }

   [[nodiscard]]
   constexpr auto
   operator[](idx index_bit) const [[clang::lifetimebound]]
   -> bit_reference<array_type_element> {
      return (*unconst(this))[index_bit];
   }

   [[nodiscard]]
   constexpr auto
   at(idx index) [[clang::lifetimebound]]
   -> maybe<bit_reference<array_type_element>> {
      if (index < bits_count) {
         return (*this)[index];
      }
      return nullopt;
   }

   [[nodiscard]]
   constexpr auto
   at(idx index) const [[clang::lifetimebound]]
   -> maybe<bit_reference<array_type_element> const> {
      if (index < bits_count) {
         return (*this)[index];
      }
      return nullopt;
   }

   // `bitwise_interface` generates `operator&` and `operator&=` from this.
   [[nodiscard]]
   constexpr auto
   bit_and(bitset const& other) const -> bitset {
      bitset result;
      for (idx i; i < storage_array_size; ++i) {
         result.m_data[i] = m_data[i] & other.m_data[i];
      }
      return result;
   }

   // `bitwise_interface` generates `operator|` and `operator|=` from this.
   [[nodiscard]]
   constexpr auto
   bit_or(bitset const& other) const -> bitset {
      bitset result;
      for (idx i; i < storage_array_size; ++i) {
         result.m_data[i] = m_data[i] | other.m_data[i];
      }
      return result;
   }

   // `bitwise_interface` generates `operator~` from this. Padding bits are
   // reset to zero afterwards to preserve the class invariant.
   [[nodiscard]]
   constexpr auto
   bit_complement() const -> bitset {
      bitset result;
      for (idx i; i < storage_array_size; ++i) {
         result.m_data[i] = ~m_data[i];
      }
      result.clear_padding_bits();
      return result;
   }

   // XOR is not part of `bitwise_interface` and `cat::basic_int` does not
   // define `operator^`, so compute on the raw underlying integers.
   [[nodiscard]]
   friend constexpr auto
   operator^(bitset const& lhs, bitset const& rhs) -> bitset {
      bitset result;
      for (idx i; i < storage_array_size; ++i) {
         result.m_data[i] =
            array_type_element(lhs.m_data[i].raw ^ rhs.m_data[i].raw);
      }
      return result;
   }

   friend constexpr auto
   operator^=(bitset& self, bitset const& other) -> bitset& {
      self = self ^ other;
      return self;
   }

   // Evaluate true if every bit in this bitset is 1.
   [[nodiscard]]
   constexpr auto
   all_of() const -> bool {
      return popcount() == bits_count;
   }

   // Evaluate true if at least one bit in this bitset is 1.
   [[nodiscard]]
   constexpr auto
   any_of() const -> bool {
      return popcount() != 0u;
   }

   // Evaluate true if every bit in this bitset is 0.
   [[nodiscard]]
   constexpr auto
   none_of() const -> bool {
      return !(any_of());
   }

   [[nodiscard]]
   constexpr auto
   bit_width() const -> idx {
      return idx(bits_count - countl_zero());
   }

   [[nodiscard]]
   constexpr auto
   countl_zero() const -> idx {
      idx count;
      for (auto&& bytes : m_data) {
         idx next_count = cat::countl_zero(bytes);
         count += next_count;

         // If any 1s are found, skip remaining bytes.
         if (next_count != sizeof(array_type_element) * 8u) {
            break;
         }
      }
      return min(count, bits_count);
   }

   [[nodiscard]]
   constexpr auto
   countl_one() const -> idx {
      idx count;
      for (auto&& bytes : m_data) {
         idx next_count = cat::countl_one(bytes);
         count += next_count;

         if (next_count != sizeof(array_type_element) * 8u) {
            break;
         }
      }
      return min(count, bits_count);
   }

   [[nodiscard]]
   constexpr auto
   countr_zero() const -> idx {
      idx count;

      // Iff `leading_skipped_bits` is not zero, then the first iteration of
      // this loop requires special handling to prevent leading bits from being
      // considered in the ctz.
      constexpr bool has_prologue = (leading_skipped_bits != 0u);
      if constexpr (has_prologue) {
         // This mask is all one bits except for the leading zero bits.
         constexpr array_type_element mask =
            ~((array_type_element(1u) << leading_skipped_bits) - 1u);
         // Set leading bits to zero, and then subtract them from the count.
         // `array_type` always holds at least one element, so the last storage
         // index is `storage_array_size - 1u` without unsigned wrap.
         count += cat::countr_zero(m_data[storage_array_size - 1u] & mask);
         count = (count - leading_skipped_bits).to_idx().value();

         // If any zeros were found, return early.
         if (count != storage_element_size * 8u - leading_skipped_bits) {
            return count;
         }
      }

      // `i` is signed so the prologue case can start at -1 when the backing
      // store is a single element and the first byte was already scanned.
      // `to_idx` is only called after `i >= 0`, so the value fits `idx`.
      for (iword i = storage_array_size - 1u - has_prologue; i >= 0; --i) {
         idx const byte_index = i.to_idx().value();
         idx next_count = cat::countr_zero(m_data[byte_index]);
         count += next_count;

         // If any 1's are found, skip remaining bytes.
         if (next_count != sizeof(array_type_element) * 8u) {
            break;
         }
      }
      return count;
   }

   [[nodiscard]]
   constexpr auto
   countr_one() const -> idx {
      idx count;

      constexpr bool has_prologue = (leading_skipped_bits != 0u);
      if constexpr (has_prologue) {
         constexpr array_type_element mask =
            ~((array_type_element(1u) << leading_skipped_bits) - 1u);
         count += cat::countr_one(m_data[storage_array_size - 1u] | ~mask);
         count = (count - leading_skipped_bits).to_idx().value();

         if (count != storage_element_size * 8u - leading_skipped_bits) {
            return count;
         }
      }

      for (iword i = storage_array_size - 1u - has_prologue; i >= 0; --i) {
         idx const byte_index = i.to_idx().value();
         idx next_count = cat::countr_one(m_data[byte_index]);
         count += next_count;

         if (next_count != sizeof(array_type_element) * 8u) {
            break;
         }
      }
      return count;
   }

   // Clear every bit (all logical indices `0..bits_count`) to 0.
   constexpr auto
   clear() -> bitset& {
      for (auto& word : m_data) {
         word = array_type_element(0u);
      }
      return *this;
   }

   // Set every bit (all logical indices `0..bits_count`) to `value`. Padding
   // bits are left at 0 so the class invariant holds.
   constexpr auto
   fill(bit_value value = true) -> bitset& {
      if (value) {
         if constexpr (bits_count != 0u) {
            for (auto& word : m_data) {
               word = array_type_element::max();
            }
            clear_padding_bits();
         }
      } else {
         clear();
      }
      return *this;
   }

   // Set every even-indexed bit (logical indices 0, 2, 4, ...) to 1. Bits at
   // odd logical indices are left unchanged.
   constexpr auto
   set_even() -> bitset& {
      if constexpr (bits_count != 0u) {
         for (auto& word : m_data) {
            word |= even_bits_pattern;
         }
         clear_padding_bits();
      }
      return *this;
   }

   // Set every odd-indexed bit (logical indices 1, 3, 5, ...) to 1. Bits at
   // even logical indices are left unchanged.
   constexpr auto
   set_odd() -> bitset& {
      if constexpr (bits_count != 0u) {
         for (auto& word : m_data) {
            word |= odd_bits_pattern;
         }
         clear_padding_bits();
      }
      return *this;
   }

   // Clear every even-indexed bit (logical indices 0, 2, 4, ...) to 0. Bits at
   // odd logical indices are left unchanged.
   constexpr auto
   unset_even() -> bitset& {
      if constexpr (bits_count != 0u) {
         // AND cannot set padding bits, so no post-clear is needed.
         for (auto& word : m_data) {
            word &= ~even_bits_pattern;
         }
      }
      return *this;
   }

   // Clear every odd-indexed bit (logical indices 1, 3, 5, ...) to 0. Bits at
   // even logical indices are left unchanged.
   constexpr auto
   unset_odd() -> bitset& {
      if constexpr (bits_count != 0u) {
         for (auto& word : m_data) {
            word &= ~odd_bits_pattern;
         }
      }
      return *this;
   }

   // Bitwise rotate left by `shift` positions, across all `bits_count` bits.
   // `shift` is reduced mod `bits_count`. Negative shifts rotate the other way.
   [[nodiscard]]
   constexpr auto
   rotate_left(iword shift) const -> bitset {
      if constexpr (bits_count == 0u) {
         return *this;
      } else if constexpr (
         storage_array_size == 1u && leading_skipped_bits == 0u
      ) {
         // The bitset exactly fills one storage word, so `cat::rotate_left` on
         // the element is the rotation of the whole bitset.
         bitset result;
         result.m_data[0] = cat::rotate_left(m_data[0], shift);
         return result;
      } else if constexpr (storage_array_size == 1u) {
         using raw_type = raw_arithmetic_type<array_type_element>;
         constexpr raw_type logical_mask =
            (raw_type(1u) << bits_count.raw) - 1u;
         constexpr raw_type storage_shift = leading_skipped_bits.raw;
         constexpr auto bw = iword::raw_type(bits_count);
         auto s = shift.raw % bw;
         if (s < 0) {
            s += bw;
         }
         uword const left_shift = uword(s);
         raw_type const packed =
            raw_type(m_data[0].raw >> storage_shift) & logical_mask;
         raw_type const rotated =
            left_shift == 0u
               ? packed
               : raw_type(
                    (packed << left_shift.raw)
                    | (packed >> (bits_count.raw - left_shift.raw))
                 ) & logical_mask;
         bitset result;
         result.m_data[0] = array_type_element(rotated << storage_shift);
         return result;
      } else {
         // TODO: For the padded single-word case, delegate to
         // `cat::rotate_left` plus masking to rotate within `bits_count` bits.
         // For the multi-word case, use per-word shifts + carries. The current
         // loop is `O(bits_count)` bit copies.
         bitset result;
         constexpr auto bw = iword::raw_type(bits_count);
         auto s = shift.raw % bw;
         if (s < 0) {
            s += bw;
         }
         // Rotating left by `s` is equivalent to indexing backward by `s`,
         // which is forward by `bw - s` under unsigned modular arithmetic.
         idx const backward_shift = idx(bw - s);
         for (idx i = 0u; i < bits_count; ++i) {
            idx const src = (i + backward_shift) % bits_count;
            result[i] = bool((*this)[src]);
         }
         return result;
      }
   }

   // Bitwise rotate right by `shift` positions, across all `bits_count` bits.
   // `shift` is reduced mod `bits_count`. Negative shifts rotate the other way.
   [[nodiscard]]
   constexpr auto
   rotate_right(iword shift) const -> bitset {
      if constexpr (bits_count == 0u) {
         return *this;
      } else if constexpr (
         storage_array_size == 1u && leading_skipped_bits == 0u
      ) {
         bitset result;
         result.m_data[0] = cat::rotate_right(m_data[0], shift);
         return result;
      } else if constexpr (storage_array_size == 1u) {
         using raw_type = raw_arithmetic_type<array_type_element>;
         constexpr raw_type logical_mask =
            (raw_type(1u) << bits_count.raw) - 1u;
         constexpr raw_type storage_shift = leading_skipped_bits.raw;
         constexpr auto bw = iword::raw_type(bits_count);
         auto s = shift.raw % bw;
         if (s < 0) {
            s += bw;
         }
         uword const right_shift = uword(s);
         raw_type const packed =
            raw_type(m_data[0].raw >> storage_shift) & logical_mask;
         raw_type const rotated =
            right_shift == 0u
               ? packed
               : raw_type(
                    (packed >> right_shift.raw)
                    | (packed << (bits_count.raw - right_shift.raw))
                 ) & logical_mask;
         bitset result;
         result.m_data[0] = array_type_element(rotated << storage_shift);
         return result;
      } else {
         bitset result;
         constexpr auto bw = iword::raw_type(bits_count);
         auto s = shift.raw % bw;
         if (s < 0) {
            s += bw;
         }
         idx const forward_shift = idx(s);
         for (idx i = 0u; i < bits_count; ++i) {
            idx const src = (i + forward_shift) % bits_count;
            result[i] = bool((*this)[src]);
         }
         return result;
      }
   }

   constexpr void
   reverse_inplace() {
      auto first = bit_stepanov_iterator(m_data.rbegin(), leading_skipped_bits);
      cat::stepanov_reverse_inplace(first, first + bits_count);
   }

   // Because `bit_stepanov_iterator` produces proxy-references, the
   // `stepanov_iterable_interface` base cannot generate these iterator methods
   // automatically.

   [[nodiscard]]
   constexpr auto
   begin() -> iterator {
      return iterator(m_data.begin());
   }

   [[nodiscard]]
   constexpr auto
   end() -> iterator {
      return iterator(m_data.end());
   }

   [[nodiscard]]
   constexpr auto
   begin() const -> const_iterator {
      return const_iterator(m_data.begin());
   }

   [[nodiscard]]
   constexpr auto
   end() const -> const_iterator {
      return const_iterator(m_data.end());
   }

   [[nodiscard]]
   constexpr auto
   cbegin() const -> const_iterator {
      return const_iterator(m_data.cbegin());
   }

   [[nodiscard]]
   constexpr auto
   cend() const -> const_iterator {
      return const_iterator(m_data.cend());
   }

   [[nodiscard]]
   constexpr auto
   rbegin() -> reverse_iterator {
      return reverse_iterator(
         m_data.end(), limits<array_type_element>::bits - 1u
      );
   }

   [[nodiscard]]
   constexpr auto
   rend() -> reverse_iterator {
      return reverse_iterator(m_data.begin());
   }

   [[nodiscard]]
   constexpr auto
   rbegin() const -> const_reverse_iterator {
      return reverse_iterator(
         m_data.end(), limits<array_type_element>::bits - 1u
      );
   }

   [[nodiscard]]
   constexpr auto
   rend() const -> const_reverse_iterator {
      return const_reverse_iterator(m_data.begin());
   }

   [[nodiscard]]
   constexpr auto
   crbegin() const -> const_reverse_iterator {
      return const_reverse_iterator(
         m_data.end(), limits<array_type_element>::bits - 1u
      );
   }

   [[nodiscard]]
   constexpr auto
   crend() const -> const_reverse_iterator {
      return const_reverse_iterator(m_data.begin());
   }

 private:
   // Base pattern `0x55...55`. Every other bit set starting at physical bit 0.
   static constexpr array_type_element every_other_bit_pattern =
      array_type_element::max() / array_type_element(3u);

   // Pattern for even logical indices. Logical index `i` corresponds to
   // physical bit position `i + leading_skipped_bits` (mod word size), so when
   // `leading_skipped_bits` is odd, even logical bits sit at odd physical
   // positions and the base pattern is inverted.
   static constexpr array_type_element even_bits_pattern =
      (leading_skipped_bits % 2u == 1u) ? ~every_other_bit_pattern
                                        : every_other_bit_pattern;

   static constexpr array_type_element odd_bits_pattern = ~even_bits_pattern;

   // Reset the low `leading_skipped_bits` bits of `m_data.back()` to zero. Used
   // to restore the class invariant after a bitwise-OR that may have set
   // padding bits.
   constexpr auto
   clear_padding_bits() -> void {
      if constexpr (leading_skipped_bits != 0u) {
         constexpr array_type_element keep_mask = ~array_type_element(
            (array_type_element(1u) << leading_skipped_bits) - 1u
         );
         // Simply & mask the bits off the end of the bitset.
         m_data[storage_array_size - 1u] &= keep_mask;
      }
   }

   array_type m_data = {};
};

// Subtract 1 to skip the null terminator.
template <__SIZE_TYPE__ bits_count>
bitset(char const (&bitstring)[bits_count]) -> bitset<idx(bits_count - 1u)>;

template <is_unsigned_integral Storage>
template <idx bits_count>
constexpr bit_span<Storage>::bit_span(
   bitset<bits_count>& storage [[clang::lifetimebound]]
)
    : bit_span(
         storage.m_data.data(), bitset<bits_count>::leading_skipped_bits,
         bits_count
      ) {
   static_assert(is_same<Storage, typename bitset<bits_count>::storage_type>);
}

template <is_unsigned_integral Storage>
template <idx bits_count>
constexpr bit_span<Storage>::bit_span(
   bitset<bits_count> const& storage [[clang::lifetimebound]]
)
    : bit_span(
         storage.m_data.data(), bitset<bits_count>::leading_skipped_bits,
         bits_count
      ) {
   static_assert(
      is_same<Storage, typename bitset<bits_count>::storage_type const>
   );
}

template <idx bits_count>
bit_span(bitset<bits_count>&)
   -> bit_span<typename bitset<bits_count>::storage_type>;

template <idx bits_count>
bit_span(bitset<bits_count> const&)
   -> bit_span<typename bitset<bits_count>::storage_type const>;

template <idx bits_count, is_unsigned_integral... Arguments>
// Ensure that all `types` are the same size. e.g., `uint4` and unsigned are
// compatible here.
   requires(detail::are_bitset_arguments_same_size<Arguments...>)
[[nodiscard]]
constexpr auto
make_bitset(Arguments... arguments) {
   // TODO: Assert that the input fits in `bits_count`.
   static_assert(
      sizeof...(Arguments) == bitset<bits_count>::array_type::size(),
      "The arguments passed into this bitset do not fit within the "
      "`bits_count` alloted."
   );

   bitset<bits_count> new_bitset;
   new_bitset.m_data = {arguments...};
   if !consteval {
      bitset<bits_count> cleared = new_bitset;
      // Confirm no padding bits are 1.
      cleared.clear_padding_bits();
      assert(new_bitset == cleared);
   } else {
      bitset<bits_count> cleared = new_bitset;
      cleared.clear_padding_bits();
      bool const padding_is_clear = new_bitset == cleared;
      [[assume(padding_is_clear)]];
   }
   return new_bitset;
}

template <idx bits_count>
[[nodiscard]]
constexpr auto
make_bitset_filled(bit_value value) {
   bitset<bits_count> new_bitset;
   new_bitset.fill(value);
   return new_bitset;
}

// Construct a bitset with only the even-indexed bits (logical indices 0, 2, 4,
// ...) set. Odd-indexed bits are 0.
template <idx bits_count>
[[nodiscard]]
constexpr auto
make_bitset_even() {
   bitset<bits_count> new_bitset;
   new_bitset.set_even();
   return new_bitset;
}

// Construct a bitset with only the odd-indexed bits (logical indices 1, 3, 5,
// ...) set. Even-indexed bits are 0.
template <idx bits_count>
[[nodiscard]]
constexpr auto
make_bitset_odd() {
   bitset<bits_count> new_bitset;
   new_bitset.set_odd();
   return new_bitset;
}

}  // namespace cat
