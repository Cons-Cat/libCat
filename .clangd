Index:
  StandardLibrary: No

CompileFlags:
  CompilationDatabase: .
  Add:
    - -std=gnu++26

# Merged with `.clang-tidy`. clangd config wins on conflict. Stops unusable
# lints if another layer (e.g. user `config.yaml`) re-enables them.
Diagnostics:
  ClangTidy:
    Remove:
      - readability-magic-numbers
      - cppcoreguidelines-avoid-magic-numbers
      - bugprone-easily-swappable-parameters
      - modernize-type-traits
  Suppress:
    - readability-magic-numbers
    - cppcoreguidelines-avoid-magic-numbers
    - bugprone-easily-swappable-parameters
    - modernize-type-traits