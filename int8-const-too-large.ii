template <overflow_policies P, is_integral U>
[[nodiscard, gnu::always_inline, gnu::nodebug]]
constexpr auto
sat_shl(index<P> value, U bits) -> index<P> {
   using signed_size = make_signed_type<long unsigned int>;
   auto const raw_bits = make_raw_arithmetic(bits);
   auto const signed_value = __builtin_bit_cast(signed_size, value.raw);
   return index<P>(
      __builtin_bit_cast(long unsigned int, sat_shl(signed_value, raw_bits)));
}





template <overflow_policies P, is_integral U>
[[nodiscard, gnu::always_inline, gnu::nodebug]]
constexpr auto
sat_shr(index<P> value, U bits) -> index<P> {
   using signed_size = make_signed_type<long unsigned int>;
   auto const raw_bits = make_raw_arithmetic(bits);
   auto const signed_value = __builtin_bit_cast(signed_size, value.raw);
   return index<P>(
      __builtin_bit_cast(long unsigned int, sat_shr(signed_value, raw_bits)));
}





template <overflow_policies P, is_integral U>
[[nodiscard, gnu::always_inline, gnu::nodebug]]
constexpr auto
wrap_shl(index<P> value, U bits) -> index<P> {
   constexpr long unsigned int ring_bits = (sizeof(long unsigned int) * 8u) - 1u;
   constexpr long unsigned int ring_mask =
      (static_cast<long unsigned int>(1) << ring_bits) - 1u;
   long unsigned int const norm =
      static_cast<long unsigned int>(make_raw_arithmetic(bits)) % ring_bits;
   if (norm == 0) {
      return index<P>(value.raw & ring_mask);
   }
   return index<P>(((value.raw << norm) | (value.raw >> (ring_bits - norm)))
                   & ring_mask);
}




template <overflow_policies P, is_integral U>
[[nodiscard, gnu::always_inline, gnu::nodebug]]
constexpr auto
wrap_shr(index<P> value, U bits) -> index<P> {
   constexpr long unsigned int ring_bits = (sizeof(long unsigned int) * 8u) - 1u;
   constexpr long unsigned int ring_mask =
      (static_cast<long unsigned int>(1) << ring_bits) - 1u;
   long unsigned int const norm =
      static_cast<long unsigned int>(make_raw_arithmetic(bits)) % ring_bits;
   if (norm == 0) {
      return index<P>(value.raw & ring_mask);
   }
   return index<P>(((value.raw >> norm) | (value.raw << (ring_bits - norm)))
                   & ring_mask);
}

