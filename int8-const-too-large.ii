namespace cat {

template <typename T, typename in_abi>
class alignas(in_abi::alignment.raw) simd_mask {
 public:
   using abi_type = in_abi;
   using mask_traits = typename in_abi::template simd_mask_lane<T>;
   using mask_type = simd_mask<T, abi_type>;
   using value_type = bool;
   using reference = unsigned char&;
   using simd_type = simd<T, abi_type>;
   using scalar_type = value_type;

   using lane_scalar = typename mask_traits::lane_scalar;
   using raw_type = typename mask_traits::raw_type;

   using iterator = detail::simd_range_iterator<mask_type>;
   using const_iterator = detail::simd_range_iterator<mask_type const>;

   constexpr simd_mask() = default;

   constexpr simd_mask(simd_mask<T, in_abi> const& operand) = default;

   constexpr simd_mask(simd_mask<T, in_abi>&& operand) = default;

   constexpr simd_mask(raw_type value) : raw(value) {
   }

   constexpr simd_mask(bool) = delete (
      "A `cat::simd_mask` was constructed from a `bool`. This may mean == or "
      "!= was used to compare `cat::simd` or `cat::simd_mask`."
      "Use `equal_lanes` / `unequal_lanes` instead. To broadcast one bool to "
      "every "
      "lane, use `make_simd_mask_filled`.");


   template <typename... bools>
   constexpr simd_mask(bools&&... values)
      requires(sizeof...(values) > 1
               && sizeof...(values) == abi_type::lanes.raw)
   {
      this->raw = raw_type{};
      bool const lane_vals[] = {static_cast<bool>(::cat::forward<decltype(values)>(values))...};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         this->set_lane(i, lane_vals[i.raw]);
      }
   }



   template <bool... bools>
   constexpr simd_mask(value_type_list<bool, bools...> const)
      requires(sizeof...(bools) == abi_type::lanes.raw)
   {
      this->raw = raw_type{};
      bool const lane_vals[] = {bools...};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         this->set_lane(i, lane_vals[i.raw]);
      }
   }




   template <typename other_abi_type>
   explicit constexpr
   operator simd_mask<T, other_abi_type>() const
      requires(other_abi_type::size == abi_type::size
               && other_abi_type::alignment <= abi_type::alignment
               && other_abi_type::lanes == abi_type::lanes)
   {
      return this->raw;
   }




   template <typename other_abi_type, typename U>
   explicit constexpr
   operator simd_mask<U, other_abi_type>() const
      requires(is_convertible<U, T> && other_abi_type::size == abi_type::size
               && other_abi_type::alignment <= abi_type::alignment
               && other_abi_type::lanes == abi_type::lanes)
   {
      return __builtin_convertvector(
         this->raw, typename simd_mask<U, other_abi_type>::raw_type);
   }


   constexpr auto
   operator=(mask_type const& operand) -> mask_type& = default;


   constexpr auto
   operator=(mask_type&& operand) -> mask_type& {
      this->raw = move(operand).raw;
      return *this;
   }




   [[nodiscard]]
   constexpr auto
   operator==(mask_type const& operand) const -> mask_type {
      if constexpr (is_integral<lane_scalar>) {
         return mask_type(this->raw == operand.raw);
      }
      simd_mask out{};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         out.set_lane(i, (*this)[i] == operand[i]);
      }
      return out;
   }

   [[nodiscard]]
   constexpr auto
   operator!=(mask_type const& operand) const -> mask_type {
      if constexpr (is_integral<lane_scalar>) {
         return mask_type(this->raw != operand.raw);
      }
      simd_mask out{};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         out.set_lane(i, (*this)[i] != operand[i]);
      }
      return out;
   }



   [[nodiscard]]
   friend constexpr auto
   operator&&(simd_mask const& lhs, simd_mask const& rhs) -> simd_mask {
      simd_mask out{};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         out.set_lane(i, lhs[i] && rhs[i]);
      }
      return out;
   }

   [[nodiscard]]
   friend constexpr auto
   operator||(simd_mask const& lhs, simd_mask const& rhs) -> simd_mask {
      simd_mask out{};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         out.set_lane(i, lhs[i] || rhs[i]);
      }
      return out;
   }

   [[nodiscard]]
   constexpr auto
   operator&(mask_type const& operand) const -> mask_type {
      if constexpr (is_integral<lane_scalar>) {
         return mask_type(this->raw & operand.raw);
      } else {
         using lane_bits = detail::simd_mask_lane_bits_t<lane_scalar>;
         using bits_abi = typename abi_type::template make_abi_type<lane_bits>;
         using bits_vec = simd<lane_bits, bits_abi>;
         typename bits_vec::raw_type const a =
            __builtin_bit_cast(typename bits_vec::raw_type, this->raw);
         typename bits_vec::raw_type const b =
            __builtin_bit_cast(typename bits_vec::raw_type, operand.raw);
         return mask_type(__builtin_bit_cast(raw_type, a & b));
      }
   }

   constexpr auto
   operator&=(mask_type const& operand) -> mask_type& {
      *this = *this & operand;
      return *this;
   }

   [[nodiscard]]
   constexpr auto
   operator|(mask_type const& operand) const -> mask_type {
      if constexpr (is_integral<lane_scalar>) {
         return mask_type(this->raw | operand.raw);
      } else {
         using lane_bits = detail::simd_mask_lane_bits_t<lane_scalar>;
         using bits_abi = typename abi_type::template make_abi_type<lane_bits>;
         using bits_vec = simd<lane_bits, bits_abi>;
         typename bits_vec::raw_type const a =
            __builtin_bit_cast(typename bits_vec::raw_type, this->raw);
         typename bits_vec::raw_type const b =
            __builtin_bit_cast(typename bits_vec::raw_type, operand.raw);
         return mask_type(__builtin_bit_cast(raw_type, a | b));
      }
   }

   constexpr auto
   operator|=(mask_type const& operand) -> mask_type& {
      *this = *this | operand;
      return *this;
   }

   [[nodiscard]]
   constexpr auto
   operator^(mask_type const& operand) const -> mask_type {
      if constexpr (is_integral<lane_scalar>) {
         return mask_type(this->raw ^ operand.raw);
      } else {
         using lane_bits = detail::simd_mask_lane_bits_t<lane_scalar>;
         using bits_abi = typename abi_type::template make_abi_type<lane_bits>;
         using bits_vec = simd<lane_bits, bits_abi>;
         typename bits_vec::raw_type const a =
            __builtin_bit_cast(typename bits_vec::raw_type, this->raw);
         typename bits_vec::raw_type const b =
            __builtin_bit_cast(typename bits_vec::raw_type, operand.raw);
         return mask_type(__builtin_bit_cast(raw_type, a ^ b));
      }
   }

   constexpr auto
   operator^=(mask_type const& operand) -> mask_type& {
      *this = *this ^ operand;
      return *this;
   }

   [[nodiscard]]
   constexpr auto
   operator%(mask_type const& operand) const -> mask_type {
      if constexpr (is_integral<lane_scalar>) {
         return mask_type(this->raw % operand.raw);
      } else {
         using lane_bits = detail::simd_mask_lane_bits_t<lane_scalar>;
         using bits_abi = typename abi_type::template make_abi_type<lane_bits>;
         using bits_vec = simd<lane_bits, bits_abi>;
         typename bits_vec::raw_type const a =
            __builtin_bit_cast(typename bits_vec::raw_type, this->raw);
         typename bits_vec::raw_type const b =
            __builtin_bit_cast(typename bits_vec::raw_type, operand.raw);
         return mask_type(__builtin_bit_cast(raw_type, a % b));
      }
   }

   constexpr auto
   operator%=(mask_type const& operand) -> mask_type& {
      *this = *this % operand;
      return *this;
   }

   [[nodiscard]]
   constexpr auto
   operator<<(mask_type const& operand) const -> mask_type {
      if constexpr (is_integral<lane_scalar>) {
         return mask_type(this->raw << operand.raw);
      } else {
         using lane_bits = detail::simd_mask_lane_bits_t<lane_scalar>;
         using bits_abi = typename abi_type::template make_abi_type<lane_bits>;
         using bits_vec = simd<lane_bits, bits_abi>;
         typename bits_vec::raw_type const a =
            __builtin_bit_cast(typename bits_vec::raw_type, this->raw);
         typename bits_vec::raw_type const b =
            __builtin_bit_cast(typename bits_vec::raw_type, operand.raw);
         return mask_type(__builtin_bit_cast(raw_type, a << b));
      }
   }

   constexpr auto
   operator<<=(mask_type const& operand) -> mask_type& {
      *this = *this << operand;
      return *this;
   }

   [[nodiscard]]
   constexpr auto
   operator>>(mask_type const& operand) const -> mask_type {
      if constexpr (is_integral<lane_scalar>) {
         return mask_type(this->raw >> operand.raw);
      } else {
         using lane_bits = detail::simd_mask_lane_bits_t<lane_scalar>;
         using bits_abi = typename abi_type::template make_abi_type<lane_bits>;
         using bits_vec = simd<lane_bits, bits_abi>;
         typename bits_vec::raw_type const a =
            __builtin_bit_cast(typename bits_vec::raw_type, this->raw);
         typename bits_vec::raw_type const b =
            __builtin_bit_cast(typename bits_vec::raw_type, operand.raw);
         return mask_type(__builtin_bit_cast(raw_type, a >> b));
      }
   }

   constexpr auto
   operator>>=(mask_type const& operand) -> mask_type& {
      *this = *this >> operand;
      return *this;
   }



   [[nodiscard, gnu::no_sanitize("bounds")]]
   constexpr auto
   operator[](idx index) const -> bool {
      return mask_traits::decode_lane(raw, index);
   }

   constexpr auto
   set_lane(idx index, bool value) -> void {
      mask_traits::encode_lane(raw, index, value);
   }


   [[nodiscard]]
   constexpr auto
   operator!() const -> mask_type {

      mask_type result{};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         result.set_lane(i, !(*this)[i]);
      }
      return result;
   }


   [[nodiscard]]
   constexpr auto
   operator+() const
      -> simd<detail::simd_unary_signed_integer_from_element_t<T>,
              typename abi_type::template make_abi_type<
                 detail::simd_unary_signed_integer_from_element_t<T>>>
      requires(detail::has_simd_mask_unary_integral_conversion_v<T>)
   {

      using I = detail::simd_unary_signed_integer_from_element_t<T>;
      using vec = simd<I, typename abi_type::template make_abi_type<I>>;
      vec out{};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         bool const lane = (*this)[i];
         out.set_lane(i, static_cast<I>(+static_cast<bool>(lane)));
      }
      return out;
   }

   [[nodiscard]]
   constexpr auto
   operator-() const
      -> simd<detail::simd_unary_signed_integer_from_element_t<T>,
              typename abi_type::template make_abi_type<
                 detail::simd_unary_signed_integer_from_element_t<T>>>
      requires(detail::has_simd_mask_unary_integral_conversion_v<T>)
   {

      using I = detail::simd_unary_signed_integer_from_element_t<T>;
      using vec = simd<I, typename abi_type::template make_abi_type<I>>;
      vec out{};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         bool const lane = (*this)[i];
         out.set_lane(i, static_cast<I>(-static_cast<bool>(lane)));
      }
      return out;
   }

   [[nodiscard]]
   constexpr auto
   operator~() const
      -> simd<detail::simd_unary_signed_integer_from_element_t<T>,
              typename abi_type::template make_abi_type<
                 detail::simd_unary_signed_integer_from_element_t<T>>>
      requires(detail::has_simd_mask_unary_integral_conversion_v<T>)
   {


      using I = detail::simd_unary_signed_integer_from_element_t<T>;
      using vec = simd<I, typename abi_type::template make_abi_type<I>>;
      vec out{};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         bool const lane = (*this)[i];
         int const promoted = static_cast<bool>(lane);
         out.set_lane(i, static_cast<I>(~promoted));
      }
      return out;
   }

   [[nodiscard, gnu::no_sanitize("bounds")]]
   constexpr auto
   lane_byte(idx index) const -> unsigned char const& {
      return *(reinterpret_cast<unsigned char const*>(__builtin_addressof(raw))
               + index.raw * sizeof(lane_scalar));
   }


   [[nodiscard]]
   constexpr auto
   all_of() const -> bool {
      return simd_all_of(*this);
   }


   [[nodiscard]]
   constexpr auto
   any_of() const -> bool {
      return simd_any_of(*this);
   }


   [[nodiscard]]
   constexpr auto
   none_of() const -> bool {
      return !(this->any_of());
   }



   [[nodiscard]]
   constexpr auto
   count_if_true() const -> idx {
      return detail::simd_abi::mask_count_if_true<T, abi_type>::invoke(*this);
   }



   [[nodiscard]]
   constexpr auto
   find_if_true() const -> idx {
      return detail::simd_abi::mask_find_if_true<T, abi_type>::invoke(*this);
   }



   [[nodiscard]]
   constexpr auto
   find_last_if_true() const -> idx {
      return detail::simd_abi::mask_find_last_if_true<T, abi_type>::invoke(
         *this);
   }




   [[nodiscard]]
   constexpr auto
   to_bitset() const -> ::cat::bitset<abi_type::lanes>;






   [[nodiscard]]
   constexpr auto
   to_uword() const -> uword {
      typename uword::raw_type bits = 0u;
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         if (i >= word_bits) {
            break;
         }
         if ((*this)[i]) {
            bits |= (1uz << i.raw);
         }
      }
      return uword(bits);
   }

   template <typename UInt>
      requires(is_unsigned_integral<UInt> && !is_bool<UInt>)
   explicit constexpr simd_mask(UInt pattern_bits) {
      this->raw = raw_type{};
      uword const bits = static_cast<uword>(pattern_bits);
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         this->set_lane(i, ((bits.raw >> i.raw) & 1uz) != 0uz);
      }
   }


   constexpr auto
   fill(bool value) -> mask_type {
      this->raw = raw_type{};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         this->set_lane(i, value);
      }
      return *this;
   }




   constexpr auto
   load(bool const* lane_bools) -> mask_type& {
      this->raw = raw_type{};
      for (idx i = 0u; i < abi_type::lanes; ++i) {
         this->set_lane(i, lane_bools[i.raw]);
      }
      return *this;
   }

   [[nodiscard]]
   static constexpr auto
   size() -> idx {
      return abi_type::lanes;
   }

   [[nodiscard]]
   constexpr iterator
   begin() {
      return iterator(this, 0u);
   }

   [[nodiscard]]
   constexpr const_iterator
   begin() const {
      return const_iterator(this, 0u);
   }

   [[nodiscard]]
   constexpr const_iterator
   cbegin() const {
      return begin();
   }

   [[nodiscard]]
   constexpr default_sentinel_t
   end() const {
      return default_sentinel;
   }

   [[nodiscard]]
   constexpr default_sentinel_t
   cend() const {
      return end();
   }

   [[nodiscard]]
   constexpr auto
   data() -> lane_scalar* {
      return reinterpret_cast<lane_scalar*>(__builtin_addressof(raw));
   }

   [[nodiscard]]
   constexpr auto
   data() const -> lane_scalar const* {
      return reinterpret_cast<lane_scalar const*>(__builtin_addressof(raw));
   }

   raw_type raw;
};


template <typename T, typename Abi>
[[nodiscard]]
constexpr auto
popcount(simd_mask<T, Abi> const& mask) -> int {

   return static_cast<int>(mask.count_if_true());
}


