template <typename T, typename Abi>
[[nodiscard]]
constexpr auto
simd_equal_lanes(simd<T, Abi> const& a, simd<T, Abi> const& b)
   -> simd_mask<T, Abi> {
   return a.equal_lanes(b);
}

template <typename T, typename Abi>
[[nodiscard]]
constexpr auto
simd_unequal_lanes(simd<T, Abi> const& a, simd<T, Abi> const& b)
   -> simd_mask<T, Abi> {
   return a.unequal_lanes(b);
}

template <long unsigned int I, typename T, typename Abi>
inline auto
get(simd<T, Abi>& v) -> T& {
   static_assert(I < simd<T, Abi>::abi_type::lanes.raw);
   return *(reinterpret_cast<T*>(__builtin_addressof(v.raw)) + idx(I).raw);
}

template <long unsigned int I, typename T, typename Abi>
constexpr auto
get(simd<T, Abi> const& v) -> T {
   static_assert(I < simd<T, Abi>::abi_type::lanes.raw);
   return v[idx(I)];
}

template <long unsigned int I, typename T, typename Abi>
constexpr auto
get(simd<T, Abi>&& v) -> T {
   static_assert(I < simd<T, Abi>::abi_type::lanes.raw);
   return static_cast<T&&>(static_cast<simd<T, Abi>&&>(v)[idx(I)]);
}

template <long unsigned int I, typename T, typename Abi>
constexpr auto
get(simd<T, Abi> const&& v) -> T {
   static_assert(I < simd<T, Abi>::abi_type::lanes.raw);
   return get<I>(static_cast<simd<T, Abi> const&>(v));
}

template <long unsigned int I, typename T, typename Abi>
inline auto
get(simd_mask<T, Abi>& m) -> typename simd_mask<T, Abi>::lane_scalar& {
   using M = simd_mask<T, Abi>;
   static_assert(I < M::abi_type::lanes.raw);
   return (reinterpret_cast<typename M::lane_scalar*>(
      __builtin_addressof(m.raw)))[idx(I).raw];
}

template <long unsigned int I, typename T, typename Abi>
constexpr auto
get(simd_mask<T, Abi> const& m) -> typename simd_mask<T, Abi>::lane_scalar {
   using M = simd_mask<T, Abi>;
   static_assert(I < M::abi_type::lanes.raw);
   return m.raw[static_cast<unsigned>(idx(I).raw)];
}

template <long unsigned int I, typename T, typename Abi>
constexpr auto
get(simd_mask<T, Abi>&& m) -> typename simd_mask<T, Abi>::lane_scalar {
   using M = simd_mask<T, Abi>;
   static_assert(I < M::abi_type::lanes.raw);
   return static_cast<M&&>(m).raw[static_cast<unsigned>(idx(I).raw)];
}

template <long unsigned int I, typename T, typename Abi>
constexpr auto
get(simd_mask<T, Abi> const&& m) -> typename simd_mask<T, Abi>::lane_scalar {
   return get<I>(static_cast<simd_mask<T, Abi> const&>(m));
}

template <typename T, idx lanes>
using fixed_size_simd = simd<T, fixed_size_abi<T, lanes>>;

template <typename T, idx lanes>
using fixed_size_simd_mask = simd_mask<T, fixed_size_abi<T, lanes>>;

template <typename T>
using native_simd = simd<T, native_abi<T>>;

template <typename T>
using native_simd_mask = simd_mask<T, native_abi<T>>;

template <typename T>
using scalar_simd = simd<T, scalar_abi<T>>;

template <typename T>
using scalar_simd_mask = simd_mask<T, scalar_abi<T>>;

template <typename T, idx lanes>
using fixed_size_unaligned_simd =
   simd<T, simd_abi::unaligned<fixed_size_abi<T, lanes>>>;
template <typename T, idx lanes>
using fixed_size_unaligned_simd_mask =
   simd_mask<T, simd_abi::unaligned<fixed_size_abi<T, lanes>>>;

template <typename T>
using native_unaligned_simd = simd<T, simd_abi::unaligned<native_abi<T>>>;
template <typename T>
using native_unaligned_simd_mask =
   simd_mask<T, simd_abi::unaligned<native_abi<T>>>;

template <typename T>
using compatible_unaligned_simd =
   simd<T, simd_abi::unaligned<compatible_abi<T>>>;
template <typename T>
using compatible_unaligned_simd_mask =
   simd_mask<T, simd_abi::unaligned<compatible_abi<T>>>;

template <typename T>
using scalar_unaligned_simd = simd<T, simd_abi::unaligned<scalar_abi<T>>>;
template <typename T>
using scalar_unaligned_simd_mask =
   simd_mask<T, simd_abi::unaligned<scalar_abi<T>>>;

namespace detail {

template <typename T, typename V>
struct rebind_simd_impl;

template <typename T, typename U, typename Abi>
struct rebind_simd_impl<T, simd<U, Abi>> {
   using type = simd<T, typename Abi::template make_abi_type<T>>;
};

template <typename T, typename U, typename Abi>
struct rebind_simd_impl<T, simd_mask<U, Abi>> {
   using type = simd_mask<T, typename Abi::template make_abi_type<T>>;
};

template <idx N, typename V>
struct resize_simd_impl;

template <idx N, typename U, typename Abi>
struct resize_simd_impl<N, simd<U, Abi>> {
   using type = simd<U, fixed_size_abi<U, N>>;
};

template <idx N, typename U, typename Abi>
struct resize_simd_impl<N, simd_mask<U, Abi>> {
   using type = simd_mask<U, fixed_size_abi<U, N>>;
};

}



template <typename T, typename V>
using rebind_simd = typename detail::rebind_simd_impl<T, V>::type;

template <idx N, typename V>
using resize_simd = typename detail::resize_simd_impl<N, V>::type;



template <typename T, typename Abi>
inline constexpr bool is_simd_array_like =
   sizeof(simd<T, Abi>) == Abi::lanes.raw * sizeof(T);

