   static constexpr idx lanes{size.raw / sizeof(T)};
   static constexpr uword alignment = 16u;

   static_assert(sizeof(T) > 0 && size.raw % sizeof(T) == 0,
                 "`scalar_abi` element size must divide 16 bytes");
   static_assert(lanes > 0,
                 "`scalar_abi` lane count derived from sizeof(T) must be "
                 "positive");

   template <typename ElementT>
   using simd_mask_lane = simd_abi::mask_lane<scalar_abi<ElementT>, ElementT>;
};

namespace simd_abi {
template <typename T, idx N>
using fixed_size = fixed_size_abi<T, N>;
template <typename T>
using native = native_abi<T>;
template <typename T>
using compatible = compatible_abi<T>;
template <typename T>
using scalar = scalar_abi<T>;

template <typename BaseAbi>
using unaligned = unaligned_abi<BaseAbi>;
}

namespace detail {


template <typename abi_type, typename T>
constexpr auto
native_cast(simd<T, abi_type> vector) {
   return static_cast<simd<T, typename native_abi<T>::target_abi>>(vector);
}

template <typename abi_type, typename T>
constexpr auto
native_cast(simd_mask<T, abi_type> mask) {
   return static_cast<simd_mask<T, typename native_abi<T>::target_abi>>(mask);
}

template <typename V>
inline constexpr bool is_cat_simd = false;

template <typename T, typename Abi>
inline constexpr bool is_cat_simd<simd<T, Abi>> = true;

template <typename M>
inline constexpr bool is_cat_simd_mask = false;

template <typename T, typename Abi>
inline constexpr bool is_cat_simd_mask<simd_mask<T, Abi>> = true;

template <typename Ty>
inline constexpr bool has_simd_mask_unary_integral_conversion_v =
   sizeof(Ty) == 1zu || sizeof(Ty) == 2zu || sizeof(Ty) == 4zu
   || sizeof(Ty) == 8zu;

template <typename Ty>
   requires(has_simd_mask_unary_integral_conversion_v<Ty>)
using simd_unary_signed_integer_from_element_t =
   conditional<sizeof(Ty) == 1zu, signed char,
               conditional<sizeof(Ty) == 2zu, short,
                           conditional<sizeof(Ty) == 4zu, int, long long>>>;

}

template <typename V>
concept is_simd = detail::is_cat_simd<V>;

template <typename M>
concept is_simd_mask = detail::is_cat_simd_mask<M>;

template <typename X>
concept is_simd_or_mask = is_simd<X> || is_simd_mask<X>;





template <typename T>
struct simd_vector_element_trait {
   using type = raw_arithmetic_type<T>;
};

template <>
struct simd_vector_element_trait<bool> {
   using type = unsigned char;
};

template <typename T>
using simd_vector_element = simd_vector_element_trait<T>::type;

namespace detail {



template <typename LaneScalar>
using simd_mask_lane_bits_t =
   conditional<sizeof(LaneScalar) == 4zu, unsigned int,
               conditional<sizeof(LaneScalar) == 8zu, unsigned long long,
                           conditional<sizeof(LaneScalar) == 2zu,
                                       unsigned short, unsigned char>>>;

}


template <typename T>
[[gnu::always_inline, gnu::nodebug]]
constexpr auto
simd_lane_to_storage(T lane) -> simd_vector_element<T> {
   if constexpr (is_same<T, bool>) {
      return static_cast<unsigned char>(lane ? 1u : 0u);
   }
   return static_cast<simd_vector_element<T>>(make_raw_arithmetic(lane));
}




template <typename T>
[[gnu::always_inline, gnu::nodebug]]
constexpr auto
simd_lane_from_raw(simd_vector_element<T> slot) -> T {
   if constexpr (is_same<T, bool>) {
      return static_cast<bool>(slot);
   }
   if constexpr (is_same<T, bool2>) {
      return bool2(slot);
   }
   if constexpr (is_same<T, bool4>) {
      return bool4(slot);
   }
   return static_cast<T>(static_cast<raw_arithmetic_type<T>>(slot));
}

template <typename T, typename Abi>
   requires(is_same<typename Abi::scalar_type, T>)
class simd;

namespace detail {
template <typename T, typename Abi, overflow_policies Semantics>
class simd_overflow_reference;

template <typename T, typename Abi>
constexpr auto
simd_integral_add_follow_storage(simd<T, Abi> const& left,
                                 simd<T, Abi> const& right) -> simd<T, Abi>;

template <typename T, typename Abi>
constexpr auto
simd_integral_sub_follow_storage(simd<T, Abi> const& left,
                                 simd<T, Abi> const& right) -> simd<T, Abi>;

template <typename T, typename Abi>
constexpr auto
simd_integral_mul_follow_storage(simd<T, Abi> const& left,
                                 simd<T, Abi> const& right) -> simd<T, Abi>;

template <typename T, typename Abi>
constexpr auto
simd_integral_shl_follow_storage(simd<T, Abi> const& left,
                                 simd<T, Abi> const& right) -> simd<T, Abi>;

template <typename T, typename Abi>
constexpr auto
simd_integral_shr_follow_storage(simd<T, Abi> const& left,
                                 simd<T, Abi> const& right) -> simd<T, Abi>;
}

template <typename T, typename in_abi>
   requires(is_same<typename in_abi::scalar_type, T>)
class alignas(in_abi::alignment.raw) simd {



   using mapped_type = simd_vector_element<T>;

   struct unaligned_abi {
      using scalar_type = T;
      static constexpr idx size = in_abi::size;
      static constexpr idx lanes = in_abi::lanes;



      static constexpr uword alignment = 1u;
   };

   using unaligned_vector = simd<T, unaligned_abi>;

 public:
   using value_type = T;
   using reference = T&;
   using abi_type = in_abi;
   using mask_type = simd_mask<T, abi_type>;
   using scalar_type = value_type;


   using memory_lane = simd_vector_element<T>;

   using iterator = detail::simd_range_iterator<simd>;
   using const_iterator = detail::simd_range_iterator<simd const>;




   using raw_type [[gnu::vector_size(in_abi::size.raw),
                    gnu::aligned(in_abi::alignment.raw)]] = mapped_type;

   constexpr simd() = default;

   constexpr simd(simd const& operand) = default;

   constexpr simd(simd&& operand) = default;


   constexpr simd(unaligned_vector operand) : raw(operand.raw) {
   }

   [[gnu::nodebug]]
   constexpr simd(raw_type values)
       : raw(values) {
   }



   template <typename U>
      requires(
         is_constructible<T, remove_cvref<U>>
         && detail::simd_broadcast_really_convertible_to<remove_cvref<U>, T>())
   constexpr explicit(
      !detail::simd_broadcast_really_convertible_to<remove_cvref<U>, T>())
      simd(U&& value) {

      this->fill(static_cast<scalar_type>(::cat::forward<decltype(value)>(value)));
   }




   template <typename U>
      requires detail::simd_consteval_broadcast_arg<remove_cvref<U>, T>
   consteval simd(U value) {

      [[assume(detail::has_simd_broadcast_consteval_value<remove_cvref<U>, T>(
         value))]];
      this->fill(static_cast<scalar_type>(value));
   }


   template <typename... Us>
      requires(sizeof...(Us) > 1u && sizeof...(Us) == in_abi::lanes.raw)
   [[gnu::nodebug]] constexpr simd(Us&&... values)

       : raw(raw_type{simd_lane_to_storage(static_cast<T>(::cat::forward<decltype(values)>(values)))...}) {
   }




   template <typename U, U... Us>
      requires(sizeof...(Us) == in_abi::lanes.raw)
   [[gnu::nodebug]] constexpr simd(value_type_list<U, Us...>)
       : raw(raw_type{simd_lane_to_storage(static_cast<T>(Us))...}) {
   }


   template <typename U, typename AbiM>
   constexpr simd(simd_mask<U, AbiM> const& k)
      requires(
         detail::has_simd_mask_unary_integral_conversion_v<U>
         && is_same<
            simd<T, in_abi>,
            simd<detail::simd_unary_signed_integer_from_element_t<U>,
                 typename AbiM::template make_abi_type<
                    detail::simd_unary_signed_integer_from_element_t<U>>>>)
       : simd(+k) {


   }



   template <typename other_abi_type>
      requires(other_abi_type::size == abi_type::size
               && other_abi_type::alignment <= abi_type::alignment
               && other_abi_type::lanes == abi_type::lanes)
   explicit constexpr
   operator simd<T, other_abi_type>() const {
      return this->raw;
   }




   template <typename other_abi_type, typename U>
      requires(is_convertible<U, T> && other_abi_type::size == abi_type::size
               && other_abi_type::alignment <= abi_type::alignment
               && other_abi_type::lanes == abi_type::lanes)
   explicit constexpr
   operator simd<U, other_abi_type>() const {
      return __builtin_convertvector(
         this->raw, typename simd<U, other_abi_type>::raw_type);
   }


   constexpr auto
   operator=(simd const& operand) -> simd& = default;


   constexpr auto
   operator=(simd&& operand) -> simd& = default;



   [[nodiscard]]
   constexpr auto
   operator==(simd const& operand) const -> bool {
      for (idx i = 0u; i < in_abi::lanes; ++i) {
         if ((*this)[i] != operand[i]) {
            return false;
         }
      }
      return true;
   }



   [[nodiscard]]
   constexpr auto
   operator>(simd const& operand) const -> simd_mask<T, abi_type> {
      return this->raw > operand.raw;
   }



   [[nodiscard]]
   constexpr auto
   operator>=(simd const& operand) const -> simd_mask<T, abi_type> {
      return this->raw >= operand.raw;
   }



   [[nodiscard]]
   constexpr auto
   operator<(simd const& operand) const -> simd_mask<T, abi_type> {
      return this->raw < operand.raw;
   }



   [[nodiscard]]
   constexpr auto
   operator<=(simd const& operand) const -> simd_mask<T, abi_type> {
      return this->raw <= operand.raw;
   }





   constexpr auto
   undef() & -> detail::simd_overflow_reference<T, in_abi,
                                                overflow_policies::wrap>
      requires(!is_bool<T>);
   constexpr auto
   wrap() & -> detail::simd_overflow_reference<T, in_abi,
                                               overflow_policies::wrap>
      requires(!is_bool<T>);
   constexpr auto
   sat() & -> detail::simd_overflow_reference<T, in_abi,
                                              overflow_policies::saturate>
      requires(!is_bool<T>);



   [[nodiscard]]
   constexpr auto
   operator+(simd const& operand) const -> simd
      requires(!is_bool<T>)
   {
      return detail::simd_integral_add_follow_storage(*this, operand);
   }

   constexpr auto
   operator+=(simd const& operand) -> simd&
      requires(!is_bool<T>)
   {
      *this = detail::simd_integral_add_follow_storage(*this, operand);
      return *this;
   }

   [[nodiscard]]
   constexpr auto
   operator-(simd const& operand) const -> simd
      requires(!is_bool<T>)
   {
      return detail::simd_integral_sub_follow_storage(*this, operand);
   }

   constexpr auto
   operator-=(simd const& operand) -> simd&
      requires(!is_bool<T>)
   {
      *this = detail::simd_integral_sub_follow_storage(*this, operand);
      return *this;
   }

   [[nodiscard]]
   constexpr auto
   operator*(simd const& operand) const -> simd
      requires(!is_bool<T>)
   {
      return detail::simd_integral_mul_follow_storage(*this, operand);
   }

   constexpr auto
   operator*=(simd const& operand) -> simd&
      requires(!is_bool<T>)
   {
      *this = detail::simd_integral_mul_follow_storage(*this, operand);
      return *this;
   }

   [[nodiscard]]
   constexpr auto
   operator/(simd const& operand) const -> simd
      requires(!is_bool<T>)
   {
      return this->raw / operand.raw;
   }

   constexpr auto
   operator/=(simd const& operand) -> simd&
      requires(!is_bool<T>)
   {
      this->raw = this->raw / operand.raw;
      return *this;
   }

   template <typename U>
      requires(
         !is_bool<T> && is_constructible<T, remove_cvref<U>>
         && detail::simd_broadcast_really_convertible_to<remove_cvref<U>, T>())
   [[nodiscard]]
   constexpr auto
   operator+(U&& operand) const -> simd {
      return *this + simd(::cat::forward<decltype(operand)>(operand));
   }

   template <typename U>
      requires(
         !is_bool<T> && is_constructible<T, remove_cvref<U>>
         && detail::simd_broadcast_really_convertible_to<remove_cvref<U>, T>())
   constexpr auto
   operator+=(U&& operand) -> simd& {
      *this += simd(::cat::forward<decltype(operand)>(operand));
      return *this;
   }

   template <typename U>
      requires(
         !is_bool<T> && is_constructible<T, remove_cvref<U>>
         && detail::simd_broadcast_really_convertible_to<remove_cvref<U>, T>())
   [[nodiscard]]
   constexpr auto
   operator-(U&& operand) const -> simd {
      return *this - simd(::cat::forward<decltype(operand)>(operand));
   }

   template <typename U>
      requires(
         !is_bool<T> && is_constructible<T, remove_cvref<U>>
         && detail::simd_broadcast_really_convertible_to<remove_cvref<U>, T>())
   constexpr auto
   operator-=(U&& operand) -> simd& {
      *this -= simd(::cat::forward<decltype(operand)>(operand));
      return *this;
   }

   template <typename U>
      requires(
         !is_bool<T> && is_constructible<T, remove_cvref<U>>
         && detail::simd_broadcast_really_convertible_to<remove_cvref<U>, T>())
   [[nodiscard]]
   constexpr auto
   operator*(U&& operand) const -> simd {
      return *this * simd(::cat::forward<decltype(operand)>(operand));
   }

   template <typename U>
      requires(
         !is_bool<T> && is_constructible<T, remove_cvref<U>>
         && detail::simd_broadcast_really_convertible_to<remove_cvref<U>, T>())
   constexpr auto
   operator*=(U&& operand) -> simd& {
      *this *= simd(::cat::forward<decltype(operand)>(operand));
      return *this;
   }

   template <typename U>
      requires(
         !is_bool<T> && is_constructible<T, remove_cvref<U>>
         && detail::simd_broadcast_really_convertible_to<remove_cvref<U>, T>())
   [[nodiscard]]
   constexpr auto
   operator/(U&& operand) const -> simd {
      return *this / simd(::cat::forward<decltype(operand)>(operand));
   }

   template <typename U>
      requires(
         !is_bool<T> && is_constructible<T, remove_cvref<U>>
         && detail::simd_broadcast_really_convertible_to<remove_cvref<U>, T>())
   constexpr auto
   operator/=(U&& operand) -> simd& {
      *this /= simd(::cat::forward<decltype(operand)>(operand));
      return *this;
   }

   [[nodiscard]]
   constexpr auto
   operator&(simd const& operand) const -> simd {
      return this->raw & operand.raw;
   }

   constexpr auto
   operator&=(simd const& operand) -> simd& {
      this->raw = this->raw & operand.raw;
      return *this;
   }

   [[nodiscard]]
   constexpr auto
   operator|(simd const& operand) const -> simd {
      return this->raw | operand.raw;
   }

   constexpr auto
   operator|=(simd const& operand) -> simd& {
      this->raw = this->raw | operand.raw;
      return *this;
   }

   [[nodiscard]]
   constexpr auto
   operator%(simd const& operand) const -> simd
      requires(!is_bool<T>)
   {
      return this->raw % operand.raw;
   }

   constexpr auto
   operator%=(simd const& operand) -> simd&
      requires(!is_bool<T>)
   {
      this->raw = this->raw % operand.raw;
      return *this;
   }

   [[nodiscard]]
   constexpr auto
   operator<<(simd const& operand) const -> simd
      requires(!is_bool<T>)
   {
      return detail::simd_integral_shl_follow_storage(*this, operand);
   }

   constexpr auto
   operator<<=(simd const& operand) -> simd&
      requires(!is_bool<T>)
   {
      *this = detail::simd_integral_shl_follow_storage(*this, operand);
      return *this;
   }

   [[nodiscard]]
   constexpr auto
   operator>>(simd const& operand) const -> simd
      requires(!is_bool<T>)
   {
      return detail::simd_integral_shr_follow_storage(*this, operand);
   }

   constexpr auto
   operator>>=(simd const& operand) -> simd&
      requires(!is_bool<T>)
   {
      *this = detail::simd_integral_shr_follow_storage(*this, operand);
      return *this;
   }

   [[nodiscard]]
   constexpr auto
   operator^(simd const& operand) const -> simd {
      return this->raw ^ operand.raw;
   }

   constexpr auto
   operator^=(simd const& operand) -> simd& {
      this->raw = this->raw ^ operand.raw;
      return *this;
   }



   [[nodiscard, gnu::no_sanitize("bounds")]]
   constexpr auto
   operator[](idx index) const -> T {
      return simd_lane_from_raw<T>(raw[index.raw]);
   }



   [[nodiscard]]
   constexpr auto
   equal_lanes(simd const& operand) const -> simd_mask<T, abi_type> {
      return this->raw == operand.raw;
   }



   [[nodiscard]]
   constexpr auto
   unequal_lanes(simd const& operand) const -> simd_mask<T, abi_type> {
      return this->raw != operand.raw;
   }

   constexpr auto
   set_lane(idx index, scalar_type value) -> void {
      raw[index.raw] = simd_lane_to_storage(value);
   }



   template <typename Idx, typename IdxAbi>
   [[nodiscard]]
   constexpr auto
   operator[](simd<Idx, IdxAbi> const& indices) const;



   template <typename... Ts>
      requires(sizeof...(Ts) >= 2)
   [[nodiscard]]
   constexpr auto
   operator[](Ts&&... lanes) const;

   [[nodiscard]]
   constexpr auto
   popcount() const -> simd
      requires(is_integral<T> && !is_bool<T>)
   {
      return simd(__builtin_elementwise_popcount(this->raw));
   }

   [[nodiscard]]
   constexpr auto
   reduce_add() const -> simd<T, fixed_size_abi<T, 1u>>
      requires(is_integral<T> && !is_bool<T>)
   {

      simd<T, fixed_size_abi<T, 1u>> out{};
      out.set_lane(0u, static_cast<T>(__builtin_reduce_add(this->raw)));
      return out;
   }

   [[nodiscard]]
   constexpr auto
   reduce_mul() const -> simd<T, fixed_size_abi<T, 1u>>
      requires(is_integral<T> && !is_bool<T>)
   {


      simd<T, fixed_size_abi<T, 1u>> out{};
      out.set_lane(0u, static_cast<T>(__builtin_reduce_mul(this->raw)));
      return out;
   }

   [[nodiscard]]
   constexpr auto
   reduce_and() const -> simd<T, fixed_size_abi<T, 1u>>
      requires(is_integral<T> && !is_bool<T>)
   {

      simd<T, fixed_size_abi<T, 1u>> out{};
      out.set_lane(0u, static_cast<T>(__builtin_reduce_and(this->raw)));
      return out;
   }

   [[nodiscard]]
   constexpr auto
   reduce_or() const -> simd<T, fixed_size_abi<T, 1u>>
      requires(is_integral<T> && !is_bool<T>)
   {

      simd<T, fixed_size_abi<T, 1u>> out{};
      out.set_lane(0u, static_cast<T>(__builtin_reduce_or(this->raw)));
      return out;
   }

   [[nodiscard]]
   constexpr auto
   reduce_xor() const -> simd<T, fixed_size_abi<T, 1u>>
      requires(is_integral<T> && !is_bool<T>)
   {

      simd<T, fixed_size_abi<T, 1u>> out{};
      out.set_lane(0u, static_cast<T>(__builtin_reduce_xor(this->raw)));
      return out;
   }

   [[nodiscard]]
   constexpr auto
   reduce_max() const -> simd<T, fixed_size_abi<T, 1u>>
      requires(is_arithmetic<T> && !is_bool<T>)
   {

      simd<T, fixed_size_abi<T, 1u>> out{};
      out.set_lane(0u, static_cast<T>(__builtin_reduce_max(this->raw)));
      return out;
   }

   [[nodiscard]]
   constexpr auto
   reduce_min() const -> simd<T, fixed_size_abi<T, 1u>>
      requires(is_arithmetic<T> && !is_bool<T>)
   {

      simd<T, fixed_size_abi<T, 1u>> out{};
      out.set_lane(0u, static_cast<T>(__builtin_reduce_min(this->raw)));
      return out;
   }

   [[nodiscard]]
   constexpr auto
   reduce_maximum() const -> simd<T, fixed_size_abi<T, 1u>>
      requires(is_floating_point<T>)
   {

      simd<T, fixed_size_abi<T, 1u>> out{};
      out.set_lane(0u, static_cast<T>(__builtin_reduce_maximum(this->raw)));
      return out;
   }

   [[nodiscard]]
   constexpr auto
   reduce_minimum() const -> simd<T, fixed_size_abi<T, 1u>>
      requires(is_floating_point<T>)
   {

      simd<T, fixed_size_abi<T, 1u>> out{};
      out.set_lane(0u, static_cast<T>(__builtin_reduce_minimum(this->raw)));
      return out;
   }

   [[nodiscard]]
   constexpr auto
   reduce_assoc_fadd() const -> simd<T, fixed_size_abi<T, 1u>>
      requires(is_floating_point<T>)
   {

      simd<T, fixed_size_abi<T, 1u>> out{};
      out.set_lane(0u, static_cast<T>(__builtin_reduce_assoc_fadd(this->raw)));
      return out;
   }

   [[nodiscard]]
   constexpr auto
   reduce_assoc_fadd(scalar_type seed) const -> simd<T, fixed_size_abi<T, 1u>>
      requires(is_floating_point<T>)
   {

      simd<T, fixed_size_abi<T, 1u>> out{};
      out.set_lane(0u, static_cast<T>(__builtin_reduce_assoc_fadd(
                          this->raw, static_cast<raw_arithmetic_type<T>>(
                                        make_raw_arithmetic(seed)))));
      return out;
   }

   [[nodiscard]]
   constexpr auto
   reduce_in_order_fadd(scalar_type seed) const
      -> simd<T, fixed_size_abi<T, 1u>>
      requires(is_floating_point<T>)
   {

      simd<T, fixed_size_abi<T, 1u>> out{};
      out.set_lane(0u, static_cast<T>(__builtin_reduce_in_order_fadd(
                          this->raw, static_cast<raw_arithmetic_type<T>>(
                                        make_raw_arithmetic(seed)))));
      return out;
   }


   template <typename U>
      requires(is_constructible<scalar_type, U>)

   [[gnu::no_sanitize_address]]
   constexpr auto
   fill(U value) -> simd& {
      scalar_type const fill_value = static_cast<scalar_type>(value);
      mapped_type const lane = simd_lane_to_storage(fill_value);
      if constexpr (abi_type::lanes == 2uz) {
         this->raw = raw_type{lane, lane};
      } else if constexpr (abi_type::lanes == 4uz) {
         this->raw = raw_type{lane, lane, lane, lane};
      } else if constexpr (abi_type::lanes == 8uz) {
         this->raw = raw_type{lane, lane, lane, lane, lane, lane, lane, lane};
      } else if constexpr (abi_type::lanes == 16uz) {
         this->raw = raw_type{lane, lane, lane, lane, lane, lane, lane, lane,
                              lane, lane, lane, lane, lane, lane, lane, lane};
      } else if constexpr (abi_type::lanes == 32uz) {
         this->raw = raw_type{lane, lane, lane, lane, lane, lane, lane, lane,
                              lane, lane, lane, lane, lane, lane, lane, lane,
                              lane, lane, lane, lane, lane, lane, lane, lane,
                              lane, lane, lane, lane, lane, lane, lane, lane};
      }
      return *this;
   }



   constexpr auto
   load_aligned(memory_lane const* p_data) -> simd& {
      this->raw =
         static_cast<simd const*>(static_cast<void const*>(p_data))->raw;
      return *this;
   }



   [[gnu::no_sanitize_address]]
   constexpr auto
   load_unaligned(memory_lane const* p_data) -> simd& {
      this->raw =
         static_cast<unaligned_vector const*>(static_cast<void const*>(p_data))
            ->raw;
      return *this;
   }


   constexpr auto
   load(memory_lane const* p_data) -> simd& {
      if constexpr (abi_type::alignment > alignof(T) && alignof(T) > 1uz) {
         return this->load_aligned(p_data);
      } else {
         return this->load_unaligned(p_data);
      }
   }





   constexpr void
   store_aligned(memory_lane* p_data) const {
      static_cast<simd*>(static_cast<void*>(p_data))->raw = this->raw;
   }


   constexpr void
   store_unaligned(memory_lane* p_data) const {
      static_cast<unaligned_vector*>(static_cast<void*>(p_data))->raw =
         this->raw;
   }


   constexpr void
   store(memory_lane* p_data) const {
      if constexpr (abi_type::alignment > alignof(T) && alignof(T) > 1uz) {
         this->store_aligned(p_data);
      } else {
         this->store_unaligned(p_data);
      }
   }




   constexpr auto
   partial_load(memory_lane const* p_data, idx count) -> simd& {
      this->fill(scalar_type{});
      idx const n = count < abi_type::lanes ? count : abi_type::lanes;
      for (idx i = 0u; i < n; ++i) {
         this->set_lane(i, static_cast<T>(p_data[i]));
      }
      return *this;
   }



   constexpr void
   partial_store(memory_lane* p_data, idx count) const {
      idx const n = count < abi_type::lanes ? count : abi_type::lanes;
      for (idx i = 0u; i < n; ++i) {
         p_data[i] = simd_lane_to_storage((*this)[i]);
      }
   }

   [[nodiscard]]
   static constexpr auto
   size() -> idx {
      return abi_type::lanes;
   }

   [[nodiscard]]
   constexpr iterator
   begin() {
      return iterator(this, 0u);
   }

   [[nodiscard]]
   constexpr const_iterator
   begin() const {
      return const_iterator(this, 0u);
   }

   [[nodiscard]]
   constexpr const_iterator
   cbegin() const {
      return begin();
   }

   [[nodiscard]]
   constexpr default_sentinel_t
   end() const {
      return default_sentinel;
   }

   [[nodiscard]]
   constexpr default_sentinel_t
   cend() const {
      return end();
   }

   [[nodiscard]]
   constexpr auto
   data() -> T* {

      return __builtin_bit_cast(T*, this);
   }

   [[nodiscard]]
   constexpr auto
   data() const -> T* {

      return __builtin_bit_cast(T const*, this);
   }

   raw_type raw;
};


template <is_arithmetic U, typename T, typename Abi>
   requires(detail::simd_broadcast_really_convertible_to<U, T>())
[[nodiscard]]
constexpr auto
operator+(U lhs, simd<T, Abi> const& rhs) -> simd<T, Abi> {
   return rhs + lhs;
}


template <is_arithmetic U, typename T, typename Abi>
   requires(detail::simd_broadcast_really_convertible_to<U, T>())
[[nodiscard]]
constexpr auto
operator-(U lhs, simd<T, Abi> const& rhs) -> simd<T, Abi> {
   return simd<T, Abi>(lhs) - rhs;
}


template <is_arithmetic U, typename T, typename Abi>
   requires(detail::simd_broadcast_really_convertible_to<U, T>())
[[nodiscard]]
constexpr auto
operator*(U lhs, simd<T, Abi> const& rhs) -> simd<T, Abi> {
   return simd<T, Abi>(lhs) * rhs;
}


template <is_arithmetic U, typename T, typename Abi>
   requires(detail::simd_broadcast_really_convertible_to<U, T>())
[[nodiscard]]
constexpr auto
operator/(U lhs, simd<T, Abi> const& rhs) -> simd<T, Abi> {
   return simd<T, Abi>(lhs) / rhs;
}

}

