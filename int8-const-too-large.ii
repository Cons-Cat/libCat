struct simd_add_sat_impl
    : simd_elementwise_binary_interface<simd_add_sat_impl,
                                        simd_abi::op_add_sat> {
   constexpr simd_add_sat_impl() = default;

   template <typename T, typename Abi>
      requires(is_integral<T> && !is_bool<T>)
   [[nodiscard]]
   constexpr auto
   invoke_full(simd<T, Abi> left, simd<T, Abi> right) const -> simd<T, Abi> {
      if constexpr (has_simd_abi_binary_full<simd_abi::op_add_sat, T, Abi>) {
         return simd_abi_apply_binary_full<simd_abi::op_add_sat, T, Abi>(left,
                                                                         right);
      } else {
         return simd<T, Abi>(
            __builtin_elementwise_add_sat(left.raw, right.raw));
      }
   }

   template <typename T>
      requires(is_integral<T> && !is_bool<T>)
   [[nodiscard]]
   constexpr auto
   invoke_lanewise(T left, T right) const -> T {
      return static_cast<T>(
         __builtin_add_sat(static_cast<T>(left), static_cast<T>(right)));
   }
};

