struct simd_abs_impl : simd_elementwise_interface<simd_abs_impl> {
   constexpr simd_abs_impl() = default;

   template <typename T, typename Abi>
      requires((is_integral<T> && is_signed<T>) || is_floating_point<T>)
   [[nodiscard]]
   constexpr auto
   invoke_full(simd<T, Abi> input) const -> simd<T, Abi> {
      if constexpr (has_simd_abi_unary_full<simd_abi::op_abs, T, Abi>) {
         return simd_abi_apply_unary_full<simd_abi::op_abs, T, Abi>(input);
      } else {
         return simd<T, Abi>(__builtin_elementwise_abs(input.raw));
      }
   }

   template <typename T>
      requires((is_integral<T> && is_signed<T>) || is_floating_point<T>)
   [[nodiscard]]
   constexpr auto
   invoke_lanewise(T x) const -> T {
      if constexpr (is_floating_point<T>) {
         using R = raw_arithmetic_type<T>;
         if constexpr (is_same<R, float>) {
            return T(__builtin_fabsf(static_cast<R>(make_raw_arithmetic(x))));
         }
         return T(__builtin_fabs(static_cast<R>(make_raw_arithmetic(x))));
      }
      if (x < T(0)) {
         return static_cast<T>(-static_cast<make_unsigned_type<T>>(x));
      }
      return x;
   }
};

struct simd_bitreverse_impl : simd_elementwise_interface<simd_bitreverse_impl> {
   constexpr simd_bitreverse_impl() = default;

   template <typename T, typename Abi>
      requires(is_integral<T> && !is_bool<T>)
   [[nodiscard]]
   constexpr auto
   invoke_full(simd<T, Abi> input) const -> simd<T, Abi> {


      if constexpr (has_simd_abi_unary_full<simd_abi::op_bitreverse, T, Abi>) {
         return simd_abi_apply_unary_full<simd_abi::op_bitreverse, T, Abi>(
            input);
      } else {
         return simd<T, Abi>(__builtin_elementwise_bitreverse(input.raw));
      }
   }

   template <typename T>
      requires(is_unsigned_integral<T> && !is_bool<T>)
   [[nodiscard]]
   constexpr auto
   invoke_lanewise(T x) const -> T {


      using U = make_unsigned_type<T>;
      U const u = static_cast<U>(x);
      U reversed{};
      if constexpr (sizeof(U) == 1) {
         reversed = __builtin_bitreverse8(static_cast<unsigned char>(u));
      } else if constexpr (sizeof(U) == 2) {
         reversed = __builtin_bitreverse16(static_cast<unsigned short>(u));
      } else if constexpr (sizeof(U) == 4) {
         reversed = __builtin_bitreverse32(static_cast<unsigned int>(u));
      } else {
         reversed = __builtin_bitreverse64(static_cast<unsigned long long>(u));
      }
      return static_cast<T>(reversed);
   }
};

struct simd_pow_impl : simd_elementwise_binary_interface<simd_pow_impl> {
   constexpr simd_pow_impl() = default;

   template <typename T, typename Abi>
      requires(is_floating_point<T>)
   [[nodiscard]]
   constexpr auto
   invoke_full(simd<T, Abi> left, simd<T, Abi> right) const -> simd<T, Abi> {
      if constexpr (has_simd_abi_binary_full<simd_abi::op_pow, T, Abi>) {
         return simd_abi_apply_binary_full<simd_abi::op_pow, T, Abi>(left,
                                                                     right);
      } else {
         return simd<T, Abi>(__builtin_elementwise_pow(left.raw, right.raw));
      }
   }

   template <typename T>
      requires(is_floating_point<T>)
   [[nodiscard]]
   constexpr auto
   invoke_lanewise(T left, T right) const -> T {
      using R = raw_arithmetic_type<T>;
      if constexpr (is_same<R, float>) {
         return T(__builtin_powf(static_cast<R>(make_raw_arithmetic(left)),
                                 static_cast<R>(make_raw_arithmetic(right))));
      }
      return T(__builtin_pow(static_cast<R>(make_raw_arithmetic(left)),
                             static_cast<R>(make_raw_arithmetic(right))));
   }
};
