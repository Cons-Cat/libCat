      return static_cast<Derived const&>(*this);
   }
};

template <typename Derived>
struct simd_elementwise_unary_int_interface {
   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   operator()(simd<T, Abi> input, iword count) const -> decltype(auto) {
      return self().invoke_full(input, count);
   }

   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   operator[](simd_mask<T, Abi> lane_mask) const
      -> simd_unary_int_masked_impl<Derived, simd_mask<T, Abi>> {
      return {self(), lane_mask};
   }

 private:
