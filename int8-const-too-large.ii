namespace cat {

template <typename T, typename in_abi>
   requires(is_same<typename in_abi::scalar_type, T>)
template <typename Idx, typename IdxAbi>
constexpr auto
simd<T, in_abi>::operator[](simd<Idx, IdxAbi> const& indices) const {
   return simd_permute(*this, indices);
}

template <typename T, typename in_abi>
   requires(is_same<typename in_abi::scalar_type, T>)
template <typename... Ts>
   requires(sizeof...(Ts) >= 2)
constexpr auto
simd<T, in_abi>::operator[](Ts&&... lanes) const {
   return simd_permute(*this, simd<T, fixed_size_abi<T, idx(sizeof...(Ts))>>(
                                 static_cast<T>(::cat::forward<decltype(lanes)>(lanes))...));
}

}




namespace cat::detail::simd_abi {


template <typename T, typename Abi>
struct mask_count_if_true {
   [[nodiscard]]
   static constexpr auto
   invoke(simd_mask<T, Abi> const& m) -> idx {

      idx n = 0u;
      for (idx i = 0u; i < Abi::lanes; ++i) {
         if (m[i]) {
            ++n;
         }
      }
      return n;
   }
};



template <typename T, typename Abi>
struct mask_find_if_true {
   [[nodiscard]]
   static constexpr auto
   invoke(simd_mask<T, Abi> const& m) -> idx {

      for (idx i = 0u; i < Abi::lanes; ++i) {
         if (m[i]) {
            return i;
         }
      }
      __builtin_unreachable();
   }
};



template <typename T, typename Abi>
struct mask_find_last_if_true {
   [[nodiscard]]
   static constexpr auto
   invoke(simd_mask<T, Abi> const& m) -> idx {

      idx max_i = 0u;
      for (idx i = 0u; i < Abi::lanes; ++i) {
         if (m[i]) {
            max_i = i;
         }
      }
      return max_i;
   }
};


template <typename T, typename Abi>
struct mask_all_of {
   [[nodiscard]]
   static constexpr auto
   invoke(simd_mask<T, Abi> const& mask) -> bool {

#pragma clang loop vectorize_predicate(enable)
      for (idx i = 0u; i < Abi::lanes; ++i) {
         if (!mask[i]) {
            return false;
         }
      }
      return true;
   }
};


template <typename T, typename Abi>
struct mask_any_of {
   [[nodiscard]]
   static constexpr auto
   invoke(simd_mask<T, Abi> const& mask) -> bool {

#pragma clang loop vectorize_predicate(enable)
      for (idx i = 0u; i < Abi::lanes; ++i) {
         if (mask[i]) {
            return true;
         }
      }
      return false;
   }
};

}

