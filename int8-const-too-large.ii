namespace cat {

template <typename T, overflow_policies overflow_policy>
constexpr auto
arithmetic<T, overflow_policy>::undef() & -> overflow_reference<
   arithmetic<T, overflow_policy>, overflow_policies::undefined> {
   return overflow_reference<arithmetic<T, overflow_policy>,
                             overflow_policies::undefined>{*this};
}

template <typename T, overflow_policies overflow_policy>
constexpr auto
arithmetic<T, overflow_policy>::undef() const& -> overflow_reference<
   arithmetic<T, overflow_policy> const, overflow_policies::undefined> {
   return overflow_reference<arithmetic<T, overflow_policy> const,
                             overflow_policies::undefined>{*this};
}

template <typename T, overflow_policies overflow_policy>
constexpr auto
arithmetic<T, overflow_policy>::wrap() & -> overflow_reference<
   arithmetic<T, overflow_policy>, overflow_policies::wrap> {
   return overflow_reference<arithmetic<T, overflow_policy>,
                             overflow_policies::wrap>{*this};
}

template <typename T, overflow_policies overflow_policy>
constexpr auto
arithmetic<T, overflow_policy>::wrap() const& -> overflow_reference<
   arithmetic<T, overflow_policy> const, overflow_policies::wrap> {
   return overflow_reference<arithmetic<T, overflow_policy> const,
                             overflow_policies::wrap>{*this};
}

template <typename T, overflow_policies overflow_policy>
constexpr auto
arithmetic<T, overflow_policy>::sat() & -> overflow_reference<
   arithmetic<T, overflow_policy>, overflow_policies::saturate> {
   return overflow_reference<arithmetic<T, overflow_policy>,
                             overflow_policies::saturate>{*this};
}

template <typename T, overflow_policies overflow_policy>
constexpr auto
arithmetic<T, overflow_policy>::sat() const& -> overflow_reference<
   arithmetic<T, overflow_policy> const, overflow_policies::saturate> {
   return overflow_reference<arithmetic<T, overflow_policy> const,
                             overflow_policies::saturate>{*this};
}





