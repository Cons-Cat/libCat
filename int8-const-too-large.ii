namespace detail {
template <typename T, typename U>
concept is_partially_ordered_with =
   requires(remove_reference<T> const& t, remove_reference<U> const& u) {
      { t < u } -> is_boolean_testable;
      { t > u } -> is_boolean_testable;
      { t <= u } -> is_boolean_testable;
      { t >= u } -> is_boolean_testable;
      { u < t } -> is_boolean_testable;
      { u > t } -> is_boolean_testable;
      { u <= t } -> is_boolean_testable;
      { u >= t } -> is_boolean_testable;
   };
}

