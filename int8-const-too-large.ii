   [[nodiscard]]
   constexpr auto
   first(this derived_type const& self, idx count) -> span<T const>
      requires(is_array_like)
   {
      return self.subspan(0u, count);
   }

   [[nodiscard]]
   constexpr auto
   last(this auto&& self, idx count) -> span<T>
      requires(is_array_like && !is_const_ref<decltype(self)>)
   {
      return ::cat::forward<decltype(self)>(self).subspan(idx(::cat::forward<decltype(self)>(self).size() - count), ::cat::forward<decltype(self)>(self).size());
   }

   [[nodiscard]]
   constexpr auto
   last(this derived_type const& self, idx count) -> span<T const>
      requires(is_array_like)
