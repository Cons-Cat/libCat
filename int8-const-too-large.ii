      -> simd<T, Abi> {
      if constexpr (has_simd_abi_ternary_full<simd_abi::op_fshr, T, Abi>) {
         return simd_abi_apply_ternary_full<simd_abi::op_fshr, T, Abi>(x, y, z);
      }
      return simd<T, Abi>(__builtin_elementwise_fshr(x.raw, y.raw, z.raw));
   }

   template <typename T>
      requires(is_integral<T> && !is_bool<T>)
   [[nodiscard]]
   constexpr auto
   invoke_lanewise(T x, T y, T z) const -> T {
      using U = make_unsigned_type<T>;
      U const hi = static_cast<U>(x);
      U const lo = static_cast<U>(y);
      unsigned int const count =
         static_cast<unsigned int>(make_raw_arithmetic(z))
         % static_cast<unsigned int>(sizeof(T) * 8u);
      return static_cast<T>(__builtin_fshr(hi, lo, count));
   }
};

struct simd_ldexp_impl
    : simd_elementwise_binary_mixed_interface<simd_ldexp_impl> {
   constexpr simd_ldexp_impl() = default;

   template <typename T, typename IntT, typename Abi>
      requires(is_floating_point<T> && is_integral<IntT>)
   [[nodiscard]]
   constexpr auto
   invoke_full(simd<T, Abi> x, simd<IntT, Abi> y) const -> simd<T, Abi> {
      if constexpr (has_simd_abi_binary_mixed<simd_abi::op_ldexp, T, IntT,
                                              Abi>) {
         return simd_abi_apply_binary_mixed<simd_abi::op_ldexp, T, IntT, Abi>(
            x, y);
      }
      return simd<T, Abi>(__builtin_elementwise_ldexp(x.raw, y.raw));
   }

   template <typename T, typename IntT>
      requires(is_floating_point<T> && is_integral<IntT>)
   [[nodiscard]]
   constexpr auto
   invoke_lanewise(T x, IntT y) const -> T {
      using R = raw_arithmetic_type<T>;
      int const exp = static_cast<int>(make_raw_arithmetic(y));
      if constexpr (is_same<R, float>) {
         return T(
            __builtin_ldexpf(static_cast<R>(make_raw_arithmetic(x)), exp));
      }
      return T(__builtin_ldexp(static_cast<R>(make_raw_arithmetic(x)), exp));
   }
};

}




