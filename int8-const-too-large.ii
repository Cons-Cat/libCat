template <typename M, typename A>
struct make_simd_mask_else;

struct simd_if_else_impl {
   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   operator()(simd_mask<T, Abi> mask, simd<T, Abi> on_true,
              simd<T, Abi> on_false) const -> simd<T, Abi> {


      return detail::simd_if_else_apply(mask, on_true, on_false);
   }

   template <typename T, typename Abi, typename U>
      requires(
         is_constructible<T, remove_cvref<U>>
         && detail::simd_broadcast_really_convertible_to<remove_cvref<U>, T>())
   [[nodiscard]]
   constexpr auto
   operator()(simd_mask<T, Abi> mask, simd<T, Abi> on_true, U&& on_false) const
      -> simd<T, Abi> {
      return (*this)(mask, on_true, simd<T, Abi>(::cat::forward<decltype(on_false)>(on_false)));
   }

   template <typename T, typename Abi, typename A>
   [[nodiscard]]
   constexpr auto
   operator()(make_simd_mask_else<simd_mask<T, Abi>, A> const& else_branch,
              simd<T, Abi> on_true) const -> simd<T, Abi> {


      simd<T, Abi> on_false{};
      if constexpr (is_same<remove_cvref<A>, simd<T, Abi>>) {
         on_false = else_branch.otherwise;
      } else {
         on_false.fill(static_cast<T>(else_branch.otherwise));
      }
      return detail::simd_if_else_apply(else_branch.lane_mask, on_true,
                                        on_false);
   }
};

struct simd_select_impl {
   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   operator()(simd_mask<T, Abi> mask, simd<T, Abi> on_true,
              simd<T, Abi> on_false) const -> simd<T, Abi> {


      return detail::simd_if_else_apply(mask, on_true, on_false);
   }
};

template <typename M, typename A>
struct make_simd_mask_else {
   M lane_mask;
   A otherwise;
};

template <typename M>
struct make_simd_mask_if_builder {
   M lane_mask;

   template <typename Alt>
   [[nodiscard]]
   constexpr auto
   else_(Alt&& alt) const -> make_simd_mask_else<M, remove_cvref<Alt>> {
      return {lane_mask, static_cast<remove_cvref<Alt>>(::cat::forward<decltype(alt)>(alt))};
   }
};

struct make_simd_mask_if_impl {
   template <typename M>
   [[nodiscard]]
   constexpr auto
   operator()(M lane_mask) const -> make_simd_mask_if_builder<M> {
      return {lane_mask};
   }
};




template <typename Simd>
struct make_simd_mask_from_count_impl {
   [[nodiscard]]
   constexpr auto
   operator()(idx active_lanes) const -> typename Simd::mask_type {



      using Abi = typename Simd::abi_type;
      typename Simd::mask_type lane_mask{};
      for (idx i = 0u; i < Abi::lanes; ++i) {
         lane_mask.set_lane(i, i < active_lanes);
      }
      return lane_mask;
   }
};

template <typename Simd>
struct make_simd_mask_ignore_first_impl {
   [[nodiscard]]
   constexpr auto
   operator()(idx ignore_head_count) const -> typename Simd::mask_type {
      typename Simd::mask_type lane_mask{};
      for (idx i = 0u; i < Simd::abi_type::lanes; ++i) {
         lane_mask.set_lane(i, i >= ignore_head_count);
      }
      return lane_mask;
   }
};

template <typename Simd>
struct make_simd_mask_ignore_last_impl {
   [[nodiscard]]
   constexpr auto
   operator()(idx ignore_tail_count) const -> typename Simd::mask_type {
      idx const width = Simd::abi_type::lanes;
      typename Simd::mask_type lane_mask{};
      for (idx i = 0u; i < width; ++i) {
         lane_mask.set_lane(i, i < width - ignore_tail_count);
      }
      return lane_mask;
   }
};

template <typename Simd>
struct make_simd_mask_keep_between_impl {
   [[nodiscard]]
   constexpr auto
   operator()(idx first, idx last_exclusive) const -> typename Simd::mask_type {
      typename Simd::mask_type lane_mask{};
      for (idx i = 0u; i < Simd::abi_type::lanes; ++i) {
         lane_mask.set_lane(i, i >= first && i < last_exclusive);
      }
      return lane_mask;
   }
};

struct simd_sqrt_impl : simd_elementwise_interface<simd_sqrt_impl> {
   constexpr simd_sqrt_impl() = default;

   template <typename T, typename Abi>
      requires(is_floating_point<T>)
   [[nodiscard]]
   constexpr auto
   invoke_full(simd<T, Abi> input) const -> simd<T, Abi> {
      if constexpr (has_simd_abi_unary_full<simd_abi::op_sqrt, T, Abi>) {
         return simd_abi_apply_unary_full<simd_abi::op_sqrt, T, Abi>(input);
      } else {
         return simd<T, Abi>(__builtin_elementwise_sqrt(input.raw));
      }
   }

   template <typename T>
      requires(is_floating_point<T>)
   [[nodiscard]]
   constexpr auto
   invoke_lanewise(T x) const -> T {
      using R = raw_arithmetic_type<T>;
      return T(cat::sqrt(static_cast<R>(make_raw_arithmetic(x))));
   }
};

template <typename T>
   requires(is_floating_point<T>)
[[nodiscard]]
constexpr auto
simd_rsqrt_lane(T x) -> T {
   using R = raw_arithmetic_type<T>;
   R const rx = static_cast<R>(make_raw_arithmetic(x));
   return T(static_cast<R>(1) / cat::sqrt(rx));
}

struct simd_rsqrt_impl : simd_elementwise_interface<simd_rsqrt_impl> {
   constexpr simd_rsqrt_impl() = default;

   template <typename T, typename Abi>
      requires(is_floating_point<T>)
   [[nodiscard]]
   constexpr auto
   invoke_full(simd<T, Abi> input) const -> simd<T, Abi> {
      if constexpr (has_simd_abi_unary_full<simd_abi::op_rsqrt, T, Abi>) {
         return simd_abi_apply_unary_full<simd_abi::op_rsqrt, T, Abi>(input);
      } else {
         simd<T, Abi> one{};
         one.fill(T(1));
         return simd<T, Abi>(one.raw / __builtin_elementwise_sqrt(input.raw));
      }
   }

   template <typename T>
      requires(is_floating_point<T>)
   [[nodiscard]]
   constexpr auto
   invoke_lanewise(T x) const -> T {
      return simd_rsqrt_lane(x);
   }
};

template <typename T>
   requires(is_floating_point<T>)
[[nodiscard]]
constexpr auto
simd_nroot_lane(T x, iword n) -> T {
   if (n <= 1) {
      return x;
   }
   if (x == T(0)) {
      return x;
   }
   T abs_x = x < T(0) ? static_cast<T>(-x) : x;
   T const root_magnitude = [&]() -> T {
      auto const abs_raw = make_raw_arithmetic(abs_x);
      if constexpr (is_same<raw_arithmetic_type<T>, float>) {
         return static_cast<T>(
            emulated_powf(abs_raw, 1.f / static_cast<float>(n.raw)));
      } else {
         return static_cast<T>(emulated_pow(static_cast<double>(abs_raw),
                                            1. / static_cast<double>(n.raw)));
      }
   }();
   if (x < T(0)) {
      if ((n.raw & 1u) != 0u) {
         return static_cast<T>(-root_magnitude);
      }
      if constexpr (is_same<raw_arithmetic_type<T>, float>) {
         return static_cast<T>(__builtin_nanf(""));
      } else {
         return static_cast<T>(__builtin_nan(""));
      }
   }
   return root_magnitude;
}

template <typename T>
   requires(is_floating_point<T>)
[[nodiscard]]
constexpr auto
simd_rnroot_lane(T x, iword n) -> T {
   if (n <= 0) {
      return x;
   }
   if (n == 1) {
      using R = raw_arithmetic_type<T>;
      R const rx = static_cast<R>(make_raw_arithmetic(x));
      return T(static_cast<R>(1) / rx);
   }
   using R = raw_arithmetic_type<T>;
   R const root = static_cast<R>(make_raw_arithmetic(simd_nroot_lane(x, n)));
   return T(static_cast<R>(1) / root);
}

template <typename T>
   requires(is_floating_point<T>)
[[nodiscard]]
constexpr auto
simd_rcbrt_lane(T x) -> T {
   return simd_rnroot_lane(x, iword(3));
}

template <typename T, typename Abi>
   requires(is_floating_point<T>)
[[nodiscard]]
constexpr auto
simd_nroot_generic(simd<T, Abi> input, iword n) -> simd<T, Abi> {
   if (n <= 1) {
      return input;
   }
   simd<T, Abi> abs_x(__builtin_elementwise_abs(input.raw));
   simd<T, Abi> reciprocal_root{};
   reciprocal_root.fill(T(1) / static_cast<T>(n.raw));
   simd<T, Abi> root_magnitude(
      __builtin_elementwise_pow(abs_x.raw, reciprocal_root.raw));
   simd<T, Abi> zeros{};
   zeros.fill(T(0));
   if ((n.raw & 1u) != 0u) {
      return simd_if_else_impl{}(input < zeros, zeros - root_magnitude,
                                 root_magnitude);
   }
   simd<T, Abi> quiet_nans{};
   if constexpr (is_same<raw_arithmetic_type<T>, float>) {
      quiet_nans.fill(static_cast<T>(__builtin_nanf("")));
   } else {
      quiet_nans.fill(static_cast<T>(__builtin_nan("")));
   }
   return simd_if_else_impl{}(input < zeros, quiet_nans, root_magnitude);
}

struct simd_nroot_impl : simd_elementwise_unary_int_interface<simd_nroot_impl> {
   constexpr simd_nroot_impl() = default;

   template <typename T, typename Abi>
      requires(is_floating_point<T>)
   [[nodiscard]]
   constexpr auto
   invoke_full(simd<T, Abi> input, iword n) const -> simd<T, Abi> {
      return simd_nroot_generic(input, n);
   }

   template <typename T>
      requires(is_floating_point<T>)
   [[nodiscard]]
   constexpr auto
   invoke_lanewise(T x, iword n) const -> T {
      return simd_nroot_lane(x, n);
   }
};

struct simd_cbrt_impl : simd_elementwise_interface<simd_cbrt_impl> {
   constexpr simd_cbrt_impl() = default;

   template <typename T, typename Abi>
      requires(is_floating_point<T>)
   [[nodiscard]]
   constexpr auto
   invoke_full(simd<T, Abi> input) const -> simd<T, Abi> {
      return simd_nroot_impl{}.invoke_full(input, iword(3));
   }

   template <typename T>
      requires(is_floating_point<T>)
   [[nodiscard]]
   constexpr auto
   invoke_lanewise(T x) const -> T {
      return simd_nroot_lane(x, iword(3));
   }
};

struct simd_rcbrt_impl : simd_elementwise_interface<simd_rcbrt_impl> {
   constexpr simd_rcbrt_impl() = default;

   template <typename T, typename Abi>
      requires(is_floating_point<T>)
   [[nodiscard]]
   constexpr auto
   invoke_full(simd<T, Abi> input) const -> simd<T, Abi> {
      simd<T, Abi> const cbrt = simd_cbrt_impl{}.invoke_full(input);
      simd<T, Abi> one{};
      one.fill(T(1));
      return simd<T, Abi>(one.raw / cbrt.raw);
   }

   template <typename T>
      requires(is_floating_point<T>)
   [[nodiscard]]
   constexpr auto
   invoke_lanewise(T x) const -> T {
      return simd_rcbrt_lane(x);
   }
};

struct simd_rnroot_impl
    : simd_elementwise_unary_int_interface<simd_rnroot_impl> {
   constexpr simd_rnroot_impl() = default;

   template <typename T, typename Abi>
      requires(is_floating_point<T>)
   [[nodiscard]]
   constexpr auto
   invoke_full(simd<T, Abi> input, iword n) const -> simd<T, Abi> {
      if (n <= 0) {
         return input;
      }
      if (n == 1) {
         simd<T, Abi> one{};
         one.fill(T(1));
         return simd<T, Abi>(one.raw / input.raw);
      }
      simd<T, Abi> const root = simd_nroot_impl{}.invoke_full(input, n);
      simd<T, Abi> one{};
      one.fill(T(1));
      return simd<T, Abi>(one.raw / root.raw);
   }

   template <typename T>
      requires(is_floating_point<T>)
   [[nodiscard]]
   constexpr auto
   invoke_lanewise(T x, iword n) const -> T {
      return simd_rnroot_lane(x, n);
   }
};

template <typename T>
   requires(is_integral<T> && !is_bool<T>)
[[nodiscard]]
constexpr auto
simd_popcount_lane(T x) -> T {
   auto const unsigned_bits = static_cast<make_unsigned_type<T>>(x);



   return static_cast<T>(__builtin_popcountg(unsigned_bits));
}

struct simd_popcount_impl : simd_elementwise_interface<simd_popcount_impl> {
   constexpr simd_popcount_impl() = default;

   template <typename T, typename Abi>
      requires(is_integral<T> && !is_bool<T>)
   [[nodiscard]]
   constexpr auto
   invoke_full(simd<T, Abi> input) const -> simd<T, Abi> {
      return input.popcount();
   }

   template <typename T>
      requires(is_integral<T> && !is_bool<T>)
   [[nodiscard]]
   constexpr auto
   invoke_lanewise(T x) const -> T {
      return simd_popcount_lane(x);
   }
};

template <typename NewT>
struct simd_bit_cast_as_impl {
   template <typename T, typename Abi>
      requires(sizeof(NewT) == sizeof(T) && Abi::lanes > 0
               && (sizeof(NewT) * Abi::lanes.raw
                   == sizeof(typename simd<T, Abi>::raw_type)))
   [[nodiscard]]
   constexpr auto
   operator()(simd<T, Abi> const& input) const {
      using out_abi =
         fixed_size_abi<NewT, idx{Abi::lanes.raw * sizeof(T) / sizeof(NewT)}>;
      return simd<NewT, out_abi>(
         __builtin_bit_cast(typename simd<NewT, out_abi>::raw_type, input.raw));
   }
};

struct simd_permute_impl {
   template <typename T, typename Abi, typename IdxAbi, typename Idx>
   [[nodiscard]]
   constexpr auto
   operator()(simd<T, Abi> input, simd<Idx, IdxAbi> indices) const {


      if constexpr (IdxAbi::lanes == Abi::lanes) {
         simd<T, Abi> result{};
         idx::raw_type const width = Abi::lanes.raw;

#pragma clang loop vectorize(enable)
         for (idx lane_i = 0u; lane_i < Abi::lanes; ++lane_i) {
            idx::raw_type const requested_index =
               static_cast<idx::raw_type>(indices[lane_i]);
            idx::raw_type const wrapped_lane_index = requested_index % width;
            result.set_lane(lane_i, input[idx(wrapped_lane_index)]);
         }
         return result;
      } else {
         simd<T, fixed_size_abi<T, IdxAbi::lanes>> result{};
         idx::raw_type const width = Abi::lanes.raw;

#pragma clang loop vectorize(enable)
         for (idx lane_i = 0u; lane_i < IdxAbi::lanes; ++lane_i) {
            idx::raw_type const requested_index =
               static_cast<idx::raw_type>(indices[lane_i]);
            idx::raw_type const wrapped_lane_index = requested_index % width;
            result.set_lane(lane_i, input[idx(wrapped_lane_index)]);
         }
         return result;
      }
   }
};

template <int... Idx>
struct simd_shuffle_impl {
   template <typename T, typename Abi>
      requires(sizeof...(Idx) == Abi::lanes.raw)
   [[nodiscard]]
   constexpr auto
   operator()(simd<T, Abi> input) const -> simd<T, Abi> {
      return simd<T, Abi>(
         __builtin_shufflevector(input.raw, input.raw, Idx...));
   }
};

}

namespace detail {

struct simd_compress_impl {
   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   operator()(simd<T, Abi> input, simd_mask<T, Abi> selector) const
      -> simd<T, Abi> {
      if constexpr (has_simd_abi_compress<T, Abi>) {
         return simd_abi_apply_compress<T, Abi>(input, selector);
      } else {
         simd<T, Abi> result{};
         idx next_packed_lane = 0u;
#pragma clang loop vectorize_predicate(enable)
         for (idx i = 0u; i < Abi::lanes; ++i) {
            if (selector[i]) {
               result.set_lane(next_packed_lane, input[i]);
               ++next_packed_lane;
            }
         }
         for (; next_packed_lane < Abi::lanes; ++next_packed_lane) {
            result.set_lane(next_packed_lane, T{});
         }
         return result;
      }
   }
};

struct simd_expand_impl {
   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   operator()(simd<T, Abi> packed_values, simd_mask<T, Abi> selector,
              simd<T, Abi> background = {}) const -> simd<T, Abi> {
      if constexpr (has_simd_abi_expand<T, Abi>) {
         return simd_abi_apply_expand<T, Abi>(packed_values, selector,
                                              background);
      } else {
         simd<T, Abi> result = background;
         idx packed_read_index = 0u;
#pragma clang loop vectorize_predicate(enable)
         for (idx i = 0u; i < Abi::lanes; ++i) {
            if (selector[i]) {
               result.set_lane(i, packed_values[packed_read_index]);
               ++packed_read_index;
            }
         }
         return result;
      }
   }
};

template <is_unsigned_integral T>
[[nodiscard]]
constexpr auto
simd_rotate_left_lane(T operand, iword count) -> T {
   return rotate_left(operand, count);
}

template <is_unsigned_integral T>
[[nodiscard]]
constexpr auto
simd_rotate_right_lane(T operand, iword count) -> T {
   return rotate_right(operand, count);
}

template <typename T, typename Abi>
   requires(is_unsigned_integral<T>)
[[nodiscard]]
constexpr auto
simd_rotate_left_generic(simd<T, Abi> input, iword count) -> simd<T, Abi> {
   simd<T, Abi> result{};
   for (idx i = 0u; i < Abi::lanes; ++i) {
      result.set_lane(i, simd_rotate_left_lane(input[i], count));
   }
   return result;
}

template <typename T, typename Abi>
   requires(is_unsigned_integral<T>)
[[nodiscard]]
constexpr auto
simd_rotate_right_generic(simd<T, Abi> input, iword count) -> simd<T, Abi> {
   simd<T, Abi> result{};
   for (idx i = 0u; i < Abi::lanes; ++i) {
      result.set_lane(i, simd_rotate_right_lane(input[i], count));
   }
   return result;
}

struct simd_rotate_left_impl
    : simd_elementwise_unary_int_interface<simd_rotate_left_impl> {
   constexpr simd_rotate_left_impl() = default;

   template <typename T, typename Abi>
      requires(is_unsigned_integral<T>)
   [[nodiscard]]
   constexpr auto
   invoke_full(simd<T, Abi> input, iword count) const -> simd<T, Abi> {
      if constexpr (has_simd_abi_unary_int<simd_abi::op_rotate_left, T, Abi>) {
         return simd_abi_apply_unary_int<simd_abi::op_rotate_left, T, Abi>(
            input, count);
      } else {
         return simd_rotate_left_generic(input, count);
      }
   }

   template <is_unsigned_integral T>
   [[nodiscard]]
   constexpr auto
   invoke_lanewise(T operand, iword count) const -> T {
      return simd_rotate_left_lane(operand, count);
   }
};

