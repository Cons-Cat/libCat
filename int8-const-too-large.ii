struct simd_maxnum_impl : simd_elementwise_binary_interface<simd_maxnum_impl> { constexpr simd_maxnum_impl() = default; template <typename T, typename Abi> requires(is_floating_point<T>) [[nodiscard]] constexpr auto invoke_full(simd<T, Abi> left, simd<T, Abi> right) const -> simd<T, Abi> { if constexpr (has_simd_abi_binary_full<simd_abi::op_maxnum, T, Abi>) { return simd_abi_apply_binary_full<simd_abi::op_maxnum, T, Abi>( left, right); } else { return simd<T, Abi>( __builtin_elementwise_maxnum(left.raw, right.raw)); } } template <typename T> requires(is_floating_point<T>) [[nodiscard]] constexpr auto invoke_lanewise(T left, T right) const -> T { using R = raw_arithmetic_type<T>; if constexpr (is_same<R, float>) { return T(__builtin_fmaxf( static_cast<R>(make_raw_arithmetic(left)), static_cast<R>(make_raw_arithmetic(right)))); } else { return T(__builtin_fmax( static_cast<R>(make_raw_arithmetic(left)), static_cast<R>(make_raw_arithmetic(right)))); } } };



struct simd_minimumnum_impl
    : simd_elementwise_binary_interface<simd_minimumnum_impl> {
   constexpr simd_minimumnum_impl() = default;

   template <typename T, typename Abi>
      requires(is_floating_point<T>)
   [[nodiscard]]
   constexpr auto
   invoke_full(simd<T, Abi> left, simd<T, Abi> right) const -> simd<T, Abi> {
      if constexpr (has_simd_abi_binary_full<simd_abi::op_minimumnum, T, Abi>) {
         return simd_abi_apply_binary_full<simd_abi::op_minimumnum, T, Abi>(
            left, right);
      } else {
         return simd<T, Abi>(
            __builtin_elementwise_minimumnum(left.raw, right.raw));
      }
   }

   template <typename T>
      requires(is_floating_point<T>)
   [[nodiscard]]
   constexpr auto
   invoke_lanewise(T left, T right) const -> T {
      using R = raw_arithmetic_type<T>;
      return T(
         __builtin_fminimum_num(static_cast<R>(make_raw_arithmetic(left)),
                                static_cast<R>(make_raw_arithmetic(right))));
   }
};

