namespace std {

template <typename T>
class initializer_list {
  public:
    using value_type = T;
    using reference = T&;
    using const_reference = T&;
    using size_type = long unsigned int;

    constexpr initializer_list() = default;

    constexpr initializer_list(T const* p_data, long unsigned int in_size)
        : m_p_data(p_data), m_size(in_size) {
    }


    [[nodiscard]]
    constexpr auto
    size() const -> long unsigned int {
        return m_size;
    }

    [[nodiscard]]
    constexpr auto
    begin() const -> T* {
        return m_p_data;
    }

    [[nodiscard]]
    constexpr auto
    end() const -> T* {
        return m_p_data + m_size;
    }

  private:
    T const* m_p_data = nullptr;
    long unsigned int m_size = 0u;
};

template <class T>
constexpr auto
begin(initializer_list<T> initializers) -> T const* {
    return initializers.begin();
}

template <class T>
constexpr auto
end(initializer_list<T> initializers) -> T const* {
    return initializers.end();
}

}

namespace cat {
using std::initializer_list;
