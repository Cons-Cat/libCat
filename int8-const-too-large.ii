   at(this auto&& self [[clang::lifetimebound]], idx index) -> maybe<T&>
      requires(is_array_like && !is_const_ref<decltype(self)>)
   {
      if (index < ::cat::forward<decltype(self)>(self).size()) {
         return ::cat::forward<decltype(self)>(self).data()[index.raw];
      }
      return nullopt;
   }


   [[nodiscard]]
   constexpr auto
   at(this derived_type const& self [[clang::lifetimebound]], idx index)
      -> maybe<T&> {

      return unconst(self).at(index);
   }

   [[nodiscard]]
   constexpr auto
   front(this auto&& self) -> T&
      requires(is_array_like && !is_const_ref<decltype(self)>)
   {
      cat::assert(::cat::forward<decltype(self)>(self).size() > 0);
      return ::cat::forward<decltype(self)>(self).data()[0];
   }

   [[nodiscard]]
   constexpr auto
   front(this derived_type const& self) -> T const& {
      cat::assert(self.size() > 0);
      return unconst(self).front();
   }

   [[nodiscard]]
   constexpr auto
   back(this auto&& self) -> T&
      requires(is_array_like && !is_const_ref<decltype(self)>)
   {
      cat::assert(::cat::forward<decltype(self)>(self).size() > 0);
      return ::cat::forward<decltype(self)>(self).data()[::cat::forward<decltype(self)>(self).size().raw - 1u];
   }

   [[nodiscard]]
   constexpr auto
   back(this derived_type const& self) -> T const& {
      cat::assert(self.size() > 0);
      return unconst(self).back();
   }

   [[nodiscard]]
   constexpr auto
   subspan(this auto&& self, idx start_index, idx end_index) -> span<T>
      requires(is_array_like && !is_const_ref<decltype(self)>)
   {
      if !consteval {
         assert(end_index <= ::cat::forward<decltype(self)>(self).capacity());
      }

      return span<T>(::cat::forward<decltype(self)>(self).data() + start_index,
                     idx(end_index - start_index));
   }

   [[nodiscard]]
   constexpr auto
   subspan(this derived_type const& self, idx start_index, idx end_index)
      -> span<T const>
      requires(is_array_like)
   {
      if !consteval {
         assert(end_index <= self.capacity());
      }

      return span<T const>(self.data() + start_index,
                           idx(end_index - start_index));
   }

