         it++;
      };

template <typename T>
concept is_incrementable =
   is_weakly_incrementable<T>
   && requires(remove_cvref<T> it) {
         { it++ } -> is_same<remove_cvref<T>>;
      } && (detail::is_object_pointer_iterator<T> || detail::is_iterator_regular<remove_cvref<T>>);

template <typename T>
using iterator_reference = decltype(*declval<T&>());

template <typename T>
using iter_reference_t = iterator_reference<T>;

template <typename T>
using iter_rvalue_reference_t = decltype(move(*declval<T&>()));

template <typename T>
using iter_difference_t = iterator_difference_type<T>;

template <typename T>
concept is_input_or_output_iterator =
   requires(T it) { *it; } && is_weakly_incrementable<T>;


template <typename In>
concept is_indirectly_readable = requires(remove_cvref<In> const in) {
                                    typename iter_value_t<remove_cvref<In>>;
                                    { *in };
                                 };


template <typename T>
concept is_input_iterator =
   is_input_or_output_iterator<T> && is_indirectly_readable<T>
   && is_equality_comparable<T>;

template <typename T>
concept is_random_access_iterator =
   detail::is_object_pointer_iterator<T>
   || (is_base_of<iterator_interface_base, remove_cvref<T>>
       && is_same<typename remove_cvref<T>::iterator_concept,
                  random_access_iterator_tag>);

template <typename T>
concept is_contiguous_iterator =
   is_random_access_iterator<T>
   && (detail::is_object_pointer_iterator<T>
       || (is_base_of<iterator_interface_base, remove_cvref<T>>
           && is_same<typename remove_cvref<T>::iterator_concept,
                      contiguous_iterator_tag>));

template <typename T>
concept is_bidirectional_iterator =
   is_random_access_iterator<T>
   || (is_base_of<iterator_interface_base, remove_cvref<T>>
       && is_same<typename remove_cvref<T>::iterator_concept,
                  bidirectional_iterator_tag>);

namespace detail {

template <typename T>
concept iter_has_forward_capacity_tag =
   is_base_of<iterator_interface_base, remove_cvref<T>>
   && (is_same<typename remove_cvref<T>::iterator_concept, forward_iterator_tag>
       || is_same<typename remove_cvref<T>::iterator_concept,
                  bidirectional_iterator_tag>
       || is_same<typename remove_cvref<T>::iterator_concept,
                  random_access_iterator_tag>
       || is_same<typename remove_cvref<T>::iterator_concept,
                  contiguous_iterator_tag>);

template <typename T>
concept iter_is_pure_input_interface_iterator =
   is_base_of<iterator_interface_base, remove_cvref<T>>
   && is_same<typename remove_cvref<T>::iterator_concept, input_iterator_tag>;

}


template <typename T>
concept is_forward_iterator =
   is_input_iterator<T> && is_incrementable<T>
   && (detail::is_object_pointer_iterator<T>
       || (detail::iter_has_forward_capacity_tag<T>
           && !detail::iter_is_pure_input_interface_iterator<T>));

template <typename outputter, typename value_type>
concept is_indirectly_writable =
   requires(outputter&& output_iterator, value_type&& value) {
      *output_iterator = ::cat::forward<decltype(value)>(value);
      *::cat::forward<decltype(output_iterator)>(output_iterator) = ::cat::forward<decltype(value)>(value);
      const_cast<iterator_reference<outputter> const&&>(*output_iterator) =
         ::cat::forward<decltype(value)>(value);
      const_cast<iterator_reference<outputter> const&&>(*::cat::forward<decltype(output_iterator)>(output_iterator)) =
         ::cat::forward<decltype(value)>(value);
   };

template <typename outputter, typename value_type>
concept is_output_iterator =
   is_input_or_output_iterator<outputter>
   && is_indirectly_writable<outputter, value_type>
   && requires(outputter iterator, value_type&& value) {
         *iterator++ = ::cat::forward<decltype(value)>(value);
      };



template <is_bidi_iterable T>
struct as_reverse : T {
   constexpr as_reverse(T& base) : T(base) {
   }

   constexpr as_reverse(T&& base)
      requires(is_rvalue_reference<decltype(base)>)
       : T(move(base)) {
   }

   constexpr auto
   begin() {
      return static_cast<T*>(this)->rbegin();
   }

   constexpr auto
   end() {
      return static_cast<T*>(this)->rend();
   }

   constexpr auto
   begin() const {
      return static_cast<T*>(this)->rbegin();
   }

   constexpr auto
   end() const {
      return static_cast<T*>(this)->rend();
   }

   constexpr auto
   cbegin() const {
      return static_cast<T*>(this)->crbegin();
   }

   constexpr auto
   cend() const {
      return static_cast<T*>(this)->crend();
   }

   constexpr auto
   rbegin() {
      return static_cast<T*>(this)->begin();
   }

   constexpr auto
   rend() {
      return static_cast<T*>(this)->end();
   }

   constexpr auto
   rbegin() const {
      return static_cast<T*>(this)->cbegin();
   }

   constexpr auto
   rend() const {
      return static_cast<T*>(this)->cend();
   }

   constexpr auto
   crbegin() const {
      return static_cast<T*>(this)->cbegin();
   }

   constexpr auto
   crend() const {
      return static_cast<T*>(this)->cend();
   }
};




template <is_bidi_iterable T>
struct as_const_reverse : T {
   constexpr as_const_reverse(T& base) : T(base) {
   }

   constexpr as_const_reverse(T&& base)
      requires(is_rvalue_reference<decltype(base)>)
       : T(move(base)) {
   }

   constexpr auto
   begin() const {
      return static_cast<T const*>(this)->rbegin();
   }

   constexpr auto
   end() const {
      return static_cast<T const*>(this)->rend();
   }

   constexpr auto
   cbegin() const {
      return static_cast<T const*>(this)->crbegin();
   }

   constexpr auto
   cend() const {
      return static_cast<T const*>(this)->crend();
   }

   constexpr auto
   rbegin() const {
      return static_cast<T const*>(this)->cbegin();
   }

   constexpr auto
   rend() const {
      return static_cast<T const*>(this)->cend();
   }

   constexpr auto
   crbegin() const {
      return static_cast<T const*>(this)->cbegin();
   }

   constexpr auto
   crend() const {
      return static_cast<T const*>(this)->cend();
   }
};

