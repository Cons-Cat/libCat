};

struct simd_min_impl : simd_elementwise_binary_interface<simd_min_impl> {
   constexpr simd_min_impl() = default;

   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   invoke_full(simd<T, Abi> left, simd<T, Abi> right) const -> simd<T, Abi> {
      if constexpr (is_floating_point<T>) {
         if constexpr (has_simd_abi_binary_full<simd_abi::op_minimum, T, Abi>) {
            return simd_abi_apply_binary_full<simd_abi::op_minimum, T, Abi>(
               left, right);
         } else {
            return simd<T, Abi>(
               __builtin_elementwise_minimum(left.raw, right.raw));
         }
      } else {
         simd<T, Abi> result{};
         for (idx i = 0u; i < Abi::lanes; ++i) {
            result.set_lane(i, left[i] < right[i] ? left[i] : right[i]);
         }
         return result;
      }
   }

   template <typename T>
   [[nodiscard]]
   constexpr auto
   invoke_lanewise(T left, T right) const -> T {
      if constexpr (is_floating_point<T>) {
         using R = raw_arithmetic_type<T>;
         if constexpr (is_same<R, float>) {
            return T(
               __builtin_fminf(static_cast<R>(make_raw_arithmetic(left)),
                               static_cast<R>(make_raw_arithmetic(right))));
         }
         return T(__builtin_fmin(static_cast<R>(make_raw_arithmetic(left)),
                                 static_cast<R>(make_raw_arithmetic(right))));
      } else {
         return left < right ? left : right;
      }
   }
};

struct simd_max_impl : simd_elementwise_binary_interface<simd_max_impl> {
   constexpr simd_max_impl() = default;

   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   invoke_full(simd<T, Abi> left, simd<T, Abi> right) const -> simd<T, Abi> {
      if constexpr (is_floating_point<T>) {
         if constexpr (has_simd_abi_binary_full<simd_abi::op_maximum, T, Abi>) {
            return simd_abi_apply_binary_full<simd_abi::op_maximum, T, Abi>(
               left, right);
         } else {
            return simd<T, Abi>(
               __builtin_elementwise_maximum(left.raw, right.raw));
         }
      } else {
         simd<T, Abi> result{};
         for (idx i = 0u; i < Abi::lanes; ++i) {
            result.set_lane(i, left[i] > right[i] ? left[i] : right[i]);
         }
         return result;
      }
   }

   template <typename T>
   [[nodiscard]]
   constexpr auto
   invoke_lanewise(T left, T right) const -> T {
      if constexpr (is_floating_point<T>) {
         using R = raw_arithmetic_type<T>;
         if constexpr (is_same<R, float>) {
            return T(
               __builtin_fmaxf(static_cast<R>(make_raw_arithmetic(left)),
                               static_cast<R>(make_raw_arithmetic(right))));
         }
         return T(__builtin_fmax(static_cast<R>(make_raw_arithmetic(left)),
                                 static_cast<R>(make_raw_arithmetic(right))));
      } else {
         return left > right ? left : right;
      }
   }
};

struct simd_fma_impl
    : simd_elementwise_ternary_interface<simd_fma_impl, simd_abi::op_fma> {
   constexpr simd_fma_impl() = default;

   template <typename T, typename Abi>
      requires(is_floating_point<T>)
   [[nodiscard]]
   constexpr auto
   invoke_full(simd<T, Abi> x, simd<T, Abi> y, simd<T, Abi> z) const
      -> simd<T, Abi> {


      if constexpr (has_simd_abi_ternary_full<simd_abi::op_fma, T, Abi>) {
         return simd_abi_apply_ternary_full<simd_abi::op_fma, T, Abi>(x, y, z);
      }
      return simd<T, Abi>(__builtin_elementwise_fma(x.raw, y.raw, z.raw));
   }

   template <typename T>
      requires(is_floating_point<T>)
   [[nodiscard]]
   constexpr auto
   invoke_lanewise(T x, T y, T z) const -> T {


      using R = raw_arithmetic_type<T>;
      if constexpr (is_same<R, float>) {
         return T(__builtin_fmaf(static_cast<R>(make_raw_arithmetic(x)),
                                 static_cast<R>(make_raw_arithmetic(y)),
                                 static_cast<R>(make_raw_arithmetic(z))));
      }
      return T(__builtin_fma(static_cast<R>(make_raw_arithmetic(x)),
                             static_cast<R>(make_raw_arithmetic(y)),
                             static_cast<R>(make_raw_arithmetic(z))));
   }
};

struct simd_fshl_impl
    : simd_elementwise_ternary_interface<simd_fshl_impl, simd_abi::op_fshl> {
   constexpr simd_fshl_impl() = default;

   template <typename T, typename Abi>
      requires(is_integral<T> && !is_bool<T>)
   [[nodiscard]]
   constexpr auto
   invoke_full(simd<T, Abi> x, simd<T, Abi> y, simd<T, Abi> z) const
      -> simd<T, Abi> {
      if constexpr (has_simd_abi_ternary_full<simd_abi::op_fshl, T, Abi>) {
         return simd_abi_apply_ternary_full<simd_abi::op_fshl, T, Abi>(x, y, z);
      }
      return simd<T, Abi>(__builtin_elementwise_fshl(x.raw, y.raw, z.raw));
   }

   template <typename T>
      requires(is_integral<T> && !is_bool<T>)
   [[nodiscard]]
   constexpr auto
   invoke_lanewise(T x, T y, T z) const -> T {
      using U = make_unsigned_type<T>;
      U const hi = static_cast<U>(x);
      U const lo = static_cast<U>(y);
      unsigned int const count =
         static_cast<unsigned int>(make_raw_arithmetic(z))
         % static_cast<unsigned int>(sizeof(T) * 8u);
      return static_cast<T>(__builtin_fshl(hi, lo, count));
   }
};

struct simd_fshr_impl
    : simd_elementwise_ternary_interface<simd_fshr_impl, simd_abi::op_fshr> {
