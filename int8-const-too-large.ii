template <is_raw_integral T, is_raw_integral U>
   requires(is_unsigned<T>)
[[nodiscard]]
constexpr auto
wrap_shl(T value, U bits) -> T {
   constexpr unsigned width = static_cast<unsigned>(sizeof(T) * 8u);
   unsigned const norm = static_cast<unsigned>(bits) % width;
   if (norm == 0) {
      return value;
   }
   return static_cast<T>((value << norm) | (value >> (width - norm)));
}





