template <typename T>
struct proxy_arrow_result {
 private:
   T m_value;

 public:
   constexpr proxy_arrow_result(T const& value) noexcept(noexcept(T(value)))
       : m_value(value) {
   }

   constexpr proxy_arrow_result(T&& value) noexcept(noexcept(T(::cat::forward<decltype(value)>(value))))
       : m_value(::cat::forward<decltype(value)>(value)) {
   }

   constexpr auto
   operator->() const noexcept -> T const* {
      return &m_value;
   }

   constexpr auto
   operator->() noexcept -> T* {
      return &m_value;
   }
};

