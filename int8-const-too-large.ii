   requires(remove_reference<T> const& t, remove_reference<U> const& u) {
      { t == u } -> is_boolean_testable_detail;
      { t != u } -> is_boolean_testable_detail;
      { u == t } -> is_boolean_testable_detail;
      { u != t } -> is_boolean_testable_detail;
   };
}

