template <typename iterator_concept_tag, typename element_type,
          typename reference_type = element_type&,
          typename pointer_type = element_type*, typename difference = iword>
class iterator_interface : public iterator_interface_base {
 public:
   using iterator_concept = iterator_concept_tag;
   using value_type =
      conditional<is_void<element_type>, void, remove_const<element_type>>;
   using reference = reference_type;
   using pointer = pointer_type;
   using difference_type = difference;
   using const_value_type =
      conditional<is_void<value_type>, void, add_const<value_type>>;
   using const_reference =
      conditional<is_void<value_type>, void,
                  add_lvalue_reference<add_const<value_type>>>;


   constexpr auto
   advance_to(this auto&& self,
              remove_cvref<decltype(self)> const& other_iterator)
      -> remove_cvref<decltype(self)> const& {
      if (other_iterator > self) {
         while (other_iterator > self) {
            ++self;
         }
      } else if (other_iterator < self) {
         while (other_iterator < self) {
            --self;
         }
      }
      return self;
   }

   constexpr auto
   operator*(this auto&& self) -> decltype(auto) {
      if constexpr (requires { iterator_interface_access::base(self); }) {
         return *iterator_interface_access::base(self);
      } else {
         return self.dereference();
      }
   }

   constexpr auto
   operator->(this auto const& self) -> pointer
      requires(!is_same<pointer, void>)
   {
      decltype(auto) ref = *self;
      if constexpr (is_reference<decltype(ref)>) {
         return static_cast<pointer>(__builtin_addressof(ref));
      } else {
         return static_cast<pointer>(proxy_arrow_result(move(ref)));
      }
   }

   constexpr auto
   operator+=(this auto&& self, auto offset) -> decltype(auto)
      requires(detail::is_difference_type<decltype(offset),
                                          remove_cvref<decltype(self)>>)
   {
      if constexpr (detail::has_advance<remove_cvref<decltype(self)>>) {
         self.advance(
            static_cast<typename remove_cvref<decltype(self)>::difference_type>(
               offset));
      } else {
         for (idx i; i < offset; ++i) {
            self.increment();
         }
      }
      return self;
   }

   constexpr auto
   operator++(this auto&& self) -> decltype(auto) {
      if constexpr (detail::has_increment<remove_cvref<decltype(self)>>) {
         self.increment();
      } else {
         self.advance(
            static_cast<typename remove_cvref<decltype(self)>::difference_type>(
               1));
      }
      return self;
   }

   constexpr auto
   operator++(this auto&& self, int) -> remove_cvref<decltype(self)> {
      auto copy = self;
      ++self;
      return copy;
   }

   constexpr auto
   operator--(this auto&& self) -> decltype(auto)
      requires(detail::has_bidirectional<remove_cvref<decltype(self)>>)
   {
      if constexpr (detail::has_decrement<remove_cvref<decltype(self)>>) {
         self.decrement();
      } else {
         self.advance(
            static_cast<typename remove_cvref<decltype(self)>::difference_type>(
               -1));
      }
      return self;
   }

   constexpr auto
   operator--(this auto&& self, int) -> remove_cvref<decltype(self)>
      requires(detail::has_bidirectional<remove_cvref<decltype(self)>>)
   {
      auto copy = self;
      --self;
      return copy;
   }

   constexpr auto
   operator[](this auto const& self [[clang::lifetimebound]], auto offset)
      -> decltype(auto)
      requires(detail::has_advance<remove_cvref<decltype(self)>>
               && detail::is_difference_type<decltype(offset),
                                             remove_cvref<decltype(self)>>)
   {
      return *(self + offset);
   }
};

template <typename iterator_concept_tag, typename element_type,
          typename reference_type = element_type, typename difference = iword>
using proxy_iterator_interface =
   iterator_interface<iterator_concept_tag, element_type, reference_type,
                      proxy_iterator_pointer<reference_type>, difference>;

template <typename iterator_type>
using infer_iterator_pointer =
   conditional<is_lvalue_reference<typename iterator_type::reference>,
               add_pointer<remove_reference<typename iterator_type::reference>>,
               proxy_iterator_pointer<typename iterator_type::reference>>;

template <typename D>
   requires(is_base_of<iterator_interface_base, remove_cvref<D>>)
constexpr auto
operator==(D const& left, D const& right) -> bool {
   using iter = remove_cvref<D>;
   if constexpr (detail::has_equal_to<iter>) {
      return left.equal_to(right);
   } else if constexpr (detail::has_distance_to<iter>) {
      return left.distance_to(right)
             == static_cast<infer_difference_type<iter>>(0);
   } else {
      __builtin_unreachable();
   }
}

template <typename D>
   requires(is_base_of<iterator_interface_base, remove_cvref<D>>
            && detail::has_distance_to<remove_cvref<D>>)
constexpr auto
operator<=>(D const& left, D const& right) {
   using iter = remove_cvref<D>;
   using diff = infer_difference_type<iter>;
   return (left - right) <=> static_cast<diff>(0);
}

template <typename D>
   requires(is_base_of<iterator_interface_base, remove_cvref<D>>)
constexpr auto
operator+(D const& left, auto offset) -> remove_cvref<D>
   requires(detail::is_difference_type<decltype(offset), remove_cvref<D>>)
{
   using iter = remove_cvref<D>;
   iter new_iterator = left;
   if constexpr (detail::has_advance<iter>) {
      new_iterator.advance(static_cast<typename iter::difference_type>(offset));
   } else {
      for (idx i; i < offset; ++i) {
         ++new_iterator;
      }
   }
   return new_iterator;
}

template <typename D>
   requires(is_base_of<iterator_interface_base, remove_cvref<D>>)
constexpr auto
operator+(auto offset, D const& right) -> remove_cvref<D>
   requires(detail::is_difference_type<decltype(offset), remove_cvref<D>>)
{
   using iter = remove_cvref<D>;
   iter new_iterator = right;
   if constexpr (detail::has_advance<iter>) {
      new_iterator.advance(static_cast<typename iter::difference_type>(offset));
   } else {
      for (idx i; i < offset; ++i) {
         ++new_iterator;
      }
   }
   return new_iterator;
}

template <typename D>
   requires(is_base_of<iterator_interface_base, remove_cvref<D>>)
constexpr auto
operator-(D const& left, auto offset) -> remove_cvref<D>
   requires(detail::is_difference_type<decltype(offset), remove_cvref<D>>)
{
   using iter = remove_cvref<D>;
   iter new_iterator = left;
   if constexpr (detail::has_advance<iter>) {
      new_iterator.advance(
         -static_cast<typename iter::difference_type>(offset));
   } else {
      for (idx i; i < offset; ++i) {
         --new_iterator;
      }
   }
   return new_iterator;
}

template <typename D>
   requires(is_base_of<iterator_interface_base, remove_cvref<D>>)
constexpr auto
operator-=(D& left, auto offset) -> remove_cvref<D>&
   requires(detail::is_difference_type<decltype(offset), remove_cvref<D>>)
{
   using iter = remove_cvref<D>;
   if constexpr (detail::has_advance<iter>) {
      left.advance(-static_cast<typename iter::difference_type>(offset));
   } else {
      for (idx i; i < offset; ++i) {
         --left;
      }
   }
   return left;
}

template <typename D>
   requires(is_base_of<iterator_interface_base, remove_cvref<D>>
            && detail::has_distance_to<remove_cvref<D>>)
constexpr auto
operator-(D const& left, D const& right)
   -> infer_difference_type<remove_cvref<D>> {
   return right.distance_to(left);
}

template <typename iterator_type>
class reverse_proxy_iterator
    : public iterator_interface<random_access_iterator_tag,
                                typename iterator_type::value_type,
                                typename iterator_type::reference,
                                infer_iterator_pointer<iterator_type>,
                                infer_difference_type<iterator_type>> {
 private:
   using self_type = reverse_proxy_iterator<iterator_type>;

 public:
   using value_type = iterator_type::value_type;
   using const_value_type = iterator_type::const_value_type;
   using reference = iterator_type::reference;
   using const_reference = iterator_type::const_reference;

   constexpr reverse_proxy_iterator(iterator_type const& other)
       : m_internal_iterator(other) {
   }


   template <typename... argument_types>
   constexpr reverse_proxy_iterator(argument_types&&... arguments)
       : m_internal_iterator(::cat::forward<decltype(arguments)>(arguments)...) {
   }

   constexpr auto
   dereference() -> decltype(auto) {
      return m_internal_iterator.dereference();
   }

   constexpr auto
   dereference() const -> decltype(auto) {
      return m_internal_iterator.dereference();
   }

   constexpr void
   advance(iword offset)
      requires(detail::has_advance<iterator_type>)
   {
      m_internal_iterator.advance(-offset);
   }

   constexpr void
   increment() {
      --m_internal_iterator;
   }

   constexpr void
   decrement() {
      ++m_internal_iterator;
   }

   constexpr auto
   distance_to(self_type const& other) const
      requires(detail::has_distance_to<iterator_type>)
   {

      return -m_internal_iterator.distance_to(other.m_internal_iterator);
   }

 private:
   iterator_type m_internal_iterator;
};

template <template <typename, auto...> typename iterator_type, typename T,
          auto... args>
using const_proxy_iterator = iterator_type<T const, args...>;


template <typename T>
concept is_iterable = requires(T it) {
                         it.begin();
                         it.end();
                      };

template <typename T>
concept is_bidi_iterable = requires(T it) {
                              it.begin();
                              it.end();
                              it.rbegin();
                              it.rend();
                           };

template <typename T>
concept is_weakly_incrementable =
   detail::is_iterator_movable<remove_cvref<T>>
   && detail::is_signed_integer_like<iterator_difference_type<T>>
   && detail::is_iterator_movable<iterator_difference_type<T>>
