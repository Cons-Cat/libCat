namespace cat {

template <typename T>
[[nodiscard]]
constexpr auto
is_memory_overlapping(span<T const> const first, span<T const> const second)
   -> bool {
   return is_memory_overlapping(first.data(), first.size() * sizeof(T),
                                second.data(), second.size() * sizeof(T));
}

template <typename T>
   requires(is_implicit_lifetime<T>)
constexpr void
copy_memory(span<T const> const source, span<T> destination) {
   copy_memory(source.data(), destination.data(),
               (source.size() * sizeof(T)).to_idx().assert());
}

template <typename T>
   requires(is_implicit_lifetime<T>)
constexpr void
copy_memory_backward(span<T const> const source, span<T> destination) {
   copy_memory_backward(source.data(), destination.data(),
                        (source.size() * sizeof(T)).to_idx().assert());
}

}
# 7 "/home/lgooch/libCat/src/libraries/memory/cat/../implementations/is_memory_overlapping.tpp" 2

namespace cat {




[[nodiscard]]
constexpr auto
is_memory_overlapping(void const* p_first, idx first_bytes,
                      void const* p_second, idx second_bytes) -> bool {
   if (first_bytes == 0u || second_bytes == 0u) {
      return false;
   }
   cat::uintptr const a{const_cast<void*>(p_first)};
   cat::uintptr const b{const_cast<void*>(p_second)};
   auto const a_end = a.raw + first_bytes;
   auto const b_end = b.raw + second_bytes;
   return b < a_end && a < b_end;
}

}
