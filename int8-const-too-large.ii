namespace cat {

template <typename V>
concept is_simd_integral = is_simd<V> && is_integral<typename V::scalar_type>;

template <typename V>
concept vec_floating_point =
   is_simd<V> && is_floating_point<typename V::scalar_type>;

template <typename V, typename T>
concept is_simd_of = is_simd<V> && is_same<typename V::scalar_type, T>;






enum class simd_memory_kind : unsigned char {
   aligned,
   unaligned,
   dispatch
};

namespace detail {

template <typename>
struct simd_mask_pack_parameters {};

template <typename T, typename Abi>
struct simd_mask_pack_parameters<simd_mask<T, Abi>> {
   using lane = T;
   using abi = Abi;
};

template <typename T>
using simd_abi_scalar = conditional<is_bool<T>, T, raw_arithmetic_type<T>>;

template <typename T, typename Abi>
   requires(is_bool<T> || requires {
               typename Abi::template make_abi_type<simd_abi_scalar<T>>;
            })
using simd_abi_vec =
   simd<simd_abi_scalar<T>,
        typename Abi::template make_abi_type<simd_abi_scalar<T>>>;

template <typename T, typename Abi>
using simd_abi_mask_vec =
   simd_mask<simd_abi_scalar<T>,
             typename Abi::template make_abi_type<simd_abi_scalar<T>>>;

template <typename OpTag, typename T, typename Abi>
concept has_simd_abi_unary_full =
   requires(simd_abi_vec<T, Abi> input) {
      simd_abi::unary_full<
         OpTag, typename simd_abi_vec<T, Abi>::scalar_type,
         typename simd_abi_vec<T, Abi>::abi_type>::invoke(input);
   };

template <typename OpTag, typename T, typename Abi>
concept has_simd_abi_unary_int =
   requires(simd_abi_vec<T, Abi> input, iword n) {
      simd_abi::unary_int<
         OpTag, typename simd_abi_vec<T, Abi>::scalar_type,
         typename simd_abi_vec<T, Abi>::abi_type>::invoke(input, n);
   };

template <typename T, typename Abi>
concept has_simd_abi_compress =
   requires(simd_abi_vec<T, Abi> input, simd_abi_mask_vec<T, Abi> selector) {
      simd_abi::compress<
         typename simd_abi_vec<T, Abi>::scalar_type,
         typename simd_abi_vec<T, Abi>::abi_type>::invoke(input, selector);
   };

template <typename T, typename Abi>
concept has_simd_abi_expand =
   requires(simd_abi_vec<T, Abi> packed, simd_abi_mask_vec<T, Abi> selector,
            simd_abi_vec<T, Abi> background) {
      simd_abi::expand<
         typename simd_abi_vec<T, Abi>::scalar_type,
         typename simd_abi_vec<T, Abi>::abi_type>::invoke(packed, selector,
                                                          background);
   };

template <typename OpTag, typename T, typename Abi>
concept has_simd_abi_binary_full =
   requires(simd_abi_vec<T, Abi> left, simd_abi_vec<T, Abi> right) {
      simd_abi::binary_full<
         OpTag, typename simd_abi_vec<T, Abi>::scalar_type,
         typename simd_abi_vec<T, Abi>::abi_type>::invoke(left, right);
   };

template <typename OpTag, typename T, typename Abi>
concept has_simd_abi_ternary_full =
   requires(simd_abi_vec<T, Abi> x, simd_abi_vec<T, Abi> y,
            simd_abi_vec<T, Abi> z) {
      simd_abi::ternary_full<
         OpTag, typename simd_abi_vec<T, Abi>::scalar_type,
         typename simd_abi_vec<T, Abi>::abi_type>::invoke(x, y, z);
   };

template <typename OpTag, typename T, typename IntT, typename Abi>
concept has_simd_abi_binary_mixed =
   requires(simd_abi_vec<T, Abi> x, simd_abi_vec<IntT, Abi> y) {
      simd_abi::binary_mixed<
         OpTag, typename simd_abi_vec<T, Abi>::scalar_type,
         typename simd_abi_vec<IntT, Abi>::scalar_type,
         typename simd_abi_vec<T, Abi>::abi_type>::invoke(x, y);
   };

template <typename OpTag, typename T, typename Abi>
concept has_simd_abi_binary_masked =
   requires(simd_abi_vec<T, Abi> left, simd_abi_vec<T, Abi> right,
            simd_abi_mask_vec<T, Abi> mask) {
      simd_abi::binary_masked<
         OpTag, typename simd_abi_vec<T, Abi>::scalar_type,
         typename simd_abi_vec<T, Abi>::abi_type>::invoke(left, right, mask);
   };

template <typename OpTag, typename T, typename Abi>
concept has_simd_abi_ternary_masked =
   requires(simd_abi_vec<T, Abi> x, simd_abi_vec<T, Abi> y,
            simd_abi_vec<T, Abi> z, simd_abi_mask_vec<T, Abi> mask) {
      simd_abi::ternary_masked<
         OpTag, typename simd_abi_vec<T, Abi>::scalar_type,
         typename simd_abi_vec<T, Abi>::abi_type>::invoke(x, y, z, mask);
   };

template <typename T, typename Abi>
concept has_simd_abi_fill_masked =
   requires(simd_abi_vec<T, Abi> passthrough,
            typename simd_abi_vec<T, Abi>::scalar_type fill,
            simd_abi_mask_vec<T, Abi> lane_mask) {
      simd_abi::fill_masked<T, Abi>::invoke(passthrough, fill, lane_mask);
   };

template <typename OpTag, typename T, typename Abi>
[[nodiscard]]
constexpr auto
simd_abi_apply_unary_full(simd<T, Abi> const& input) -> simd<T, Abi> {
   return simd<T, Abi>(
      simd_abi::invoke<
         simd_abi_vec<T, Abi>,
         simd_abi::unary_full<OpTag, typename simd_abi_vec<T, Abi>::scalar_type,
                              typename simd_abi_vec<T, Abi>::abi_type>>(
         simd_abi_vec<T, Abi>(input.raw))
         .raw);
}

template <typename OpTag, typename T, typename Abi>
[[nodiscard]]
constexpr auto
simd_abi_apply_unary_int(simd<T, Abi> const& input, iword n) -> simd<T, Abi> {
   return simd<T, Abi>(
      simd_abi::invoke<
         simd_abi_vec<T, Abi>,
         simd_abi::unary_int<OpTag, typename simd_abi_vec<T, Abi>::scalar_type,
                             typename simd_abi_vec<T, Abi>::abi_type>>(
         simd_abi_vec<T, Abi>(input.raw), n)
         .raw);
}

template <typename OpTag, typename T, typename Abi>
[[nodiscard]]
constexpr auto
simd_abi_apply_binary_full(simd<T, Abi> const& left, simd<T, Abi> const& right)
   -> simd<T, Abi> {
   return simd<T, Abi>(
      simd_abi::invoke<simd_abi_vec<T, Abi>,
                       simd_abi::binary_full<
                          OpTag, typename simd_abi_vec<T, Abi>::scalar_type,
                          typename simd_abi_vec<T, Abi>::abi_type>>(
         simd_abi_vec<T, Abi>(left.raw), simd_abi_vec<T, Abi>(right.raw))
         .raw);
}

template <typename OpTag, typename T, typename Abi>
[[nodiscard]]
constexpr auto
simd_abi_apply_binary_masked(simd<T, Abi> const& left,
                             simd<T, Abi> const& right,
                             simd_mask<T, Abi> const& mask) -> simd<T, Abi> {
   return simd<T, Abi>(
      simd_abi::invoke<simd_abi_vec<T, Abi>,
                       simd_abi::binary_masked<
                          OpTag, typename simd_abi_vec<T, Abi>::scalar_type,
                          typename simd_abi_vec<T, Abi>::abi_type>>(
         simd_abi_vec<T, Abi>(left.raw), simd_abi_vec<T, Abi>(right.raw),
         simd_abi_mask_vec<T, Abi>(mask.raw))
         .raw);
}

template <typename OpTag, typename T, typename Abi>
[[nodiscard]]
constexpr auto
simd_abi_apply_ternary_full(simd<T, Abi> const& x, simd<T, Abi> const& y,
                            simd<T, Abi> const& z) -> simd<T, Abi> {
   return simd<T, Abi>(
      simd_abi::invoke<simd_abi_vec<T, Abi>,
                       simd_abi::ternary_full<
                          OpTag, typename simd_abi_vec<T, Abi>::scalar_type,
                          typename simd_abi_vec<T, Abi>::abi_type>>(
         simd_abi_vec<T, Abi>(x.raw), simd_abi_vec<T, Abi>(y.raw),
         simd_abi_vec<T, Abi>(z.raw))
         .raw);
}

template <typename OpTag, typename T, typename Abi>
[[nodiscard]]
constexpr auto
simd_abi_apply_ternary_masked(simd<T, Abi> const& x, simd<T, Abi> const& y,
                              simd<T, Abi> const& z,
                              simd_mask<T, Abi> const& mask) -> simd<T, Abi> {
   return simd<T, Abi>(
      simd_abi::invoke<simd_abi_vec<T, Abi>,
                       simd_abi::ternary_masked<
                          OpTag, typename simd_abi_vec<T, Abi>::scalar_type,
                          typename simd_abi_vec<T, Abi>::abi_type>>(
         simd_abi_vec<T, Abi>(x.raw), simd_abi_vec<T, Abi>(y.raw),
         simd_abi_vec<T, Abi>(z.raw), simd_abi_mask_vec<T, Abi>(mask.raw))
         .raw);
}

template <typename T, typename Abi>
[[nodiscard]]
constexpr auto
simd_abi_apply_fill_masked(simd<T, Abi> const& passthrough,
                           typename simd_abi_vec<T, Abi>::scalar_type fill,
                           simd_mask<T, Abi> const& mask) -> simd<T, Abi> {
   return simd<T, Abi>(
      simd_abi::invoke<simd_abi_vec<T, Abi>, simd_abi::fill_masked<T, Abi>>(
         simd_abi_vec<T, Abi>(passthrough.raw), fill,
         simd_abi_mask_vec<T, Abi>(mask.raw))
         .raw);
}

template <typename OpTag, typename T, typename IntT, typename Abi>
[[nodiscard]]
constexpr auto
simd_abi_apply_binary_mixed(simd<T, Abi> const& x, simd<IntT, Abi> const& y)
   -> simd<T, Abi> {
   return simd<T, Abi>(
      simd_abi::invoke<simd_abi_vec<T, Abi>,
                       simd_abi::binary_mixed<
                          OpTag, typename simd_abi_vec<T, Abi>::scalar_type,
                          typename simd_abi_vec<IntT, Abi>::scalar_type,
                          typename simd_abi_vec<T, Abi>::abi_type>>(
         simd_abi_vec<T, Abi>(x.raw), simd_abi_vec<IntT, Abi>(y.raw))
         .raw);
}

template <typename T, typename Abi>
[[nodiscard]]
constexpr auto
simd_abi_apply_compress(simd<T, Abi> const& input,
                        simd_mask<T, Abi> const& selector) -> simd<T, Abi> {
   return simd<T, Abi>(
      simd_abi::invoke<
         simd_abi_vec<T, Abi>,
         simd_abi::compress<typename simd_abi_vec<T, Abi>::scalar_type,
                            typename simd_abi_vec<T, Abi>::abi_type>>(
         simd_abi_vec<T, Abi>(input.raw),
         simd_abi_mask_vec<T, Abi>(selector.raw))
         .raw);
}

template <typename T, typename Abi>
[[nodiscard]]
constexpr auto
simd_abi_apply_expand(simd<T, Abi> const& packed_values,
                      simd_mask<T, Abi> const& selector,
                      simd<T, Abi> const& background) -> simd<T, Abi> {
   return simd<T, Abi>(
      simd_abi::invoke<
         simd_abi_vec<T, Abi>,
         simd_abi::expand<typename simd_abi_vec<T, Abi>::scalar_type,
                          typename simd_abi_vec<T, Abi>::abi_type>>(
         simd_abi_vec<T, Abi>(packed_values.raw),
         simd_abi_mask_vec<T, Abi>(selector.raw),
         simd_abi_vec<T, Abi>(background.raw))
         .raw);
}

template <typename Derived, typename T, typename Abi>
[[nodiscard]]
constexpr auto
simd_binary_masked_lanewise_fallback(Derived const& derived, simd<T, Abi> left,
                                     simd<T, Abi> right, simd_mask<T, Abi> mask)
   -> simd<T, Abi> {
   simd<T, Abi> result{};
#pragma clang loop vectorize_predicate(enable)
   for (idx i = 0u; i < Abi::lanes; ++i) {
      result.set_lane(
         i, mask[i] ? derived.invoke_lanewise(left[i], right[i]) : left[i]);
   }
   return result;
}

template <typename Derived, typename T, typename Abi>
[[nodiscard]]
constexpr auto
simd_ternary_masked_lanewise_fallback(Derived const& derived, simd<T, Abi> x,
                                      simd<T, Abi> y, simd<T, Abi> z,
                                      simd_mask<T, Abi> mask) -> simd<T, Abi> {
   simd<T, Abi> result{};
#pragma clang loop vectorize_predicate(enable)
   for (idx i = 0u; i < Abi::lanes; ++i) {
      result.set_lane(
         i, mask[i] ? derived.invoke_lanewise(x[i], y[i], z[i]) : x[i]);
   }
   return result;
}

template <typename Derived, typename Mask>
struct simd_unary_masked_impl {
   Derived const& self;
   Mask mask;

   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   operator()(simd<T, Abi> input) const -> simd<T, Abi> {
      simd<T, Abi> result{};
#pragma clang loop vectorize_predicate(enable)
      for (idx i = 0u; i < Abi::lanes; ++i) {
         result.set_lane(i,
                         mask[i] ? self.invoke_lanewise(input[i]) : input[i]);
      }
      return result;
   }
};

template <typename Derived, typename Mask>
struct simd_binary_masked_impl {
   Derived const& self;
   Mask mask;

   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   operator()(simd<T, Abi> left, simd<T, Abi> right) const -> simd<T, Abi> {
      return self.invoke_masked(left, right, mask);
   }
};

template <typename Derived, typename Mask>
struct simd_ternary_masked_impl {
   Derived const& self;
   Mask mask;

   template <typename T, typename Abi>
      requires(is_same<Mask, simd_mask<T, Abi>>)
   [[nodiscard]]
   constexpr auto
   operator()(simd<T, Abi> x, simd<T, Abi> y, simd<T, Abi> z) const
      -> simd<T, Abi> {
      return self.invoke_masked(x, y, z, mask);
   }
};

template <typename Derived, typename Mask>
struct simd_binary_mixed_masked_impl {
   Derived const& self;
   Mask mask;

   template <typename T, typename IntT, typename Abi>
      requires(is_floating_point<T> && is_integral<IntT>
               && is_same<Mask, simd_mask<T, Abi>>)
   [[nodiscard]]
   constexpr auto
   operator()(simd<T, Abi> x, simd<IntT, Abi> y) const -> simd<T, Abi> {
      simd<T, Abi> result{};
#pragma clang loop vectorize_predicate(enable)
      for (idx i = 0u; i < Abi::lanes; ++i) {
         result.set_lane(i, mask[i] ? self.invoke_lanewise(x[i], y[i]) : x[i]);
      }
      return result;
   }
};

template <typename Derived, typename Mask>
struct simd_unary_int_masked_impl {
   Derived const& self;
   Mask mask;

   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   operator()(simd<T, Abi> input, iword count) const -> simd<T, Abi> {
      simd<T, Abi> result{};
#pragma clang loop vectorize_predicate(enable)
      for (idx i = 0u; i < Abi::lanes; ++i) {
         result.set_lane(
            i, mask[i] ? self.invoke_lanewise(input[i], count) : input[i]);
      }
      return result;
   }
};


template <typename Mask>
struct simd_load_blend_masked_impl {
   Mask mask;

   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   operator()(simd<T, Abi> passthrough,
              typename simd<T, Abi>::memory_lane const* source) const
      -> simd<T, Abi> {
      simd<T, Abi> result = passthrough;
#pragma clang loop vectorize_predicate(enable)
      for (idx i = 0u; i < Abi::lanes; ++i) {
         if (mask[i]) {
            result.set_lane(i, static_cast<T>(source[i]));
         }
      }
      return result;
   }

   template <typename U>
      requires(is_simd_mask<Mask>
               && is_constructible<
                  typename detail::simd_mask_pack_parameters<Mask>::lane,
                  remove_cvref<U>>
               && detail::simd_broadcast_really_convertible_to<
                  remove_cvref<U>,
                  typename detail::simd_mask_pack_parameters<Mask>::lane>())
   [[nodiscard]]
   constexpr auto
   operator()(
      U&& passthrough_fill,
      typename simd<typename detail::simd_mask_pack_parameters<Mask>::lane,
                    typename detail::simd_mask_pack_parameters<Mask>::abi>::
         memory_lane const* source) const
      -> simd<typename detail::simd_mask_pack_parameters<Mask>::lane,
              typename detail::simd_mask_pack_parameters<Mask>::abi> {
      using lane = typename detail::simd_mask_pack_parameters<Mask>::lane;
      using abi = typename detail::simd_mask_pack_parameters<Mask>::abi;
      return (*this)(simd<lane, abi>(::cat::forward<decltype(passthrough_fill)>(passthrough_fill)), source);
   }
};


template <typename Mask>
struct simd_load_aligned_blend_masked_impl {
   Mask mask;

   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   operator()(simd<T, Abi> passthrough,
              typename simd<T, Abi>::memory_lane const* source) const
      -> maybe<simd<T, Abi>> {
      if (!is_aligned(unconst(source), simd<T, Abi>::abi_type::alignment)) {
         return maybe<simd<T, Abi>>{};
      }
      simd<T, Abi> result = passthrough;
#pragma clang loop vectorize_predicate(enable)
      for (idx i = 0u; i < Abi::lanes; ++i) {
         if (mask[i]) {
            result.set_lane(i, static_cast<T>(source[i]));
         }
      }
      return result;
   }

   template <typename U>
      requires(is_simd_mask<Mask>
               && is_constructible<
                  typename detail::simd_mask_pack_parameters<Mask>::lane,
                  remove_cvref<U>>
               && detail::simd_broadcast_really_convertible_to<
                  remove_cvref<U>,
                  typename detail::simd_mask_pack_parameters<Mask>::lane>())
   [[nodiscard]]
   constexpr auto
   operator()(
      U&& passthrough_fill,
      typename simd<typename detail::simd_mask_pack_parameters<Mask>::lane,
                    typename detail::simd_mask_pack_parameters<Mask>::abi>::
         memory_lane const* source) const
      -> maybe<simd<typename detail::simd_mask_pack_parameters<Mask>::lane,
                    typename detail::simd_mask_pack_parameters<Mask>::abi>> {
      using lane = typename detail::simd_mask_pack_parameters<Mask>::lane;
      using abi = typename detail::simd_mask_pack_parameters<Mask>::abi;
      return (*this)(simd<lane, abi>(::cat::forward<decltype(passthrough_fill)>(passthrough_fill)), source);
   }
};






template <typename Mask>
struct simd_store_to_masked_impl {
   Mask mask;

   template <typename T, typename Abi>
   constexpr void
   operator()(simd<T, Abi> values,
              typename simd<T, Abi>::memory_lane* destination) const {
#pragma clang loop vectorize_predicate(enable)
      for (idx i = 0u; i < Abi::lanes; ++i) {
         if (mask[i]) {
            destination[i] = simd_lane_to_storage(values[i]);
         }
      }
   }

   template <typename T, typename Abi, typename IdxAbi, typename Idx>
   constexpr void
   operator()(T* base, simd<Idx, IdxAbi> indices, simd<T, Abi> values) const {
#pragma clang loop vectorize_predicate(enable)
      for (idx i = 0u; i < Abi::lanes; ++i) {
         if (mask[i]) {
            base[idx(static_cast<idx::raw_type>(indices[i]))] = values[i];
         }
      }
   }
};

template <typename Mask>
struct simd_partial_load_blend_masked_impl {
   Mask mask;

   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   operator()(simd<T, Abi> passthrough,
              typename simd<T, Abi>::memory_lane const* source, idx count) const
      -> simd<T, Abi> {
      simd<T, Abi> result = passthrough;
      idx const active_lane_count = count < Abi::lanes ? count : Abi::lanes;
#pragma clang loop vectorize_predicate(enable)
      for (idx i = 0u; i < Abi::lanes; ++i) {
         if (mask[i]) {
            result.set_lane(
               i, i < active_lane_count ? static_cast<T>(source[i]) : T{});
         }
      }
      return result;
   }
};

template <typename Mask>
struct simd_fill_blend_masked_impl {
   Mask mask;

   template <typename T, typename Abi, typename U>
      requires(is_convertible<U, T>)
   [[nodiscard]]
   constexpr auto
   operator()(simd<T, Abi> passthrough, U value) const -> simd<T, Abi> {
      T const fill = static_cast<T>(value);
      if constexpr (is_same<Mask, simd_mask<T, Abi>>
                    && has_simd_abi_fill_masked<T, Abi>) {
         return simd_abi_apply_fill_masked<T, Abi>(passthrough, fill, mask);
      }
      simd<T, Abi> result = passthrough;
#pragma clang loop vectorize_predicate(enable)
      for (idx i = 0u; i < Abi::lanes; ++i) {
         if (mask[i]) {
            result.set_lane(i, fill);
         }
      }
      return result;
   }
};

template <typename Mask>
struct simd_iota_blend_masked_impl {
   Mask mask;

   template <is_simd V>
   [[nodiscard]]
   constexpr auto
   operator()(V passthrough, V::scalar_type start) const -> V {
      using T = typename V::scalar_type;
      T const base = static_cast<T>(start);
      V result = passthrough;
#pragma clang loop vectorize_predicate(enable)
      for (idx i = 0u; i < V::abi_type::lanes; ++i) {
         if (mask[i]) {
            result.set_lane(i, static_cast<T>(base + static_cast<T>(i)));
         }
      }
      return result;
   }
};



template <typename Mask>
struct simd_load_from_blend_masked_impl {
   Mask mask;

   template <typename T, typename Abi, typename IdxAbi, typename Idx>
   [[nodiscard]]
   constexpr auto
   operator()(simd<T, Abi> passthrough, T const* p_base,
              simd<Idx, IdxAbi> indices) const -> simd<T, Abi> {
      simd<T, Abi> result = passthrough;
#pragma clang loop vectorize_predicate(enable)
      for (idx i = 0u; i < Abi::lanes; ++i) {
         if (mask[i]) {
            result.set_lane(
               i, p_base[idx(static_cast<idx::raw_type>(indices[i]))]);
         }
      }
      return result;
   }
};






template <typename Derived, is_simd V>
class simd_elementwise_factory_interface {
   friend Derived;

 public:
   using simd_vector = V;

   [[nodiscard]]
   constexpr auto
   operator()(typename V::memory_lane const* source) const -> decltype(auto) {
      return static_cast<Derived const*>(this)->invoke(source);
   }

   [[nodiscard]]
   constexpr auto
   operator[](
      simd_mask<typename V::scalar_type, typename V::abi_type> lane_mask) const
      -> decltype(auto) {
      return static_cast<Derived const*>(this)->bind_masked(lane_mask);
   }

 private:
   constexpr simd_elementwise_factory_interface() = default;
};



template <is_simd V>
struct make_simd_loaded_aligned_impl
    : simd_elementwise_factory_interface<make_simd_loaded_aligned_impl<V>, V> {
   using simd_vector = V;

   constexpr make_simd_loaded_aligned_impl() = default;

   [[nodiscard]]
   constexpr auto
   invoke(typename V::memory_lane const* source) const -> maybe<V> {
      if (!is_aligned(unconst(source), V::abi_type::alignment)) {
         return maybe<V>{};
      }
      V result{};
      result.load_aligned(source);
      return result;
   }

   [[nodiscard]]
   constexpr auto
   bind_masked(simd_mask<typename V::scalar_type, typename V::abi_type> mask)
      const -> simd_load_aligned_blend_masked_impl<
         simd_mask<typename V::scalar_type, typename V::abi_type>> {
      return {mask};
   }
};



template <is_simd V>
struct make_simd_loaded_unaligned_impl
    : simd_elementwise_factory_interface<make_simd_loaded_unaligned_impl<V>,
                                         V> {
   using simd_vector = V;

   constexpr make_simd_loaded_unaligned_impl() = default;

   [[nodiscard, gnu::no_sanitize_address]]
   constexpr auto
   invoke(typename V::memory_lane const* source) const -> V {
      V result{};
      result.load_unaligned(source);
      return result;
   }

   [[nodiscard]]
   constexpr auto
   bind_masked(simd_mask<typename V::scalar_type, typename V::abi_type> mask)
      const -> simd_load_blend_masked_impl<
         simd_mask<typename V::scalar_type, typename V::abi_type>> {
      return {mask};
   }
};



template <is_simd V>
struct make_simd_loaded_impl
    : simd_elementwise_factory_interface<make_simd_loaded_impl<V>, V> {
   using simd_vector = V;

   constexpr make_simd_loaded_impl() = default;

   [[nodiscard]]
   constexpr auto
   invoke(typename V::memory_lane const* source) const -> V {
      V result{};
      result.load(source);
      return result;
   }

   [[nodiscard]]
   constexpr auto
   bind_masked(simd_mask<typename V::scalar_type, typename V::abi_type> mask)
      const -> simd_load_blend_masked_impl<
         simd_mask<typename V::scalar_type, typename V::abi_type>> {
      return {mask};
   }
};


template <is_simd V>
struct make_simd_partial_loaded_impl {
   [[nodiscard]]
   constexpr auto
   operator()(typename V::memory_lane const* source, idx count) const -> V {
      V result{};
      result.partial_load(source, count);
      return result;
   }

   [[nodiscard]]
   constexpr auto
   operator[](simd_mask<typename V::scalar_type, typename V::abi_type> mask)
      const -> simd_partial_load_blend_masked_impl<
         simd_mask<typename V::scalar_type, typename V::abi_type>> {
      return {mask};
   }
};

template <is_simd V>
struct make_simd_filled_impl {
   template <typename U>
      requires(is_convertible<U, typename V::scalar_type>)
   [[nodiscard]]
   constexpr auto
   operator()(U value) const -> V {
      V result{};
      result.fill(value);
      return result;
   }

   [[nodiscard]]
   constexpr auto
   operator[](simd_mask<typename V::scalar_type, typename V::abi_type> mask)
      const -> simd_fill_blend_masked_impl<
         simd_mask<typename V::scalar_type, typename V::abi_type>> {
      return {mask};
   }
};

template <is_simd V>
struct simd_iota_impl {
   [[nodiscard]]
   constexpr auto
   operator()(V::scalar_type start) const -> V {

      using T = typename V::scalar_type;
      T const base = static_cast<T>(start);
      V result{};
#pragma clang loop vectorize(enable)
      for (idx i = 0u; i < V::abi_type::lanes; ++i) {
         result.set_lane(i, static_cast<T>(base + static_cast<T>(i.raw)));
      }
      return result;
   }

   [[nodiscard]]
   constexpr auto
   operator[](V::mask_type lane_mask) const -> simd_iota_blend_masked_impl<
      simd_mask<typename V::scalar_type, typename V::abi_type>> {
      return {lane_mask};
   }
};

template <typename LaneBlendMask>
struct simd_mask_load_blend_masked_impl {
   LaneBlendMask lane_blend_mask;

   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   operator()(simd_mask<T, Abi> passthrough, bool const* lane_bools) const
      -> simd_mask<T, Abi> {
      simd_mask<T, Abi> result = passthrough;
#pragma clang loop vectorize_predicate(enable)
      for (idx i = 0u; i < simd_mask<T, Abi>::abi_type::lanes; ++i) {
         if (lane_blend_mask[i]) {
            result.set_lane(i, lane_bools[i.raw]);
         }
      }
      return result;
   }
};

template <typename LaneBlendMask>
struct simd_mask_fill_blend_masked_impl {
   LaneBlendMask lane_blend_mask;

   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   operator()(simd_mask<T, Abi> passthrough, bool value) const
      -> simd_mask<T, Abi> {
      simd_mask<T, Abi> result = passthrough;
#pragma clang loop vectorize_predicate(enable)
      for (idx i = 0u; i < simd_mask<T, Abi>::abi_type::lanes; ++i) {
         if (lane_blend_mask[i]) {
            result.set_lane(i, value);
         }
      }
      return result;
   }
};




template <typename Derived, is_simd_mask M>
class simd_elementwise_mask_factory_interface {
   friend Derived;

 public:
   using mask_type = M;

   [[nodiscard]]
   constexpr auto
   operator()(bool const* lane_bools) const -> decltype(auto) {
      return static_cast<Derived const*>(this)->invoke(lane_bools);
   }

   [[nodiscard]]
   constexpr auto
   operator[](M lane_blend_mask) const -> decltype(auto) {
      return static_cast<Derived const*>(this)->bind_masked(lane_blend_mask);
   }

 private:
   constexpr simd_elementwise_mask_factory_interface() = default;
};

template <is_simd_mask M>
struct make_simd_mask_filled_impl {
   [[nodiscard]]
   constexpr auto
   operator()(bool value) const -> M {
      M mask{};
      mask.fill(value);
      return mask;
   }

   [[nodiscard]]
   constexpr auto
   operator[](M lane_blend_mask) const -> simd_mask_fill_blend_masked_impl<M> {
      return {lane_blend_mask};
   }
};


template <is_simd_mask M>
struct make_simd_mask_loaded_impl
    : simd_elementwise_mask_factory_interface<make_simd_mask_loaded_impl<M>,
                                              M> {
   using mask_type = M;

   constexpr make_simd_mask_loaded_impl() = default;

   [[nodiscard]]
   constexpr auto
   invoke(bool const* p_data) const -> M {
      M mask{};
      mask.load(p_data);
      return mask;
   }

   [[nodiscard]]
   constexpr auto
   bind_masked(M lane_blend_mask) const -> simd_mask_load_blend_masked_impl<M> {
      return {lane_blend_mask};
   }
};


template <simd_memory_kind Kind>
struct simd_load_impl {
   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   operator[](simd_mask<T, Abi> lane_mask) const {
      if constexpr (Kind == simd_memory_kind::aligned) {
         return simd_load_aligned_blend_masked_impl<simd_mask<T, Abi>>{
            lane_mask};
      } else {
         return simd_load_blend_masked_impl<simd_mask<T, Abi>>{lane_mask};
      }
   }
};







struct simd_store_impl {
   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   operator[](simd_mask<T, Abi> lane_mask) const
      -> simd_store_to_masked_impl<simd_mask<T, Abi>> {
      return {lane_mask};
   }
};

template <typename T, typename Abi>
[[nodiscard]]
constexpr auto
simd_if_else_apply(simd_mask<T, Abi> mask, simd<T, Abi> on_true,
                   simd<T, Abi> on_false) -> simd<T, Abi> {


   simd<T, Abi> result{};
#pragma clang loop vectorize_predicate(enable)
   for (idx i = 0u; i < Abi::lanes; ++i) {
      result.set_lane(i, mask[i] ? on_true[i] : on_false[i]);
   }
   return result;
}


template <typename T, typename Abi>
struct simd_load_from_impl {
   template <typename IdxAbi, typename Idx>
   [[nodiscard]]
   constexpr auto
   operator()(T const* base, simd<Idx, IdxAbi> indices) const -> simd<T, Abi> {
      simd<T, Abi> result{};
      for (idx i = 0u; i < Abi::lanes; ++i) {
         result.set_lane(i, base[idx(static_cast<idx::raw_type>(indices[i]))]);
      }
      return result;
   }

   [[nodiscard]]
   constexpr auto
   operator[](simd_mask<T, Abi> lane_mask) const
      -> simd_load_from_blend_masked_impl<simd_mask<T, Abi>> {
      return {lane_mask};
   }
};


template <typename T, typename Abi>
struct simd_store_to_impl {
   template <typename IdxAbi, typename Idx>
   constexpr void
   operator()(T* base, simd<Idx, IdxAbi> indices, simd<T, Abi> values) const {
      for (idx i = 0u; i < Abi::lanes; ++i) {
         base[idx(static_cast<idx::raw_type>(indices[i]))] = values[i];
      }
   }

   [[nodiscard]]
   constexpr auto
   operator[](simd_mask<T, Abi> lane_mask) const
      -> simd_store_to_masked_impl<simd_mask<T, Abi>> {
      return {lane_mask};
   }
};

template <typename Derived>
struct simd_elementwise_interface {
   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   operator()(simd<T, Abi> input) const -> decltype(auto) {
      return self().invoke_full(input);
   }

   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   operator[](simd_mask<T, Abi> lane_mask) const
      -> simd_unary_masked_impl<Derived, simd_mask<T, Abi>> {
      return {self(), lane_mask};
   }

 private:
   constexpr simd_elementwise_interface() = default;
   friend Derived;

   [[nodiscard]]
   constexpr Derived const&
   self() const {
      return static_cast<Derived const&>(*this);
   }
};




template <typename Derived>
concept simd_binary_derived_supplies_invoke_masked =
   requires { typename Derived::simd_binary_derived_supplies_invoke_masked; };

template <typename Derived>
concept simd_ternary_derived_supplies_invoke_masked =
   requires { typename Derived::simd_ternary_derived_supplies_invoke_masked; };






template <typename Derived, typename AbiBinaryMaskedOpTag = void>
struct simd_elementwise_binary_interface {
   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   operator()(simd<T, Abi> left, simd<T, Abi> right) const -> decltype(auto) {
      return self().invoke_full(left, right);
   }

   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   operator[](simd_mask<T, Abi> lane_mask) const
      -> simd_binary_masked_impl<Derived, simd_mask<T, Abi>> {
      return {self(), lane_mask};
   }

   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   invoke_masked(simd<T, Abi> left, simd<T, Abi> right,
                 simd_mask<T, Abi> mask) const -> simd<T, Abi>
      requires(!simd_binary_derived_supplies_invoke_masked<Derived>)
   {
      if constexpr (!is_void<AbiBinaryMaskedOpTag>) {
         if constexpr (has_simd_abi_binary_masked<AbiBinaryMaskedOpTag, T,
                                                  Abi>) {
            return simd_abi_apply_binary_masked<AbiBinaryMaskedOpTag, T, Abi>(
               left, right, mask);
         }
         return simd_if_else_apply(mask, self().invoke_full(left, right), left);
      } else {
         return simd_binary_masked_lanewise_fallback(self(), left, right, mask);
      }
   }

 private:
   constexpr simd_elementwise_binary_interface() = default;
   friend Derived;

   [[nodiscard]]
   constexpr Derived const&
   self() const {
      return static_cast<Derived const&>(*this);
   }
};



template <typename Derived, typename AbiTernaryMaskedOpTag = void>
struct simd_elementwise_ternary_interface {
   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   operator()(simd<T, Abi> x, simd<T, Abi> y, simd<T, Abi> z) const
      -> decltype(auto) {
      return self().invoke_full(x, y, z);
   }

   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   operator[](simd_mask<T, Abi> lane_mask) const
      -> simd_ternary_masked_impl<Derived, simd_mask<T, Abi>> {
      return {self(), lane_mask};
   }

   template <typename T, typename Abi>
   [[nodiscard]]
   constexpr auto
   invoke_masked(simd<T, Abi> x, simd<T, Abi> y, simd<T, Abi> z,
                 simd_mask<T, Abi> mask) const -> simd<T, Abi>
      requires(!simd_ternary_derived_supplies_invoke_masked<Derived>)
   {
      if constexpr (!is_void<AbiTernaryMaskedOpTag>) {
         if constexpr (has_simd_abi_ternary_masked<AbiTernaryMaskedOpTag, T,
                                                   Abi>) {
            return simd_abi_apply_ternary_masked<AbiTernaryMaskedOpTag, T, Abi>(
               x, y, z, mask);
         }
         return simd_if_else_apply(mask, self().invoke_full(x, y, z), x);
      } else {
         return simd_ternary_masked_lanewise_fallback(self(), x, y, z, mask);
      }
   }

 private:
   constexpr simd_elementwise_ternary_interface() = default;
   friend Derived;

   [[nodiscard]]
   constexpr Derived const&
   self() const {
      return static_cast<Derived const&>(*this);
   }
};

template <typename Derived>
struct simd_elementwise_binary_mixed_interface {
   template <typename T, typename IntT, typename Abi>
      requires(is_floating_point<T> && is_integral<IntT>)
   [[nodiscard]]
   constexpr auto
   operator()(simd<T, Abi> x, simd<IntT, Abi> y) const -> decltype(auto) {
      return self().invoke_full(x, y);
