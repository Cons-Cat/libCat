      __builtin_ia32_movntq128(p_destination, source);
   } else if constexpr (cat::is_same<T, cat::uint1x4>
                        || cat::is_same<T, cat::int1x4>) {
      __builtin_ia32_movntdq256(p_destination, source);
   }
}
